#!/bin/sh /etc/rc.common

START=90
USE_PROCD=1

start_service() {
        local port https_port

        [ -x /usr/libexec/sheepfold/sheepfold-site-lists ] &&
                /usr/libexec/sheepfold/sheepfold-site-lists cron-apply >/dev/null 2>&1 || true

        procd_open_instance
        procd_set_param command /usr/libexec/sheepfold/sheepfold-service
        procd_set_param respawn
        procd_close_instance

        procd_open_instance telegram
        procd_set_param command /usr/libexec/sheepfold/sheepfold-telegram-bot run
        procd_set_param respawn
        procd_close_instance

        port="$(uci -q get sheepfold.global.app_port 2>/dev/null || printf 5201)"
        https_port="$(uci -q get sheepfold.global.app_https_port 2>/dev/null || printf 5200)"
        case "$port" in ''|*[!0-9]*) port=5201 ;; esac
        case "$https_port" in ''|*[!0-9]*) https_port=5200 ;; esac

        procd_open_instance api
        if [ -s /etc/uhttpd.crt ] && [ -s /etc/uhttpd.key ] && \
           /usr/sbin/uhttpd -h 2>&1 | grep -q -- '-s'; then
                # HTTPS — основной транспорт. HTTP остаётся совместимым LAN fallback.
                procd_set_param command /usr/sbin/uhttpd -f -h /www -x /cgi-bin \
                        -s "0.0.0.0:$https_port" -C /etc/uhttpd.crt -K /etc/uhttpd.key \
                        -p "0.0.0.0:$port" -T 30
        else
                logger -t sheepfold "TLS certificate or uhttpd TLS support is unavailable; using LAN HTTP fallback"
                procd_set_param command /usr/sbin/uhttpd -f -h /www -x /cgi-bin -p "0.0.0.0:$port" -T 30
        fi
        procd_set_param respawn
        procd_close_instance
}

reload_service() {
        /usr/libexec/sheepfold/sheepfold-service reload
}

stop_service() {
        [ -x /usr/libexec/sheepfold/sheepfold-router-control ] &&
                /usr/libexec/sheepfold/sheepfold-router-control blocked-page-stop >/dev/null 2>&1 || true
}
