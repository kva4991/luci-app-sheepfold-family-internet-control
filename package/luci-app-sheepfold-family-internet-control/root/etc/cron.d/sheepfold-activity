# Суточная архивация приватных логов (в окне техобслуживания)
5 2 * * * root /usr/libexec/sheepfold/sheepfold-maintenance-window && /usr/libexec/sheepfold/sheepfold-activity-log rotate

# Резервный вариант: если не сработал в 2:05 — повтор в 4:55
55 4 * * * root /usr/libexec/sheepfold/sheepfold-activity-log rotate 2>/dev/null || true
