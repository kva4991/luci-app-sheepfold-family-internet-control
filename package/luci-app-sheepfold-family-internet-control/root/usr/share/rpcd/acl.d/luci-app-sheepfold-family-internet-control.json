{
  "luci-app-sheepfold-family-internet-control": {
    "description": "Grant access to Sheepfold Family Internet Control",
    "read": {
      "uci": [ "sheepfold", "dhcp", "wireless", "system" ],
      "file": {
        "/tmp/dhcp.leases": [ "read" ],
        "/proc/net/arp": [ "read" ],
        "/tmp/sheepfold/events.log": [ "read" ],
        "/tmp/sheepfold/*": [ "read" ]
      }
    },
    "write": {
      "uci": [ "sheepfold", "dhcp", "wireless", "system" ],
      "file": {
        "/tmp/sheepfold/events.log": [ "write" ],
        "/tmp/sheepfold/*": [ "write" ],
        "/www/.well-known/sheepfold.json": [ "write" ],
        "/etc/init.d/sheepfold": [ "exec" ],
        "/usr/libexec/sheepfold/sheepfold-site-lists": [ "exec" ],
        "/usr/libexec/sheepfold/sheepfold-telegram-bot": [ "exec" ],
        "/usr/libexec/sheepfold/sheepfold-updater": [ "exec" ],
        "/usr/libexec/sheepfold/sheepfold-router-control": [ "exec" ]
      }
    }
  }
}
