config sheepfold 'global'
        # SHEEPFOLD_STANDARD_BEGIN
        option product_variant 'sheepfold'
        # SHEEPFOLD_STANDARD_END
        # SHEEPFOLD_AI_BEGIN
        option product_variant 'sheepfoldAi'
        # SHEEPFOLD_AI_END
        option enabled '0'
        option language 'ru'
	option country_profile 'ru'
	option country_profile_schema '1'
	option country_profile_migrated '1'
	option router_install_id ''
        option lan_interface 'br-lan'
        option wan_interface 'wan'
        option lan_firewall_zones 'lan'
        option block_on_boot '0'
        option access_priority 'blocklist admin_devices no_restrictions allowlist global_block temp_access device_schedule group_schedule default_access'
        option schedule_conflict_internet 'off'
        option logging '1'
        option log_level 'important'
        option log_retention '3d'
        option log_max_size_kb '1024'
        option log_masking 'balanced'
        option log_export_mask_sensitive '1'
        option allow_router_for_blocked '1'
        option block_router_for_blacklist '1'
        option domain_allowlist_enabled '0'
        option domain_allowlist_for_blocklist '1'
        option domain_allowlist_for_blocklist_default_migrated '1'
        option emergency_sites_initialized '1'
        option site_allowlist_sources 'UT1 child | https://dsi.ut-capitole.fr/blacklists/download/child.tar.gz'
        option site_blocklist_mode 'except_allowlist_admins'
        option site_blocklist_sources 'HaGeZi NSFW | https://raw.githubusercontent.com/hagezi/dns-blocklists/main/adblock/nsfw.txt; HaGeZi Gambling mini | https://raw.githubusercontent.com/hagezi/dns-blocklists/main/adblock/gambling.mini.txt; HaGeZi Threat Intelligence mini | https://raw.githubusercontent.com/hagezi/dns-blocklists/main/adblock/tif.mini.txt; URLhaus malware domains | https://urlhaus.abuse.ch/downloads/hostfile/'
        option site_lists_update_interval 'weekly'
        # SHEEPFOLD_AI_BEGIN
        option activity_log_enabled '0'
        option private_logs '0'
        option log_days '7'
        option log_max_dir_kb '0'
        option log_max_device_kb '0'
        # SHEEPFOLD_AI_END
        option new_device_policy 'allow'
        option next_device_id '1'
        option auto_configure '1'
        option detection_mode 'full'
        option device_monitoring_mode 'automatic'
        option no_restrictions_auto_assign '1'
        option personal_devices_auto_assign '1'
        option detector_watch_interval_seconds '10'
        option detector_interval_seconds '86400'
        option detector_connection_delay_seconds '20'
	option detector_offline_grace_seconds '90'
        option detector_max_event_scans_per_tick '4'
        option detector_max_hosts_per_scan '16'
        option detector_min_device_type_confidence '70'
        option detector_min_no_restrictions_confidence '80'
        option detector_nmap_host_timeout_seconds '20'
        option detector_full_rescan_seconds '86400'
        option detector_low_confidence_retry_seconds '86400'
        option detector_ssdp_rescan_seconds '3600'
	option detector_wsd_rescan_seconds '3600'
	option detector_max_upnp_fetches_per_scan '4'
	option identity_quarantine_reminder_seconds '86400'
        option service_control_interval_seconds '30'
        option update_check_install_mode 'weekly'
        option active_messenger 'none'
        option sim_change_notifications 'new_only'
        option child_wifi_network_notifications 'off'
        # SHEEPFOLD_AI_BEGIN
        option ai_enabled '0'
        option ai_provider 'none'
        option ai_rate_limit_requests '20'
        option ai_rate_limit_window_seconds '3600'
        option ai_individual_logs '0'
        option child_ai_parental_consent '0'
        option child_ai_consent_version 'child-ai-v1'
        option parent_ai_prompt_version 'v2'
        option child_ai_prompt_version 'v1'
        option deepseek_model 'deepseek-chat'
        option deepseek_api_url 'https://api.deepseek.com/chat/completions'
        option deepseek_api_key ''
        option gemini_model 'gemini-2.5-flash'
        option gemini_api_url 'https://generativelanguage.googleapis.com/v1beta/models'
        option gemini_api_key ''
        option grok_model 'grok-3-mini'
        option grok_api_url 'https://api.x.ai/v1/chat/completions'
        option grok_api_key ''
        # SHEEPFOLD_AI_END
        option vk_access_token ''
        option vk_community_id ''
        option vk_admin_user_id ''
        option telegram_bot_token ''
        option telegram_admin_chat_id ''
        option wifi_auto_enable_mode 'never'
        option wifi_auto_enable_time '07:00'
        option wifi_auto_disable_mode 'never'
        option wifi_auto_disable_time '23:00'
        option router_ntp_server_enabled '1'
        option router_ntp_client_auto_configure '1'
        option router_timezone_name 'Europe/Moscow'
        option router_timezone 'MSK-3'
        option router_ntp_servers 'ntp1.vniiftri.ru ntp2.ntp-servers.net 3.openwrt.pool.ntp.org'
        option wps_short_press_action 'router_default'
        option wps_long_press_action 'router_default'
        option router_led_control 'router_default'
        option router_led_repair '0'
        option blocked_page_port '5202'
        option bedtime '21:00'
        option offline_device_retention_days '90'
        option log_storage 'ram'
        option log_cache_path '/tmp/sheepfold/events.log'
        option blocked_page_enabled '1'
        option blocked_page_text 'Интернет временно недоступен по семейным правилам. Если это ошибка, обратитесь к родителю.'
        option ui_asset_version '0.0.0-0'
	option app_port '5201'
	option pairing_diagnostics '0'
        option integration_mode 'none'
        option integration_mode_source 'default'
        option integration_mode_user_set '0'
        option router_ipv6_disabled '0'
        option router_ipv6_mode_source 'default'
        option site_filter_backend 'auto'
	option adguard_auto_manage '1'
	option adguard_health_interval_seconds '300'
        option adguard_integration '0'
        option podkop_compatibility '0'
        option require_router_root_password '1'
        option quick_allowlist_window_seconds '30'
        # Адрес добавляет владелец проекта после развёртывания Yandex Cloud.
        # В интерфейсе конечного пользователя технический endpoint не показывается.
        option feedback_endpoint ''
        option feedback_install_id ''

config list 'allowlist'
        option description 'Devices that must never be blocked'

config list 'blocklist'
        option description 'Devices that must always be blocked'

config list 'domain_allowlist'
        option description 'Domains available for temporarily blocked devices'

config emergency_site 'emergency_gosuslugi_ru'
        option domain 'gosuslugi.ru'
        option name 'Госуслуги'
        option description 'Государственные услуги'
        option enabled '1'
        option order '1'
	option source 'country_profile'
	option profile_country 'ru'
	option profile_id 'gosuslugi'

config emergency_site 'emergency_esia_gosuslugi_ru'
        option domain 'esia.gosuslugi.ru'
        option name 'ЕСИА'
        option description 'Вход в государственную учётную запись'
        option enabled '1'
        option order '2'
	option source 'country_profile'
	option profile_country 'ru'
	option profile_id 'esia'

config emergency_site 'emergency_mos_ru'
        option domain 'mos.ru'
        option name 'Услуги Москвы'
        option description 'Городские сервисы'
        option enabled '1'
        option order '3'
	option source 'country_profile'
	option profile_country 'ru'
	option profile_id 'mos'

config emergency_site 'emergency_school_mos_ru'
        option domain 'school.mos.ru'
        option name 'Московская школа'
        option description 'Доступ к школе'
        option enabled '1'
        option order '4'
	option source 'country_profile'
	option profile_country 'ru'
	option profile_id 'school_mos'

config emergency_site 'emergency_dnevnik_ru'
        option domain 'dnevnik.ru'
        option name 'Дневник.ру'
        option description 'Школьный дневник'
        option enabled '1'
        option order '5'
	option source 'country_profile'
	option profile_country 'ru'
	option profile_id 'dnevnik'

config emergency_site 'emergency_ya_ru'
        option domain 'ya.ru'
        option name 'Поиск Яндекса'
        option description 'Узкая точка входа в поиск'
        option enabled '1'
        option order '6'
	option source 'country_profile'
	option profile_country 'ru'
	option profile_id 'ya_search'

config emergency_site 'emergency_2gis_ru'
        option domain '2gis.ru'
        option name '2ГИС'
        option description 'Карты и организации'
        option enabled '1'
        option order '7'
	option source 'country_profile'
	option profile_country 'ru'
	option profile_id '2gis'

config emergency_site 'emergency_mchs_ru'
	option domain 'mchs.gov.ru'
	option name 'МЧС России'
	option description 'Официальная информация о чрезвычайных ситуациях и безопасности.'
	option enabled '1'
	option order '8'
	option source 'country_profile'
	option profile_country 'ru'
	option profile_id 'mchs'

config emergency_site 'emergency_mchs_psychology_ru'
	option domain 'psi.mchs.gov.ru'
	option name 'Экстренная психологическая помощь МЧС'
	option description 'Информация и контакты психологической помощи в кризисной ситуации.'
	option enabled '1'
	option order '9'
	option source 'country_profile'
	option profile_country 'ru'
	option profile_id 'mchs_psychology'

config emergency_site 'emergency_minzdrav_ru'
	option domain 'minzdrav.gov.ru'
	option name 'Минздрав России'
	option description 'Официальная информация здравоохранения.'
	option enabled '1'
	option order '10'
	option source 'country_profile'
	option profile_country 'ru'
	option profile_id 'minzdrav'

config emergency_site 'emergency_rzd_ru'
	option domain 'rzd.ru'
	option name 'Российские железные дороги'
	option description 'Расписание поездов и информация о железнодорожных поездках.'
	option enabled '1'
	option order '11'
	option source 'country_profile'
	option profile_country 'ru'
	option profile_id 'rzd'

config group 'no_restrictions'
        option name 'Без ограничений'
        option protected '1'
        option personal '0'
        option auto_assignable '1'
        option allowlist_only '0'
        # SHEEPFOLD_AI_BEGIN
        option activity_log_enabled '0'
        # SHEEPFOLD_AI_END
        option description 'Trusted home infrastructure devices that should not be limited unless they are blocklisted'

config group 'child_1'
        option name 'Первый ребёнок'
        option protected '0'
        option personal '1'
        option auto_assignable '0'
        option allowlist_only '0'
        # SHEEPFOLD_AI_BEGIN
        option activity_log_enabled '0'
        # SHEEPFOLD_AI_END
        option description 'Default first child group'

config group 'personal_devices'
        option name 'Персональные устройства'
        option protected '1'
        option personal '0'
        option auto_assignable '1'
        option allowlist_only '0'
        option description 'Personal phones, tablets, computers, media players, TVs, and smart watches'

config integration 'adguard'
        option enabled '0'
        option url 'http://127.0.0.1:3000'
        option username ''
        option password ''

config integration 'podkop'
        option enabled '0'
        option compatibility_mode '1'

config messenger 'messenger_global'
        option active 'none'
        option default_adapter 'vk'
        option max_experimental '1'
        option polling_mode 'long_polling'
        option show_technical_details '0'
        option require_confirmation '1'

config export 'export_global'
        option default_format 'json'
        option include_secrets '0'
        option encrypted_full_backup '1'

config wifi_control 'wifi_control_global'
        option enabled '0'
        option allow_24ghz '1'
        option allow_5ghz '1'
        option require_confirmation '1'

config administrator 'owner'
        option id '1'
        option display_name 'Родитель'
        option login 'SuperParent'
        option role 'owner'
        option password_hash ''
        option password_setup_required '1'
        option allow_child_access_requests '0'

config usb 'usb'
        option enabled '0'
        option device ''
        option role 'logs_only'
        option encrypt '1'

config yandex_disk 'cloud'
        option login ''
        option password ''
        option root_folder '/sheepfold'
        option quota_mb '500'
        option authorized '0'

config google_drive 'gdrive'
        option client_id ''
        option client_secret ''
        option refresh_token ''
        option root_folder '/sheepfold'
        option quota_mb '500'
        option authorized '0'

config pairing 'pairing_global'
        option enabled '1'
        option token_lifetime_seconds '600'
        option require_admin_device '1'
        option store_tokens_hashed '1'
        option consume_token_on_success '1'
        option max_attempts '10'
        option attempt_window_seconds '600'
