#!/bin/sh
set -eu

COMMAND="${1:-status}"
RUNTIME_DIR="/tmp/sheepfold"
LED_DEFAULTS="$RUNTIME_DIR/led-defaults.tsv"
LED_ALERT_FLAG="$RUNTIME_DIR/new-device-alert"
LED_ALERT_ACK="$RUNTIME_DIR/new-device-alert.ack"
LED_ALERT_PID="$RUNTIME_DIR/led-alert.pid"
WPS_LEASES_BEFORE="$RUNTIME_DIR/wps-leases-before.tsv"
WPS_ALLOWLIST_FLAG="$RUNTIME_DIR/wps-allowlist-window"
WIFI_LAST_ACTION="$RUNTIME_DIR/wifi-automation-last-action"
BLOCKED_HTTPD_PID="$RUNTIME_DIR/blocked-httpd.pid"
BLOCKED_HTTPD_ROOT="$RUNTIME_DIR/blocked-www"
WAN_STATE_FILE="$RUNTIME_DIR/wan-state"
LOG_HELPER="/usr/libexec/sheepfold/sheepfold-log"

mkdir -p "$RUNTIME_DIR"

log() {
        logger -t sheepfold-router-control "$*"
}

log_event() {
        if [ -x "$LOG_HELPER" ]; then
                "$LOG_HELPER" "$*"
        else
                log "$*"
        fi
}

global_get() {
        uci -q get "sheepfold.global.$1" 2>/dev/null || printf '%s' "$2"
}

repair_sheepfold_uci_sections() {
        mkdir -p /etc/config
        [ -e /etc/config/sheepfold ] || : > /etc/config/sheepfold
        chmod 600 /etc/config/sheepfold 2>/dev/null || true

        for pair in messenger:messenger_global export:export_global wifi_control:wifi_control_global pairing:pairing_global; do
                type="${pair%%:*}"
                name="${pair#*:}"

                if [ "$(uci -q get sheepfold.global 2>/dev/null || true)" = "$type" ]; then
                        uci -q rename sheepfold.global="$name" 2>/dev/null || {
                                uci -q delete sheepfold.global 2>/dev/null || true
                                uci -q set "sheepfold.$name=$type"
                        }
                fi

                uci -q rename "sheepfold.@$type[0]=$name" 2>/dev/null || true
        done

        if [ "$(uci -q get sheepfold.global 2>/dev/null || true)" != "sheepfold" ]; then
                uci -q rename sheepfold.global=legacy_global 2>/dev/null ||
                        uci -q delete sheepfold.global 2>/dev/null || true
                uci -q rename sheepfold.@sheepfold[0]=global 2>/dev/null ||
                        uci -q set sheepfold.global='sheepfold'
        fi

        uci -q commit sheepfold 2>/dev/null || true
}

require_active_messenger() {
        expected="$1"
        actual="$(global_get active_messenger none)"

        if [ "$actual" != "$expected" ]; then
                echo "UCI active_messenger is '$actual', expected '$expected'" >&2
                echo "Run: uci show sheepfold | grep active_messenger" >&2
                exit 1
        fi
}

valid_port() {
        case "$1" in
                ''|*[!0-9]*) return 1 ;;
        esac
        [ "$1" -ge 1 ] && [ "$1" -le 65535 ]
}

valid_hostname() {
        printf '%s' "$1" | grep -Eq '^([A-Za-z0-9]([A-Za-z0-9-]*[A-Za-z0-9])?\.)*[A-Za-z0-9]([A-Za-z0-9-]*[A-Za-z0-9])?$'
}

valid_timezone_name() {
        printf '%s' "$1" | grep -Eq '^[A-Za-z0-9_+.-]+(/[A-Za-z0-9_+.-]+)?$'
}

valid_posix_timezone() {
        printf '%s' "$1" | grep -Eq '^[A-Za-z0-9_+:-]+$'
}

normalize_mac() {
        printf '%s' "$1" | tr '[:lower:]' '[:upper:]'
}

valid_mac() {
        printf '%s' "$1" | grep -Eq '^([0-9A-F]{2}:){5}[0-9A-F]{2}$'
}

ensure_list_section() {
        name="$1"
        if [ "$(uci -q get "sheepfold.$name" 2>/dev/null || true)" != "list" ]; then
                uci -q delete "sheepfold.$name" 2>/dev/null || true
                uci -q set "sheepfold.$name=list"
        fi
}

list_has_mac() {
        list_name="$1"
        mac="$(normalize_mac "$2")"

        valid_mac "$mac" || return 1

        for existing in $(uci -q get "sheepfold.$list_name.mac" 2>/dev/null || true); do
                [ "$(normalize_mac "$existing")" = "$mac" ] && return 0
        done

        return 1
}

add_mac_to_allowlist() {
        mac="$(normalize_mac "$1")"
        valid_mac "$mac" || return 0
        ensure_list_section allowlist

        for existing in $(uci -q get sheepfold.allowlist.mac 2>/dev/null || true); do
                [ "$(normalize_mac "$existing")" = "$mac" ] && return 0
        done

        uci -q add_list "sheepfold.allowlist.mac=$mac"
}

remove_mac_from_list() {
        list_name="$1"
        mac="$(normalize_mac "$2")"
        valid_mac "$mac" || return 0
        ensure_list_section "$list_name"

        values="$(uci -q get "sheepfold.$list_name.mac" 2>/dev/null || true)"
        uci -q delete "sheepfold.$list_name.mac" 2>/dev/null || true

        for existing in $values; do
                normalized="$(normalize_mac "$existing")"
                [ "$normalized" = "$mac" ] && continue
                valid_mac "$normalized" || continue
                uci -q add_list "sheepfold.$list_name.mac=$normalized"
        done
}

add_mac_to_list() {
        list_name="$1"
        mac="$(normalize_mac "$2")"
        valid_mac "$mac" || return 1
        ensure_list_section "$list_name"

        for existing in $(uci -q get "sheepfold.$list_name.mac" 2>/dev/null || true); do
                [ "$(normalize_mac "$existing")" = "$mac" ] && return 0
        done

        uci -q add_list "sheepfold.$list_name.mac=$mac"
}

device_section_for_mac() {
        mac="$(normalize_mac "$1")"
        valid_mac "$mac" || return 1

        for section in $(uci -q show sheepfold 2>/dev/null | sed -n "s/^sheepfold\.\([^.=]*\)=device$/\1/p"); do
                existing="$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)"
                [ "$(normalize_mac "$existing")" = "$mac" ] && {
                        printf '%s\n' "$section"
                        return 0
                }
        done

        section="device_$(printf '%s' "$mac" | tr -d ':' | tr '[:upper:]' '[:lower:]')"
        uci -q get "sheepfold.$section" >/dev/null 2>&1 || uci -q set "sheepfold.$section=device"
        printf '%s\n' "$section"
}

admin_section_for_login() {
        login="$1"
        [ -n "$login" ] || return 1

        for section in $(uci -q show sheepfold 2>/dev/null | sed -n "s/^sheepfold\.\([^.=]*\)=administrator$/\1/p"); do
                existing="$(uci -q get "sheepfold.$section.login" 2>/dev/null || true)"
                [ "$existing" = "$login" ] && {
                        printf '%s\n' "$section"
                        return 0
                }
        done

        return 1
}

admin_section_name_for_login() {
        login="$1"

        case "$login" in
                SuperParent) printf '%s\n' owner ;;
                *)
                        section="admin_$(printf '%s' "$login" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9_]/_/g; s/^_*//; s/_*$//')"
                        [ "$section" != "admin_" ] || section="admin_manual"
                        printf '%s\n' "$section"
                        ;;
        esac
}

activate_admin_pairing_code() {
        login="${1:-}"
        code="${2:-}"
        display_name="${3:-}"
        lifetime="${4:-600}"

        [ -n "$login" ] || {
                echo "Administrator login is required" >&2
                return 2
        }
        [ -n "$code" ] || {
                echo "Pairing code is required" >&2
                return 2
        }

        case "$lifetime" in
                ''|*[!0-9]*) lifetime=600 ;;
        esac

        repair_sheepfold_uci_sections
        section="$(admin_section_for_login "$login" 2>/dev/null || true)"
        [ -n "$section" ] || section="$(admin_section_name_for_login "$login")"

        if [ "$(uci -q get "sheepfold.$section" 2>/dev/null || true)" != "administrator" ]; then
                uci -q delete "sheepfold.$section" 2>/dev/null || true
                uci -q set "sheepfold.$section=administrator"
        fi

        [ -n "$display_name" ] || display_name="$login"
        expires_at="$(($(date +%s) + lifetime))"

        uci -q set "sheepfold.$section.display_name=$display_name"
        uci -q set "sheepfold.$section.login=$login"
        uci -q set "sheepfold.$section.pairing_code=$code"
        uci -q set "sheepfold.$section.pairing_code_expires=$expires_at"
        uci -q commit sheepfold

        printf 'activated=1\n'
        printf 'admin_section=%s\n' "$section"
        printf 'expires_at=%s\n' "$expires_at"
}

mac_for_ip() {
        ip="$1"
        [ -n "$ip" ] || return 1

        if [ -r /tmp/dhcp.leases ]; then
                awk -v ip="$ip" '$3 == ip { print toupper($2); exit }' /tmp/dhcp.leases
        fi

        if [ -r /proc/net/arp ]; then
                awk -v ip="$ip" '$1 == ip { print toupper($4); exit }' /proc/net/arp
        fi
}

name_for_ip() {
        ip="$1"
        [ -n "$ip" ] || return 1

        if [ -r /tmp/dhcp.leases ]; then
                awk -v ip="$ip" '$3 == ip { print $4; exit }' /tmp/dhcp.leases
        fi
}

pair_admin_device() {
        login="${1:-}"
        code="${2:-}"
        remote_ip="${3:-}"
        user_agent="${4:-}"

        repair_sheepfold_uci_sections
        ensure_list_section allowlist
        ensure_list_section blocklist

        admin_section="$(admin_section_for_login "$login")" || {
                echo "Administrator login was not found" >&2
                return 2
        }

        expected_code="$(uci -q get "sheepfold.$admin_section.pairing_code" 2>/dev/null || true)"
        expires_at="$(uci -q get "sheepfold.$admin_section.pairing_code_expires" 2>/dev/null || printf 0)"
        now="$(date +%s)"

        [ -n "$expected_code" ] || {
                echo "Pairing code is not active. Open administrator settings in LuCI again." >&2
                return 3
        }

        [ "$code" = "$expected_code" ] || {
                echo "Pairing code is invalid" >&2
                return 3
        }

        case "$expires_at" in
                ''|*[!0-9]*) expires_at=0 ;;
        esac

        if [ "$expires_at" -gt 0 ] && [ "$now" -gt "$expires_at" ]; then
                uci -q delete "sheepfold.$admin_section.pairing_code" 2>/dev/null || true
                uci -q delete "sheepfold.$admin_section.pairing_code_expires" 2>/dev/null || true
                uci -q commit sheepfold
                echo "Pairing code has expired. Open administrator settings in LuCI again." >&2
                return 3
        fi

        mac="$(mac_for_ip "$remote_ip" | sed -n '1p')"
        mac="$(normalize_mac "$mac")"
        valid_mac "$mac" || {
                echo "Could not determine phone MAC address from router leases or ARP table" >&2
                return 4
        }

        if list_has_mac blocklist "$mac"; then
                echo "Blocklisted device cannot become an administrator device" >&2
                return 5
        fi

        admin_name="$(uci -q get "sheepfold.$admin_section.display_name" 2>/dev/null || printf '%s' "$login")"
        device_name="$(name_for_ip "$remote_ip" | sed -n '1p')"
        [ -n "$device_name" ] && [ "$device_name" != "*" ] || device_name="Телефон администратора"
        section="$(device_section_for_mac "$mac")"

        # Привязанный телефон администратора сразу выводим из обычных правил:
        # он не должен зависеть от детских групп/расписаний и должен оставаться в белом списке,
        # иначе родитель может потерять доступ к управлению в самый неудобный момент.
        uci -q set "sheepfold.$section.mac=$mac"
        uci -q set "sheepfold.$section.name=$device_name"
        uci -q set "sheepfold.$section.ip=$remote_ip"
        uci -q set "sheepfold.$section.device_type=phone"
        uci -q set "sheepfold.$section.manual_device_type=1"
        uci -q set "sheepfold.$section.group=Не настроено"
        uci -q set "sheepfold.$section.schedules="
        uci -q set "sheepfold.$section.status=allow"
        uci -q set "sheepfold.$section.admin_device=1"
        uci -q set "sheepfold.$section.admin_owner=$admin_name"
        uci -q set "sheepfold.$section.admin_login=$login"
        uci -q set "sheepfold.$section.paired_from=android"
        uci -q set "sheepfold.$section.paired_at=$now"
        uci -q set "sheepfold.$section.pairing_user_agent=$user_agent"
        add_mac_to_list allowlist "$mac"
        remove_mac_from_list blocklist "$mac"

        # Код сопряжения одноразовый. Удаляем его на роутере сразу после успешного использования,
        # чтобы фотография QR-кода или подсмотренный временный пароль не сработали повторно.
        uci -q delete "sheepfold.$admin_section.pairing_code" 2>/dev/null || true
        uci -q delete "sheepfold.$admin_section.pairing_code_expires" 2>/dev/null || true
        uci -q commit sheepfold

        log_event "Android-приложение привязало админское устройство: $device_name, $mac, IP ${remote_ip:-неизвестен}, администратор $admin_name"

        printf 'paired=1\n'
        printf 'admin_name=%s\n' "$admin_name"
        printf 'admin_login=%s\n' "$login"
        printf 'device_name=%s\n' "$device_name"
        printf 'mac=%s\n' "$mac"
        printf 'ip=%s\n' "$remote_ip"
}

admin_pairing_status() {
        login="${1:-}"
        since="${2:-0}"

        repair_sheepfold_uci_sections

        case "$since" in
                ''|*[!0-9]*) since=0 ;;
        esac

        for section in $(uci -q show sheepfold 2>/dev/null | sed -n "s/^sheepfold\.\([^.=]*\)=device$/\1/p"); do
                admin_login="$(uci -q get "sheepfold.$section.admin_login" 2>/dev/null || true)"
                admin_device="$(uci -q get "sheepfold.$section.admin_device" 2>/dev/null || printf 0)"
                paired_at="$(uci -q get "sheepfold.$section.paired_at" 2>/dev/null || printf 0)"

                [ "$admin_device" = "1" ] || continue
                [ "$admin_login" = "$login" ] || continue

                case "$paired_at" in
                        ''|*[!0-9]*) paired_at=0 ;;
                esac

                [ "$paired_at" -ge "$since" ] || continue

                mac="$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)"
                device_name="$(uci -q get "sheepfold.$section.name" 2>/dev/null || true)"
                [ -n "$device_name" ] || device_name="$mac"

                printf 'paired=1\n'
                printf 'admin_name=%s\n' "$(uci -q get "sheepfold.$section.admin_owner" 2>/dev/null || printf '%s' "$login")"
                printf 'admin_login=%s\n' "$admin_login"
                printf 'device_name=%s\n' "$device_name"
                printf 'mac=%s\n' "$mac"
                printf 'ip=%s\n' "$(uci -q get "sheepfold.$section.ip" 2>/dev/null || true)"
                printf 'paired_at=%s\n' "$paired_at"
                return 0
        done

        printf 'paired=0\n'
}

set_device_status() {
        mac="$(normalize_mac "${1:-}")"
        status="${2:-}"
        name="${3:-}"
        ip="${4:-}"
        group="${5:-}"
        device_type="${6:-}"

        valid_mac "$mac" || {
                echo "Invalid MAC address" >&2
                return 2
        }

        case "$status" in
                allow|blocked|restricted|scheduled|new) ;;
                *)
                        echo "Unsupported device status: $status" >&2
                        return 2
                        ;;
        esac

        repair_sheepfold_uci_sections
        ensure_list_section allowlist
        ensure_list_section blocklist
        section="$(device_section_for_mac "$mac")"

        if [ "$status" = "blocked" ] &&
                [ "$(uci -q get "sheepfold.$section.admin_device" 2>/dev/null || printf 0)" = "1" ]; then
                echo "Administrator device cannot be added to blocklist" >&2
                return 3
        fi

        # Не переносим MAC между белым и чёрным списком автоматически. Пользователь должен сам
        # убрать конфликтующий статус, потому что это явное решение о доверии или запрете устройства.
        if [ "$status" = "allow" ] && list_has_mac blocklist "$mac"; then
                echo "Device is already in blocklist. Remove it from blocklist first." >&2
                return 3
        fi

        if [ "$status" = "blocked" ] && list_has_mac allowlist "$mac"; then
                echo "Device is already in allowlist. Remove it from allowlist first." >&2
                return 3
        fi

        [ -n "$name" ] || name="$mac"
        [ -n "$group" ] || group="Не настроено"
        [ -n "$device_type" ] || device_type="smart"

        uci -q set "sheepfold.$section.mac=$mac"
        uci -q set "sheepfold.$section.name=$name"
        uci -q set "sheepfold.$section.ip=$ip"
        uci -q set "sheepfold.$section.group=$group"
        uci -q set "sheepfold.$section.device_type=$device_type"
        uci -q set "sheepfold.$section.status=$status"

        if [ "$status" = "allow" ]; then
                add_mac_to_list allowlist "$mac"
                log_event "Устройство добавлено в белый список: $mac, IP ${ip:-неизвестен}"
        elif [ "$status" = "blocked" ]; then
                add_mac_to_list blocklist "$mac"
                log_event "Устройство добавлено в чёрный список: $mac, IP ${ip:-неизвестен}"
        else
                remove_mac_from_list allowlist "$mac"
                remove_mac_from_list blocklist "$mac"
                log_event "Устройство добавлено вручную: $mac, IP ${ip:-неизвестен}"
        fi

        uci -q commit sheepfold

        actual_status="$(uci -q get "sheepfold.$section.status" 2>/dev/null || printf '')"
        if [ "$actual_status" != "$status" ]; then
                echo "UCI device status is '$actual_status', expected '$status'" >&2
                exit 1
        fi
        if [ "$status" = "allow" ] && ! list_has_mac allowlist "$mac"; then
                echo "MAC was not saved to allowlist: $mac" >&2
                exit 1
        fi
        if [ "$status" = "blocked" ] && ! list_has_mac blocklist "$mac"; then
                echo "MAC was not saved to blocklist: $mac" >&2
                exit 1
        fi

        printf 'OK\n'
}

wifi_set_all() {
        disabled="$1"
        changed=0

        for radio in $(uci -q show wireless 2>/dev/null | sed -n "s/^wireless\.\([^.=]*\)=wifi-device$/\1/p"); do
                uci -q set "wireless.$radio.disabled=$disabled"
                changed=1
        done

        [ "$changed" = "1" ] || {
                log "No wireless radios found"
                return 1
        }

        uci -q commit wireless
        wifi reload >/dev/null 2>&1 || wifi >/dev/null 2>&1 || true
}

wifi_enable() {
        wifi_set_all 0
        log_event "Wi-Fi включён Sheepfold"
        log "All Wi-Fi radios enabled"
}

wifi_disable() {
        wifi_set_all 1
        log_event "Wi-Fi отключён Sheepfold"
        log "All Wi-Fi radios disabled"
}

global_internet_enable() {
        uci -q set sheepfold.global.block_on_boot='0'
        uci -q commit sheepfold
        log_event "Глобальная блокировка интернета выключена через Sheepfold"
        printf 'OK\n'
}

global_internet_disable() {
        uci -q set sheepfold.global.block_on_boot='1'
        uci -q commit sheepfold
        log_event "Глобальная блокировка интернета включена через Sheepfold"
        printf 'OK\n'
}

global_internet_status() {
        if [ "$(global_get block_on_boot 0)" = "1" ]; then
                printf 'disabled\n'
        else
                printf 'enabled\n'
        fi
}

messenger_disable() {
        repair_sheepfold_uci_sections
        uci -q set sheepfold.global.active_messenger='none'
        uci -q commit sheepfold
        require_active_messenger none
        log_event "Мессенджер Sheepfold выключен"
        printf 'OK\n'
}

messenger_save_telegram() {
        telegram_bot_token="${1:-}"
        telegram_admin_chat_id="${2:-}"

        repair_sheepfold_uci_sections
        uci -q set sheepfold.global.active_messenger='telegram'
        uci -q set sheepfold.global.telegram_bot_token="$telegram_bot_token"
        uci -q set sheepfold.global.telegram_admin_chat_id="$telegram_admin_chat_id"
        uci -q commit sheepfold
        require_active_messenger telegram

        log_event "Настройки Telegram-мессенджера сохранены"
        printf 'OK\n'
}

messenger_save_vk() {
        vk_access_token="${1:-}"
        vk_community_id="${2:-}"
        vk_admin_user_id="${3:-}"

        repair_sheepfold_uci_sections
        uci -q set sheepfold.global.active_messenger='vk'
        uci -q set sheepfold.global.vk_access_token="$vk_access_token"
        uci -q set sheepfold.global.vk_community_id="$vk_community_id"
        uci -q set sheepfold.global.vk_admin_user_id="$vk_admin_user_id"
        uci -q commit sheepfold
        require_active_messenger vk

        log_event "Настройки VK-мессенджера сохранены"
        printf 'OK\n'
}

messenger_status() {
        repair_sheepfold_uci_sections
        active="$(global_get active_messenger none)"

        printf 'active=%s\n' "$active"
        printf 'telegram_token_configured=%s\n' "$([ -n "$(global_get telegram_bot_token '')" ] && printf 1 || printf 0)"
        printf 'telegram_admin_chat_id_configured=%s\n' "$([ -n "$(global_get telegram_admin_chat_id '')" ] && printf 1 || printf 0)"
        printf 'vk_token_configured=%s\n' "$([ -n "$(global_get vk_access_token '')" ] && printf 1 || printf 0)"
        printf 'vk_community_id_configured=%s\n' "$([ -n "$(global_get vk_community_id '')" ] && printf 1 || printf 0)"
        printf 'vk_admin_user_id_configured=%s\n' "$([ -n "$(global_get vk_admin_user_id '')" ] && printf 1 || printf 0)"
}

http_get() {
        url="$1"

        if command -v uclient-fetch >/dev/null 2>&1; then
                uclient-fetch -qO- "$url" 2>/dev/null || true
        elif command -v wget >/dev/null 2>&1; then
                wget -q -O - "$url" 2>/dev/null || true
        elif command -v curl >/dev/null 2>&1; then
                curl -fsSL "$url" 2>/dev/null || true
        fi
}

messenger_check() {
        repair_sheepfold_uci_sections
        active="$(global_get active_messenger none)"

        printf 'active=%s\n' "$active"

        case "$active" in
                telegram)
                        token="$(global_get telegram_bot_token '')"
                        if [ -z "$token" ]; then
                                printf 'status=error\n'
                                printf 'message=%s\n' 'Токен Telegram-бота не заполнен'
                                return 1
                        fi

                        response="$(http_get "https://api.telegram.org/bot${token}/getMe")"
                        if printf '%s' "$response" | grep -q '"ok"[[:space:]]*:[[:space:]]*true'; then
                                printf 'status=connected\n'
                                printf 'message=%s\n' 'Telegram подключён'
                                return 0
                        fi

                        printf 'status=error\n'
                        printf 'message=%s\n' 'От сервера Telegram нет ответа'
                        return 1
                        ;;
                vk)
                        token="$(global_get vk_access_token '')"
                        community_id="$(global_get vk_community_id '')"
                        if [ -z "$token" ] || [ -z "$community_id" ]; then
                                printf 'status=error\n'
                                printf 'message=%s\n' 'Данные VK не заполнены'
                                return 1
                        fi

                        response="$(http_get "https://api.vk.com/method/groups.getById?group_id=${community_id}&access_token=${token}&v=5.199")"
                        if printf '%s' "$response" | grep -q '"response"[[:space:]]*:'; then
                                printf 'status=connected\n'
                                printf 'message=%s\n' 'VK подключён'
                                return 0
                        fi

                        printf 'status=error\n'
                        printf 'message=%s\n' 'От сервера VK нет ответа'
                        return 1
                        ;;
                *)
                        printf 'status=disabled\n'
                        printf 'message=%s\n' 'Мессенджер выключен'
                        ;;
        esac
}

ensure_system_time_sections() {
        uci -q get system.@system[0] >/dev/null 2>&1 || uci -q add system system >/dev/null
        if [ "$(uci -q get system.ntp 2>/dev/null || true)" != "timeserver" ]; then
                uci -q delete system.ntp 2>/dev/null || true
                uci -q set system.ntp='timeserver'
        fi
}

time_save() {
        ntp_server_enabled="${1:-1}"
        ntp_client_enabled="${2:-1}"
        zonename="${3:-Europe/Moscow}"
        timezone="${4:-MSK-3}"
        servers="${5:-ntp1.vniiftri.ru ntp2.ntp-servers.net 3.openwrt.pool.ntp.org}"
        normalized_servers=""

        case "$ntp_server_enabled" in 0|1) ;; *) ntp_server_enabled=1 ;; esac
        case "$ntp_client_enabled" in 0|1) ;; *) ntp_client_enabled=1 ;; esac
        valid_timezone_name "$zonename" || zonename="Europe/Moscow"
        valid_posix_timezone "$timezone" || timezone="MSK-3"

        for server in $servers; do
                valid_hostname "$server" || continue
                normalized_servers="${normalized_servers}${normalized_servers:+ }$server"
        done

        [ -n "$normalized_servers" ] || normalized_servers="ntp1.vniiftri.ru ntp2.ntp-servers.net 3.openwrt.pool.ntp.org"

        repair_sheepfold_uci_sections
        ensure_system_time_sections

        uci -q set "system.@system[0].zonename=$zonename"
        uci -q set "system.@system[0].timezone=$timezone"
        uci -q set "system.ntp.enabled=$ntp_client_enabled"
        uci -q set "system.ntp.enable_server=$ntp_server_enabled"
        uci -q delete system.ntp.server 2>/dev/null || true
        for server in $normalized_servers; do
                uci -q add_list "system.ntp.server=$server"
        done
        uci -q commit system

        uci -q set sheepfold.global.router_ntp_server_enabled="$ntp_server_enabled"
        uci -q set sheepfold.global.router_ntp_client_auto_configure="$ntp_client_enabled"
        uci -q set sheepfold.global.router_timezone_name="$zonename"
        uci -q set sheepfold.global.router_timezone="$timezone"
        uci -q set sheepfold.global.router_ntp_servers="$normalized_servers"
        uci -q commit sheepfold

        [ -x /etc/init.d/sysntpd ] && /etc/init.d/sysntpd restart >/dev/null 2>&1 || true
        log_event "Настройки времени роутера сохранены Sheepfold: timezone $zonename, NTP $normalized_servers"
        printf 'OK\n'
}

ubus_wan_status() {
        iface="$(global_get wan_interface wan)"
        ubus -S call "network.interface.$iface" status 2>/dev/null || true
}

json_bool() {
        key="$1"
        sed -n "s/.*\"$key\"[[:space:]]*:[[:space:]]*\\(true\\|false\\).*/\\1/p"
}

json_string() {
        key="$1"
        sed -n "s/.*\"$key\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p"
}

wan_connectivity_ok() {
        ping -c 1 -W 2 ya.ru >/dev/null 2>&1 && return 0
        ping -c 1 -W 2 gosuslugi.ru >/dev/null 2>&1 && return 0
        ping -c 1 -W 2 ntp1.vniiftri.ru >/dev/null 2>&1 && return 0
        ping -c 1 -W 2 1.1.1.1 >/dev/null 2>&1 && return 0
        ping -c 1 -W 2 8.8.8.8 >/dev/null 2>&1 && return 0
        return 1
}

kv_safe() {
        printf '%s' "$1" | tr '\r\n\t' '   ' | sed 's/[[:space:]][[:space:]]*/ /g; s/^ //; s/ $//'
}

print_kv() {
        printf '%s=%s\n' "$1" "$(kv_safe "$2")"
}

opkg_version() {
        pkg="$1"
        opkg status "$pkg" 2>/dev/null | sed -n 's/^Version: //p' | sed -n '1p'
}

package_version_any() {
        for pkg in "$@"; do
                version="$(opkg_version "$pkg")"
                if [ -n "$version" ]; then
                        printf '%s' "$version"
                        return 0
                fi
        done

        return 1
}

ping_average_ms() {
        host="$1"
        ping -c 3 -W 2 "$host" 2>/dev/null |
                awk -F'/' '/round-trip|rtt/ { print $5; found=1 } END { if (!found) exit 1 }'
}

lan_ports_text() {
        ports=""

        for port_path in /sys/class/net/lan*; do
                [ -e "$port_path" ] || continue
                ports="$ports ${port_path##*/}"
        done

        if [ -z "$ports" ] && [ -d /sys/class/net/br-lan/brif ]; then
                for port_path in /sys/class/net/br-lan/brif/*; do
                        [ -e "$port_path" ] || continue
                        ports="$ports ${port_path##*/}"
                done
        fi

        printf '%s' "$ports" | sed 's/^ //'
}

router_info() {
        status_json="$(ubus_wan_status)"
        wan_state="unknown"
        wan_reason="статус WAN неизвестен"
        ping_ms="$(ping_average_ms ya.ru 2>/dev/null || true)"
        firmware="unknown"
        release="unknown"
        model="$(cat /tmp/sysinfo/model 2>/dev/null || cat /tmp/sysinfo/board_name 2>/dev/null || printf unknown)"
        kernel="$(uname -r 2>/dev/null || printf unknown)"
        sheepfold_version="$(opkg_version luci-app-sheepfold-family-internet-control)"
        podkop_version="$(package_version_any podkop luci-app-podkop || true)"
        adguard_version="$(package_version_any AdGuardHome adguardhome luci-app-adguardhome || true)"
        lan_ports="$(lan_ports_text)"
        lan_count="0"
        uptime_text="$(awk '{ seconds=int($1); days=int(seconds/86400); hours=int((seconds%86400)/3600); minutes=int((seconds%3600)/60); printf "%sd %sh %sm", days, hours, minutes }' /proc/uptime 2>/dev/null || printf unknown)"
        load_avg="$(cut -d' ' -f1-3 /proc/loadavg 2>/dev/null || printf unknown)"
        memory_text="$(awk '/MemTotal:/ { total=$2 } /MemAvailable:/ { available=$2 } END { if (total > 0) printf "%.0f MB free / %.0f MB total", available/1024, total/1024; else print "unknown" }' /proc/meminfo 2>/dev/null || printf unknown)"

        [ -n "$sheepfold_version" ] || sheepfold_version="$(global_get ui_asset_version unknown)"

        if [ -r /etc/openwrt_release ]; then
                # shellcheck disable=SC1091
                . /etc/openwrt_release
                release="${DISTRIB_RELEASE:-unknown}"
                firmware="${DISTRIB_DESCRIPTION:-OpenWrt $release}"
        elif [ -r /etc/openwrt_version ]; then
                release="$(cat /etc/openwrt_version 2>/dev/null || printf unknown)"
                firmware="OpenWrt $release"
        fi

        if [ -n "$status_json" ]; then
                up="$(printf '%s' "$status_json" | json_bool up | head -n 1)"
                available="$(printf '%s' "$status_json" | json_bool available | head -n 1)"
                device="$(printf '%s' "$status_json" | json_string l3_device | head -n 1)"

                if [ -n "$device" ] && [ -r "/sys/class/net/$device/carrier" ] &&
                        [ "$(cat "/sys/class/net/$device/carrier" 2>/dev/null || printf 1)" = "0" ]; then
                        wan_state="offline"
                        wan_reason="кабель WAN отключён или порт без линка"
                elif [ "$up" != "true" ]; then
                        wan_state="offline"
                        if [ "$available" = "false" ]; then
                                wan_reason="WAN-интерфейс недоступен"
                        else
                                wan_reason="WAN-интерфейс не поднят"
                        fi
                elif [ -n "$ping_ms" ]; then
                        wan_state="online"
                        wan_reason="ya.ru отвечает"
                else
                        wan_state="limited"
                        wan_reason="WAN поднят, но ya.ru не ответил на ping"
                fi
        fi

        if [ -n "$lan_ports" ]; then
                lan_count="$(printf '%s\n' "$lan_ports" | awk '{ print NF + 0 }')"
        fi

        print_kv current_time "$(date '+%d.%m.%Y %H:%M:%S %Z' 2>/dev/null || date)"
        print_kv sheepfold_version "$sheepfold_version"
        print_kv internet_status "$wan_state"
        print_kv internet_reason "$wan_reason"
        print_kv ping_yandex_ms "${ping_ms:-timeout}"
        print_kv firmware_version "$firmware"
        print_kv openwrt_release "$release"
        print_kv kernel_version "$kernel"
        print_kv router_model "$model"
        print_kv uptime "$uptime_text"
        print_kv load_average "$load_avg"
        print_kv memory "$memory_text"
        print_kv lan_ports_count "$lan_count"
        print_kv lan_ports "${lan_ports:-unknown}"
        print_kv podkop_installed "$([ -n "$podkop_version" ] && printf yes || printf no)"
        print_kv podkop_version "${podkop_version:-not installed}"
        print_kv adguard_installed "$([ -n "$adguard_version" ] && printf yes || printf no)"
        print_kv adguard_version "${adguard_version:-not installed}"

        wifi_index=0
        for radio in $(uci -q show wireless 2>/dev/null | sed -n "s/^wireless\.\([^.=]*\)=wifi-device$/\1/p"); do
                wifi_index=$((wifi_index + 1))
                disabled="$(uci -q get "wireless.$radio.disabled" 2>/dev/null || printf 0)"
                type="$(uci -q get "wireless.$radio.type" 2>/dev/null || printf unknown)"
                path="$(uci -q get "wireless.$radio.path" 2>/dev/null || uci -q get "wireless.$radio.phy" 2>/dev/null || printf unknown)"
                band="$(uci -q get "wireless.$radio.band" 2>/dev/null || uci -q get "wireless.$radio.hwmode" 2>/dev/null || printf unknown)"
                channel="$(uci -q get "wireless.$radio.channel" 2>/dev/null || printf auto)"
                country="$(uci -q get "wireless.$radio.country" 2>/dev/null || printf unknown)"
                htmode="$(uci -q get "wireless.$radio.htmode" 2>/dev/null || printf unknown)"

                print_kv "wifi_${wifi_index}_name" "$radio"
                print_kv "wifi_${wifi_index}_status" "$([ "$disabled" = "1" ] && printf disabled || printf enabled)"
                print_kv "wifi_${wifi_index}_type" "$type"
                print_kv "wifi_${wifi_index}_path" "$path"
                print_kv "wifi_${wifi_index}_band" "$band"
                print_kv "wifi_${wifi_index}_channel" "$channel"
                print_kv "wifi_${wifi_index}_country" "$country"
                print_kv "wifi_${wifi_index}_mode" "$htmode"
        done
        print_kv wifi_count "$wifi_index"
}

wan_status_tick() {
        now="$(date +%s)"
        last_line="$(cat "$WAN_STATE_FILE" 2>/dev/null || true)"
        last_check="$(printf '%s' "$last_line" | awk -F '\t' '{ print $3 }')"

        case "$last_check" in
                ''|*[!0-9]*) last_check=0 ;;
        esac

        [ $((now - last_check)) -ge 60 ] || return 0

        status_json="$(ubus_wan_status)"
        if [ -z "$status_json" ]; then
                state="offline"
                reason="не удалось получить статус WAN через ubus"
        else
                up="$(printf '%s' "$status_json" | json_bool up | head -n 1)"
                available="$(printf '%s' "$status_json" | json_bool available | head -n 1)"
                device="$(printf '%s' "$status_json" | json_string l3_device | head -n 1)"

                if [ -n "$device" ] && [ -r "/sys/class/net/$device/carrier" ] &&
                        [ "$(cat "/sys/class/net/$device/carrier" 2>/dev/null || printf 1)" = "0" ]; then
                        state="offline"
                        reason="кабель WAN отключён или порт без линка"
                elif [ "$up" != "true" ]; then
                        state="offline"
                        if [ "$available" = "false" ]; then
                                reason="WAN-интерфейс недоступен"
                        else
                                reason="WAN-интерфейс не поднят"
                        fi
                elif wan_connectivity_ok; then
                        state="online"
                        reason="проверка связи прошла успешно"
                else
                        state="offline"
                        reason="таймаут проверки связи"
                fi
        fi

        previous_state="$(printf '%s' "$last_line" | awk -F '\t' '{ print $1 }')"
        previous_reason="$(printf '%s' "$last_line" | awk -F '\t' '{ print $2 }')"

        if [ -z "$previous_state" ] && [ "$state" = "online" ]; then
                :
        elif [ "$state" != "$previous_state" ] || { [ "$state" = "offline" ] && [ "$reason" != "$previous_reason" ]; }; then
                if [ "$state" = "online" ]; then
                        log_event "Интернет на роутере восстановлен: $reason"
                else
                        log_event "У роутера пропал интернет: $reason"
                fi
        fi

        printf '%s\t%s\t%s\n' "$state" "$reason" "$now" > "$WAN_STATE_FILE"
}

blocked_httpd_running() {
        [ -r "$BLOCKED_HTTPD_PID" ] || return 1
        pid="$(cat "$BLOCKED_HTTPD_PID" 2>/dev/null || true)"
        [ -n "$pid" ] || return 1
        kill -0 "$pid" 2>/dev/null
}

blocked_httpd_stop() {
        if blocked_httpd_running; then
                kill "$(cat "$BLOCKED_HTTPD_PID")" 2>/dev/null || true
        fi
        rm -f "$BLOCKED_HTTPD_PID"
}

blocked_httpd_start() {
        port="$(global_get blocked_page_port 5202)"
        valid_port "$port" || port=5202

        mkdir -p "$BLOCKED_HTTPD_ROOT"
        rm -f "$BLOCKED_HTTPD_ROOT/index.html"

        if blocked_httpd_running; then
                return 0
        fi

        if ! command -v uhttpd >/dev/null 2>&1; then
                log "uhttpd is not available for blocked page responder"
                return 0
        fi

        uhttpd -f -p "0.0.0.0:$port" -h "$BLOCKED_HTTPD_ROOT" -x /cgi-bin \
                -E /cgi-bin/sheepfold-blocked >/dev/null 2>&1 &
        echo "$!" > "$BLOCKED_HTTPD_PID"
        log "Blocked page responder started on port $port"
}

blocked_page_apply() {
        enabled="$(global_get blocked_page_enabled 1)"
        if [ "$enabled" = "1" ]; then
                blocked_httpd_start
        else
                blocked_httpd_stop
        fi
}

save_led_defaults() {
        [ -s "$LED_DEFAULTS" ] && return 0
        : > "$LED_DEFAULTS"

        for led in /sys/class/leds/*; do
                [ -d "$led" ] || continue
                name="${led##*/}"
                trigger="$(sed -n 's/.*\[\([^]]*\)\].*/\1/p' "$led/trigger" 2>/dev/null || true)"
                brightness="$(cat "$led/brightness" 2>/dev/null || printf 0)"
                printf '%s\t%s\t%s\n' "$name" "${trigger:-none}" "${brightness:-0}" >> "$LED_DEFAULTS"
        done
}

led_set() {
        led="$1"
        brightness="$2"
        [ -d "$led" ] || return 0
        [ -w "$led/trigger" ] && printf none > "$led/trigger" 2>/dev/null || true
        [ -w "$led/brightness" ] && printf '%s' "$brightness" > "$led/brightness" 2>/dev/null || true
}

led_all() {
        brightness="$1"
        save_led_defaults
        for led in /sys/class/leds/*; do
                led_set "$led" "$brightness"
        done
}

led_restore_defaults() {
        if [ -r "$LED_DEFAULTS" ]; then
                while IFS="$(printf '\t')" read -r name trigger brightness; do
                        led="/sys/class/leds/$name"
                        [ -d "$led" ] || continue
                        [ -n "$trigger" ] && [ -w "$led/trigger" ] && printf '%s' "$trigger" > "$led/trigger" 2>/dev/null || true
                        [ -n "$brightness" ] && [ -w "$led/brightness" ] && printf '%s' "$brightness" > "$led/brightness" 2>/dev/null || true
                done < "$LED_DEFAULTS"
                rm -f "$LED_DEFAULTS"
        else
                for led in /sys/class/leds/*; do
                        [ -d "$led" ] || continue
                        [ -w "$led/trigger" ] && printf default-on > "$led/trigger" 2>/dev/null || true
                done
        fi
}

led_off_forever() {
        led_all 0
        log "All router LEDs turned off by Sheepfold"
}

led_blink_code() {
        seconds="${1:-30}"
        pattern="${2:-1010000}"
        end=$(( $(date +%s) + seconds ))

        save_led_defaults
        while [ "$(date +%s)" -lt "$end" ]; do
                i=1
                while [ "$i" -le "${#pattern}" ] && [ "$(date +%s)" -lt "$end" ]; do
                        bit="$(printf '%s' "$pattern" | cut -c "$i")"
                        [ "$bit" = "1" ] && led_all 1 || led_all 0
                        sleep 0.5
                        i=$((i + 1))
                done
        done
        led_restore_defaults
}

led_alert_loop_running() {
        [ -r "$LED_ALERT_PID" ] || return 1
        pid="$(cat "$LED_ALERT_PID" 2>/dev/null || true)"
        [ -n "$pid" ] || return 1
        kill -0 "$pid" 2>/dev/null
}

led_alert_loop() {
        echo "$$" > "$LED_ALERT_PID"
        save_led_defaults

        while [ -e "$LED_ALERT_FLAG" ] &&
                [ "$(global_get router_led_control router_default)" = "new_device_alert_until_luci_login" ]; do
                set -- /sys/class/leds/*
                count=0
                for led in "$@"; do
                        [ -d "$led" ] && count=$((count + 1))
                done

                if [ "$count" -le 0 ]; then
                        sleep 5
                elif [ "$count" -eq 1 ]; then
                        for value in 1 0 1 0; do
                                led_all "$value"
                                sleep 0.5
                        done
                else
                        for active in /sys/class/leds/*; do
                                [ -d "$active" ] || continue
                                for led in /sys/class/leds/*; do
                                        [ -d "$led" ] || continue
                                        [ "$led" = "$active" ] && led_set "$led" 1 || led_set "$led" 0
                                done
                                sleep 0.5
                        done
                fi
        done

        led_restore_defaults
        rm -f "$LED_ALERT_PID"
}

led_alert_start() {
        [ "$(global_get router_led_control router_default)" = "new_device_alert_until_luci_login" ] || return 0
        [ -e "$LED_ALERT_FLAG" ] || return 0
        led_alert_loop_running && return 0
        "$0" led-alert-loop >/dev/null 2>&1 </dev/null &
}

led_alert_ack() {
        rm -f "$LED_ALERT_FLAG" "$LED_ALERT_ACK"
        led_restore_defaults
        log "New-device LED alert acknowledged"
}

snapshot_leases() {
        if [ -r /tmp/dhcp.leases ]; then
                awk 'NF >= 4 { print toupper($2) }' /tmp/dhcp.leases | sort -u
        fi
}

start_wps_pbc() {
        started=0

        if command -v ubus >/dev/null 2>&1; then
                for service in $(ubus list 'hostapd.*' 2>/dev/null || true); do
                        ubus call "$service" wps_start '{}' >/dev/null 2>&1 && started=1 || true
                done
        fi

        if command -v hostapd_cli >/dev/null 2>&1; then
                for dir in /var/run/hostapd /var/run/hostapd-*; do
                        [ -d "$dir" ] || continue
                        for sock in "$dir"/*; do
                                [ -S "$sock" ] || continue
                                iface="${sock##*/}"
                                hostapd_cli -p "$dir" -i "$iface" wps_pbc >/dev/null 2>&1 && started=1 || true
                        done
                done
        fi

        [ "$started" = "1" ] && log "WPS PBC started" || log "WPS PBC could not be started on this router"
        [ "$started" = "1" ] && log_event "WPS-подключение разрешено на 30 секунд" || log_event "Не удалось запустить WPS-подключение на роутере"
        return 0
}

wps_allowlist_window() {
        snapshot_leases > "$WPS_LEASES_BEFORE"
        touch "$WPS_ALLOWLIST_FLAG"
        start_wps_pbc
        "$0" led-blink-code 30 1010000 >/dev/null 2>&1 </dev/null &
        sleep 30

        snapshot_leases | while read -r mac; do
                [ -n "$mac" ] || continue
                grep -qx "$mac" "$WPS_LEASES_BEFORE" 2>/dev/null && continue
                add_mac_to_allowlist "$mac"
        done

        uci -q commit sheepfold
        rm -f "$WPS_ALLOWLIST_FLAG" "$WPS_LEASES_BEFORE"
        log_event "Окно WPS-добавления в белый список завершено"
        log "WPS allowlist window finished"
}

wps_handle_action() {
        action="$1"

        case "$action" in
                router_default|"")
                        return 0
                        ;;
                allow_wifi_connection)
                        start_wps_pbc
                        "$0" led-blink-code 30 1010000 >/dev/null 2>&1 </dev/null &
                        ;;
                allow_wifi_and_allowlist)
                        "$0" wps-allowlist-window >/dev/null 2>&1 </dev/null &
                        ;;
                disable_wifi)
                        wifi_disable
                        ;;
        esac
}

wps_button() {
        press_kind="${1:-short}"
        if [ "$press_kind" = "long" ]; then
                action="$(global_get wps_long_press_action router_default)"
        else
                action="$(global_get wps_short_press_action router_default)"
        fi

        wps_handle_action "$action"
}

wifi_automation_tick() {
        now_time="$(date +%H:%M)"
        today="$(date +%Y-%m-%d)"
        enable_mode="$(global_get wifi_auto_enable_mode never)"
        enable_time="$(global_get wifi_auto_enable_time 07:00)"
        disable_mode="$(global_get wifi_auto_disable_mode never)"
        disable_time="$(global_get wifi_auto_disable_time 23:00)"

        last="$(cat "$WIFI_LAST_ACTION" 2>/dev/null || true)"

        if [ "$enable_mode" = "time" ] && [ "$now_time" = "$enable_time" ]; then
                key="$today enable $enable_time"
                if [ "$last" != "$key" ]; then
                        wifi_enable
                        echo "$key" > "$WIFI_LAST_ACTION"
                fi
        fi

        if [ "$disable_mode" = "time" ] && [ "$now_time" = "$disable_time" ]; then
                key="$today disable $disable_time"
                if [ "$last" != "$key" ]; then
                        wifi_disable
                        echo "$key" > "$WIFI_LAST_ACTION"
                fi
        fi
}

