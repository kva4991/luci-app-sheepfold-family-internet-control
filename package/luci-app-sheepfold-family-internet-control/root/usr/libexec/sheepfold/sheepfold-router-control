#!/bin/sh
set -eu

. /usr/libexec/sheepfold/sheepfold-token-common

LEGACY="/usr/libexec/sheepfold/sheepfold-router-control-legacy"
PAIR_DEVICE="/usr/libexec/sheepfold/sheepfold-pair-device"
PAIR_ACTIVATE="/usr/libexec/sheepfold/sheepfold-pair-activate"
CLIENT_STATUS="/usr/libexec/sheepfold/sheepfold-client-status-effective"
DEVICE_RECLASSIFY="/usr/libexec/sheepfold/sheepfold-device-reclassify"
DEVICE_PRESENCE="/usr/libexec/sheepfold/sheepfold-device-presence"
LED_CONTROL="/usr/libexec/sheepfold/sheepfold-led-control"
FEEDBACK="/usr/libexec/sheepfold/sheepfold-feedback"
IPV6_CONTROL="/usr/libexec/sheepfold/sheepfold-ipv6-control"
TOKEN_STATE_DIR="/etc/sheepfold/tokens"
TOKEN_RUNTIME_LINK="/tmp/sheepfold/tokens"
command="${1:-status}"

root_password_status() {
    password_field="$(awk -F: '$1 == "root" { print $2; exit }' /etc/shadow 2>/dev/null || true)"
    case "$password_field" in
        ''|'!'|'*'|'!!'|'x') printf 'unset\n' ;;
        *) printf 'set\n' ;;
    esac
}

ensure_token_storage() {
    umask 077
    mkdir -p /etc/sheepfold "$TOKEN_STATE_DIR" /tmp/sheepfold
    chmod 700 /etc/sheepfold "$TOKEN_STATE_DIR" 2>/dev/null || true

    if [ -L "$TOKEN_RUNTIME_LINK" ]; then
        if [ "$(readlink "$TOKEN_RUNTIME_LINK" 2>/dev/null || true)" = "$TOKEN_STATE_DIR" ]; then
            return 0
        fi
        rm -f "$TOKEN_RUNTIME_LINK"
    elif [ -d "$TOKEN_RUNTIME_LINK" ]; then
        for token_file in "$TOKEN_RUNTIME_LINK"/*; do
            [ -f "$token_file" ] || continue
            cp -p "$token_file" "$TOKEN_STATE_DIR/" 2>/dev/null || true
        done
        rm -rf "$TOKEN_RUNTIME_LINK"
    elif [ -e "$TOKEN_RUNTIME_LINK" ]; then
        rm -f "$TOKEN_RUNTIME_LINK"
    fi

    ln -s "$TOKEN_STATE_DIR" "$TOKEN_RUNTIME_LINK"
}

sha256_value() {
    if command -v sha256sum >/dev/null 2>&1; then
        printf '%s' "$1" | sha256sum | cut -d' ' -f1
    elif command -v openssl >/dev/null 2>&1; then
        printf '%s' "$1" | openssl dgst -sha256 | awk '{print $NF}'
    else
        echo "SHA-256 implementation is unavailable." >&2
        return 1
    fi
}

check_token() {
    bearer="${1:-}"
    client_device_id="${2:-}"
    client_mac="${3:-}"
    token_file hash now

    [ -n "$bearer" ] || { printf 'fail\n'; return 0; }

    for section in $(uci -q show sheepfold 2>/dev/null | sed -n 's/^sheepfold\.\([^.=]*\)=administrator$/\1/p'); do
        login="$(uci -q get "sheepfold.$section.login" 2>/dev/null || true)"
        [ -n "$login" ] || continue
        hash="$(sha256_value "$login:$bearer")" || { printf 'fail\n'; return 0; }
        token_file="$TOKEN_STATE_DIR/$hash"
        [ -f "$token_file" ] || continue
        now="$(date +%s)"
        if token_bound_file_valid "$token_file" "$client_device_id" "$client_mac" "$now"; then
            printf 'ok\n'
            return 0
        fi
        printf 'fail\n'
        return 0
    done

    printf 'fail\n'
}

token_login() {
    bearer="${1:-}"
    client_device_id="${2:-}"
    client_mac="${3:-}"

    [ -n "$bearer" ] || return 1
    for section in $(uci -q show sheepfold 2>/dev/null | sed -n 's/^sheepfold\.\([^.=]*\)=administrator$/\1/p'); do
        login="$(uci -q get "sheepfold.$section.login" 2>/dev/null || true)"
        [ -n "$login" ] || continue
        hash="$(sha256_value "$login:$bearer")" || return 1
        token_file="$TOKEN_STATE_DIR/$hash"
        [ -f "$token_file" ] || continue
        if token_bound_file_valid "$token_file" "$client_device_id" "$client_mac" "$(date +%s)"; then
            printf '%s\n' "$login"
            return 0
        fi
        return 1
    done
    return 1
}

revoke_tokens() {
    login="${1:-}"
    token_file file_login

    if [ -z "$login" ]; then
        rm -f "$TOKEN_STATE_DIR"/* 2>/dev/null || true
        return 0
    fi

    for token_file in "$TOKEN_STATE_DIR"/*; do
        [ -f "$token_file" ] || continue
        if token_file_is_legacy "$token_file"; then
            continue
        fi
        file_login="$(token_file_get "$token_file" login)"
        [ "$file_login" = "$login" ] || continue
        rm -f "$token_file" 2>/dev/null || true
    done
}

revoke_device_tokens() {
    device_id="${1:-}"
    token_file file_device_id

    [ -n "$device_id" ] || return 1
    for token_file in "$TOKEN_STATE_DIR"/*; do
        [ -f "$token_file" ] || continue
        if token_file_is_legacy "$token_file"; then
            continue
        fi
        file_device_id="$(token_file_get "$token_file" device_id)"
        [ "$file_device_id" = "$device_id" ] || continue
        rm -f "$token_file" 2>/dev/null || true
    done
}

ensure_token_storage

case "$command" in
    root-password-status)
        root_password_status
        ;;
    check-token)
        check_token "${2:-}" "${3:-}" "${4:-}"
        ;;
    token-login)
        token_login "${2:-}" "${3:-}" "${4:-}"
        ;;
    revoke-tokens)
        revoke_tokens "${2:-}"
        ;;
    revoke-device-tokens)
        revoke_device_tokens "${2:-}"
        ;;
    pair-admin-device)
        shift
        exec "$PAIR_DEVICE" "$@"
        ;;
    activate-admin-pairing-code)
        shift
        exec "$PAIR_ACTIVATE" "$@"
        ;;
    client-status)
        shift
        exec "$CLIENT_STATUS" "$@"
        ;;
    device-reclassify)
        shift
        exec "$DEVICE_RECLASSIFY" "$@"
        ;;
    device-presence)
        shift
        exec "$DEVICE_PRESENCE" "$@"
        ;;
    led-dependency-status)
        exec "$LED_CONTROL" dependency-status
        ;;
    led-dependency-install)
        exec "$LED_CONTROL" dependency-install
        ;;
    led-repair-status)
        exec "$LED_CONTROL" repair-status
        ;;
    led-repair-apply)
        exec "$LED_CONTROL" repair-apply
        ;;
    led-apply)
        exec "$LED_CONTROL" apply
        ;;
    feedback-status)
        exec "$FEEDBACK" status
        ;;
    feedback-submit)
        shift
        exec "$FEEDBACK" submit "$@"
        ;;
    ipv6-apply)
        exec "$IPV6_CONTROL" apply
        ;;
    ipv6-status)
        exec "$IPV6_CONTROL" status
        ;;
    ipv6-release)
        exec "$IPV6_CONTROL" release
        ;;
    *)
        exec "$LEGACY" "$@"
        ;;
esac
