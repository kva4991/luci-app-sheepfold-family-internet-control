#!/bin/sh
set -eu
set -f

LOCK_COMMON="${SHEEPFOLD_LOCK_COMMON:-${0%/*}/sheepfold-lock-common}"
[ -r "$LOCK_COMMON" ] || LOCK_COMMON=/usr/libexec/sheepfold/sheepfold-lock-common
. "$LOCK_COMMON"

COMMAND="${1:-status}"
[ "$#" -eq 0 ] || shift
TIME_LOCK="${SHEEPFOLD_TIME_LOCK:-/tmp/sheepfold/time-settings.flock}"
TRANSACTION_ROOT="${SHEEPFOLD_TIME_TRANSACTION_ROOT:-/tmp/sheepfold/time-settings}"
SYSTEM_CONFIG="${SHEEPFOLD_TIME_SYSTEM_CONFIG:-/etc/config/system}"
SHEEPFOLD_CONFIG="${SHEEPFOLD_TIME_APP_CONFIG:-/etc/config/sheepfold}"
SYSNTPD_INIT="${SHEEPFOLD_SYSNTPD_INIT:-/etc/init.d/sysntpd}"
LOG_HELPER="${SHEEPFOLD_LOG_HELPER:-/usr/libexec/sheepfold/sheepfold-log}"
TRANSACTION_DIR=""
TRANSACTION_ACTIVE=0

uci_get() {
	uci -q get "$1" 2>/dev/null || true
}

valid_timezone_name() {
	printf '%s' "$1" | grep -Eq '^(UTC|[A-Za-z0-9_+-][A-Za-z0-9_+.-]*(/[A-Za-z0-9_+-][A-Za-z0-9_+.-]*)+)$'
}

valid_posix_timezone() {
	printf '%s' "$1" | grep -Eq '^[A-Za-z0-9_+:<>,./-]+$'
}

valid_hostname() {
	printf '%s' "$1" | grep -Eq '^([A-Za-z0-9]([A-Za-z0-9-]*[A-Za-z0-9])?\.)*[A-Za-z0-9]([A-Za-z0-9-]*[A-Za-z0-9])?$'
}

normalize_country() {
	case "${1:-}" in ru|by|cn) printf '%s\n' "$1" ;; *) printf 'ru\n' ;; esac
}

country_defaults() {
	case "$(normalize_country "${1:-}")" in
		ru) printf '%s\n' 'Europe/Moscow|MSK-3|ntp1.vniiftri.ru ntp2.ntp-servers.net 3.openwrt.pool.ntp.org' ;;
		by) printf '%s\n' 'Europe/Minsk|+03-3|by.pool.ntp.org pool.ntp.org' ;;
		cn) printf '%s\n' 'Asia/Shanghai|CST-8|cn.pool.ntp.org ntp.aliyun.com time1.cloud.tencent.com' ;;
	esac
}

normalize_servers() {
	normalized=""
	for server in $1; do
		valid_hostname "$server" || return 1
		normalized="${normalized}${normalized:+ }$server"
	done
	printf '%s\n' "$normalized"
}

clock_sane() {
	year="$(date +%Y 2>/dev/null || printf 0)"
	case "$year" in ''|*[!0-9]*) year=0 ;; esac
	[ "$year" -ge 2024 ]
}

print_status() {
	country="$(normalize_country "$(uci_get sheepfold.global.country_profile)")"
	defaults="$(country_defaults "$country")"
	recommended_zone="${defaults%%|*}"
	rest="${defaults#*|}"
	recommended_timezone="${rest%%|*}"
	recommended_servers="${rest#*|}"
	zone="$(uci_get 'system.@system[0].zonename')"
	timezone="$(uci_get 'system.@system[0].timezone')"
	servers="$(uci_get system.ntp.server)"
	configured=0
	[ -n "$zone" ] && [ -n "$timezone" ] && configured=1
	printf 'country_profile=%s\n' "$country"
	printf 'system_configured=%s\n' "$configured"
	printf 'clock_sane=%s\n' "$(clock_sane && printf 1 || printf 0)"
	printf 'timezone_name=%s\n' "$zone"
	printf 'timezone=%s\n' "$timezone"
	printf 'ntp_client_enabled=%s\n' "$(uci_get system.ntp.enabled)"
	printf 'ntp_server_enabled=%s\n' "$(uci_get system.ntp.enable_server)"
	printf 'servers=%s\n' "$servers"
	printf 'recommended_timezone_name=%s\n' "$recommended_zone"
	printf 'recommended_timezone=%s\n' "$recommended_timezone"
	printf 'recommended_servers=%s\n' "$recommended_servers"
}

snapshot_file() {
	path="$1"
	name="$2"
	if [ -r "$path" ]; then
		cp -p "$path" "$TRANSACTION_DIR/$name.before" || return 1
		printf 'present\n' > "$TRANSACTION_DIR/$name.state"
	else
		printf 'absent\n' > "$TRANSACTION_DIR/$name.state"
	fi
}

restore_file() {
	path="$1"
	name="$2"
	case "$(sed -n '1p' "$TRANSACTION_DIR/$name.state" 2>/dev/null || true)" in
		present)
			parent="${path%/*}"
			[ "$parent" = "$path" ] || mkdir -p "$parent"
			cp -p "$TRANSACTION_DIR/$name.before" "$path"
			;;
		absent) rm -f "$path" ;;
		*) return 1 ;;
	esac
}

rollback() {
	restore_file "$SYSTEM_CONFIG" system 2>/dev/null || true
	restore_file "$SHEEPFOLD_CONFIG" sheepfold 2>/dev/null || true
}

transaction_cleanup() {
	cleanup_status="${1:-1}"
	trap - EXIT HUP INT TERM
	if [ "${TRANSACTION_ACTIVE:-0}" = 1 ]; then
		rollback
	fi
	[ -z "${TRANSACTION_DIR:-}" ] || rm -rf "$TRANSACTION_DIR" 2>/dev/null || true
	sheepfold_lock_release
	exit "$cleanup_status"
}

save_time() {
	server_enabled="${1:-}"
	client_enabled="${2:-}"
	requested_zone="${3:-}"
	requested_timezone="${4:-}"
	requested_servers="${5:-}"
	country="$(normalize_country "${6:-$(uci_get sheepfold.global.country_profile)}")"
	defaults="$(country_defaults "$country")"
	recommended_zone="${defaults%%|*}"
	rest="${defaults#*|}"
	recommended_timezone="${rest%%|*}"
	recommended_servers="${rest#*|}"
	current_zone="$(uci_get 'system.@system[0].zonename')"
	current_timezone="$(uci_get 'system.@system[0].timezone')"
	current_servers="$(uci_get system.ntp.server)"

	case "$server_enabled" in 0|1) ;; '') server_enabled="$(uci_get system.ntp.enable_server)" ;; *) printf 'Invalid NTP server flag.\n' >&2; return 2 ;; esac
	case "$client_enabled" in 0|1) ;; '') client_enabled="$(uci_get system.ntp.enabled)" ;; *) printf 'Invalid NTP client flag.\n' >&2; return 2 ;; esac
	case "$server_enabled" in 0|1) ;; *) server_enabled=1 ;; esac
	case "$client_enabled" in 0|1) ;; *) client_enabled=1 ;; esac

	zone="${requested_zone:-${current_zone:-$recommended_zone}}"
	timezone="${requested_timezone:-${current_timezone:-$recommended_timezone}}"
	servers="${requested_servers:-${current_servers:-$recommended_servers}}"
	valid_timezone_name "$zone" || { printf 'Invalid router timezone name.\n' >&2; return 2; }
	valid_posix_timezone "$timezone" || { printf 'Invalid router POSIX timezone.\n' >&2; return 2; }
	if ! servers="$(normalize_servers "$servers")"; then
		printf 'NTP server list contains an invalid hostname.\n' >&2
		return 2
	fi
	[ -n "$servers" ] || { printf 'At least one valid NTP server hostname is required.\n' >&2; return 2; }

	sheepfold_lock_acquire "$TIME_LOCK" 10 || { printf 'Time settings are busy.\n' >&2; return 3; }
	trap 'transaction_cleanup $?' EXIT
	trap 'exit 129' HUP
	trap 'exit 130' INT
	trap 'exit 143' TERM
	mkdir -p "$TRANSACTION_ROOT"
	chmod 700 "$TRANSACTION_ROOT" 2>/dev/null || true
	TRANSACTION_DIR="$TRANSACTION_ROOT/transaction.$$"
	UCI_SAVEDIR="$TRANSACTION_DIR/uci"
	umask 077
	mkdir "$TRANSACTION_DIR" "$UCI_SAVEDIR"
	snapshot_file "$SYSTEM_CONFIG" system
	snapshot_file "$SHEEPFOLD_CONFIG" sheepfold
	TRANSACTION_ACTIVE=1

	uci() { command uci -t "$UCI_SAVEDIR" -p "$UCI_SAVEDIR" "$@"; }
	uci -q get 'system.@system[0]' >/dev/null 2>&1 || uci -q add system system >/dev/null
	if [ "$(uci -q get system.ntp 2>/dev/null || true)" != timeserver ]; then
		uci -q delete system.ntp 2>/dev/null || true
		uci -q set system.ntp=timeserver
	fi
	[ "$(uci -q get sheepfold.global 2>/dev/null || true)" = sheepfold ] || uci -q set sheepfold.global=sheepfold
	uci -q set "system.@system[0].zonename=$zone"
	uci -q set "system.@system[0].timezone=$timezone"
	uci -q set "system.ntp.enabled=$client_enabled"
	uci -q set "system.ntp.enable_server=$server_enabled"
	uci -q delete system.ntp.server 2>/dev/null || true
	for server in $servers; do uci -q add_list "system.ntp.server=$server"; done
	uci -q set "sheepfold.global.router_ntp_server_enabled=$server_enabled"
	uci -q set "sheepfold.global.router_ntp_client_auto_configure=$client_enabled"
	uci -q set "sheepfold.global.router_timezone_name=$zone"
	uci -q set "sheepfold.global.router_timezone=$timezone"
	uci -q set "sheepfold.global.router_ntp_servers=$servers"
	uci -q set "sheepfold.global.router_time_configured=1"
	uci -q set "sheepfold.global.router_time_country_profile=$country"
	uci -q set "sheepfold.global.router_time_configured_at=$(date +%s)"

	if ! uci -q commit system || ! uci -q commit sheepfold; then
		printf 'Could not commit router time settings; previous configuration was restored.\n' >&2
		return 4
	fi

	if [ "$(command uci -q get 'system.@system[0].zonename' 2>/dev/null || true)" != "$zone" ] ||
	   [ "$(command uci -q get 'system.@system[0].timezone' 2>/dev/null || true)" != "$timezone" ] ||
	   [ "$(command uci -q get sheepfold.global.router_time_configured 2>/dev/null || true)" != 1 ]; then
		printf 'Router time settings verification failed; previous configuration was restored.\n' >&2
		return 4
	fi

	TRANSACTION_ACTIVE=0
	rm -rf "$TRANSACTION_DIR"
	TRANSACTION_DIR=""
	trap - EXIT HUP INT TERM
	sheepfold_lock_release
	[ -x "$SYSNTPD_INIT" ] && "$SYSNTPD_INIT" restart >/dev/null 2>&1 || true
	[ ! -x "$LOG_HELPER" ] || "$LOG_HELPER" "Настройки времени сохранены: timezone $zone, NTP $servers"
	printf 'status=ok\n'
	printf 'timezone_name=%s\n' "$zone"
	printf 'timezone=%s\n' "$timezone"
	printf 'servers=%s\n' "$servers"
	printf 'country_profile=%s\n' "$country"
}

case "$COMMAND" in
	status) print_status ;;
	save) save_time "$@" ;;
	*) echo 'Usage: sheepfold-time-control [status|save SERVER_ENABLED CLIENT_ENABLED ZONENAME TIMEZONE SERVERS COUNTRY]' >&2; exit 2 ;;
esac
