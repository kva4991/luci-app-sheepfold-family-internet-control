should_collect_upnp_description() {
	local section confidence min_confidence
	section="$1"
	min_confidence="$2"
	[ "$(uci -q get "sheepfold.$section.manual_device_type" 2>/dev/null || true)" != 1 ] || return 1
	[ -z "$(uci -q get "sheepfold.$section.detected_type" 2>/dev/null || true)" ] && return 0
	confidence="$(uci -q get "sheepfold.$section.detection_confidence" 2>/dev/null || printf 0)"
	case "$confidence" in ''|*[!0-9]*) confidence=0 ;; esac
	[ "$confidence" -lt "$min_confidence" ] || needs_more_auto_group_evidence "$section"
}

collect_upnp_description() {
	local mode section ip min_confidence max_fetches location
	mode="$1"
	section="$2"
	ip="$3"
	min_confidence="$4"
	[ "$mode" = full ] || return 0
	[ -x "$UPNP_DESCRIPTION_COLLECTOR" ] || return 0
	should_collect_upnp_description "$section" "$min_confidence" || return 0
	max_fetches="$(global_get detector_max_upnp_fetches_per_scan 4)"
	case "$max_fetches" in ''|*[!0-9]*) max_fetches=4 ;; esac
	[ "$max_fetches" -ge 1 ] || max_fetches=1
	[ "$max_fetches" -le 8 ] || max_fetches=8
	[ "$upnp_fetches" -lt "$max_fetches" ] || return 0
	location="$(ssdp_location_for_ip "$ip" || true)"
	[ -n "$location" ] || return 0
	upnp_fetches=$((upnp_fetches + 1))
	"$UPNP_DESCRIPTION_COLLECTOR" "$ip" "$location" 86400 >/dev/null 2>&1 || true
}

is_reserved_device_name() {
        case "$(printf '%s' "${1:-}" | tr 'A-Z' 'a-z')" in
		''|'*'|arp|dhcp|static) return 0 ;;
                *) return 1 ;;
        esac
}

append_router_devices() {
        local section ip name mac
        : > "$RAW_FILE"

        if [ -r /tmp/dhcp.leases ]; then
                awk 'NF >= 4 { print $2 "\t" $3 "\t" $4 "\tdhcp" }' /tmp/dhcp.leases >> "$RAW_FILE"
        fi

        if [ -x "$PRESENCE" ]; then
                # Общий helper исключает WAN и добавляет hostapd association. Так detector
                # и LuCI одинаково понимают «устройство сейчас в домашней сети». §detlife1
                "$PRESENCE" current 2>/dev/null |
                        awk -F '\t' 'NF >= 1 { print $1 "\t" $2 "\t*\t" $3 }' >> "$RAW_FILE" || true
        elif [ -r /proc/net/arp ]; then
                # Fallback нужен только для повреждённой установки без presence-helper.
                awk 'NR > 1 && $3 == "0x2" { print $4 "\t" $1 "\t*\tarp" }' /proc/net/arp >> "$RAW_FILE"
        fi

        for section in $(uci -q show dhcp 2>/dev/null | sed -n "s/^dhcp\.\([^.=]*\)=host$/\1/p"); do
                ip="$(uci -q get "dhcp.$section.ip" 2>/dev/null || true)"
                name="$(uci -q get "dhcp.$section.name" 2>/dev/null || uci -q get "dhcp.$section.hostname" 2>/dev/null || true)"
                for mac in $(uci -q get "dhcp.$section.mac" 2>/dev/null || true); do
                        printf '%s\t%s\t%s\tstatic\n' "$mac" "$ip" "$name" >> "$RAW_FILE"
                done
        done
}

aggregate_router_devices() {
        awk -F '\t' '
        function valid_mac(value) {
                return value ~ /^([0-9A-Fa-f][0-9A-Fa-f]:){5}[0-9A-Fa-f][0-9A-Fa-f]$/
        }
        {
                mac = toupper($1)
                if (!valid_mac(mac) || mac == "00:00:00:00:00:00")
                        next
                if (!(mac in seen)) {
                        order[++count] = mac
                        seen[mac] = 1
                }
                if ($2 != "" && ip[mac] == "")
                        ip[mac] = $2
                if ($3 != "" && $3 != "*" && name[mac] == "" && $3 !~ /^(arp|dhcp|static)$/i)
                        name[mac] = $3
                if ($4 != "" && sources[mac] !~ $4)
                        sources[mac] = sources[mac] (sources[mac] == "" ? "" : ",") $4
        }
        END {
                for (i = 1; i <= count; i++) {
                        mac = order[i]
				# BusyBox read считает tab пробельным IFS и схлопывает пустое третье
				# поле. Явный placeholder сохраняет sources на четвёртой позиции. §devpas1
				print mac "\t" ip[mac] "\t" (name[mac] == "" ? "*" : name[mac]) "\t" sources[mac]
                }
        }' "$RAW_FILE"
}

scan_ports() {
        local ip mode max_seconds ports
        ip="$1"
        mode="$2"
        max_seconds="$(global_get detector_nmap_host_timeout_seconds 20)"
        ports="$(global_get detector_scan_ports "$DEFAULT_SCAN_PORTS")"

        [ "$mode" = "full" ] || return 0
        [ -n "$ip" ] || return 0
        command -v nmap >/dev/null 2>&1 || return 0

        # Эти значения берутся из UCI. Ограничения не дают опечатке превратить
        # фоновое распознавание в долгий процесс или в дополнительные аргументы nmap.
        case "$max_seconds" in ''|*[!0-9]*) max_seconds=20 ;; esac
        [ "$max_seconds" -ge 2 ] || max_seconds=2
        [ "$max_seconds" -le 60 ] || max_seconds=60
        case "$ports" in ''|*[!0-9,]*) ports="$DEFAULT_SCAN_PORTS" ;; esac
        [ "${#ports}" -le 256 ] || ports="$DEFAULT_SCAN_PORTS"
        case "$ip" in -*|*[!0-9A-Fa-f:.]*) return 0 ;; esac

        nmap -n -Pn -T2 --max-retries 1 --host-timeout "${max_seconds}s" -p "$ports" "$ip" 2>/dev/null |
                awk -F/ '/open/ { ports = ports (ports == "" ? "" : ",") $1 } END { print ports }'
}

set_auto_group_status() {
        local section status
        section="$1"
        status="$2"
	uci_set_if_changed "sheepfold.$section.detection_auto_group_status" "$status"
}

remove_stale_auto_no_restrictions() {
	local section mac ip name target_group current_group no_restrictions_group personal_devices_group
	local device_id group_source
	section="$1"
	mac="$2"
	ip="$3"
	name="$4"
	target_group="$5"
	no_restrictions_group="$(no_restrictions_group_name)"
	personal_devices_group="$(personal_devices_group_name)"
	current_group="$(uci -q get "sheepfold.$section.group" 2>/dev/null || true)"
	group_source="$(uci -q get "sheepfold.$section.group_source" 2>/dev/null || true)"

	[ "$current_group" = "$no_restrictions_group" ] || return 0
	[ "$target_group" = "$personal_devices_group" ] || return 0
	[ "$(uci -q get "sheepfold.$section.auto_group_assigned" 2>/dev/null || printf 0)" = 1 ] || return 0
	[ "$group_source" != user ] || return 0

	# Удаляется только прежнее автоматическое решение. Ручное помещение родителем
	# в «Без ограничений» является более сильным источником и неприкосновенно.
	uci_delete_if_present "sheepfold.$section.group"
	uci_set_if_changed "sheepfold.$section.auto_group_assigned" 0
	uci_delete_if_present "sheepfold.$section.auto_group_reason"
	uci_delete_if_present "sheepfold.$section.group_source"
	uci_delete_if_present "sheepfold.$section.group_observed_at"
	device_id="$(uci -q get "sheepfold.$section.id" 2>/dev/null || true)"
	log_event "Автоматическая группа \"$no_restrictions_group\" снята с устройства #${device_id} ${name:-$mac}, IP ${ip:-неизвестен}: устройство теперь распознано как персональное"
	notify_admin auto_group_changed "auto-group-$device_id-personal" \
		"Sheepfold: изменился тип устройства" \
		"Устройство #${device_id} ${name:-$mac} больше не считается домашней инфраструктурой. Автоматическая группа \"$no_restrictions_group\" снята; ручные назначения не изменялись."
}

assign_detected_group_if_allowed() {
        local section mac ip name target_group reason auto_score evidence_count hard_deny confidence
        local no_restrictions_group personal_devices_group min_score min_type_confidence auto_configure
        local current_group enabled auto_excluded device_id assigned_group
        section="$1"
        mac="$2"
        ip="$3"
        name="$4"
        target_group="$5"
        reason="$6"
        auto_score="$7"
        evidence_count="$8"
        hard_deny="$9"
        confidence="${10}"
        no_restrictions_group="$(no_restrictions_group_name)"
        personal_devices_group="$(personal_devices_group_name)"
        min_score="$(global_get detector_min_no_restrictions_confidence 80)"
        min_type_confidence="$(global_get detector_min_device_type_confidence 70)"
        auto_configure="$(global_get auto_configure 1)"
        current_group="$(uci -q get "sheepfold.$section.group" 2>/dev/null || true)"

        case "$auto_score" in ''|*[!0-9]*) auto_score=0 ;; esac
        case "$evidence_count" in ''|*[!0-9]*) evidence_count=0 ;; esac
        case "$min_score" in ''|*[!0-9]*) min_score=80 ;; esac
        case "$confidence" in ''|*[!0-9]*) confidence=0 ;; esac
        case "$min_type_confidence" in ''|*[!0-9]*) min_type_confidence=70 ;; esac

        # Тип устройства можно уточнять всегда, но менять политику доступа можно только
        # когда родитель явно включил автонастройку новых устройств.
        if [ "$auto_configure" != "1" ]; then
                set_auto_group_status "$section" auto_configuration_disabled
                return 0
        fi

        case "$target_group" in
                'No restrictions'|'Без ограничений'|"$no_restrictions_group")
                        target_group="$no_restrictions_group"
                        enabled="$(global_get no_restrictions_auto_assign 1)"
                        auto_excluded="$(uci -q get "sheepfold.$section.no_restrictions_auto_excluded" 2>/dev/null || true)"
                        if [ "$enabled" != "1" ]; then
                                set_auto_group_status "$section" no_restrictions_assignment_disabled
                                return 0
                        fi
                        if [ "$auto_excluded" = "1" ]; then
                                set_auto_group_status "$section" no_restrictions_manually_excluded
                                return 0
                        fi
                        if [ "$hard_deny" != "0" ]; then
                                set_auto_group_status "$section" unsafe_device_type
                                return 0
                        fi
                        if [ "$auto_score" -lt "$min_score" ] || [ "$evidence_count" -lt 2 ]; then
                                set_auto_group_status "$section" independent_evidence_required
                                return 0
                        fi
                        ;;
                'Personal devices'|'Персональные устройства'|'个人设备'|"$personal_devices_group")
                        target_group="$personal_devices_group"
                        enabled="$(global_get personal_devices_auto_assign 1)"
                        auto_excluded="$(uci -q get "sheepfold.$section.personal_devices_auto_excluded" 2>/dev/null || true)"
                        if [ "$enabled" != "1" ]; then
                                set_auto_group_status "$section" personal_devices_assignment_disabled
                                return 0
                        fi
                        if [ "$auto_excluded" = "1" ]; then
                                set_auto_group_status "$section" personal_devices_manually_excluded
                                return 0
                        fi
                        if [ "$confidence" -lt "$min_type_confidence" ]; then
                                set_auto_group_status "$section" device_type_confidence_too_low
                                return 0
                        fi
                        ;;
                *)
                        set_auto_group_status "$section" no_target_group
                        return 0
                        ;;
        esac
        [ -n "$target_group" ] || return 0
        if mac_in_named_list blocklist "$mac"; then
                set_auto_group_status "$section" device_blocklisted
                return 0
        fi
        # Администраторские и явно белосписочные устройства уже имеют выбранную
        # родителем политику. Автогруппа не должна возвращать им обычные правила. §detlock
        if [ "$(uci -q get "sheepfold.$section.admin_device" 2>/dev/null || printf 0)" = 1 ]; then
                set_auto_group_status "$section" administrator_device
                return 0
        fi
        if mac_in_named_list allowlist "$mac"; then
                set_auto_group_status "$section" allowlisted_device
                return 0
        fi

        is_reserved_device_name "$name" && name=""

        if [ "$current_group" = "$target_group" ]; then
                set_auto_group_status "$section" assigned
                return 0
        fi

        if ! device_group_unassigned "$current_group"; then
                set_auto_group_status "$section" another_group_already_selected
                return 0
        fi

	uci_set_if_changed "sheepfold.$section.group" "$target_group"
	uci_set_if_changed "sheepfold.$section.auto_group_assigned" 1
	uci_set_if_changed "sheepfold.$section.auto_group_reason" "$reason"
	uci_set_if_changed "sheepfold.$section.group_source" detector
	uci_set_if_changed "sheepfold.$section.group_observed_at" "$(date +%s)"
        set_auto_group_status "$section" assigned

        device_id="$("$DEVICE_ID_HELPER" ensure "$section" 2>/dev/null || true)"
        [ -n "$device_id" ] || device_id="$(uci -q get "sheepfold.$section.id" 2>/dev/null || true)"
        assigned_group="$(uci -q get "sheepfold.$section.group" 2>/dev/null || true)"
        [ "$assigned_group" = "$target_group" ] || {
                log_event "Не удалось сохранить группу \"$target_group\" для устройства #${device_id} ${name:-$mac}: UCI вернул \"${assigned_group:-пусто}\""
                return 0
        }

        log_event "Устройство #${device_id} ${name:-$mac}, IP ${ip:-неизвестен} автоматически добавлено в группу \"$target_group\": $reason; score=$auto_score; evidence=$evidence_count"
        if [ "$target_group" = "$no_restrictions_group" ]; then
                notify_admin auto_no_restrictions "auto-group-$device_id-no-restrictions" \
                        "Sheepfold: устройство без ограничений" \
                        "Устройство #${device_id} ${name:-$mac}, IP ${ip:-неизвестен}, автоматически добавлено в группу \"$target_group\"."
        fi
}

needs_more_auto_group_evidence() {
        local section target_group no_restrictions_group current_group auto_score evidence_count min_score
        section="$1"
        target_group="$(uci -q get "sheepfold.$section.detection_target_group" 2>/dev/null || true)"
        no_restrictions_group="$(no_restrictions_group_name)"
        current_group="$(uci -q get "sheepfold.$section.group" 2>/dev/null || true)"

        device_group_unassigned "$current_group" || return 1
        [ "$(global_get auto_configure 1)" = 1 ] || return 1
        [ "$(global_get no_restrictions_auto_assign 1)" = 1 ] || return 1
        [ "$(uci -q get "sheepfold.$section.no_restrictions_auto_excluded" 2>/dev/null || true)" != 1 ] || return 1

        case "$target_group" in
                'No restrictions'|'Без ограничений'|"$no_restrictions_group") ;;
                *) return 1 ;;
        esac

        auto_score="$(uci -q get "sheepfold.$section.detection_auto_group_score" 2>/dev/null || printf 0)"
        evidence_count="$(uci -q get "sheepfold.$section.detection_evidence_count" 2>/dev/null || printf 0)"
        min_score="$(global_get detector_min_no_restrictions_confidence 80)"
        case "$auto_score" in ''|*[!0-9]*) auto_score=0 ;; esac
        case "$evidence_count" in ''|*[!0-9]*) evidence_count=0 ;; esac
        case "$min_score" in ''|*[!0-9]*) min_score=80 ;; esac

        [ "$auto_score" -lt "$min_score" ] || [ "$evidence_count" -lt 2 ]
}

identity_key_strength() {
        local keys
        keys="$1"
        [ -x "$IDENTITY_RECONCILER" ] || {
                printf 'insufficient\n'
                return 0
        }
        "$IDENTITY_RECONCILER" strength "$keys" 2>/dev/null || printf 'insufficient\n'
}

