}

apply_identity_quarantine() {
	local section mac ip name current_keys reason now response_mode quarantine_mode old_mode
	local device_id message last_notified reminder_seconds day_bucket
        section="$1"
        mac="$2"
        ip="$3"
        name="$4"
        current_keys="$5"
        reason="$6"
        now="$7"
        response_mode="$(global_get device_monitoring_mode automatic)"
        case "$response_mode" in automatic) quarantine_mode=block ;; *) quarantine_mode=restrict ;; esac
        old_mode="$(uci -q get "sheepfold.$section.identity_quarantine_mode" 2>/dev/null || true)"

        uci_set_if_changed "sheepfold.$section.identity_quarantine_mode" "$quarantine_mode"
	uci_set_if_changed "sheepfold.$section.identity_quarantine_reason" "$reason"
	uci_set_if_changed "sheepfold.$section.identity_quarantine_keys" "$current_keys"
	uci_set_if_changed "sheepfold.$section.identity_quarantine_keys_version" 2
	[ -n "$old_mode" ] || uci_set_if_changed "sheepfold.$section.identity_quarantine_at" "$now"

	# Нерешённая тревога напоминает о себе не чаще раза в сутки. Карантин при этом
	# не ослабляется и ждёт явного решения родителя бессрочно. §detlife1
	last_notified="$(uci -q get "sheepfold.$section.identity_quarantine_notified_at" 2>/dev/null || printf 0)"
	reminder_seconds="$(global_get identity_quarantine_reminder_seconds 86400)"
	case "$last_notified" in ''|*[!0-9]*) last_notified=0 ;; esac
	case "$reminder_seconds" in ''|*[!0-9]*) reminder_seconds=86400 ;; esac
	[ "$reminder_seconds" -ge 86400 ] || reminder_seconds=86400
	if [ -n "$old_mode" ] && [ "$old_mode" = "$quarantine_mode" ] && \
	   [ $((now - last_notified)) -lt "$reminder_seconds" ]; then
		return 0
	fi
	uci_set_if_changed "sheepfold.$section.identity_quarantine_notified_at" "$now"
	device_id="$(uci -q get "sheepfold.$section.id" 2>/dev/null || true)"
	if [ "$quarantine_mode" = block ]; then
		message="Подключение устройства #${device_id} ${name:-$mac}, IP ${ip:-неизвестен}, не совпало с доверенным отпечатком. Включён бессрочный временный карантин с сетевыми ограничениями чёрного списка устройств, но запись в постоянный чёрный список устройств не создаётся. Права настоящего устройства сохранены."
	else
		message="Подключение устройства #${device_id} ${name:-$mac}, IP ${ip:-неизвестен}, не совпало с доверенным отпечатком. Оно ограничено до решения родителя; привилегии белого списка устройств и группы \"Без ограничений\" приостановлены."
	fi
	case "$reason" in
		duplicate_uuid_online_with_device_\#*)
			# Родителю нужен понятный конфликт и IP нового подключения, а не внутреннее
			# имя причины или перечень положительных баллов классификатора. §devident1
			message="$message Тот же устойчивый UUID сейчас объявляет устройство #${reason##*#}."
			;;
	esac
	log_event "$message Причина: $reason"
	day_bucket=$((now / reminder_seconds))
	notify_admin identity_change "identity-change-$device_id-$day_bucket" "Sheepfold: подозрительное устройство" "$message"
}

evaluate_identity_state() {
	local section mac ip name current_keys stored_keys legacy_current_keys trusted_keys baseline strength assessment now
	local trusted_version legacy_assessment
        section="$1"
        mac="$2"
        ip="$3"
        name="$4"
        current_keys="$5"
	stored_keys="$6"
	legacy_current_keys="$7"
	now="$8"
	IDENTITY_DECISION=continue
	trusted_keys="$(uci -q get "sheepfold.$section.trusted_identity_keys" 2>/dev/null || true)"
	trusted_version="$(uci -q get "sheepfold.$section.trusted_identity_version" 2>/dev/null || true)"

	if [ -z "$trusted_keys" ]; then
		baseline="$current_keys"
		strength="$(identity_key_strength "$baseline")"
		case "$strength" in
			strong|multifactor)
                                # Доверенный baseline создаётся один раз. Обычная переклассификация
                                # не переписывает его вслед за потенциальным подменившимся клиентом.
				uci_set_if_changed "sheepfold.$section.trusted_identity_keys" "$baseline"
				uci_set_if_changed "sheepfold.$section.trusted_identity_version" 2
				;;
		esac
		return 0
	fi

	# Старые записи были SHA-256/MD5 cache-hash без локального секрета. Сначала
	# сравниваем их прежним способом и только после положительного совпадения
	# атомарно переносим baseline на HMAC v2. Так обновление пакета не помещает
	# все домашние устройства в карантин одновременно. §devident1
	if [ "$trusted_version" != 2 ]; then
		if [ -n "$legacy_current_keys" ] && [ -x "$IDENTITY_RECONCILER" ]; then
			legacy_assessment="$("$IDENTITY_RECONCILER" assess "$trusted_keys" "$legacy_current_keys" 2>/dev/null || printf insufficient)"
		else
			legacy_assessment=insufficient
		fi
		case "$legacy_assessment" in
			match_strong|match_multifactor)
				if [ -n "$current_keys" ]; then
					uci_set_if_changed "sheepfold.$section.trusted_identity_keys" "$current_keys"
					uci_set_if_changed "sheepfold.$section.trusted_identity_version" 2
					clear_identity_quarantine "$section" "$mac" "$name"
				fi
				;;
			suspicious_strong|suspicious_multifactor)
				apply_identity_quarantine "$section" "$mac" "$ip" "$name" "$current_keys" "$legacy_assessment" "$now"
				IDENTITY_DECISION=quarantine
				;;
		esac
		return 0
	fi

        if [ -n "$current_keys" ] && [ -x "$IDENTITY_RECONCILER" ]; then
                assessment="$("$IDENTITY_RECONCILER" assess "$trusted_keys" "$current_keys" 2>/dev/null || printf insufficient)"
        else
                assessment=insufficient
        fi
        case "$assessment" in
                match_strong|match_multifactor)
                        clear_identity_quarantine "$section" "$mac" "$name"
                        ;;
                suspicious_strong|suspicious_multifactor)
                        apply_identity_quarantine "$section" "$mac" "$ip" "$name" "$current_keys" "$assessment" "$now"
                        IDENTITY_DECISION=quarantine
                        ;;
                *)
                        # Исчезновение одного объявления ещё не доказывает подмену. Но уже
                        # включённый карантин снимается только положительным совпадением.
                        if [ -n "$(uci -q get "sheepfold.$section.identity_quarantine_mode" 2>/dev/null || true)" ]; then
                                IDENTITY_DECISION=quarantine
                        fi
                        ;;
        esac
}

apply_pending_identity_collisions() {
	local section pending mac ip name current_keys collision_with now
	now="$1"
	for section in $(device_sections); do
		pending="$(uci -q get "sheepfold.$section.identity_uuid_collision_pending" 2>/dev/null || true)"
		[ "$pending" = 1 ] || continue
		mac="$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)"
		if device_is_blocklisted "$section" "$mac"; then
			uci_delete_if_present "sheepfold.$section.identity_uuid_collision_pending"
			continue
		fi
		ip="$(uci -q get "sheepfold.$section.ip" 2>/dev/null || true)"
		name="$(uci -q get "sheepfold.$section.name" 2>/dev/null || true)"
		current_keys="$(uci -q get "sheepfold.$section.detection_identity_keys" 2>/dev/null || true)"
		collision_with="$(uci -q get "sheepfold.$section.identity_uuid_collision_with_id" 2>/dev/null || true)"
		apply_identity_quarantine "$section" "$mac" "$ip" "$name" "$current_keys" \
			"duplicate_uuid_online_with_device_#${collision_with:-unknown}" "$now"
		uci_delete_if_present "sheepfold.$section.identity_uuid_collision_pending"
	done
}

write_common_observation() {
        local section mac ip name sources now stored_name device_id
        section="$1"
        mac="$2"
        ip="$3"
        name="$4"
        sources="$5"
        now="$6"
	NEW_DEVICE_NOTICE_PENDING=0

        write_runtime_observation "$mac" "$ip" "$name" "$sources" "$now"
        [ -n "$ip" ] && uci_set_if_changed "sheepfold.$section.ip" "$ip"
        is_reserved_device_name "$name" && name=""
        if [ -n "$name" ]; then
                stored_name="$(uci -q get "sheepfold.$section.name" 2>/dev/null || true)"
                if is_reserved_device_name "$stored_name"; then
                        uci_delete_if_present "sheepfold.$section.name"
                        stored_name=""
                fi
		if [ -z "$stored_name" ]; then
			uci_set_if_changed "sheepfold.$section.name" "$name"
			uci_set_if_changed "sheepfold.$section.name_source" router
		fi
        fi

        if [ "$(uci -q get "sheepfold.$section.just_detected" 2>/dev/null || true)" = "1" ]; then
                device_id="$(uci -q get "sheepfold.$section.id" 2>/dev/null || true)"
                log_event "Обнаружено новое устройство: #${device_id}, $mac, IP ${ip:-неизвестен}${name:+, имя $name}"
		NEW_DEVICE_NOTICE_PENDING=1
                uci_delete_if_present "sheepfold.$section.just_detected"
        fi
}

notify_new_device_if_pending() {
	local section mac ip name competing competing_text device_id message
	section="$1"
	mac="$2"
	ip="$3"
	name="$4"
	competing="${5:-}"
	[ "${NEW_DEVICE_NOTICE_PENDING:-0}" = 1 ] || return 0
	device_id="$(uci -q get "sheepfold.$section.id" 2>/dev/null || true)"
	message="Обнаружено новое устройство #${device_id}: ${name:-без имени}, MAC $mac, IP ${ip:-неизвестен}."
	# В обычном уведомлении не перечисляем внутренние положительные баллы. Если
	# источники спорят, родителю важен именно конфликт и IP нового клиента.
	competing_text="$(printf '%s' "$competing" | awk -F ',' '
		function source_label(value) {
			if (value == "name") return "имя устройства"
			if (value == "owner_configured") return "постоянная DHCP-запись"
			if (value == "dhcp") return "DHCP-признаки"
			if (value == "oui") return "производитель MAC"
			if (value == "mdns") return "mDNS"
			if (value == "upnp") return "UPnP"
			if (value == "wsd") return "WS-Discovery"
			if (value == "ports") return "сетевые сервисы"
			return value
		}
		function type_label(value) {
			if (value == "computer") return "компьютер"
			if (value == "phone") return "телефон"
			if (value == "tablet") return "планшет"
			if (value == "printer") return "принтер"
			if (value == "camera") return "камера"
			if (value == "server") return "сервер"
			if (value == "network") return "сетевое устройство"
			if (value == "speaker") return "умная колонка"
			if (value == "smart_home") return "умный дом"
			return value
		}
		{
			for (i = 1; i <= NF; i++) {
				split($i, parts, ":")
				if (parts[1] == "" || parts[2] == "") continue
				text = source_label(parts[1]) " указывают на тип «" type_label(parts[2]) "»"
				output = output (output == "" ? "" : "; ") text
			}
		}
		END { print output }
	')"
	[ -z "$competing_text" ] || message="$message Противоречащие признаки: $competing_text."
	notify_admin new_device "new-device-$device_id" "Sheepfold: новое устройство" "$message"
	NEW_DEVICE_NOTICE_PENDING=0
}

