#!/bin/sh
set -eu

COMMAND="${1:-scan}"
CACHE_DIR="/tmp/sheepfold"
CACHE_FILE="$CACHE_DIR/device-detection.tsv"
RAW_FILE="$CACHE_DIR/device-detection.raw"
NEW_DEVICE_ALERT_FLAG="$CACHE_DIR/new-device-alert"
LOG_HELPER="/usr/libexec/sheepfold/sheepfold-log"
DEFAULT_SCAN_PORTS="22,53,80,81,443,445,548,554,631,1883,3000,3001,5000,5001,5353,8000,8006,8080,8081,8123,8554,9000,9100,32400"
NO_RESTRICTIONS_GROUP="Без ограничений"
NETWORK_NAME_PATTERN='(^|[^a-z0-9])(openwrt|router|gateway|repeater|extender|access[ _-]?point|wireless[ _-]?ap|wi-?fi[ _-]?ap|mesh)([^a-z0-9]|$)|(^|[^a-z0-9])ap[-_][a-z0-9]'
SMART_HOME_NETWORK_PATTERN='zigbee|z-wave|zwave|thread border router|matter bridge|homekit bridge|smart[ _-]?home|smarthome|aqara|xiaomi|mijia|tuya|tradfri|dirigera|hue bridge|sonoff'

global_get() {
        uci -q get "sheepfold.global.$1" 2>/dev/null || printf '%s' "$2"
}

normalize_mac() {
        printf '%s' "$1" | tr '[:lower:]' '[:upper:]'
}

log_event() {
        if [ -x "$LOG_HELPER" ]; then
                "$LOG_HELPER" "$*"
        else
                logger -t sheepfold "$*"
        fi
}

section_for_mac() {
        wanted="$(normalize_mac "$1")"
        for section in $(uci -q show sheepfold 2>/dev/null | sed -n "s/^sheepfold\.\([^.=]*\)=device$/\1/p"); do
                current="$(normalize_mac "$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)")"
                [ "$current" = "$wanted" ] && {
                        printf '%s\n' "$section"
                        return 0
                }
        done
        return 1
}

ensure_device_section() {
        mac="$(normalize_mac "$1")"
        if section="$(section_for_mac "$mac")"; then
                printf '%s\n' "$section"
                return 0
        fi

        section="device_$(printf '%s' "$mac" | tr '[:upper:]' '[:lower:]' | tr -d ':')"
        uci -q set "sheepfold.$section=device"
        uci -q set "sheepfold.$section.mac=$mac"
        uci -q set "sheepfold.$section.just_detected=1"
        date +%s > "$NEW_DEVICE_ALERT_FLAG"
        printf '%s\n' "$section"
}

mac_in_named_list() {
        list_name="$1"
        wanted="$(normalize_mac "$2")"

        for section in $(uci -q show sheepfold 2>/dev/null | sed -n "s/^sheepfold\.\([^.=]*\)=list$/\1/p"); do
                [ "$section" = "$list_name" ] || continue
                for mac in $(uci -q get "sheepfold.$section.mac" 2>/dev/null || true); do
                        [ "$(normalize_mac "$mac")" = "$wanted" ] && return 0
                done
                for mac in $(uci -q get "sheepfold.$section.macs" 2>/dev/null || true); do
                        [ "$(normalize_mac "$mac")" = "$wanted" ] && return 0
                done
        done

        return 1
}

text_has() {
        printf '%s' "$1" | grep -Eiq "$2"
}

name_is_network_infrastructure() {
        candidate_name="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"
        [ -n "$candidate_name" ] || return 1

        # Шлюзы умного дома являются конечными бытовыми устройствами, а не сетевыми роутерами
        if text_has "$candidate_name" "$SMART_HOME_NETWORK_PATTERN"; then
                return 1
        fi

        text_has "$candidate_name" "$NETWORK_NAME_PATTERN"
}

target_group_for_detected_type() {
        # Автоматически разрешаем только устройства, через которые обычно нельзя пользоваться интернетом
        case "$1" in
                server|engineering|camera|smart_home|vacuum|speaker)
                        printf '%s\n' "$NO_RESTRICTIONS_GROUP"
                        ;;
                *)
                        printf '\n'
                        ;;
        esac
}

revoke_unsafe_auto_assignment() {
        section="$1"
        mac="$2"
        ip="$3"
        name="$4"
        reason="$5"
        current_group="$(uci -q get "sheepfold.$section.group" 2>/dev/null || true)"
        auto_assigned="$(uci -q get "sheepfold.$section.auto_group_assigned" 2>/dev/null || true)"

        [ "$auto_assigned" = "1" ] || return 0
        case "$current_group" in
                "$NO_RESTRICTIONS_GROUP"|"No restrictions") ;;
                *) return 0 ;;
        esac

        uci -q delete "sheepfold.$section.group" 2>/dev/null || true
        uci -q set "sheepfold.$section.auto_group_assigned=0"
        uci -q delete "sheepfold.$section.auto_group_reason" 2>/dev/null || true
        uci -q set "sheepfold.$section.auto_group_revoked_reason=$reason"
        uci -q set "sheepfold.$section.auto_group_revoked_at=$(date +%s)"
        log_event "Устройство ${name:-$mac}, IP ${ip:-неизвестен} удалено из группы \"$NO_RESTRICTIONS_GROUP\": $reason"
}

assign_no_restrictions_if_allowed() {
        section="$1"
        mac="$2"
        ip="$3"
        name="$4"
        confidence="$5"
        target_group="$6"
        reason="$7"
        device_type="$8"
        min_confidence="$(global_get detector_min_no_restrictions_confidence 80)"
        no_restrictions_auto_assign="$(global_get no_restrictions_auto_assign 1)"
        current_group="$(uci -q get "sheepfold.$section.group" 2>/dev/null || true)"
        auto_excluded="$(uci -q get "sheepfold.$section.no_restrictions_auto_excluded" 2>/dev/null || true)"

        # Роутеры, точки доступа и другие сетевые устройства никогда не получают эту группу автоматически
        if [ "$device_type" = "network" ] || name_is_network_infrastructure "$name"; then
                revoke_unsafe_auto_assignment "$section" "$mac" "$ip" "$name" "network infrastructure must be configured manually"
                return 0
        fi

        case "$confidence" in
                ''|*[!0-9]*) confidence=0 ;;
        esac
        case "$min_confidence" in
                ''|*[!0-9]*) min_confidence=80 ;;
        esac

        [ "$no_restrictions_auto_assign" = "1" ] || return 0
        [ "$auto_excluded" = "1" ] && return 0
        [ -n "$target_group" ] || return 0
        [ "$confidence" -ge "$min_confidence" ] || return 0

        # Чёрный список всегда старше любой автоматики
        mac_in_named_list blocklist "$mac" && return 0

        case "$current_group" in
                ""|"Не настроено"|"Not configured")
                        uci -q set "sheepfold.$section.group=$target_group"
                        uci -q set "sheepfold.$section.auto_group_assigned=1"
                        uci -q set "sheepfold.$section.auto_group_reason=$reason"
                        uci -q delete "sheepfold.$section.auto_group_revoked_reason" 2>/dev/null || true
                        uci -q delete "sheepfold.$section.auto_group_revoked_at" 2>/dev/null || true
                        log_event "Устройство ${name:-$mac}, IP ${ip:-неизвестен} автоматически добавлено в группу \"$target_group\": $reason"
                        ;;
        esac
}

append_router_devices() {
        : > "$RAW_FILE"

        if [ -r /tmp/dhcp.leases ]; then
                awk 'NF >= 4 { print $2 "\t" $3 "\t" $4 "\tdhcp" }' /tmp/dhcp.leases >> "$RAW_FILE"
        fi

        if [ -r /proc/net/arp ]; then
                awk 'NR > 1 { print $4 "\t" $1 "\t" "" "\tarp" }' /proc/net/arp >> "$RAW_FILE"
        fi

        for section in $(uci -q show dhcp 2>/dev/null | sed -n "s/^dhcp\.\([^.=]*\)=host$/\1/p"); do
                ip="$(uci -q get "dhcp.$section.ip" 2>/dev/null || true)"
                name="$(uci -q get "dhcp.$section.name" 2>/dev/null || uci -q get "dhcp.$section.hostname" 2>/dev/null || true)"
                for mac in $(uci -q get "dhcp.$section.mac" 2>/dev/null || true); do
                        printf '%s\t%s\t%s\tstatic\n' "$mac" "$ip" "$name" >> "$RAW_FILE"
                done
        done
}

aggregate_router_devices() {
        awk -F '\t' '
        function valid_mac(value) {
                return value ~ /^([0-9A-Fa-f][0-9A-Fa-f]:){5}[0-9A-Fa-f][0-9A-Fa-f]$/
        }
        {
                mac = toupper($1)
                if (!valid_mac(mac) || mac == "00:00:00:00:00:00")
                        next
                if (!(mac in seen)) {
                        order[++count] = mac
                        seen[mac] = 1
                }
                if ($2 != "" && ip[mac] == "")
                        ip[mac] = $2
                if ($3 != "" && $3 != "*" && name[mac] == "")
                        name[mac] = $3
                if ($4 != "" && sources[mac] !~ $4)
                        sources[mac] = sources[mac] (sources[mac] == "" ? "" : ",") $4
        }
        END {
                for (i = 1; i <= count; i++) {
                        mac = order[i]
                        print mac "\t" ip[mac] "\t" name[mac] "\t" sources[mac]
                }
        }' "$RAW_FILE"
}

scan_ports() {
        ip="$1"
        mode="$2"
        max_seconds="$(global_get detector_nmap_host_timeout_seconds 20)"
        ports="$(global_get detector_scan_ports "$DEFAULT_SCAN_PORTS")"

        [ "$mode" = "full" ] || return 0
        [ -n "$ip" ] || return 0
        command -v nmap >/dev/null 2>&1 || return 0

        nmap -Pn -T2 --host-timeout "${max_seconds}s" -p "$ports" "$ip" 2>/dev/null |
                awk -F/ '/open/ { ports = ports (ports == "" ? "" : ",") $1 } END { print ports }'
}

classify_device() {
        name="$1"
        ports="$2"
        lower="$(printf '%s' "$name" | tr '[:upper:]' '[:lower:]')"
        type="smart"
        confidence=35
        reason="lightweight router metadata"
        target_group=""

        if name_is_network_infrastructure "$name"; then
                type="network"
                confidence=96
                reason="network infrastructure marker"
        elif text_has "$lower" 'home[ -]?assistant|hassio|hass\.io|haos|openhab|adguard[ -]?home|adguardhome|file server|proxmox|truenas|freenas|openmediavault|synology|diskstation|qnap|unraid|docker host|portainer|smlight|slzb|zigbee2mqtt|zha coordinator|zigbee coordinator|zigbee gateway|zigbee bridge|matter bridge|thread border router|homekit bridge|smart home hub|smarthome hub|philips hue bridge|hue bridge|ikea dirigera|dirigera|tradfri gateway|aqara hub|aqara gateway|xiaomi gateway|mijia gateway|tuya gateway|sonoff zigbee bridge|hubitat|smartthings hub|aeotec hub|homey|fibaro home center|homematic|deconz|conbee|skyconnect|zwavejs|z-wave js|z-wave gateway|zwave gateway' ||
             text_has "$lower" '(^|[^a-z0-9])(samba|smb|cifs|nas|pve|omv)([^a-z0-9]|$)'; then
                type="server"
                confidence=86
                reason="home infrastructure name marker"
        elif text_has "$lower" 'nvr|dvr|xvr|video recorder|videoregistrar|videonablyudenie|videonablydenie|videonabludenie|video-nablyudenie|video-nablydenie|cctv server|surveillance server|video server|ltv-rne|rvi-r|trassir|xmeye|ivms|hik-connect|smartpss|uniview|hikvision|hiwatch|hilook|dahua|beward|optimus|tantos|polyvision|hanwha|wisenet|axis|vivotek|tiandy'; then
                type="server"
                confidence=86
                reason="video recorder or surveillance server name marker"
        elif text_has "$lower" 'zont|ectostroy|ectocontrol|myheat|teplocom|xital|telemetrika|owen|saures|baxi|navien|vaillant|buderus|protherm|ariston' ||
             text_has "$lower" '(^|[^a-z0-9])(boiler|kotel|heating|thermostat|alarm)([^a-z0-9]|$)|кот[её]л'; then
                type="engineering"
                confidence=86
                reason="engineering, heating, or safety controller name marker"
        elif text_has "$lower" 'printer|print|epson|canon|hp-|brother'; then
                type="printer"
                confidence=82
                reason="printer marker"
        elif text_has "$lower" '(^|[^a-z0-9])(ip[-_ ]?cam|webcam|camera|cam[0-9]+|cam[-_ ][0-9]+)([^a-z0-9]|$)'; then
                type="camera"
                confidence=82
                reason="camera marker"
        elif text_has "$lower" 'iphone|android|galaxy|redmi|pixel|phone'; then
                type="phone"
                confidence=78
                reason="phone marker"
        elif text_has "$lower" 'ipad|tablet|pad'; then
                type="tablet"
                confidence=78
                reason="tablet marker"
        elif text_has "$lower" 'desktop|laptop|notebook|macbook|pc-'; then
                type="computer"
                confidence=76
                reason="computer marker"
        elif text_has "$lower" 'tv|chromecast|mi box|androidtv|smarttv'; then
                type="tv"
                confidence=76
                reason="TV or media marker"
        elif text_has "$lower" 'playstation|ps4|ps5|xbox|switch|console'; then
                type="console"
                confidence=82
                reason="game console marker"
        elif text_has "$lower" 'alice|alisa|yandex[ _-]?(station|stantsiya)|яндекс[ _-]?станц|smart speaker|sonos|homepod|alexa|amazon echo|google home|sberboom|marusya'; then
                type="speaker"
                confidence=84
                reason="smart speaker marker"
        elif text_has "$lower" 'vacuum|roborock|dreame|deebot|ecovacs|irobot|roomba|miio|xiaomi-vacuum|viomi|ilife|eufy|yeedi'; then
                type="vacuum"
                confidence=80
                reason="robot vacuum marker"
        elif text_has "$lower" 'warm floor|underfloor|floor heating|heated floor|thermoregulator|терморегулятор|т[её]пл[ыо]й пол|теплый пол|тёплый пол|подогрев пола|heater relay|smart relay|relay|реле|switch module|wall switch|light switch|выключател|освещен|свет|ламп|dimmer|диммер|curtain|curtains|blind|blinds|shade|roller shade|штор|жалюзи|карниз|kettle|чайник|iron|утюг|socket|plug|розетк|tuya|ewelink|sonoff|shelly|aqara|mijia|xiaomi smart|yeelight|philips hue|nanoleaf|wled|led controller|контроллер led|контроллер света|motion sensor|датчик движения|door sensor|window sensor|датчик двери|датчик окна|leak sensor|датчик протечки|smoke sensor|датчик дыма|temperature sensor|датчик температуры|humidity sensor|датчик влажности'; then
                type="smart_home"
                confidence=80
                reason="smart-home appliance, relay, sensor, or actuator marker"
        elif text_has "$lower" '(^|[^a-z0-9])(espressif|esp8266|esp32|esp32c3|esp32-c3|esp32s3|esp32-s3|tasmota|esphome)([^a-z0-9]|$)'; then
                type="smart_home"
                confidence=82
                reason="ESP smart-home device marker"
        fi

        target_group="$(target_group_for_detected_type "$type")"

        case ",$ports," in
                *,8123,*)
                        type="server"; confidence=95; reason="Home Assistant port 8123 is open"; target_group="$NO_RESTRICTIONS_GROUP" ;;
                *,8006,*)
                        type="server"; confidence=95; reason="Proxmox port 8006 is open"; target_group="$NO_RESTRICTIONS_GROUP" ;;
                *,3000,*|*,3001,*)
                        if text_has "$lower" 'adguard|grafana|server|home|nas'; then
                                type="server"; confidence=90; reason="server-like web service port is open"; target_group="$NO_RESTRICTIONS_GROUP"
                        fi ;;
        esac

        if printf '%s' "$ports" | grep -Eq '(^|,)(445|548|2049)(,|$)'; then
                type="server"
                [ "$confidence" -lt 86 ] && confidence=86
                reason="file sharing service is open"
                target_group="$NO_RESTRICTIONS_GROUP"
        fi

        if printf '%s' "$ports" | grep -Eq '(^|,)(554|8554)(,|$)' && text_has "$lower" 'nvr|dvr|recorder|video|cctv|ltv|hikvision|dahua|axis|uniview'; then
                type="server"
                [ "$confidence" -lt 88 ] && confidence=88
                reason="surveillance streaming service is open"
                target_group="$NO_RESTRICTIONS_GROUP"
        fi

        if printf '%s' "$ports" | grep -Eq '(^|,)(554|8554)(,|$)' && text_has "$lower" '(^|[^a-z0-9])(ip[-_ ]?cam|webcam|camera|cam[0-9]+|cam[-_ ][0-9]+)([^a-z0-9]|$)'; then
                type="camera"
                [ "$confidence" -lt 88 ] && confidence=88
                reason="camera streaming service is open"
                target_group="$(target_group_for_detected_type "$type")"
        fi

        if printf '%s' "$ports" | grep -Eq '(^|,)(9100|631)(,|$)'; then
                type="printer"
                [ "$confidence" -lt 86 ] && confidence=86
                reason="printer service is open"
                target_group="$(target_group_for_detected_type "$type")"
        fi

        # Имя сетевого устройства имеет максимальный приоритет над портовыми эвристиками
        if name_is_network_infrastructure "$name"; then
                type="network"
                confidence=96
                reason="network infrastructure marker"
                target_group=""
        fi

        printf '%s\t%s\t%s\t%s\n' "$type" "$confidence" "$target_group" "$reason"
}

write_manual_device_observation() {
        mac="$1"
        ip="$2"
        name="$3"
        sources="$4"
        now="$5"
        section="$(ensure_device_section "$mac")"
        device_type="$(uci -q get "sheepfold.$section.device_type" 2>/dev/null || printf unknown)"

        # Ручной тип устройства всегда старше автоопределения
        uci -q set "sheepfold.$section.ip=$ip"
        [ -n "$name" ] && [ -z "$(uci -q get "sheepfold.$section.name" 2>/dev/null || true)" ] && uci -q set "sheepfold.$section.name=$name"
        uci -q set "sheepfold.$section.detection_sources=$sources"
        uci -q set "sheepfold.$section.detection_updated_at=$now"

        if [ "$(uci -q get "sheepfold.$section.just_detected" 2>/dev/null || true)" = "1" ]; then
                log_event "Обнаружено новое устройство: $mac, IP ${ip:-неизвестен}${name:+, имя $name}"
                uci -q delete "sheepfold.$section.just_detected" 2>/dev/null || true
        fi

        printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$mac" "$ip" "$name" "$device_type" "" "" "manual device type" "" >> "$CACHE_FILE"
}

write_locked_device_observation() {
        mac="$1"
        ip="$2"
        name="$3"
        sources="$4"
        now="$5"
        section="$(ensure_device_section "$mac")"
        device_type="$(uci -q get "sheepfold.$section.detected_type" 2>/dev/null || uci -q get "sheepfold.$section.device_type" 2>/dev/null || printf unknown)"
        confidence="$(uci -q get "sheepfold.$section.detection_confidence" 2>/dev/null || true)"
        reason="$(uci -q get "sheepfold.$section.detection_reason" 2>/dev/null || printf 'locked confident device type')"
        target_group="$(target_group_for_detected_type "$device_type")"

        uci -q set "sheepfold.$section.ip=$ip"
        [ -n "$name" ] && [ -z "$(uci -q get "sheepfold.$section.name" 2>/dev/null || true)" ] && uci -q set "sheepfold.$section.name=$name"
        uci -q set "sheepfold.$section.detection_sources=$sources"
        uci -q set "sheepfold.$section.detection_updated_at=$now"

        if [ "$(uci -q get "sheepfold.$section.just_detected" 2>/dev/null || true)" = "1" ]; then
                log_event "Обнаружено новое устройство: $mac, IP ${ip:-неизвестен}${name:+, имя $name}"
                uci -q delete "sheepfold.$section.just_detected" 2>/dev/null || true
        fi

        assign_no_restrictions_if_allowed "$section" "$mac" "$ip" "$name" "$confidence" "$target_group" "$reason" "$device_type"

        printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$mac" "$ip" "$name" "$device_type" "$confidence" "$target_group" "$reason" "" >> "$CACHE_FILE"
}

write_detection() {
        mac="$1"
        ip="$2"
        name="$3"
        sources="$4"
        mode="$5"
        ports="$6"
        now="$7"
        result="$(classify_device "$name" "$ports")"
        device_type="$(printf '%s' "$result" | awk -F '\t' '{ print $1 }')"
        confidence="$(printf '%s' "$result" | awk -F '\t' '{ print $2 }')"
        target_group="$(printf '%s' "$result" | awk -F '\t' '{ print $3 }')"
        reason="$(printf '%s' "$result" | awk -F '\t' '{ print $4 }')"
        section="$(ensure_device_section "$mac")"

        uci -q set "sheepfold.$section.ip=$ip"
        [ -n "$name" ] && [ -z "$(uci -q get "sheepfold.$section.name" 2>/dev/null || true)" ] && uci -q set "sheepfold.$section.name=$name"
        uci -q set "sheepfold.$section.detected_type=$device_type"
        uci -q set "sheepfold.$section.detection_confidence=$confidence"
        uci -q set "sheepfold.$section.detection_reason=$reason"
        uci -q set "sheepfold.$section.detection_sources=$sources"
        uci -q set "sheepfold.$section.detection_ports=$ports"
        uci -q set "sheepfold.$section.detection_updated_at=$now"

        if [ "$(uci -q get "sheepfold.$section.just_detected" 2>/dev/null || true)" = "1" ]; then
                log_event "Обнаружено новое устройство: $mac, IP ${ip:-неизвестен}${name:+, имя $name}"
                uci -q delete "sheepfold.$section.just_detected" 2>/dev/null || true
        fi

        assign_no_restrictions_if_allowed "$section" "$mac" "$ip" "$name" "$confidence" "$target_group" "$reason" "$device_type"

        printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$mac" "$ip" "$name" "$device_type" "$confidence" "$target_group" "$reason" "$ports" >> "$CACHE_FILE"
}

scan_devices() {
        mode="$(global_get detection_mode full)"
        max_hosts="$(global_get detector_max_hosts_per_scan 16)"
        min_device_type_confidence="$(global_get detector_min_device_type_confidence 70)"
        now="$(date +%s)"
        scanned=0

        case "$max_hosts" in
                ''|*[!0-9]*) max_hosts=16 ;;
        esac
        case "$min_device_type_confidence" in
                ''|*[!0-9]*) min_device_type_confidence=70 ;;
        esac

        mkdir -p "$CACHE_DIR"
        chmod 700 "$CACHE_DIR"
        append_router_devices
        : > "$CACHE_FILE"

        aggregate_router_devices | while IFS="$(printf '\t')" read -r mac ip name sources; do
                section="$(section_for_mac "$mac" 2>/dev/null || true)"
                if [ -n "$section" ] && [ -z "$name" ]; then
                        name="$(uci -q get "sheepfold.$section.name" 2>/dev/null || true)"
                fi

                if [ -n "$section" ] && [ "$(uci -q get "sheepfold.$section.manual_device_type" 2>/dev/null || true)" = "1" ]; then
                        write_manual_device_observation "$mac" "$ip" "$name" "$sources" "$now"
                        continue
                fi

                if [ -n "$section" ]; then
                        existing_confidence="$(uci -q get "sheepfold.$section.detection_confidence" 2>/dev/null || true)"
                        existing_type="$(uci -q get "sheepfold.$section.detected_type" 2>/dev/null || true)"
                        force_network_reclassification=0
                        case "$existing_confidence" in
                                ''|*[!0-9]*) existing_confidence=0 ;;
                        esac

                        # Сетевой маркер исправляет даже ранее закреплённую ошибочную классификацию
                        if name_is_network_infrastructure "$name" && [ "$existing_type" != "network" ]; then
                                force_network_reclassification=1
                        fi

                        # Уверенный тип фиксируется, если не сработал более важный сетевой запрет
                        if [ -n "$existing_type" ] && [ "$existing_confidence" -ge "$min_device_type_confidence" ] && [ "$force_network_reclassification" != "1" ]; then
                                write_locked_device_observation "$mac" "$ip" "$name" "$sources" "$now"
                                continue
                        fi
                fi

                ports=""
                if [ "$mode" = "full" ] && [ "$scanned" -lt "$max_hosts" ]; then
                        ports="$(scan_ports "$ip" "$mode" || true)"
                        scanned=$((scanned + 1))
                fi
                write_detection "$mac" "$ip" "$name" "$sources" "$mode" "$ports" "$now"
        done

        uci -q set "sheepfold.global.detector_last_scan=$now"
        uci -q commit sheepfold
}

case "$COMMAND" in
        scan|run|once)
                scan_devices
                ;;
        status)
                [ -r "$CACHE_FILE" ] && cat "$CACHE_FILE"
                ;;
        classify)
                classify_device "${2:-}" "${3:-}"
                ;;
        *)
                echo "Usage: sheepfold-device-detector [scan|status|classify <name> [ports]]" >&2
                exit 1
                ;;
esac
