#!/bin/sh
set -eu

COMMAND="${1:-scan}"
CACHE_DIR="/tmp/sheepfold"
CACHE_FILE="$CACHE_DIR/device-detection.tsv"
RAW_FILE="$CACHE_DIR/device-detection.raw"
STATE_DIR="$CACHE_DIR/device-state"
SIGNAL_DIR="$CACHE_DIR/device-signals"
DIRTY_FLAG="$CACHE_DIR/device-detection.uci-dirty"
LAST_SCAN_FILE="$CACHE_DIR/device-detection.last-scan"
NEW_DEVICE_ALERT_FLAG="$CACHE_DIR/new-device-alert"
LOG_HELPER="/usr/libexec/sheepfold/sheepfold-log"
CLASSIFIER="/usr/libexec/sheepfold/sheepfold-device-classifier"
DEFAULT_SCAN_PORTS="22,53,80,81,443,445,548,554,631,1883,3000,3001,5000,5001,5353,8000,8006,8080,8081,8123,8554,9000,9100,32400"
NO_RESTRICTIONS_GROUP="Без ограничений"
POLICY_VERSION="2"

global_get() {
        uci -q get "sheepfold.global.$1" 2>/dev/null || printf '%s' "$2"
}

normalize_mac() {
        printf '%s' "$1" | tr '[:lower:]' '[:upper:]'
}

valid_mac() {
        printf '%s' "$1" | grep -Eq '^([0-9A-F]{2}:){5}[0-9A-F]{2}$'
}

log_event() {
        if [ -x "$LOG_HELPER" ]; then
                "$LOG_HELPER" "$*"
        else
                logger -t sheepfold "$*"
        fi
}

mark_dirty() {
        : > "$DIRTY_FLAG"
}

uci_set_if_changed() {
        path="$1"
        value="$2"
        current="$(uci -q get "$path" 2>/dev/null || true)"
        [ "$current" = "$value" ] && return 0
        uci -q set "$path=$value"
        mark_dirty
}

uci_delete_if_present() {
        path="$1"
        uci -q get "$path" >/dev/null 2>&1 || return 0
        uci -q delete "$path"
        mark_dirty
}

section_for_mac() {
        wanted="$(normalize_mac "$1")"
        for section in $(uci -q show sheepfold 2>/dev/null | sed -n "s/^sheepfold\.\([^.=]*\)=device$/\1/p"); do
                current="$(normalize_mac "$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)")"
                [ "$current" = "$wanted" ] && {
                        printf '%s\n' "$section"
                        return 0
                }
        done
        return 1
}

ensure_device_section() {
        mac="$(normalize_mac "$1")"
        if section="$(section_for_mac "$mac")"; then
                printf '%s\n' "$section"
                return 0
        fi

        section="device_$(printf '%s' "$mac" | tr '[:upper:]' '[:lower:]' | tr -d ':')"
        uci_set_if_changed "sheepfold.$section" device
        uci_set_if_changed "sheepfold.$section.mac" "$mac"
        uci_set_if_changed "sheepfold.$section.just_detected" 1
        date +%s > "$NEW_DEVICE_ALERT_FLAG"
        printf '%s\n' "$section"
}

mac_in_named_list() {
        list_name="$1"
        wanted="$(normalize_mac "$2")"

        for section in $(uci -q show sheepfold 2>/dev/null | sed -n "s/^sheepfold\.\([^.=]*\)=list$/\1/p"); do
                [ "$section" = "$list_name" ] || continue
                for mac in $(uci -q get "sheepfold.$section.mac" 2>/dev/null || true); do
                        [ "$(normalize_mac "$mac")" = "$wanted" ] && return 0
                done
                for mac in $(uci -q get "sheepfold.$section.macs" 2>/dev/null || true); do
                        [ "$(normalize_mac "$mac")" = "$wanted" ] && return 0
                done
        done

        return 1
}

signal_file_for_mac() {
        mac="$(normalize_mac "$1")"
        valid_mac "$mac" || return 1
        printf '%s/%s.dhcp\n' "$SIGNAL_DIR" "$(printf '%s' "$mac" | tr ':' '_')"
}

static_name_for_mac() {
        wanted="$(normalize_mac "$1")"

        for section in $(uci -q show dhcp 2>/dev/null | sed -n "s/^dhcp\.\([^.=]*\)=host$/\1/p"); do
                for configured_mac in $(uci -q get "dhcp.$section.mac" 2>/dev/null || true); do
                        [ "$(normalize_mac "$configured_mac")" = "$wanted" ] || continue
                        uci -q get "dhcp.$section.name" 2>/dev/null || \
                                uci -q get "dhcp.$section.hostname" 2>/dev/null || true
                        return 0
                done
        done
}

fingerprint_signal_material() {
        signal_file="$1"
        [ -r "$signal_file" ] || return 0
        awk -F '\t' '
                $1 == "hostname" ||
                $1 == "supplied_hostname" ||
                $1 == "vendor_class" ||
                $1 == "requested_options" ||
                $1 == "user_class" ||
                $1 == "client_id" ||
                $1 == "mud_url" ||
                $1 == "interface" { print }
        ' "$signal_file" 2>/dev/null | sort
}

build_fingerprint() {
        mac="$1"
        name="$2"
        static_name="$3"
        signal_file="$4"
        ports="$5"
        {
                printf 'policy=%s\n' "$POLICY_VERSION"
                printf 'mac=%s\n' "$(normalize_mac "$mac")"
                printf 'name=%s\n' "$name"
                printf 'static_name=%s\n' "$static_name"
                printf 'ports=%s\n' "$ports"
                fingerprint_signal_material "$signal_file"
        } | cksum | awk '{ print $1 "-" $2 }'
}

write_runtime_observation() {
        mac="$1"
        ip="$2"
        name="$3"
        sources="$4"
        now="$5"
        mkdir -p "$STATE_DIR"
        chmod 700 "$STATE_DIR" 2>/dev/null || true
        file="$STATE_DIR/$(printf '%s' "$mac" | tr ':' '_').tsv"
        tmp="$file.tmp.$$"
        umask 077
        {
                printf 'last_seen\t%s\n' "$now"
                printf 'ip\t%s\n' "$ip"
                printf 'name\t%s\n' "$name"
                printf 'sources\t%s\n' "$sources"
        } > "$tmp"
        chmod 600 "$tmp" 2>/dev/null || true
        mv -f "$tmp" "$file"
}

append_router_devices() {
        : > "$RAW_FILE"

        if [ -r /tmp/dhcp.leases ]; then
                awk 'NF >= 4 { print $2 "\t" $3 "\t" $4 "\tdhcp" }' /tmp/dhcp.leases >> "$RAW_FILE"
        fi

        if [ -r /proc/net/arp ]; then
                awk 'NR > 1 { print $4 "\t" $1 "\t" "" "\tarp" }' /proc/net/arp >> "$RAW_FILE"
        fi

        for section in $(uci -q show dhcp 2>/dev/null | sed -n "s/^dhcp\.\([^.=]*\)=host$/\1/p"); do
                ip="$(uci -q get "dhcp.$section.ip" 2>/dev/null || true)"
                name="$(uci -q get "dhcp.$section.name" 2>/dev/null || uci -q get "dhcp.$section.hostname" 2>/dev/null || true)"
                for mac in $(uci -q get "dhcp.$section.mac" 2>/dev/null || true); do
                        printf '%s\t%s\t%s\tstatic\n' "$mac" "$ip" "$name" >> "$RAW_FILE"
                done
        done
}

aggregate_router_devices() {
        awk -F '\t' '
        function valid_mac(value) {
                return value ~ /^([0-9A-Fa-f][0-9A-Fa-f]:){5}[0-9A-Fa-f][0-9A-Fa-f]$/
        }
        {
                mac = toupper($1)
                if (!valid_mac(mac) || mac == "00:00:00:00:00:00")
                        next
                if (!(mac in seen)) {
                        order[++count] = mac
                        seen[mac] = 1
                }
                if ($2 != "" && ip[mac] == "")
                        ip[mac] = $2
                if ($3 != "" && $3 != "*" && name[mac] == "")
                        name[mac] = $3
                if ($4 != "" && sources[mac] !~ $4)
                        sources[mac] = sources[mac] (sources[mac] == "" ? "" : ",") $4
        }
        END {
                for (i = 1; i <= count; i++) {
                        mac = order[i]
                        print mac "\t" ip[mac] "\t" name[mac] "\t" sources[mac]
                }
        }' "$RAW_FILE"
}

scan_ports() {
        ip="$1"
        mode="$2"
        max_seconds="$(global_get detector_nmap_host_timeout_seconds 20)"
        ports="$(global_get detector_scan_ports "$DEFAULT_SCAN_PORTS")"

        [ "$mode" = "full" ] || return 0
        [ -n "$ip" ] || return 0
        command -v nmap >/dev/null 2>&1 || return 0

        nmap -Pn -T2 --host-timeout "${max_seconds}s" -p "$ports" "$ip" 2>/dev/null |
                awk -F/ '/open/ { ports = ports (ports == "" ? "" : ",") $1 } END { print ports }'
}

assign_no_restrictions_if_allowed() {
        section="$1"
        mac="$2"
        ip="$3"
        name="$4"
        target_group="$5"
        reason="$6"
        auto_score="$7"
        evidence_count="$8"
        hard_deny="$9"
        min_score="$(global_get detector_min_no_restrictions_confidence 80)"
        enabled="$(global_get no_restrictions_auto_assign 1)"
        current_group="$(uci -q get "sheepfold.$section.group" 2>/dev/null || true)"
        auto_excluded="$(uci -q get "sheepfold.$section.no_restrictions_auto_excluded" 2>/dev/null || true)"

        case "$auto_score" in ''|*[!0-9]*) auto_score=0 ;; esac
        case "$evidence_count" in ''|*[!0-9]*) evidence_count=0 ;; esac
        case "$min_score" in ''|*[!0-9]*) min_score=80 ;; esac

        [ "$hard_deny" = "0" ] || return 0
        [ "$enabled" = "1" ] || return 0
        [ "$auto_excluded" = "1" ] && return 0
        [ -n "$target_group" ] || return 0
        [ "$auto_score" -ge "$min_score" ] || return 0
        [ "$evidence_count" -ge 2 ] || return 0
        mac_in_named_list blocklist "$mac" && return 0

        case "$current_group" in
                ""|"Не настроено"|"Not configured")
                        uci_set_if_changed "sheepfold.$section.group" "$target_group"
                        uci_set_if_changed "sheepfold.$section.auto_group_assigned" 1
                        uci_set_if_changed "sheepfold.$section.auto_group_reason" "$reason"
                        log_event "Устройство ${name:-$mac}, IP ${ip:-неизвестен} автоматически добавлено в группу \"$target_group\": $reason; score=$auto_score; evidence=$evidence_count"
                        ;;
        esac
}

write_common_observation() {
        section="$1"
        mac="$2"
        ip="$3"
        name="$4"
        sources="$5"
        now="$6"

        write_runtime_observation "$mac" "$ip" "$name" "$sources" "$now"
        [ -n "$ip" ] && uci_set_if_changed "sheepfold.$section.ip" "$ip"
        [ -n "$name" ] && [ -z "$(uci -q get "sheepfold.$section.name" 2>/dev/null || true)" ] && \
                uci_set_if_changed "sheepfold.$section.name" "$name"

        if [ "$(uci -q get "sheepfold.$section.just_detected" 2>/dev/null || true)" = "1" ]; then
                log_event "Обнаружено новое устройство: $mac, IP ${ip:-неизвестен}${name:+, имя $name}"
                uci_delete_if_present "sheepfold.$section.just_detected"
        fi
}

write_manual_device_observation() {
        mac="$1"
        ip="$2"
        name="$3"
        sources="$4"
        now="$5"
        section="$(ensure_device_section "$mac")"
        device_type="$(uci -q get "sheepfold.$section.device_type" 2>/dev/null || printf unknown)"

        write_common_observation "$section" "$mac" "$ip" "$name" "$sources" "$now"
        printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
                "$mac" "$ip" "$name" "$device_type" "" "" "manual device type" "" >> "$CACHE_FILE"
}

write_locked_device_observation() {
        mac="$1"
        ip="$2"
        name="$3"
        sources="$4"
        now="$5"
        section="$(ensure_device_section "$mac")"
        device_type="$(uci -q get "sheepfold.$section.detected_type" 2>/dev/null || printf unknown)"
        confidence="$(uci -q get "sheepfold.$section.detection_confidence" 2>/dev/null || true)"
        target_group="$(uci -q get "sheepfold.$section.detection_target_group" 2>/dev/null || true)"
        reason="$(uci -q get "sheepfold.$section.detection_reason" 2>/dev/null || printf 'locked confident device type')"
        auto_score="$(uci -q get "sheepfold.$section.detection_auto_group_score" 2>/dev/null || printf 0)"
        evidence="$(uci -q get "sheepfold.$section.detection_evidence" 2>/dev/null || true)"

        write_common_observation "$section" "$mac" "$ip" "$name" "$sources" "$now"
        printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
                "$mac" "$ip" "$name" "$device_type" "$confidence" "$target_group" \
                "$reason" "" "$auto_score" "$evidence" >> "$CACHE_FILE"
}

write_detection() {
        mac="$1"
        ip="$2"
        name="$3"
        sources="$4"
        ports="$5"
        now="$6"
        section="$(ensure_device_section "$mac")"
        static_name="$(static_name_for_mac "$mac" || true)"
        signal_file="$(signal_file_for_mac "$mac" || true)"
        fingerprint="$(build_fingerprint "$mac" "$name" "$static_name" "$signal_file" "$ports")"
        result="$("$CLASSIFIER" "$name" "$ports" "$static_name" "$signal_file" "$mac")"
        device_type="$(printf '%s' "$result" | awk -F '\t' '{ print $1 }')"
        confidence="$(printf '%s' "$result" | awk -F '\t' '{ print $2 }')"
        target_group="$(printf '%s' "$result" | awk -F '\t' '{ print $3 }')"
        reason="$(printf '%s' "$result" | awk -F '\t' '{ print $4 }')"
        auto_score="$(printf '%s' "$result" | awk -F '\t' '{ print $5 }')"
        evidence="$(printf '%s' "$result" | awk -F '\t' '{ print $6 }')"
        evidence_count="$(printf '%s' "$result" | awk -F '\t' '{ print $7 }')"
        hard_deny="$(printf '%s' "$result" | awk -F '\t' '{ print $8 }')"
        policy_version="$(printf '%s' "$result" | awk -F '\t' '{ print $9 }')"
        oui_vendor="$(printf '%s' "$result" | awk -F '\t' '{ print $10 }')"
        old_fingerprint="$(uci -q get "sheepfold.$section.detection_fingerprint" 2>/dev/null || true)"

        write_common_observation "$section" "$mac" "$ip" "$name" "$sources" "$now"
        uci_set_if_changed "sheepfold.$section.detected_type" "$device_type"
        uci_set_if_changed "sheepfold.$section.detection_confidence" "$confidence"
        uci_set_if_changed "sheepfold.$section.detection_reason" "$reason"
        uci_set_if_changed "sheepfold.$section.detection_target_group" "$target_group"
        uci_set_if_changed "sheepfold.$section.detection_auto_group_score" "$auto_score"
        uci_set_if_changed "sheepfold.$section.detection_evidence" "$evidence"
        uci_set_if_changed "sheepfold.$section.detection_evidence_count" "$evidence_count"
        uci_set_if_changed "sheepfold.$section.detection_hard_deny" "$hard_deny"
        uci_set_if_changed "sheepfold.$section.detection_policy_version" "$policy_version"
        uci_set_if_changed "sheepfold.$section.detection_fingerprint" "$fingerprint"
        uci_set_if_changed "sheepfold.$section.detection_ports" "$ports"
        if [ -n "$oui_vendor" ]; then
                uci_set_if_changed "sheepfold.$section.detection_oui_vendor" "$oui_vendor"
        else
                uci_delete_if_present "sheepfold.$section.detection_oui_vendor"
        fi
        if [ "$old_fingerprint" != "$fingerprint" ]; then
                uci_set_if_changed "sheepfold.$section.detection_updated_at" "$now"
        fi

        assign_no_restrictions_if_allowed "$section" "$mac" "$ip" "$name" "$target_group" \
                "$reason" "$auto_score" "$evidence_count" "$hard_deny"

        printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
                "$mac" "$ip" "$name" "$device_type" "$confidence" "$target_group" \
                "$reason" "$ports" "$auto_score" "$evidence" >> "$CACHE_FILE"
}

scan_devices() {
        mode="$(global_get detection_mode full)"
        max_hosts="$(global_get detector_max_hosts_per_scan 16)"
        min_confidence="$(global_get detector_min_device_type_confidence 70)"
        now="$(date +%s)"
        scanned=0

        case "$max_hosts" in ''|*[!0-9]*) max_hosts=16 ;; esac
        case "$min_confidence" in ''|*[!0-9]*) min_confidence=70 ;; esac

        mkdir -p "$CACHE_DIR" "$STATE_DIR" "$SIGNAL_DIR"
        chmod 700 "$CACHE_DIR" "$STATE_DIR" "$SIGNAL_DIR" 2>/dev/null || true
        rm -f "$DIRTY_FLAG"
        append_router_devices
        : > "$CACHE_FILE"

        aggregate_router_devices | while IFS="$(printf '\t')" read -r mac ip name sources; do
                section="$(section_for_mac "$mac" 2>/dev/null || true)"
                if [ -n "$section" ] && [ -z "$name" ]; then
                        name="$(uci -q get "sheepfold.$section.name" 2>/dev/null || true)"
                fi

                if [ -n "$section" ] && [ "$(uci -q get "sheepfold.$section.manual_device_type" 2>/dev/null || true)" = "1" ]; then
                        write_manual_device_observation "$mac" "$ip" "$name" "$sources" "$now"
                        continue
                fi

                static_name="$(static_name_for_mac "$mac" || true)"
                signal_file="$(signal_file_for_mac "$mac" || true)"
                stored_ports=""
                [ -z "$section" ] || stored_ports="$(uci -q get "sheepfold.$section.detection_ports" 2>/dev/null || true)"
                current_fingerprint="$(build_fingerprint "$mac" "$name" "$static_name" "$signal_file" "$stored_ports")"

                if [ -n "$section" ]; then
                        existing_confidence="$(uci -q get "sheepfold.$section.detection_confidence" 2>/dev/null || true)"
                        existing_type="$(uci -q get "sheepfold.$section.detected_type" 2>/dev/null || true)"
                        existing_fingerprint="$(uci -q get "sheepfold.$section.detection_fingerprint" 2>/dev/null || true)"
                        existing_policy="$(uci -q get "sheepfold.$section.detection_policy_version" 2>/dev/null || true)"
                        case "$existing_confidence" in ''|*[!0-9]*) existing_confidence=0 ;; esac

                        if [ -n "$existing_type" ] && [ "$existing_confidence" -ge "$min_confidence" ] && \
                           [ "$existing_fingerprint" = "$current_fingerprint" ] && [ "$existing_policy" = "$POLICY_VERSION" ]; then
                                write_locked_device_observation "$mac" "$ip" "$name" "$sources" "$now"
                                continue
                        fi
                fi

                ports="$stored_ports"
                if [ "$mode" = "full" ] && [ "$scanned" -lt "$max_hosts" ]; then
                        ports="$(scan_ports "$ip" "$mode" || true)"
                        scanned=$((scanned + 1))
                fi
                write_detection "$mac" "$ip" "$name" "$sources" "$ports" "$now"
        done

        printf '%s\n' "$now" > "$LAST_SCAN_FILE"
        chmod 600 "$LAST_SCAN_FILE" 2>/dev/null || true
        if [ -e "$DIRTY_FLAG" ]; then
                uci -q commit sheepfold
                rm -f "$DIRTY_FLAG"
        fi
}

case "$COMMAND" in
        scan|run|once)
                scan_devices
                ;;
        status)
                [ -r "$CACHE_FILE" ] && cat "$CACHE_FILE"
                ;;
        classify)
                exec "$CLASSIFIER" "${2:-}" "${3:-}" "${4:-}" "${5:-}" "${6:-}"
                ;;
        *)
                echo "Usage: sheepfold-device-detector [scan|status|classify <name> [ports] [static-name] [signal-file] [mac]]" >&2
                exit 1
                ;;
esac
