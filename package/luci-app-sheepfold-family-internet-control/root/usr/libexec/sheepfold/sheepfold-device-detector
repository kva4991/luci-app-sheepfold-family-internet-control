        local section mac name device_id had_quarantine
        section="$1"
        mac="$2"
        name="$3"
        had_quarantine="$(uci -q get "sheepfold.$section.identity_quarantine_mode" 2>/dev/null || true)"
        [ -n "$had_quarantine" ] || return 0

	for option in \
		identity_quarantine_mode \
		identity_quarantine_reason \
		identity_quarantine_at \
		identity_quarantine_keys \
		identity_quarantine_keys_version \
