#!/bin/sh
set -eu

HASH_COMMON="${SHEEPFOLD_HASH_COMMON:-${0%/*}/sheepfold-hash-common}"
[ -r "$HASH_COMMON" ] || HASH_COMMON=/usr/libexec/sheepfold/sheepfold-hash-common
. "$HASH_COMMON"
LOCK_COMMON="${SHEEPFOLD_LOCK_COMMON:-${0%/*}/sheepfold-lock-common}"
[ -r "$LOCK_COMMON" ] || LOCK_COMMON=/usr/libexec/sheepfold/sheepfold-lock-common
. "$LOCK_COMMON"

COMMAND="${1:-scan}"
CACHE_DIR="/tmp/sheepfold"
CACHE_FILE="$CACHE_DIR/device-detection.tsv"
RAW_FILE="$CACHE_DIR/device-detection.raw"
STATE_DIR="$CACHE_DIR/device-state"
SIGNAL_DIR="$CACHE_DIR/device-signals"
MDNS_FILE="$CACHE_DIR/device-mdns.tsv"
SSDP_FILE="$CACHE_DIR/device-ssdp.tsv"
WSD_FILE="$CACHE_DIR/device-ws-discovery.tsv"
WIFI_CAPABILITIES_FILE="$CACHE_DIR/device-wifi-capabilities.tsv"
UPNP_DESCRIPTION_DIR="$CACHE_DIR/device-upnp"
DIRTY_FLAG="$CACHE_DIR/device-detection.uci-dirty"
LAST_SCAN_FILE="$CACHE_DIR/device-detection.last-scan"
SCAN_LOCK="$CACHE_DIR/device-detection.flock"
NEW_DEVICE_ALERT_FLAG="$CACHE_DIR/new-device-alert"
LOG_HELPER="/usr/libexec/sheepfold/sheepfold-log"
ADMIN_NOTIFICATION="/usr/libexec/sheepfold/sheepfold-admin-notification"
CLASSIFIER="/usr/libexec/sheepfold/sheepfold-device-classifier"
MDNS_COLLECTOR="/usr/libexec/sheepfold/sheepfold-device-mdns"
SSDP_COLLECTOR="/usr/libexec/sheepfold/sheepfold-device-ssdp"
UPNP_DESCRIPTION_COLLECTOR="/usr/libexec/sheepfold/sheepfold-device-upnp-description"
WSD_COLLECTOR="/usr/libexec/sheepfold/sheepfold-device-ws-discovery"
IDENTITY_RECONCILER="/usr/libexec/sheepfold/sheepfold-device-identity"
PRESENCE="/usr/libexec/sheepfold/sheepfold-device-presence"
IDENTITY_SECRET_FILE="${SHEEPFOLD_IDENTITY_SECRET_FILE:-/etc/sheepfold/.device-identity-hmac}"
DEFAULT_SCAN_PORTS="22,53,80,81,443,445,548,554,631,1883,3000,3001,5000,5001,5353,8000,8006,8080,8081,8123,8554,9000,9100,32400"
POLICY_VERSION="10"
NEW_DEVICE_BADGE_SECONDS=86400
DEFAULT_GROUPS="/usr/libexec/sheepfold/sheepfold-default-groups"
DEVICE_ID_HELPER="/usr/libexec/sheepfold/sheepfold-device-id"

no_restrictions_group_name() {
	if [ -x /usr/libexec/sheepfold/sheepfold-default-groups ]; then
		/usr/libexec/sheepfold/sheepfold-default-groups name
		return 0
	fi
	uci -q get sheepfold.no_restrictions.name 2>/dev/null || printf 'Без ограничений'
}

personal_devices_group_name() {
	if [ -x /usr/libexec/sheepfold/sheepfold-default-groups ]; then
		/usr/libexec/sheepfold/sheepfold-default-groups personal-name
		return 0
	fi
	uci -q get sheepfold.personal_devices.name 2>/dev/null || printf 'Персональные устройства'
}

global_get() {
        local option_name default_value
        option_name="$1"
        default_value="$2"
        uci -q get "sheepfold.global.$option_name" 2>/dev/null || printf '%s' "$default_value"
}

identity_hash_secret() {
	local secret_dir tmp secret
	secret_dir="${IDENTITY_SECRET_FILE%/*}"
	if [ -r "$IDENTITY_SECRET_FILE" ]; then
		secret="$(sed -n '1p' "$IDENTITY_SECRET_FILE" 2>/dev/null || true)"
		case "$secret" in
			*[!0-9a-fA-F]*|'') ;;
			*) [ "${#secret}" -eq 64 ] && { printf '%s\n' "$secret"; return 0; } ;;
		esac
	fi

	# Детектор уже работает под общим lock, поэтому отдельный долгоживущий daemon
	# для генерации секрета не нужен. Файл создаётся атомарно и только один раз.
	mkdir -p "$secret_dir"
	chmod 700 "$secret_dir" 2>/dev/null || true
	tmp="$IDENTITY_SECRET_FILE.tmp.$$"
	umask 077
	if command -v openssl >/dev/null 2>&1; then
		openssl rand -hex 32 > "$tmp" 2>/dev/null || true
	elif command -v sha256sum >/dev/null 2>&1; then
		dd if=/dev/urandom bs=32 count=1 2>/dev/null | sha256sum | awk '{ print $1 }' > "$tmp"
	fi
	secret="$(sed -n '1p' "$tmp" 2>/dev/null || true)"
	case "$secret" in
		*[!0-9a-fA-F]*|'') rm -f "$tmp"; return 1 ;;
	esac
	[ "${#secret}" -eq 64 ] || { rm -f "$tmp"; return 1; }
	chmod 600 "$tmp" 2>/dev/null || true
	mv -f "$tmp" "$IDENTITY_SECRET_FILE"
	printf '%s\n' "$secret"
}

normalize_mac() {
        printf '%s' "$1" | tr 'a-z' 'A-Z'
}

valid_mac() {
        printf '%s' "$1" | grep -Eq '^([0-9A-F]{2}:){5}[0-9A-F]{2}$'
}

device_sections() {
	uci -q show sheepfold 2>/dev/null | sed -n 's/^sheepfold\.\([^.=]*\)=device$/\1/p'
}

log_event() {
        if [ -x "$LOG_HELPER" ]; then
                "$LOG_HELPER" "$*"
        else
                logger -t sheepfold "$*"
        fi
}

notify_admin() {
        local type dedupe_key title message
        type="$1"
        dedupe_key="$2"
        title="$3"
        message="$4"
        [ -x "$ADMIN_NOTIFICATION" ] || return 0
        "$ADMIN_NOTIFICATION" enqueue "$type" "$dedupe_key" "$title" "$message" >/dev/null 2>&1 || true
}

mark_dirty() {
        : > "$DIRTY_FLAG"
}

device_group_unassigned() {
        case "$1" in
                ""|"Не настроено"|"Not configured")
                        return 0
                        ;;
        esac
        return 1
}

ensure_default_groups() {
        [ -x "$DEFAULT_GROUPS" ] || return 0
        "$DEFAULT_GROUPS" apply >/dev/null 2>&1 || true
}

uci_set_if_changed() {
        local path value current
        path="$1"
        value="$2"
        current="$(uci -q get "$path" 2>/dev/null || true)"
        [ "$current" = "$value" ] && return 0
        uci -q set "$path=$value"
        mark_dirty
}

uci_delete_if_present() {
        local path
        path="$1"
        uci -q get "$path" >/dev/null 2>&1 || return 0
        uci -q delete "$path"
        mark_dirty
}

section_for_mac() {
        local wanted section current
        wanted="$(normalize_mac "$1")"
        for section in $(uci -q show sheepfold 2>/dev/null | sed -n "s/^sheepfold\.\([^.=]*\)=device$/\1/p"); do
                current="$(normalize_mac "$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)")"
                [ "$current" = "$wanted" ] && {
                        printf '%s\n' "$section"
                        return 0
                }
        done
        return 1
}

ensure_device_section() {
        local mac section
        mac="$(normalize_mac "$1")"
        if section="$(section_for_mac "$mac")"; then
                "$DEVICE_ID_HELPER" ensure "$section" >/dev/null
                printf '%s\n' "$section"
                return 0
        fi

        section="device_$(printf '%s' "$mac" | tr 'A-Z' 'a-z' | tr -d ':')"
        uci_set_if_changed "sheepfold.$section" device
        uci_set_if_changed "sheepfold.$section.mac" "$mac"
        uci_set_if_changed "sheepfold.$section.just_detected" 1
        uci_set_if_changed "sheepfold.$section.first_seen_at" "$(date +%s)"
        # Постоянный числовой ID выдаётся один раз и больше не зависит от сортировки таблицы.
        "$DEVICE_ID_HELPER" ensure "$section" >/dev/null
        date +%s > "$NEW_DEVICE_ALERT_FLAG"
        printf '%s\n' "$section"
}

mac_in_named_list() {
        local list_name wanted section mac
        list_name="$1"
        wanted="$(normalize_mac "$2")"

        for section in $(uci -q show sheepfold 2>/dev/null | sed -n "s/^sheepfold\.\([^.=]*\)=list$/\1/p"); do
                [ "$section" = "$list_name" ] || continue
                for mac in $(uci -q get "sheepfold.$section.mac" 2>/dev/null || true); do
                        [ "$(normalize_mac "$mac")" = "$wanted" ] && return 0
                done
                for mac in $(uci -q get "sheepfold.$section.macs" 2>/dev/null || true); do
                        [ "$(normalize_mac "$mac")" = "$wanted" ] && return 0
                done
        done

        return 1
}

device_is_blocklisted() {
        local section mac status
        section="$1"
        mac="$2"
        mac_in_named_list blocklist "$mac" && return 0
        [ -n "$section" ] || return 1
        status="$(uci -q get "sheepfold.$section.status" 2>/dev/null || true)"
        case "$status" in blocked|block) return 0 ;; esac
        return 1
}

sources_confirm_online() {
        case ",${1:-}," in
                *,arp,*|*,neighbor,*|*,wifi,*|*,dhcp_event,*) return 0 ;;
        esac
        return 1
}

signal_file_for_mac() {
	local mac
	mac="$(normalize_mac "$1")"
	valid_mac "$mac" || return 1
	printf '%s/%s.dhcp\n' "$SIGNAL_DIR" "$(printf '%s' "$mac" | tr ':' '_')"
}

ensure_dhcp_signal_file() {
	local mac ip observed_name signal_file lease_record lease_name client_id tmp
	mac="$(normalize_mac "$1")"
	ip="$2"
	observed_name="$3"
	signal_file="$(signal_file_for_mac "$mac" || true)"
	[ -n "$signal_file" ] || return 1
	[ -r "$signal_file" ] && { printf '%s\n' "$signal_file"; return 0; }
	[ -r /tmp/dhcp.leases ] || { printf '%s\n' "$signal_file"; return 0; }

	# Не все сборки dnsmasq передают Option 55/60 в hotplug. Минимальный fallback
	# сохраняет только уже имеющиеся в RAM lease-поля и не подменяет богатый снимок,
	# который мог создать штатный DHCP hotplug. §devpas1
	lease_record="$(awk -v wanted="$mac" 'toupper($2) == wanted { print $4 "\t" $5; exit }' /tmp/dhcp.leases 2>/dev/null || true)"
	[ -n "$lease_record" ] || { printf '%s\n' "$signal_file"; return 0; }
	lease_name="${lease_record%%	*}"
	client_id="${lease_record#*	}"
	[ "$client_id" != "$lease_record" ] || client_id=""
	[ "$lease_name" != "*" ] || lease_name=""
	[ -n "$lease_name" ] || lease_name="$observed_name"
	case "$lease_name" in '*') lease_name="" ;; esac
	case "$client_id" in '*') client_id="" ;; esac

	tmp="$signal_file.tmp.$$"
	umask 077
	{
		printf 'observed_at\t%s\n' "$(date +%s)"
		printf 'action\tlease_snapshot\n'
		printf 'mac\t%s\n' "$mac"
		printf 'ip\t%s\n' "$ip"
		printf 'hostname\t%s\n' "$(printf '%s' "$lease_name" | tr '\r\n\t' '   ' | cut -c1-255)"
		printf 'client_id\t%s\n' "$(printf '%s' "$client_id" | tr '\r\n\t' '   ' | cut -c1-255)"
	} > "$tmp" || { rm -f "$tmp"; printf '%s\n' "$signal_file"; return 0; }
	chmod 600 "$tmp" 2>/dev/null || true
	mv -f "$tmp" "$signal_file"
	printf '%s\n' "$signal_file"
}

static_name_for_mac() {
        wanted="$(normalize_mac "$1")"

        for section in $(uci -q show dhcp 2>/dev/null | sed -n "s/^dhcp\.\([^.=]*\)=host$/\1/p"); do
                for configured_mac in $(uci -q get "dhcp.$section.mac" 2>/dev/null || true); do
                        [ "$(normalize_mac "$configured_mac")" = "$wanted" ] || continue
                        uci -q get "dhcp.$section.name" 2>/dev/null || \
                                uci -q get "dhcp.$section.hostname" 2>/dev/null || true
                        return 0
                done
        done
}

fingerprint_signal_material() {
        signal_file="$1"
        [ -r "$signal_file" ] || return 0
        awk -F '\t' '
                $1 == "hostname" ||
                $1 == "supplied_hostname" ||
                $1 == "vendor_class" ||
                $1 == "requested_options" ||
                $1 == "user_class" ||
                $1 == "client_id" ||
                $1 == "mud_url" ||
                $1 == "interface" { print }
        ' "$signal_file" 2>/dev/null | sort
}

mdns_services_for_ip() {
        local ip
        ip="$1"
        [ -n "$ip" ] || return 0
        [ -r "$MDNS_FILE" ] || return 0
        awk -F '\t' -v wanted="$ip" '
                $1 == wanted && !seen[$2]++ {
                        output = output (output == "" ? "" : ",") $2
                }
                END { print output }
        ' "$MDNS_FILE"
}

mdns_profile_for_ip() {
        local ip
        ip="$1"
        [ -n "$ip" ] || return 0
        [ -r "$MDNS_FILE" ] || return 0
	awk -F '\t' -v wanted="$ip" '
		$1 == wanted {
			# UUID, serial и device-id участвуют в сопоставлении только как хеши.
			# В читаемом UCI-профиле оставляем лишь диагностические TXT-поля.
			public_txt = ""
			part_count = split($6, parts, ",")
			for (part = 1; part <= part_count; part++) {
				separator = index(parts[part], "=")
				key = tolower(substr(parts[part], 1, separator - 1))
				if (separator > 1 && key !~ /^(serial|serialnumber|device-id|deviceid|uuid|id)$/)
					public_txt = public_txt (public_txt == "" ? "" : ",") parts[part]
			}
			record = $2 "|" $3 "|" $4 "|" $5 "|" public_txt
                        if (!seen[record]++ && count < 8) {
                                output = output (output == "" ? "" : ";") record
                                count++
                        }
                }
                END { print substr(output, 1, 1024) }
        ' "$MDNS_FILE"
}

ssdp_profile_for_ip() {
        local ip base description
        ip="$1"
        [ -n "$ip" ] || return 0
        [ -r "$SSDP_FILE" ] || return 0
	base="$(awk -F '\t' -v wanted="$ip" '
		$1 == wanted {
			# USN и LOCATION могут содержать устойчивый ID. Для UI и классификатора
			# достаточно типа сервиса и строки SERVER; сырой ответ остаётся в RAM.
			record = $2 "||" $4 "|"
                        if (!seen[record]++ && count < 8) {
                                output = output (output == "" ? "" : ";") record
                                count++
                        }
                }
                END { print substr(output, 1, 1024) }
        ' "$SSDP_FILE")"
	description="$(upnp_description_profile_for_ip "$ip" || true)"
	if [ -n "$base" ] && [ -n "$description" ]; then
		printf '%s;%s\n' "$base" "$description"
	else
		printf '%s%s\n' "$base" "$description"
	fi
}

ssdp_location_for_ip() {
	local ip
	ip="$1"
	[ -r "$SSDP_FILE" ] || return 0
	awk -F '\t' -v wanted="$ip" '$1 == wanted && $5 != "" { print $5; exit }' "$SSDP_FILE"
}

upnp_description_file_for_ip() {
	local ip
	ip="$1"
	printf '%s/%s.tsv\n' "$UPNP_DESCRIPTION_DIR" "$(printf '%s' "$ip" | tr '.' '_')"
}

upnp_description_profile_for_ip() {
	local ip location location_hash file
	ip="$1"
	location="$(ssdp_location_for_ip "$ip" || true)"
	[ -n "$location" ] || return 0
	location_hash="$(sheepfold_state_hash_text "$location")"
	file="$(upnp_description_file_for_ip "$ip")"
	[ -r "$file" ] || return 0
	awk -F '\t' -v wanted_ip="$ip" -v wanted_hash="$location_hash" '
		$1 == wanted_ip && $2 == wanted_hash {
			# serialNumber и UDN предназначены только для HMAC identity-компонентов.
			# В читаемый профиль попадают модель и производитель без LOCATION. §devident1
			print substr("upnp-description|" $4 "|" $5 "|" $6 "|" $7 "|" $8 "|" $9, 1, 1024)
			exit
		}
	' "$file"
}

wsd_profile_for_ip() {
	local ip
	ip="$1"
	[ -n "$ip" ] || return 0
	[ -r "$WSD_FILE" ] || return 0
	awk -F '\t' -v wanted="$ip" '
		$1 == wanted {
			# Endpoint UUID и XAddrs не нужны пользовательскому профилю и не
			# должны становиться URL для последующих запросов.
			record = $3 "|" $4
			if (!seen[record]++ && count < 8) {
				output = output (output == "" ? "" : ";") record
				count++
			}
		}
		END { print substr(output, 1, 1024) }
	' "$WSD_FILE"
}

signal_value_from_file() {
        local signal_file key
        signal_file="$1"
        key="$2"
        [ -r "$signal_file" ] || return 0
        awk -F '\t' -v wanted="$key" '$1 == wanted { print $2; exit }' "$signal_file" 2>/dev/null || true
}

normalize_identity_value() {
        printf '%s' "$1" |
                tr 'A-Z' 'a-z' |
                tr '\r\n\t' '   ' |
                sed 's/[[:cntrl:]]//g; s/[[:space:]][[:space:]]*/ /g; s/^ //; s/ $//' |
                cut -c1-256
}

emit_identity_key() {
	local family value digest
	family="$1"
	value="$(normalize_identity_value "$2")"
	[ -n "$value" ] || return 0
	if [ "${IDENTITY_HASH_MODE:-secure}" = legacy ]; then
		digest="$(printf '%s=%s\n' "$family" "$value" | sheepfold_state_hash_stdin | cut -c1-32)"
		[ "${#digest}" -eq 32 ] || return 0
	else
		[ -n "${IDENTITY_HASH_SECRET:-}" ] || return 0
		digest="$(sheepfold_hmac_sha256_text "$IDENTITY_HASH_SECRET" "$family=$value" | cut -c1-40)"
		[ "${#digest}" -eq 40 ] || return 0
	fi
	printf '%s:%s\n' "$family" "$digest"
}

mdns_identity_material_for_ip() {
        local ip
        ip="$1"
        [ -n "$ip" ] || return 0
        [ -r "$MDNS_FILE" ] || return 0
        awk -F '\t' -v wanted="$ip" '
                $1 == wanted {
                        host = tolower($3)
                        if (host != "")
                                print "mdns_host\t" host
                        count = split($6, txt, ",")
                        for (i = 1; i <= count; i++) {
                                separator = index(txt[i], "=")
                                if (separator <= 0)
                                        continue
                                key = tolower(substr(txt[i], 1, separator - 1))
                                value = substr(txt[i], separator + 1)
                                if (key ~ /^(serial|serialnumber|device-id|deviceid|uuid)$/ && length(value) >= 6)
                                        print "mdns_serial\t" value
                        }
                }
        ' "$MDNS_FILE"
}

ssdp_identity_material_for_ip() {
        local ip
        ip="$1"
        [ -n "$ip" ] || return 0
        [ -r "$SSDP_FILE" ] || return 0
        awk -F '\t' -v wanted="$ip" '
                $1 == wanted {
                        value = tolower($3)
                        start = index(value, "uuid:")
                        if (!start)
                                next
                        value = substr(value, start + 5)
                        sub(/::.*/, "", value)
			if (length(value) >= 8 && value ~ /^[a-z0-9._-]+$/) {
                                print "upnp_uuid\t" value
				print "device_uuid\t" value
			}
                }
        ' "$SSDP_FILE"
}

upnp_description_identity_material_for_ip() {
	local ip location location_hash file
	ip="$1"
	location="$(ssdp_location_for_ip "$ip" || true)"
	[ -n "$location" ] || return 0
	location_hash="$(sheepfold_state_hash_text "$location")"
	file="$(upnp_description_file_for_ip "$ip")"
	[ -r "$file" ] || return 0
	awk -F '\t' -v wanted_ip="$ip" -v wanted_hash="$location_hash" '
		$1 == wanted_ip && $2 == wanted_hash {
			if (length($10) >= 6)
				print "upnp_serial\t" $10
			value = tolower($11)
			start = index(value, "uuid:")
			if (start) {
				value = substr(value, start + 5)
				sub(/::.*/, "", value)
				if (length(value) >= 8 && value ~ /^[a-z0-9._-]+$/) {
					print "upnp_uuid\t" value
					print "device_uuid\t" value
				}
			}
		}
	' "$file"
}

wsd_identity_material_for_ip() {
	local ip
	ip="$1"
	[ -n "$ip" ] || return 0
	[ -r "$WSD_FILE" ] || return 0
	awk -F '\t' -v wanted="$ip" '
		$1 == wanted && length($2) >= 8 && tolower($2) ~ /^[a-z0-9._:-]+$/ {
			print "wsd_uuid\t" tolower($2)
			print "device_uuid\t" tolower($2)
		}
	' "$WSD_FILE"
}

build_identity_keys() {
	local mac signal_file ip client_id client_compact mac_compact mode
	mac="$1"
	signal_file="$2"
	ip="$3"
	mode="${4:-secure}"
	IDENTITY_HASH_MODE="$mode"
	IDENTITY_HASH_SECRET=""
	if [ "$mode" != legacy ]; then
		IDENTITY_HASH_SECRET="$(identity_hash_secret 2>/dev/null || true)"
		[ -n "$IDENTITY_HASH_SECRET" ] || return 0
	fi
        client_id="$(signal_value_from_file "$signal_file" client_id)"
        client_compact="$(printf '%s' "$client_id" | tr -cd 'A-Za-z0-9' | tr 'A-Z' 'a-z')"
        mac_compact="$(printf '%s' "$mac" | tr -d ':' | tr 'A-Z' 'a-z')"

        {
                # DHCP client-id, равный самому MAC или 01+MAC, не является вторым
                # независимым идентификатором и не должен облегчать подмену. §devident1
                case "$client_compact" in
                        ""|"$mac_compact"|"01$mac_compact") ;;
                        *) emit_identity_key dhcp_client "$client_id" ;;
                esac
                mdns_identity_material_for_ip "$ip" |
                        while IFS="$(printf '\t')" read -r family value; do
                                emit_identity_key "$family" "$value"
                        done
		ssdp_identity_material_for_ip "$ip" |
			while IFS="$(printf '\t')" read -r family value; do
				emit_identity_key "$family" "$value"
			done
		upnp_description_identity_material_for_ip "$ip" |
			while IFS="$(printf '\t')" read -r family value; do
				emit_identity_key "$family" "$value"
			done
		wsd_identity_material_for_ip "$ip" |
			while IFS="$(printf '\t')" read -r family value; do
				emit_identity_key "$family" "$value"
			done
        } | sort -u | awk 'NF && count < 16 { output = output (output == "" ? "" : " ") $0; count++ } END { print output }'
}

build_fingerprint() {
        local mac name static_name signal_file ports mdns_services mdns_profile ssdp_profile wsd_profile identity_keys wifi_profile
        mac="$1"
        name="$2"
        static_name="$3"
        signal_file="$4"
        ports="$5"
        mdns_services="$6"
        mdns_profile="${7:-}"
        ssdp_profile="${8:-}"
        wsd_profile="${9:-}"
        identity_keys="${10:-}"
        wifi_profile="${11:-}"
        {
                printf 'policy=%s\n' "$POLICY_VERSION"
                printf 'mac=%s\n' "$(normalize_mac "$mac")"
                printf 'name=%s\n' "$name"
                printf 'static_name=%s\n' "$static_name"
                printf 'ports=%s\n' "$ports"
                printf 'mdns=%s\n' "$mdns_services"
                printf 'mdns_profile=%s\n' "$mdns_profile"
                printf 'ssdp_profile=%s\n' "$ssdp_profile"
		printf 'wsd_profile=%s\n' "$wsd_profile"
                printf 'identity_keys=%s\n' "$identity_keys"
                # Это классификационный fingerprint, а не доверенный HMAC-паспорт.
                # В него входит только монотонный класс Wi-Fi, без BSSID и текущей скорости.
                printf 'wifi_profile=%s\n' "$wifi_profile"
                fingerprint_signal_material "$signal_file"
	} | sheepfold_state_hash_stdin
}

collect_wifi_capabilities() {
        local tmp
        tmp="$WIFI_CAPABILITIES_FILE.tmp.$$"
        : > "$tmp"
        if [ -x "$PRESENCE" ]; then
                "$PRESENCE" wifi-capabilities 2>/dev/null | awk -F '\t' '
                        $1 ~ /^([0-9A-F][0-9A-F]:){5}[0-9A-F][0-9A-F]$/ &&
                        $2 ~ /^(legacy|ht|vht|he)$/ && $3 ~ /^[0-9]+$/ && $4 ~ /^[0-9]+$/ {
                                print $1 "\t" $2 "\t" $3 "\t" $4
                        }' > "$tmp" || true
        fi
        chmod 600 "$tmp" 2>/dev/null || true
        mv -f "$tmp" "$WIFI_CAPABILITIES_FILE"
}

wifi_generation_rank() {
        case "$1" in
                he) printf '4\n' ;; vht) printf '3\n' ;; ht) printf '2\n' ;;
                legacy) printf '1\n' ;; *) printf '0\n' ;;
        esac
}

wifi_speed_rank() {
        case "$1" in
                very_fast) printf '4\n' ;; fast) printf '3\n' ;; medium) printf '2\n' ;;
                slow) printf '1\n' ;; *) printf '0\n' ;;
        esac
}

wifi_speed_class() {
        local rate
        rate="${1:-0}"
        case "$rate" in ''|*[!0-9]*) rate=0 ;; esac
        if [ "$rate" -ge 600000 ]; then
                printf 'very_fast\n'
        elif [ "$rate" -ge 200000 ]; then
                printf 'fast\n'
        elif [ "$rate" -ge 72000 ]; then
                printf 'medium\n'
        else
                printf 'slow\n'
        fi
}

wifi_profile_for_device() {
        local section mac record current_generation current_rx current_tx rest
        local stored_generation stored_speed current_max current_speed merged_generation merged_speed
        section="$1"
        mac="$(normalize_mac "$2")"
        record="$(awk -F '\t' -v wanted="$mac" 'toupper($1) == wanted { print $2 "|" $3 "|" $4; exit }' "$WIFI_CAPABILITIES_FILE" 2>/dev/null || true)"
        current_generation="${record%%|*}"
        rest="${record#*|}"
        [ "$rest" != "$record" ] || rest='0|0'
        current_rx="${rest%%|*}"
        current_tx="${rest#*|}"
        case "$current_rx" in ''|*[!0-9]*) current_rx=0 ;; esac
        case "$current_tx" in ''|*[!0-9]*) current_tx=0 ;; esac
        case "$current_generation" in legacy|ht|vht|he) ;; *) current_generation='' ;; esac

        stored_generation="$(uci -q get "sheepfold.$section.detection_wifi_generation" 2>/dev/null || true)"
        stored_speed="$(uci -q get "sheepfold.$section.detection_wifi_speed_class" 2>/dev/null || true)"
        case "$stored_generation" in legacy|ht|vht|he) ;; *) stored_generation='' ;; esac
        case "$stored_speed" in slow|medium|fast|very_fast) ;; *) stored_speed='' ;; esac
        current_max="$current_rx"
        [ "$current_tx" -le "$current_max" ] || current_max="$current_tx"
        current_speed="$(wifi_speed_class "$current_max")"
        merged_speed="$stored_speed"
        if [ "$(wifi_speed_rank "$current_speed")" -gt "$(wifi_speed_rank "$stored_speed")" ]; then
                merged_speed="$current_speed"
        fi
        merged_generation="$stored_generation"
        if [ "$(wifi_generation_rank "$current_generation")" -gt "$(wifi_generation_rank "$stored_generation")" ]; then
                merged_generation="$current_generation"
        fi

        [ -n "$merged_generation" ] || { printf '||\n'; return 0; }
        [ -n "$merged_speed" ] || merged_speed=slow
        # Текущие скорости остаются в /tmp: во flash сохраняются только два коротких
        # класса, достаточных для слабой подсказки классификатору. §detlife1
        printf 'generation=%s,speed=%s|%s|%s\n' \
                "$merged_generation" "$merged_speed" "$merged_generation" "$merged_speed"
}

write_runtime_observation() {
        local mac ip name sources now file tmp
        mac="$1"
        ip="$2"
        name="$3"
        sources="$4"
        now="$5"
        mkdir -p "$STATE_DIR"
        chmod 700 "$STATE_DIR" 2>/dev/null || true
        file="$STATE_DIR/$(printf '%s' "$mac" | tr ':' '_').tsv"
        tmp="$file.tmp.$$"
        umask 077
        {
                printf 'last_seen\t%s\n' "$now"
                printf 'ip\t%s\n' "$ip"
                printf 'name\t%s\n' "$name"
                printf 'sources\t%s\n' "$sources"
        } > "$tmp"
        chmod 600 "$tmp" 2>/dev/null || true
        mv -f "$tmp" "$file"
}

