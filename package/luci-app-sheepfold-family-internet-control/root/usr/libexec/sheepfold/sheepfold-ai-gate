#!/bin/sh
set -eu

RATE_DIR="/tmp/sheepfold/ai-rate"
mkdir -p "$RATE_DIR"
chmod 700 "$RATE_DIR" 2>/dev/null || true

json_escape() {
    printf '%s' "$1" | tr '\n\r\t' '   ' | sed 's/\\/\\\\/g; s/"/\\"/g'
}

header_json() {
    printf 'Status: %s\r\n' "$1"
    printf 'Content-Type: application/json; charset=utf-8\r\n'
    printf 'Cache-Control: no-store\r\n'
    [ -z "${2:-}" ] || printf 'Retry-After: %s\r\n' "$2"
    printf '\r\n'
}

reject() {
    header_json "$1" "${4:-}"
    printf '{"app":"sheepfold","ok":false,"error":"%s","message":"%s"}\n' \
        "$(json_escape "$2")" "$(json_escape "$3")"
    exit 1
}

url_decode() {
    value="$(printf '%s' "$1" | sed 's/+/ /g; s/%/\\x/g')"
    printf '%b' "$value"
}

form_get() {
    key="$1"
    body="$2"
    printf '%s' "$body" | tr '&' '\n' | while IFS='=' read -r item_key item_value; do
        [ "$item_key" = "$key" ] || continue
        url_decode "$item_value"
        break
    done
}

normalize_mac() { printf '%s' "$1" | tr '[:lower:]' '[:upper:]'; }
valid_mac() { printf '%s' "$1" | grep -Eq '^([0-9A-F]{2}:){5}[0-9A-F]{2}$'; }

mac_for_ip() {
    ip="$1"
    mac=""
    [ ! -r /tmp/dhcp.leases ] || mac="$(awk -v ip="$ip" '$3 == ip { print toupper($2); exit }' /tmp/dhcp.leases)"
    [ -n "$mac" ] || [ ! -r /proc/net/arp ] || mac="$(awk -v ip="$ip" '$1 == ip { print toupper($4); exit }' /proc/net/arp)"
    normalize_mac "$mac"
}

device_section_for_mac() {
    wanted="$(normalize_mac "$1")"
    for section in $(uci -q show sheepfold 2>/dev/null | sed -n 's/^sheepfold\.\([^.=]*\)=device$/\1/p'); do
        existing="$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)"
        [ "$(normalize_mac "$existing")" = "$wanted" ] || continue
        printf '%s\n' "$section"
        return 0
    done
    return 1
}

list_has_mac() {
    wanted="$(normalize_mac "$2")"
    for existing in $(uci -q get "sheepfold.$1.mac" 2>/dev/null || true); do
        [ "$(normalize_mac "$existing")" = "$wanted" ] && return 0
    done
    return 1
}

personal_group_for_device() {
    section="$1"
    mac="$(normalize_mac "$2")"
    device_group="$(uci -q get "sheepfold.$section.group" 2>/dev/null || true)"

    # Детский AI открывается только для устройства, которое родитель явно
    # связал с личной группой. Поддерживаем новую personal_group-модель и
    # текущие group-секции с option personal=1, чтобы миграция была мягкой.
    for group_section in $(uci -q show sheepfold 2>/dev/null | sed -n 's/^sheepfold\.\([^.=]*\)=personal_group$/\1/p'); do
        for existing in $(uci -q get "sheepfold.$group_section.deviceMac" 2>/dev/null || true); do
            [ "$(normalize_mac "$existing")" = "$mac" ] || continue
            uci -q get "sheepfold.$group_section.displayName" 2>/dev/null || \
                uci -q get "sheepfold.$group_section.name" 2>/dev/null || \
                printf '%s' "$group_section"
            return 0
        done
    done

    [ -n "$device_group" ] || return 1
    for group_section in $(uci -q show sheepfold 2>/dev/null | sed -n 's/^sheepfold\.\([^.=]*\)=group$/\1/p'); do
        [ "$(uci -q get "sheepfold.$group_section.personal" 2>/dev/null || printf 0)" = 1 ] || continue
        group_name="$(uci -q get "sheepfold.$group_section.name" 2>/dev/null || printf '%s' "$group_section")"
        [ "$device_group" = "$group_section" ] || [ "$device_group" = "$group_name" ] || continue
        printf '%s' "$group_name"
        return 0
    done

    return 1
}

is_admin_request() {
    device_id="$1"
    mac="$2"
    bearer=""
    case "${HTTP_AUTHORIZATION:-}" in [Bb]earer\ *) bearer="${HTTP_AUTHORIZATION#* }" ;; esac
    [ -n "$bearer" ] || return 1
    [ "$(/usr/libexec/sheepfold/sheepfold-router-control check-token "$bearer" "$device_id" "$mac" 2>/dev/null || printf fail)" = ok ]
}

consume_quota() {
    identity="$1"
    limit="$(uci -q get sheepfold.global.ai_rate_limit_requests 2>/dev/null || printf 20)"
    window="$(uci -q get sheepfold.global.ai_rate_limit_window_seconds 2>/dev/null || printf 3600)"
    case "$limit" in ''|*[!0-9]*) limit=20 ;; esac
    case "$window" in ''|*[!0-9]*) window=3600 ;; esac
    [ "$limit" -ge 1 ] || limit=1
    [ "$limit" -le 1000 ] || limit=1000
    [ "$window" -ge 60 ] || window=60
    [ "$window" -le 86400 ] || window=86400

    id="$(printf '%s' "$identity" | tr -cd 'A-Za-z0-9_.-')"
    [ -n "$id" ] || id=unknown
    file="$RATE_DIR/$id"
    lock="$file.lock"
    tries=0
    while ! mkdir "$lock" 2>/dev/null; do
        tries=$((tries + 1))
        [ "$tries" -lt 10 ] || return 1
        sleep 1
    done

    now="$(date +%s)"
    started="$now"
    count=0
    [ ! -r "$file" ] || read -r started count < "$file" || true
    case "$started" in ''|*[!0-9]*) started="$now" ;; esac
    case "$count" in ''|*[!0-9]*) count=0 ;; esac
    if [ "$now" -lt "$started" ] || [ $((now - started)) -ge "$window" ]; then
        started="$now"
        count=0
    fi
    if [ "$count" -ge "$limit" ]; then
        retry_after=$((window - (now - started)))
        [ "$retry_after" -gt 0 ] || retry_after=60
        rmdir "$lock" 2>/dev/null || true
        return 1
    fi
    count=$((count + 1))
    printf '%s %s\n' "$started" "$count" > "$file"
    chmod 600 "$file" 2>/dev/null || true
    rmdir "$lock" 2>/dev/null || true
    return 0
}

body="$(cat)"
[ ${#body} -le 16384 ] || reject "413 Payload Too Large" request_too_large "AI request is too large."
[ "$(uci -q get sheepfold.global.ai_enabled 2>/dev/null || printf 0)" = 1 ] || \
    reject "503 Service Unavailable" ai_disabled "AI assistant is disabled on the router."

requested_device_id="$(form_get deviceId "$body")"
requested_role="$(form_get clientRole "$body")"
requested_admin="$(form_get isAdministrator "$body")"
consent_version="$(form_get consentVersion "$body")"
[ -n "$requested_device_id" ] || reject "400 Bad Request" device_id_required "Device id is required."
[ -n "$requested_role" ] || reject "400 Bad Request" client_role_required "Client role is required."

remote_ip="${REMOTE_ADDR:-}"
mac="$(mac_for_ip "$remote_ip")"
valid_mac "$mac" || reject "403 Forbidden" device_not_resolved "The router could not identify this LAN device."

admin_request=0
if is_admin_request "$requested_device_id" "$mac"; then
    admin_request=1
fi
list_has_mac blocklist "$mac" && reject "403 Forbidden" device_blocklisted "Blocked devices cannot use the AI assistant."
device_section="$(device_section_for_mac "$mac" 2>/dev/null || true)"
[ -n "$device_section" ] || reject "403 Forbidden" device_not_registered "This device is not registered in Sheepfold."
server_device_id="$(uci -q get "sheepfold.$device_section.id" 2>/dev/null || printf '%s' "$device_section")"
server_admin="$(uci -q get "sheepfold.$device_section.admin_device" 2>/dev/null || printf 0)"

if [ "$requested_device_id" != "$server_device_id" ]; then
    reject "403 Forbidden" device_identity_mismatch "Device id does not match the LAN device."
fi

if [ "$admin_request" = 1 ]; then
    [ "$server_admin" = 1 ] || reject "403 Forbidden" administrator_device_required "Administrator token must be used from its paired device."
    case "$requested_role" in parent|administrator) ;;
        *) reject "403 Forbidden" client_role_mismatch "Administrator request must use the parent role." ;;
    esac
    [ "$requested_admin" = 1 ] || reject "403 Forbidden" administrator_flag_mismatch "Administrator flag does not match the verified device."
else
    [ "${HTTP_X_SHEEPFOLD_CLIENT:-}" = "android-child-v1" ] || \
        reject "403 Forbidden" client_header_required "A Sheepfold child client marker is required."
    [ "$server_admin" != 1 ] || reject "403 Forbidden" client_role_mismatch "Administrator devices must use an administrator token."
    [ "$requested_role" = child ] || reject "403 Forbidden" client_role_mismatch "Child device must use the child role."
    [ "$requested_admin" = 0 ] || reject "403 Forbidden" administrator_flag_mismatch "Administrator flag does not match the verified device."
    [ "$consent_version" = child-ai-v1 ] || reject "403 Forbidden" parental_consent_version_required "The current parental consent version is required."
    [ "$(uci -q get sheepfold.global.child_ai_parental_consent 2>/dev/null || printf 0)" = 1 ] || \
        reject "403 Forbidden" parental_consent_required "A parent must enable child AI access in Sheepfold settings."
    personal_group_for_device "$device_section" "$mac" >/dev/null || \
        reject "403 Forbidden" personal_group_required "Ask a parent to put this device into your personal group in Sheepfold settings."
fi

consume_quota "$server_device_id" || reject "429 Too Many Requests" rate_limited "AI request limit reached for this device." "${retry_after:-3600}"

include_info="$(form_get includeInfo "$body")"
include_logs="$(form_get includeLogs "$body")"
google_account="$(form_get googleAccount "$body")"
provider="$(form_get provider "$body")"
model="$(form_get model "$body")"

if [ "$include_info" = 1 ] || [ "$include_logs" = 1 ] || [ -n "$google_account" ] || [ -n "$provider" ] || [ -n "$model" ]; then
    [ "$admin_request" = 1 ] || reject "403 Forbidden" privileged_context_forbidden "Diagnostics, logs, account data, and provider overrides require an administrator token."
fi

if [ "$include_logs" = 1 ] && [ "$(uci -q get sheepfold.global.ai_individual_logs 2>/dev/null || printf 0)" != 1 ]; then
    reject "403 Forbidden" individual_logs_disabled "Individual AI log context is disabled."
fi

exit 0
