#!/bin/sh
set -u

COMMAND="${1:-run}"
RUNTIME_DIR="/tmp/sheepfold"
OFFSET_FILE="$RUNTIME_DIR/telegram-update-offset"
LOG_LINE_FILE="$RUNTIME_DIR/telegram-log-line"
LOG_HELPER="/usr/libexec/sheepfold/sheepfold-log"
ROUTER_CONTROL="/usr/libexec/sheepfold/sheepfold-router-control"
UPDATER="/usr/libexec/sheepfold/sheepfold-updater"
DEFAULT_RAM_LOG="/tmp/sheepfold/events.log"

mkdir -p "$RUNTIME_DIR"

log() {
        logger -t sheepfold-telegram "$*"
}

log_event() {
        if [ -x "$LOG_HELPER" ]; then
                "$LOG_HELPER" "$*"
        else
                log "$*"
        fi
}

global_get() {
        uci -q get "sheepfold.global.$1" 2>/dev/null || printf '%s' "$2"
}

router_name() {
        uci -q get system.@system[0].hostname 2>/dev/null || printf 'OpenWRT'
}

log_cache_path() {
        path="$(global_get log_cache_path "$DEFAULT_RAM_LOG")"
        case "$path" in
                /tmp/sheepfold/*) printf '%s\n' "$path" ;;
                *) printf '%s\n' "$DEFAULT_RAM_LOG" ;;
        esac
}

telegram_active() {
        [ "$(global_get active_messenger none)" = "telegram" ]
}

telegram_token() {
        global_get telegram_bot_token ''
}

telegram_admin_chat_id() {
        global_get telegram_admin_chat_id ''
}

fetch() {
        url="$1"
        data="${2:-}"

        if [ -n "$data" ]; then
                uclient-fetch -qO- --post-data="$data" "$url" 2>/dev/null || true
        else
                uclient-fetch -qO- "$url" 2>/dev/null || true
        fi
}

form_escape() {
        sed ':a;N;$!ba;s/%/%25/g;s/&/%26/g;s/+/%2B/g;s/#/%23/g;s/=/%3D/g;s/ /%20/g;s/"/%22/g;s/{/%7B/g;s/}/%7D/g;s/\[/%5B/g;s/\]/%5D/g;s/:/%3A/g;s/,/%2C/g;s/\r//g;s/\n/%0A/g'
}

