                        ;;
                blocklist_add)
                        send_message_to "$chat_id" "$(set_device_status_by_query "#$action_arg1" blocked "–і–Њ–±–∞–≤–Є–ї —Г—Б—В—А–Њ–є—Б—В–≤–Њ –≤ —З—С—А–љ—Л–є —Б–њ–Є—Б–Њ–Ї")"
                        ;;
                *)
                        send_message_to "$chat_id" "–Э–µ–Є–Ј–≤–µ—Б—В–љ–Њ–µ –њ–Њ–і—В–≤–µ—А–ґ–і–∞–µ–Љ–Њ–µ –і–µ–є—Б—В–≤–Є–µ."
                        return 1
                        ;;
        esac
}

handle_confirmation() {
        chat_id="$1"
        text="$2"
        file="$(confirmation_file "$chat_id")" || return 1
        code="$(printf '%s' "$text" | sed -n 's/^\(–њ–Њ–і—В–≤–µ—А–ґ–і–∞—О\|–Я–Њ–і—В–≤–µ—А–ґ–і–∞—О\|confirm\|Confirm\)[[:space:]]\+\([0-9][0-9][0-9][0-9][0-9][0-9]\)$/\2/p')"

        [ -n "$code" ] || return 1
        [ -r "$file" ] || {
                send_message_to "$chat_id" "–Э–µ—В –Ї–Њ–Љ–∞–љ–і—Л, –Њ–ґ–Є–і–∞—О—Й–µ–є –њ–Њ–і—В–≤–µ—А–ґ–і–µ–љ–Є—П."
                return 0
        }

        IFS="$(printf '\t')" read -r action action_arg1 action_arg2 expected expires < "$file" || true
        now="$(date +%s)"
        rm -f "$file"

        if [ "$now" -gt "${expires:-0}" ]; then
                send_message_to "$chat_id" "–Ъ–Њ–і –њ–Њ–і—В–≤–µ—А–ґ–і–µ–љ–Є—П —Г—Б—В–∞—А–µ–ї. –Я–Њ–≤—В–Њ—А–Є—В–µ –Ї–Њ–Љ–∞–љ–і—Г –Ј–∞–љ–Њ–≤–Њ."
                return 0
        fi

        if [ "$code" != "$expected" ]; then
                send_message_to "$chat_id" "–Ъ–Њ–і –њ–Њ–і—В–≤–µ—А–ґ–і–µ–љ–Є—П –љ–µ —Б–Њ–≤–њ–∞–ї. –Ъ–Њ–Љ–∞–љ–і–∞ –Њ—В–Љ–µ–љ–µ–љ–∞."
                return 0
        fi

        run_confirmed_action "$chat_id" "$action" "$action_arg1" "$action_arg2"
        return 0
}

request_device_confirmation() {
        chat_id="$1"
        action="$2"
        query="$3"
        title="$4"
        minutes="${5:--}"
        section="$(device_section_by_query "$query")" || {
                send_message_to "$chat_id" "–Э–µ –љ–∞—И—С–ї —Г—Б—В—А–Њ–є—Б—В–≤–Њ. –Ш—Б–њ–Њ–ї—М–Ј—Г–є—В–µ –љ–Њ–Љ–µ—А –Є–Ј —Б–њ–Є—Б–Ї–∞, –љ–∞–њ—А–Є–Љ–µ—А #3, –Є–ї–Є MAC-–∞–і—А–µ—Б."
                return 1
        }
        device_id="$(/usr/libexec/sheepfold/sheepfold-device-id ensure "$section" 2>/dev/null || true)"
        case "$device_id" in ''|*[!0-9]*)
                send_message_to "$chat_id" "–Э–µ —Г–і–∞–ї–Њ—Б—М –Њ–њ—А–µ–і–µ–ї–Є—В—М ID —Г—Б—В—А–Њ–є—Б—В–≤–∞. –Ю–±–љ–Њ–≤–Є—В–µ —Б–њ–Є—Б–Њ–Ї —Г—Б—В—А–Њ–є—Б—В–≤ –Є –њ–Њ–≤—В–Њ—А–Є—В–µ –Ї–Њ–Љ–∞–љ–і—Г."
                return 1
                ;;
        esac

        if [ "$action" = grant_time ]; then
                case "$minutes" in ''|*[!0-9]*) minutes=30 ;; esac
                [ "$minutes" -gt 0 ] || minutes=30
                [ "$minutes" -le 720 ] || minutes=720
                title="–і–∞—В—М +${minutes} –Љ–Є–љ—Г—В —Г—Б—В—А–Њ–є—Б—В–≤—Г $(device_label "$section")"
        else
                title="${title} $(device_label "$section")"
                minutes="-"
        fi

        request_confirmation "$chat_id" "$action" "$title" "$device_id" "$minutes"
}

