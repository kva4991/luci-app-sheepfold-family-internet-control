sync_telegram_commands() {
        token="$(telegram_token)"
        [ -n "$token" ] || return 1

        encoded_commands="$(telegram_commands_json | tr -d '\n' | form_escape)"
        response="$(fetch "https://api.telegram.org/bot${token}/setMyCommands" "commands=${encoded_commands}")"

        if printf '%s' "$response" | grep -q '"ok"[[:space:]]*:[[:space:]]*true'; then
                log "Telegram bot command menu synchronized"
                return 0
        fi

        [ -n "$response" ] && printf '%s\n' "$response" >&2 || printf 'Telegram setMyCommands did not return a response\n' >&2
        return 1
}

send_message_to() {
        chat_id="$1"
        text="$2"
        token="$(telegram_token)"
        response=""

        [ -n "$token" ] || return 1
        [ -n "$chat_id" ] || return 1

        encoded_text="$(printf '%s' "$text" | form_escape)"
        response="$(fetch "https://api.telegram.org/bot${token}/sendMessage" "chat_id=${chat_id}&text=${encoded_text}")"

        if printf '%s' "$response" | grep -q '"ok"[[:space:]]*:[[:space:]]*true'; then
                return 0
        fi

        [ -n "$response" ] && printf '%s\n' "$response" >&2 || printf 'Telegram API did not return a response\n' >&2
        return 1
}

send_admin_message() {
        send_message_to "$(telegram_admin_chat_id)" "$1"
}

status_text() {
        if [ -x "$ROUTER_CONTROL" ]; then
                internet="$("$ROUTER_CONTROL" internet-status 2>/dev/null || printf unknown)"
        else
                if [ "$(global_get block_on_boot 0)" = "1" ]; then
                        internet="disabled"
                else
                        internet="enabled"
                fi
        fi

        case "$internet" in
                disabled) internet_text="Интернет отключен" ;;
                enabled) internet_text="Интернет включен" ;;
                *) internet_text="Статус интернета неизвестен" ;;
        esac

        wifi_disabled_count="$(uci -q show wireless 2>/dev/null | sed -n "s/.*\.disabled='\{0,1\}\([01]\)'\{0,1\}$/\1/p" | awk '$1 == 1 { count++ } END { print count + 0 }')"
        wifi_total_count="$(uci -q show wireless 2>/dev/null | sed -n "s/^wireless\.\([^.=]*\)=wifi-device$/\1/p" | wc -l | awk '{ print $1 + 0 }')"

        if [ "$wifi_total_count" -eq 0 ]; then
                wifi_text="Wi-Fi: не найден"
        elif [ "$wifi_disabled_count" -ge "$wifi_total_count" ]; then
                wifi_text="Wi-Fi: выключен"
        else
                wifi_text="Wi-Fi: включен"
        fi

        printf 'Sheepfold на роутере %s\n%s\n%s\nАктивный мессенджер: Telegram' "$(router_name)" "$internet_text" "$wifi_text"
}

device_status_text() {
        case "$1" in
                allow) printf 'Белый список' ;;
                blocked) printf 'Чёрный список' ;;
                scheduled) printf 'По расписанию' ;;
                restricted) printf 'Ограничено' ;;
                new) printf 'Новое' ;;
                *) printf '%s' "${1:-Не настроено}" ;;
        esac
}

wifi_status_text() {
        wifi_disabled_count="$(uci -q show wireless 2>/dev/null | sed -n "s/.*\.disabled='\{0,1\}\([01]\)'\{0,1\}$/\1/p" | awk '$1 == 1 { count++ } END { print count + 0 }')"
        wifi_total_count="$(uci -q show wireless 2>/dev/null | sed -n "s/^wireless\.\([^.=]*\)=wifi-device$/\1/p" | wc -l | awk '{ print $1 + 0 }')"

        if [ "$wifi_total_count" -eq 0 ]; then
                printf 'Wi-Fi на роутере не найден.'
        elif [ "$wifi_disabled_count" -ge "$wifi_total_count" ]; then
                printf 'Wi-Fi выключен.'
        else
                printf 'Wi-Fi включен.'
        fi
}

devices_text_from_uci() {
        count=0
        output=""

        for section in $(uci -q show sheepfold 2>/dev/null | sed -n "s/^sheepfold\.\([^.=]*\)=device$/\1/p"); do
                count=$((count + 1))
                name="$(uci -q get "sheepfold.$section.name" 2>/dev/null || true)"
                mac="$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)"
                ip="$(uci -q get "sheepfold.$section.ip" 2>/dev/null || true)"
                group="$(uci -q get "sheepfold.$section.group" 2>/dev/null || true)"
                status="$(device_status_text "$(uci -q get "sheepfold.$section.status" 2>/dev/null || true)")"
                [ -n "$name" ] || name="$mac"
                [ -n "$ip" ] || ip="IP неизвестен"
                [ -n "$group" ] || group="Без группы"
                output="${output}#${count} ${name}
IP: ${ip}
MAC: ${mac}
Группа: ${group}
Статус: ${status}

"
                [ "$count" -ge 30 ] && break
        done

        if [ "$count" -gt 0 ]; then
                printf 'Устройства Sheepfold:\n\n%s' "$output"
                [ "$count" -ge 30 ] && printf 'Показаны первые 30 устройств.\n'
                return 0
        fi

        return 1
}

devices_text_from_leases() {
        leases="/tmp/dhcp.leases"
        [ -r "$leases" ] || return 1

        count=0
        output=""
        while read -r _ mac ip name _rest; do
                [ -n "$mac" ] || continue
                count=$((count + 1))
                [ -n "$name" ] && [ "$name" != "*" ] || name="Без имени"
                output="${output}#${count} ${name}
IP: ${ip:-IP неизвестен}
MAC: ${mac}

"
                [ "$count" -ge 30 ] && break
        done < "$leases"

        [ "$count" -gt 0 ] || return 1
        printf 'Устройства из DHCP-аренд роутера:\n\n%s' "$output"
        [ "$count" -ge 30 ] && printf 'Показаны первые 30 устройств.\n'
}

devices_text() {
        devices_text_from_uci || devices_text_from_leases || printf 'Пока не найдено ни одного устройства.'
}

device_section_by_query() {
        query="$(printf '%s' "${1:-}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//;s/^#//')"
        [ -n "$query" ] || return 1

        case "$query" in
                *:*)
                        mac="$(printf '%s' "$query" | tr '[:lower:]' '[:upper:]')"
                        for section in $(uci -q show sheepfold 2>/dev/null | sed -n "s/^sheepfold\.\([^.=]*\)=device$/\1/p"); do
                                existing="$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)"
                                [ "$(printf '%s' "$existing" | tr '[:lower:]' '[:upper:]')" = "$mac" ] && {
                                        printf '%s\n' "$section"
                                        return 0
                                }
                        done
                        ;;
                ''|*[!0-9]*)
                        return 1
                        ;;
                *)
                        count=0
                        for section in $(uci -q show sheepfold 2>/dev/null | sed -n "s/^sheepfold\.\([^.=]*\)=device$/\1/p"); do
                                count=$((count + 1))
                                [ "$count" = "$query" ] && {
                                        printf '%s\n' "$section"
                                        return 0
                                }
                        done
                        ;;
        esac

        return 1
}

device_label() {
        section="$1"
        name="$(uci -q get "sheepfold.$section.name" 2>/dev/null || true)"
        mac="$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)"
        ip="$(uci -q get "sheepfold.$section.ip" 2>/dev/null || true)"
        [ -n "$name" ] || name="$mac"
        [ -n "$ip" ] && printf '%s (%s, %s)' "$name" "$ip" "$mac" || printf '%s (%s)' "$name" "$mac"
}

set_device_status_by_query() {
        query="$1"
        status="$2"
        action_text="$3"
        section="$(device_section_by_query "$query")" || {
                printf 'Не нашёл устройство. Используйте номер из списка, например #3, или MAC-адрес.'
                return 1
        }

        mac="$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)"
        name="$(uci -q get "sheepfold.$section.name" 2>/dev/null || true)"
        ip="$(uci -q get "sheepfold.$section.ip" 2>/dev/null || true)"
        group="$(uci -q get "sheepfold.$section.group" 2>/dev/null || true)"
        device_type="$(uci -q get "sheepfold.$section.device_type" 2>/dev/null || true)"

        if [ -x "$ROUTER_CONTROL" ] &&
                "$ROUTER_CONTROL" set-device-status "$mac" "$status" "$name" "$ip" "$group" "$device_type" >/dev/null 2>&1; then
                log_event "Telegram: $action_text $(device_label "$section")"
                printf 'Готово: %s %s.' "$action_text" "$(device_label "$section")"
                return 0
        fi

        printf 'Не удалось изменить устройство. Проверьте, что устройство существует и не конфликтует с правилами администраторов.'
        return 1
}

grant_time_by_query() {
        query="$1"
        minutes="$2"
        section="$(device_section_by_query "$query")" || {
                printf 'Не нашёл устройство. Напишите, например: #3 +30 минут.'
                return 1
        }

        case "$minutes" in
                ''|*[!0-9]*) minutes=30 ;;
        esac

        [ "$minutes" -gt 0 ] || minutes=30
        [ "$minutes" -le 720 ] || minutes=720

        until_ts="$(($(date +%s) + minutes * 60))"
        uci -q set "sheepfold.$section.temporary_access_until=$until_ts"
        uci -q set "sheepfold.$section.temporary_access_minutes=$minutes"
        uci -q commit sheepfold
        log_event "Telegram: администратор дал +$minutes минут устройству $(device_label "$section")"

        printf 'Готово: устройству %s дано +%s минут.' "$(device_label "$section")" "$minutes"
}

extract_device_query() {
        printf '%s' "$1" | sed -n 's/.*\(([0-9A-Fa-f][0-9A-Fa-f]:\)\{5\}[0-9A-Fa-f][0-9A-Fa-f]\).*/\1/p; s/.*\(#\{0,1\}[0-9][0-9]*\).*/\1/p' | sed -n '1p'
}

extract_minutes() {
        text="$1"
        value="$(printf '%s' "$text" | sed -n 's/.*+\{0,1\}\([0-9][0-9]*\)[[:space:]]*\(мин\|минут\|minutes\).*/\1/p' | sed -n '1p')"
        [ -n "$value" ] || value="$(printf '%s' "$text" | sed -n 's/.*+\{0,1\}\([0-9][0-9]*\)[[:space:]]*\(ч\|час\|hour\|hours\).*/\1/p' | sed -n '1p')"
        if printf '%s' "$text" | grep -qiE '([0-9][0-9]*)[[:space:]]*(ч|час|hour|hours)' && [ -n "$value" ]; then
                value=$((value * 60))
        fi
        [ -n "$value" ] || value=30
        printf '%s' "$value"
}

logs_text() {
        log_file="$(log_cache_path)"
        if [ ! -r "$log_file" ]; then
                printf 'Журнал пока пуст.'
                return 0
        fi

        printf 'Последние записи журнала Sheepfold:\n\n'
        tail -n 20 "$log_file"
}

clear_logs() {
        log_file="$(log_cache_path)"
        mkdir -p "${log_file%/*}"
        : > "$log_file"
        chmod 600 "$log_file" 2>/dev/null || true
        log_event "Telegram: администратор очистил журнал"
        printf 'Журнал очищен.'
}

emergency_sites_text() {
        count=0
        output=""

        for section in $(uci -q show sheepfold 2>/dev/null | sed -n "s/^sheepfold\.\([^.=]*\)=site$/\1/p"); do
                count=$((count + 1))
                url="$(uci -q get "sheepfold.$section.url" 2>/dev/null || uci -q get "sheepfold.$section.domain" 2>/dev/null || true)"
                name="$(uci -q get "sheepfold.$section.name" 2>/dev/null || true)"
                description="$(uci -q get "sheepfold.$section.description" 2>/dev/null || true)"
                [ -n "$url" ] || continue
                output="${output}${count}. ${url}"
                [ -n "$name" ] && output="${output} — ${name}"
                [ -n "$description" ] && output="${output}
   ${description}"
                output="${output}
"
        done

        for domain in $(uci -q get sheepfold.domain_allowlist.domain 2>/dev/null || true); do
                count=$((count + 1))
                output="${output}${count}. ${domain}
"
        done

        [ "$count" -gt 0 ] && {
                printf 'Аварийно-полезные сайты:\n\n%s' "$output"
                return 0
        }

        printf 'Список аварийно-полезных сайтов пока не сохранён на роутере.'
}

