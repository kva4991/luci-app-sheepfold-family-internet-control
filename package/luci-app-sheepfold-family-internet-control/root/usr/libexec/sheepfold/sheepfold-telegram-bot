                                send_message_to "$chat_id" "–Э–µ —Г–і–∞–ї–Њ—Б—М –≤—Л–Ї–ї—О—З–Є—В—М Wi-Fi."
                        fi
                        ;;
                grant_time)
                        send_message_to "$chat_id" "$(grant_time_by_query "#$action_arg1" "$action_arg2")"
                        ;;
                device_block)
