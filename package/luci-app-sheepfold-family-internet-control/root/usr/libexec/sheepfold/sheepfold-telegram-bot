sync_telegram_commands() {
        token="$(telegram_token)"
        [ -n "$token" ] || return 1

        encoded_commands="$(telegram_commands_json | tr -d '\n' | form_escape)"
        response="$(fetch "https://api.telegram.org/bot${token}/setMyCommands" "commands=${encoded_commands}")"

        if printf '%s' "$response" | grep -q '"ok"[[:space:]]*:[[:space:]]*true'; then
                log "Telegram bot command menu synchronized"
                return 0
        fi

        [ -n "$response" ] && printf '%s\n' "$response" >&2 || printf 'Telegram setMyCommands did not return a response\n' >&2
        return 1
}

send_message_to() {
        chat_id="$1"
        text="$2"
        token="$(telegram_token)"
        response=""

        [ -n "$token" ] || return 1
        [ -n "$chat_id" ] || return 1

        encoded_text="$(printf '%s' "$text" | form_escape)"
        response="$(fetch "https://api.telegram.org/bot${token}/sendMessage" "chat_id=${chat_id}&text=${encoded_text}")"

        if printf '%s' "$response" | grep -q '"ok"[[:space:]]*:[[:space:]]*true'; then
                return 0
        fi

        [ -n "$response" ] && printf '%s\n' "$response" >&2 || printf 'Telegram API did not return a response\n' >&2
        return 1
}

send_admin_message() {
        send_message_to "$(telegram_admin_chat_id)" "$1"
}

status_text() {
        if [ -x "$ROUTER_CONTROL" ]; then
                internet="$("$ROUTER_CONTROL" internet-status 2>/dev/null || printf unknown)"
        else
                if [ "$(global_get block_on_boot 0)" = "1" ]; then
                        internet="disabled"
                else
                        internet="enabled"
                fi
        fi

        case "$internet" in
                disabled) internet_text="–Ш–љ—В–µ—А–љ–µ—В –Њ—В–Ї–ї—О—З–µ–љ" ;;
                enabled) internet_text="–Ш–љ—В–µ—А–љ–µ—В –≤–Ї–ї—О—З–µ–љ" ;;
                *) internet_text="–°—В–∞—В—Г—Б –Є–љ—В–µ—А–љ–µ—В–∞ –љ–µ–Є–Ј–≤–µ—Б—В–µ–љ" ;;
        esac

        wifi_disabled_count="$(uci -q show wireless 2>/dev/null | sed -n "s/.*\.disabled='\{0,1\}\([01]\)'\{0,1\}$/\1/p" | awk '$1 == 1 { count++ } END { print count + 0 }')"
        wifi_total_count="$(uci -q show wireless 2>/dev/null | sed -n "s/^wireless\.\([^.=]*\)=wifi-device$/\1/p" | wc -l | awk '{ print $1 + 0 }')"

        if [ "$wifi_total_count" -eq 0 ]; then
                wifi_text="Wi-Fi: –љ–µ –љ–∞–є–і–µ–љ"
        elif [ "$wifi_disabled_count" -ge "$wifi_total_count" ]; then
                wifi_text="Wi-Fi: –≤—Л–Ї–ї—О—З–µ–љ"
        else
                wifi_text="Wi-Fi: –≤–Ї–ї—О—З–µ–љ"
        fi

        printf 'Sheepfold –љ–∞ —А–Њ—Г—В–µ—А–µ %s\n%s\n%s\n–Р–Ї—В–Є–≤–љ—Л–є –Љ–µ—Б—Б–µ–љ–і–ґ–µ—А: Telegram' "$(router_name)" "$internet_text" "$wifi_text"
}

device_status_text() {
        case "$1" in
                allow) printf '–С–µ–ї—Л–є —Б–њ–Є—Б–Њ–Ї' ;;
                blocked) printf '–І—С—А–љ—Л–є —Б–њ–Є—Б–Њ–Ї' ;;
                scheduled) printf '–Я–Њ —А–∞—Б–њ–Є—Б–∞–љ–Є—О' ;;
                restricted) printf '–Ю–≥—А–∞–љ–Є—З–µ–љ–Њ' ;;
                new) printf '–Э–Њ–≤–Њ–µ' ;;
                *) printf '%s' "${1:-–Э–µ –љ–∞—Б—В—А–Њ–µ–љ–Њ}" ;;
        esac
}

wifi_status_text() {
        wifi_disabled_count="$(uci -q show wireless 2>/dev/null | sed -n "s/.*\.disabled='\{0,1\}\([01]\)'\{0,1\}$/\1/p" | awk '$1 == 1 { count++ } END { print count + 0 }')"
        wifi_total_count="$(uci -q show wireless 2>/dev/null | sed -n "s/^wireless\.\([^.=]*\)=wifi-device$/\1/p" | wc -l | awk '{ print $1 + 0 }')"

        if [ "$wifi_total_count" -eq 0 ]; then
                printf 'Wi-Fi –љ–∞ —А–Њ—Г—В–µ—А–µ –љ–µ –љ–∞–є–і–µ–љ.'
        elif [ "$wifi_disabled_count" -ge "$wifi_total_count" ]; then
                printf 'Wi-Fi –≤—Л–Ї–ї—О—З–µ–љ.'
        else
                printf 'Wi-Fi –≤–Ї–ї—О—З–µ–љ.'
        fi
}

devices_text_from_uci() {
        count=0
        output=""

        for section in $(uci -q show sheepfold 2>/dev/null | sed -n "s/^sheepfold\.\([^.=]*\)=device$/\1/p"); do
                count=$((count + 1))
                device_id="$(/usr/libexec/sheepfold/sheepfold-device-id ensure "$section")"
                name="$(uci -q get "sheepfold.$section.name" 2>/dev/null || true)"
                mac="$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)"
                ip="$(uci -q get "sheepfold.$section.ip" 2>/dev/null || true)"
                group="$(uci -q get "sheepfold.$section.group" 2>/dev/null || true)"
                status="$(device_status_text "$(uci -q get "sheepfold.$section.status" 2>/dev/null || true)")"
                [ -n "$name" ] || name="$mac"
                [ -n "$ip" ] || ip="IP –љ–µ–Є–Ј–≤–µ—Б—В–µ–љ"
                [ -n "$group" ] || group="–С–µ–Ј –≥—А—Г–њ–њ—Л"
                output="${output}#${device_id} ${name}
IP: ${ip}
MAC: ${mac}
–У—А—Г–њ–њ–∞: ${group}
–°—В–∞—В—Г—Б: ${status}

"
                [ "$count" -ge 30 ] && break
        done

        if [ "$count" -gt 0 ]; then
                printf '–£—Б—В—А–Њ–є—Б—В–≤–∞ Sheepfold:\n\n%s' "$output"
                [ "$count" -ge 30 ] && printf '–Я–Њ–Ї–∞–Ј–∞–љ—Л –њ–µ—А–≤—Л–µ 30 —Г—Б—В—А–Њ–є—Б—В–≤.\n'
                return 0
        fi

        return 1
}

devices_text_from_leases() {
        leases="/tmp/dhcp.leases"
        [ -r "$leases" ] || return 1

        count=0
        output=""
        while read -r _ mac ip name _rest; do
                [ -n "$mac" ] || continue
                count=$((count + 1))
                [ -n "$name" ] && [ "$name" != "*" ] || name="–С–µ–Ј –Є–Љ–µ–љ–Є"
                output="${output}#${count} ${name}
IP: ${ip:-IP –љ–µ–Є–Ј–≤–µ—Б—В–µ–љ}
MAC: ${mac}

"
                [ "$count" -ge 30 ] && break
        done < "$leases"

        [ "$count" -gt 0 ] || return 1
        printf '–£—Б—В—А–Њ–є—Б—В–≤–∞ –Є–Ј DHCP-–∞—А–µ–љ–і —А–Њ—Г—В–µ—А–∞:\n\n%s' "$output"
        [ "$count" -ge 30 ] && printf '–Я–Њ–Ї–∞–Ј–∞–љ—Л –њ–µ—А–≤—Л–µ 30 —Г—Б—В—А–Њ–є—Б—В–≤.\n'
}

devices_text() {
        devices_text_from_uci || devices_text_from_leases || printf '–Я–Њ–Ї–∞ –љ–µ –љ–∞–є–і–µ–љ–Њ –љ–Є –Њ–і–љ–Њ–≥–Њ —Г—Б—В—А–Њ–є—Б—В–≤–∞.'
}

device_section_by_query() {
        query="$(printf '%s' "${1:-}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//;s/^#//')"
        [ -n "$query" ] || return 1

        case "$query" in
                *:*)
                        mac="$(printf '%s' "$query" | tr 'a-z' 'A-Z')"
                        for section in $(uci -q show sheepfold 2>/dev/null | sed -n "s/^sheepfold\.\([^.=]*\)=device$/\1/p"); do
                                existing="$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)"
                                [ "$(printf '%s' "$existing" | tr 'a-z' 'A-Z')" = "$mac" ] && {
                                        printf '%s\n' "$section"
                                        return 0
                                }
                        done
                        ;;
                ''|*[!0-9]*)
                        return 1
                        ;;
                *)
                        for section in $(uci -q show sheepfold 2>/dev/null | sed -n "s/^sheepfold\.\([^.=]*\)=device$/\1/p"); do
                                device_id="$(/usr/libexec/sheepfold/sheepfold-device-id ensure "$section")"
                                [ "$device_id" = "$query" ] && {
                                        printf '%s\n' "$section"
                                        return 0
                                }
                        done
                        ;;
        esac

        return 1
}

device_label() {
        section="$1"
        device_id="$(/usr/libexec/sheepfold/sheepfold-device-id ensure "$section")"
        name="$(uci -q get "sheepfold.$section.name" 2>/dev/null || true)"
        mac="$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)"
        ip="$(uci -q get "sheepfold.$section.ip" 2>/dev/null || true)"
        [ -n "$name" ] || name="$mac"
        [ -n "$ip" ] && printf '#%s %s (%s, %s)' "$device_id" "$name" "$ip" "$mac" || printf '#%s %s (%s)' "$device_id" "$name" "$mac"
}

set_device_status_by_query() {
        query="$1"
        status="$2"
        action_text="$3"
        section="$(device_section_by_query "$query")" || {
                printf '–Э–µ –љ–∞—И—С–ї —Г—Б—В—А–Њ–є—Б—В–≤–Њ. –Ш—Б–њ–Њ–ї—М–Ј—Г–є—В–µ –љ–Њ–Љ–µ—А –Є–Ј —Б–њ–Є—Б–Ї–∞, –љ–∞–њ—А–Є–Љ–µ—А #3, –Є–ї–Є MAC-–∞–і—А–µ—Б.'
                return 1
        }

        mac="$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)"
        name="$(uci -q get "sheepfold.$section.name" 2>/dev/null || true)"
        ip="$(uci -q get "sheepfold.$section.ip" 2>/dev/null || true)"
        group="$(uci -q get "sheepfold.$section.group" 2>/dev/null || true)"
        device_type="$(uci -q get "sheepfold.$section.device_type" 2>/dev/null || true)"

        if [ -x "$ROUTER_CONTROL" ] &&
                "$ROUTER_CONTROL" set-device-status "$mac" "$status" "$name" "$ip" "$group" "$device_type" >/dev/null 2>&1; then
                log_event "Telegram: $action_text $(device_label "$section")"
                printf '–У–Њ—В–Њ–≤–Њ: %s %s.' "$action_text" "$(device_label "$section")"
                return 0
        fi

        printf '–Э–µ —Г–і–∞–ї–Њ—Б—М –Є–Ј–Љ–µ–љ–Є—В—М —Г—Б—В—А–Њ–є—Б—В–≤–Њ. –Я—А–Њ–≤–µ—А—М—В–µ, —З—В–Њ —Г—Б—В—А–Њ–є—Б—В–≤–Њ —Б—Г—Й–µ—Б—В–≤—Г–µ—В –Є –љ–µ –Ї–Њ–љ—Д–ї–Є–Ї—В—Г–µ—В —Б –њ—А–∞–≤–Є–ї–∞–Љ–Є –∞–і–Љ–Є–љ–Є—Б—В—А–∞—В–Њ—А–Њ–≤.'
        return 1
}

grant_time_by_query() {
        query="$1"
        minutes="$2"
        section="$(device_section_by_query "$query")" || {
                printf '–Э–µ –љ–∞—И—С–ї —Г—Б—В—А–Њ–є—Б—В–≤–Њ. –Э–∞–њ–Є—И–Є—В–µ, –љ–∞–њ—А–Є–Љ–µ—А: #3 +30 –Љ–Є–љ—Г—В.'
                return 1
        }

        case "$minutes" in
                ''|*[!0-9]*) minutes=30 ;;
        esac

        [ "$minutes" -gt 0 ] || minutes=30
        [ "$minutes" -le 720 ] || minutes=720

        mac="$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)"
        if [ -z "$mac" ] || ! [ -x "$ROUTER_CONTROL" ] || ! "$ROUTER_CONTROL" device-temp-access "$mac" "$minutes" >/dev/null 2>&1; then
                printf '–Э–µ —Г–і–∞–ї–Њ—Б—М –і–∞—В—М –≤—А–µ–Љ—П —Г—Б—В—А–Њ–є—Б—В–≤—Г. –Я—А–Њ–≤–µ—А—М—В–µ, —З—В–Њ –Њ–љ–Њ –љ–µ –≤ —З—С—А–љ–Њ–Љ —Б–њ–Є—Б–Ї–µ.'
                return 1
        fi
        log_event "Telegram: –∞–і–Љ–Є–љ–Є—Б—В—А–∞—В–Њ—А –і–∞–ї +$minutes –Љ–Є–љ—Г—В —Г—Б—В—А–Њ–є—Б—В–≤—Г $(device_label "$section")"

        printf '–У–Њ—В–Њ–≤–Њ: —Г—Б—В—А–Њ–є—Б—В–≤—Г %s –і–∞–љ–Њ +%s –Љ–Є–љ—Г—В.' "$(device_label "$section")" "$minutes"
}

extract_device_query() {
        printf '%s' "$1" | sed -n 's/.*\(([0-9A-Fa-f][0-9A-Fa-f]:\)\{5\}[0-9A-Fa-f][0-9A-Fa-f]\).*/\1/p; s/.*\(#\{0,1\}[0-9][0-9]*\).*/\1/p' | sed -n '1p'
}

extract_minutes() {
        text="$1"
        value="$(printf '%s' "$text" | sed -n 's/.*+\{0,1\}\([0-9][0-9]*\)[[:space:]]*\(–Љ–Є–љ\|–Љ–Є–љ—Г—В\|minutes\).*/\1/p' | sed -n '1p')"
        [ -n "$value" ] || value="$(printf '%s' "$text" | sed -n 's/.*+\{0,1\}\([0-9][0-9]*\)[[:space:]]*\(—З\|—З–∞—Б\|hour\|hours\).*/\1/p' | sed -n '1p')"
        if printf '%s' "$text" | grep -qiE '([0-9][0-9]*)[[:space:]]*(—З|—З–∞—Б|hour|hours)' && [ -n "$value" ]; then
                value=$((value * 60))
        fi
        [ -n "$value" ] || value=30
        printf '%s' "$value"
}

