        sed 's#\\/#/#g; s#\\"#"#g; s#\\n# #g; s#\\r# #g; s#\\t# #g; s#\\u0023#\##g; s#\\u002b#+#g; s#\\u002B#+#g;
s#\\u0410#А#g; s#\\u0411#Б#g; s#\\u0412#В#g; s#\\u0413#Г#g; s#\\u0414#Д#g; s#\\u0415#Е#g; s#\\u0401#Ё#g; s#\\u0416#Ж#g; s#\\u0417#З#g; s#\\u0418#И#g; s#\\u0419#Й#g; s#\\u041a#К#g; s#\\u041A#К#g; s#\\u041b#Л#g; s#\\u041B#Л#g; s#\\u041c#М#g; s#\\u041C#М#g; s#\\u041d#Н#g; s#\\u041D#Н#g; s#\\u041e#О#g; s#\\u041E#О#g; s#\\u041f#П#g; s#\\u041F#П#g; s#\\u0420#Р#g; s#\\u0421#С#g; s#\\u0422#Т#g; s#\\u0423#У#g; s#\\u0424#Ф#g; s#\\u0425#Х#g; s#\\u0426#Ц#g; s#\\u0427#Ч#g; s#\\u0428#Ш#g; s#\\u0429#Щ#g; s#\\u042a#Ъ#g; s#\\u042A#Ъ#g; s#\\u042b#Ы#g; s#\\u042B#Ы#g; s#\\u042c#Ь#g; s#\\u042C#Ь#g; s#\\u042d#Э#g; s#\\u042D#Э#g; s#\\u042e#Ю#g; s#\\u042E#Ю#g; s#\\u042f#Я#g; s#\\u042F#Я#g;
s#\\u0430#а#g; s#\\u0431#б#g; s#\\u0432#в#g; s#\\u0433#г#g; s#\\u0434#д#g; s#\\u0435#е#g; s#\\u0451#ё#g; s#\\u0436#ж#g; s#\\u0437#з#g; s#\\u0438#и#g; s#\\u0439#й#g; s#\\u043a#к#g; s#\\u043A#к#g; s#\\u043b#л#g; s#\\u043B#л#g; s#\\u043c#м#g; s#\\u043C#м#g; s#\\u043d#н#g; s#\\u043D#н#g; s#\\u043e#о#g; s#\\u043E#о#g; s#\\u043f#п#g; s#\\u043F#п#g; s#\\u0440#р#g; s#\\u0441#с#g; s#\\u0442#т#g; s#\\u0443#у#g; s#\\u0444#ф#g; s#\\u0445#х#g; s#\\u0446#ц#g; s#\\u0447#ч#g; s#\\u0448#ш#g; s#\\u0449#щ#g; s#\\u044a#ъ#g; s#\\u044A#ъ#g; s#\\u044b#ы#g; s#\\u044B#ы#g; s#\\u044c#ь#g; s#\\u044C#ь#g; s#\\u044d#э#g; s#\\u044D#э#g; s#\\u044e#ю#g; s#\\u044E#ю#g; s#\\u044f#я#g; s#\\u044F#я#g;
s#\\\\#\\#g'
}

normalize_command_text() {
        printf '%s' "$1" |
                json_text_unescape |
                sed 's/^[[:space:]]*//;s/[[:space:]]*$//;s/[[:space:]][[:space:]]*/ /g;s/@[A-Za-z0-9_][A-Za-z0-9_]*//g'
}

