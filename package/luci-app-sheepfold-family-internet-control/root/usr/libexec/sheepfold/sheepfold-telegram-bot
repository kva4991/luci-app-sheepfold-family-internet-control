s#\\u0410#–Р#g; s#\\u0411#–С#g; s#\\u0412#–Т#g; s#\\u0413#–У#g; s#\\u0414#–Ф#g; s#\\u0415#–Х#g; s#\\u0401#–Б#g; s#\\u0416#–Ц#g; s#\\u0417#–Ч#g; s#\\u0418#–Ш#g; s#\\u0419#–Щ#g; s#\\u041a#–Ъ#g; s#\\u041A#–Ъ#g; s#\\u041b#–Ы#g; s#\\u041B#–Ы#g; s#\\u041c#–Ь#g; s#\\u041C#–Ь#g; s#\\u041d#–Э#g; s#\\u041D#–Э#g; s#\\u041e#–Ю#g; s#\\u041E#–Ю#g; s#\\u041f#–Я#g; s#\\u041F#–Я#g; s#\\u0420#–†#g; s#\\u0421#–°#g; s#\\u0422#–Ґ#g; s#\\u0423#–£#g; s#\\u0424#–§#g; s#\\u0425#–•#g; s#\\u0426#–¶#g; s#\\u0427#–І#g; s#\\u0428#–®#g; s#\\u0429#–©#g; s#\\u042a#–™#g; s#\\u042A#–™#g; s#\\u042b#–Ђ#g; s#\\u042B#–Ђ#g; s#\\u042c#–ђ#g; s#\\u042C#–ђ#g; s#\\u042d#–≠#g; s#\\u042D#–≠#g; s#\\u042e#–Ѓ#g; s#\\u042E#–Ѓ#g; s#\\u042f#–ѓ#g; s#\\u042F#–ѓ#g;
