confirmation_file() {
        chat_id="$(printf '%s' "$1" | tr -cd '0-9-')"
        printf '%s/telegram-confirm-%s' "$RUNTIME_DIR" "$chat_id"
}

confirmation_code() {
        if command -v od >/dev/null 2>&1; then
                raw="$(od -An -N2 -tu2 /dev/urandom 2>/dev/null | tr -d ' ' || true)"
        else
                raw=""
        fi
        case "$raw" in
                ''|*[!0-9]*) raw="$(date +%s)" ;;
        esac
        printf '%04d' "$((raw % 9000 + 1000))"
}

request_confirmation() {
        chat_id="$1"
        action="$2"
        title="$3"
        file="$(confirmation_file "$chat_id")"
        code="$(confirmation_code)"
        expires="$(($(date +%s) + 300))"

        printf '%s\t%s\t%s\n' "$action" "$code" "$expires" > "$file"
        chmod 600 "$file" 2>/dev/null || true
        send_message_to "$chat_id" "Нужно подтверждение: ${title}.

Для подтверждения напишите:
подтверждаю ${code}

Код действует 5 минут."
}

run_confirmed_action() {
        chat_id="$1"
        action="$2"

        case "$action" in
                clear_logs)
                        send_message_to "$chat_id" "$(clear_logs)"
                        ;;
                update)
                        if [ -x "$UPDATER" ]; then
                                output="$("$UPDATER" start 2>&1 || true)"
                                log_event "Telegram: администратор запустил обновление Sheepfold"
                                send_message_to "$chat_id" "${output:-Обновление запущено.}"
                        else
                                send_message_to "$chat_id" "Не найден модуль обновления Sheepfold."
                        fi
                        ;;
                reboot)
                        log_event "Telegram: администратор подтвердил перезагрузку роутера"
                        send_message_to "$chat_id" "Перезагрузка роутера запущена."
                        (sleep 2; reboot) >/dev/null 2>&1 &
                        ;;
                *)
                        send_message_to "$chat_id" "Неизвестное подтверждаемое действие."
                        return 1
                        ;;
        esac
}

handle_confirmation() {
        chat_id="$1"
        text="$2"
        file="$(confirmation_file "$chat_id")"
        code="$(printf '%s' "$text" | sed -n 's/^\(подтверждаю\|Подтверждаю\|confirm\|Confirm\)[[:space:]]\+\([0-9][0-9][0-9][0-9]\)$/\2/p')"

        [ -n "$code" ] || return 1
        [ -r "$file" ] || {
                send_message_to "$chat_id" "Нет команды, ожидающей подтверждения."
                return 0
        }

        IFS="$(printf '\t')" read -r action expected expires < "$file" || true
        now="$(date +%s)"
        rm -f "$file"

        if [ "$now" -gt "${expires:-0}" ]; then
                send_message_to "$chat_id" "Код подтверждения устарел. Повторите команду заново."
                return 0
        fi

        if [ "$code" != "$expected" ]; then
                send_message_to "$chat_id" "Код подтверждения не совпал. Команда отменена."
                return 0
        fi

        run_confirmed_action "$chat_id" "$action"
        return 0
}

handle_command() {
        chat_id="$1"
        text="$(normalize_command_text "$2")"
        admin_chat_id="$(telegram_admin_chat_id)"
        device_query=""
        minutes=""

        if [ -z "$admin_chat_id" ]; then
                send_message_to "$chat_id" "Ваш Telegram chat ID: $chat_id

Введите этот ID в настройках Sheepfold на роутере, чтобы разрешить управление через Telegram."
                log "Telegram command replied with chat ID because admin chat ID is empty"
                return 0
        fi

        if [ "$chat_id" != "$admin_chat_id" ]; then
                log "Telegram command ignored from unauthorized chat $chat_id"
                return 0
        fi

        handle_confirmation "$chat_id" "$text" && return 0

        case "$text" in
                /start*|/help*|help|Help|HELP|помощь|Помощь|ПОМОЩЬ)
                        send_message_to "$chat_id" "$(help_text)"
                        ;;
                /status*|status|Status|STATUS|статус|Статус|СТАТУС)
                        send_message_to "$chat_id" "$(status_text)"
                        ;;
                /devices*|devices|Devices|DEVICES|устройства|Устройства|ПОКАЗАТЬ\ ВСЕ\ УСТРОЙСТВА|Показать\ все\ устройства|показать\ все\ устройства)
                        send_message_to "$chat_id" "$(devices_text)"
                        ;;
                /internet_on*|internet\ on|Internet\ on|интернет\ включен|Интернет\ включен|ИНТЕРНЕТ\ ВКЛЮЧЕН|включить\ интернет|Включить\ интернет|ВКЛЮЧИТЬ\ ИНТЕРНЕТ)
                        if [ -x "$ROUTER_CONTROL" ] && "$ROUTER_CONTROL" internet-enable >/dev/null 2>&1; then
                                send_message_to "$chat_id" "Интернет включен."
                                log_event "Telegram: администратор включил интернет"
                        else
                                send_message_to "$chat_id" "Не удалось включить интернет."
                        fi
                        ;;
                /internet_off*|internet\ off|Internet\ off|интернет\ отключен|Интернет\ отключен|ИНТЕРНЕТ\ ОТКЛЮЧЕН|отключить\ интернет|Отключить\ интернет|ОТКЛЮЧИТЬ\ ИНТЕРНЕТ|выключить\ интернет|Выключить\ интернет|ВЫКЛЮЧИТЬ\ ИНТЕРНЕТ)
                        if [ -x "$ROUTER_CONTROL" ] && "$ROUTER_CONTROL" internet-disable >/dev/null 2>&1; then
                                send_message_to "$chat_id" "Интернет отключен."
                                log_event "Telegram: администратор отключил интернет"
                        else
                                send_message_to "$chat_id" "Не удалось отключить интернет."
                        fi
                        ;;
                /wifi_status*|wifi\ status|Wi-Fi\ status|WiFi\ status|статус\ wifi|статус\ wi-fi|статус\ вайфай)
                        send_message_to "$chat_id" "$(wifi_status_text)"
                        ;;
                /wifi_on*|wifi\ on|Wi-Fi\ on|WiFi\ on|включить\ wifi|включить\ wi-fi|включить\ вайфай)
                        if [ -x "$ROUTER_CONTROL" ] && "$ROUTER_CONTROL" wifi-enable >/dev/null 2>&1; then
                                send_message_to "$chat_id" "Wi-Fi включен."
                                log_event "Telegram: администратор включил Wi-Fi"
                        else
                                send_message_to "$chat_id" "Не удалось включить Wi-Fi."
                        fi
                        ;;
                /wifi_off*|wifi\ off|Wi-Fi\ off|WiFi\ off|выключить\ wifi|выключить\ wi-fi|выключить\ вайфай)
                        if [ -x "$ROUTER_CONTROL" ] && "$ROUTER_CONTROL" wifi-disable >/dev/null 2>&1; then
                                send_message_to "$chat_id" "Wi-Fi выключен."
                                log_event "Telegram: администратор выключил Wi-Fi"
                        else
                                send_message_to "$chat_id" "Не удалось выключить Wi-Fi."
                        fi
                        ;;
                /support*|support|Support|SUPPORT|саппорт|Саппорт|САППОРТ|сапорт|Сапорт|САПОРТ|поддержка|Поддержка|ПОДДЕРЖКА)
                        send_message_to "$chat_id" "$(support_text)"
                        ;;
                /logs*|logs|Logs|LOGS|журнал|Журнал|ЖУРНАЛ|показать\ журнал|Показать\ журнал|ПОКАЗАТЬ\ ЖУРНАЛ)
                        send_message_to "$chat_id" "$(logs_text)"
                        ;;
                /clear_logs*|clear\ logs|Clear\ logs|очистить\ журнал|Очистить\ журнал|ОЧИСТИТЬ\ ЖУРНАЛ)
                        request_confirmation "$chat_id" clear_logs "очистить журнал Sheepfold"
                        ;;
                /update*|update|Update|UPDATE|обновить\ приложение|Обновить\ приложение|ОБНОВИТЬ\ ПРИЛОЖЕНИЕ|обновить\ sheepfold|Обновить\ Sheepfold)
                        request_confirmation "$chat_id" update "обновить Sheepfold"
                        ;;
                /reboot*|reboot|Reboot|REBOOT|перезагрузить\ роутер|Перезагрузить\ роутер|ПЕРЕЗАГРУЗИТЬ\ РОУТЕР)
                        request_confirmation "$chat_id" reboot "перезагрузить роутер"
                        ;;
                /emergency_sites*|emergency\ sites|Emergency\ sites|аварийно-полезные\ сайты|Аварийно-полезные\ сайты|аварийные\ сайты|Аварийные\ сайты)
                        send_message_to "$chat_id" "$(emergency_sites_text)"
                        ;;
                /grant_time*|+*|дать\ *|Дать\ *)
                        device_query="$(extract_device_query "$text")"
                        minutes="$(extract_minutes "$text")"
                        send_message_to "$chat_id" "$(grant_time_by_query "$device_query" "$minutes")"
                        ;;
                /block_device*|заблокировать\ *|Заблокировать\ *|отключить\ устройство\ *|Отключить\ устройство\ *)
                        device_query="$(extract_device_query "$text")"
                        send_message_to "$chat_id" "$(set_device_status_by_query "$device_query" blocked "заблокировал устройство")"
                        ;;
                /unblock_device*|разблокировать\ *|Разблокировать\ *|вернуть\ интернет\ *|Вернуть\ интернет\ *)
                        device_query="$(extract_device_query "$text")"
                        send_message_to "$chat_id" "$(set_device_status_by_query "$device_query" new "убрал ручную блокировку устройства")"
                        ;;
                /allowlist_add*|добавить\ *\ в\ белый\ список|Добавить\ *\ в\ белый\ список)
                        device_query="$(extract_device_query "$text")"
                        send_message_to "$chat_id" "$(set_device_status_by_query "$device_query" allow "добавил устройство в белый список")"
                        ;;
                /blocklist_add*|добавить\ *\ в\ чёрный\ список|Добавить\ *\ в\ чёрный\ список|добавить\ *\ в\ черный\ список|Добавить\ *\ в\ черный\ список)
                        device_query="$(extract_device_query "$text")"
                        send_message_to "$chat_id" "$(set_device_status_by_query "$device_query" blocked "добавил устройство в чёрный список")"
                        ;;
                *)
                        send_message_to "$chat_id" "Не понял команду. Напишите «помощь», чтобы увидеть доступные команды."
                        ;;
        esac
}

parse_first_update_id() {
        sed -n 's/.*"update_id"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' | head -n 1
}

parse_first_chat_id() {
        sed -n 's/.*"chat"[[:space:]]*:[[:space:]]*{[^}]*"id"[[:space:]]*:[[:space:]]*\(-\{0,1\}[0-9][0-9]*\).*/\1/p' | head -n 1
}

parse_first_text() {
        sed -n 's/.*"text"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1 |
                json_text_unescape
}

poll_once() {
        token="$(telegram_token)"
        [ -n "$token" ] || return 0

        offset="$(cat "$OFFSET_FILE" 2>/dev/null || printf 0)"
        case "$offset" in
                ''|*[!0-9]*) offset=0 ;;
        esac

        response="$(fetch "https://api.telegram.org/bot${token}/getUpdates?timeout=25&limit=1&offset=${offset}")"
        [ -n "$response" ] || return 0

        update_id="$(printf '%s' "$response" | parse_first_update_id)"
        [ -n "$update_id" ] || return 0

        next_offset=$((update_id + 1))
        printf '%s\n' "$next_offset" > "$OFFSET_FILE"

        chat_id="$(printf '%s' "$response" | parse_first_chat_id)"
        text="$(printf '%s' "$response" | parse_first_text)"

        [ -n "$chat_id" ] || return 0
        [ -n "$text" ] || return 0

        handle_command "$chat_id" "$text"
}

notify_new_log_lines() {
        telegram_active || return 0
        [ -n "$(telegram_token)" ] || return 0
        [ -n "$(telegram_admin_chat_id)" ] || return 0

        log_file="$(log_cache_path)"
        [ -r "$log_file" ] || return 0

        current_count="$(wc -l "$log_file" 2>/dev/null | awk '{ print $1 + 0 }')"
        last_count="$(cat "$LOG_LINE_FILE" 2>/dev/null || true)"
        case "$last_count" in
                ''|*[!0-9]*)
                        printf '%s\n' "$current_count" > "$LOG_LINE_FILE"
                        return 0
                        ;;
        esac

        if [ "$current_count" -lt "$last_count" ]; then
                last_count=0
        fi

        [ "$current_count" -gt "$last_count" ] || return 0

        awk -v start="$last_count" 'NR > start { print }' "$log_file" | tail -n 10 |
                while IFS= read -r line; do
                        [ -n "$line" ] || continue
                        send_admin_message "Sheepfold: $line"
                done

        printf '%s\n' "$current_count" > "$LOG_LINE_FILE"
}

run_loop() {
        log "Telegram adapter loop started"
        if telegram_active && [ -n "$(telegram_token)" ]; then
                sync_telegram_commands >/dev/null 2>&1 || true
        fi
        while :; do
                if telegram_active && [ -n "$(telegram_token)" ]; then
                        notify_new_log_lines
                        poll_once
                else
                        sleep 15
                fi
        done
}

case "$COMMAND" in
        run)
                run_loop
                ;;
        once)
                telegram_active && poll_once
                ;;
        send-test)
                if ! telegram_active; then
                        echo "Telegram is not the active messenger" >&2
                        exit 2
                fi
                if [ -z "$(telegram_token)" ] || [ -z "$(telegram_admin_chat_id)" ]; then
                        echo "Telegram bot token or admin chat ID is empty" >&2
                        exit 2
                fi
                sync_telegram_commands >/dev/null 2>&1 || true
                send_admin_message "Sheepfold Telegram подключен к роутеру $(router_name)." || exit 1
                ;;
        sync-commands)
                telegram_active || {
                        echo "Telegram is not the active messenger" >&2
                        exit 2
                }
                sync_telegram_commands
                ;;
        status)
                printf 'active=%s\n' "$(global_get active_messenger none)"
                printf 'token_configured=%s\n' "$([ -n "$(telegram_token)" ] && printf 1 || printf 0)"
                printf 'admin_chat_id=%s\n' "$(telegram_admin_chat_id)"
                printf 'offset=%s\n' "$(cat "$OFFSET_FILE" 2>/dev/null || printf 0)"
                ;;
        *)
                echo "Usage: sheepfold-telegram-bot [run|once|send-test|sync-commands|status]" >&2
                exit 1
                ;;
esac
