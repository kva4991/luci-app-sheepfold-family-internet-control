parse_first_update_id() {
        sed -n 's/.*"update_id"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' | head -n 1
}

parse_first_chat_id() {
        sed -n 's/.*"chat"[[:space:]]*:[[:space:]]*{[^}]*"id"[[:space:]]*:[[:space:]]*\(-\{0,1\}[0-9][0-9]*\).*/\1/p' | head -n 1
}

parse_first_text() {
        sed -n 's/.*"text"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1 |
                json_text_unescape
}

poll_once() {
        token="$(telegram_token)"
        [ -n "$token" ] || return 0

        offset="$(cat "$OFFSET_FILE" 2>/dev/null || printf 0)"
        case "$offset" in
                ''|*[!0-9]*) offset=0 ;;
        esac

        response="$(fetch "https://api.telegram.org/bot${token}/getUpdates?timeout=25&limit=1&offset=${offset}")" || return 2
        [ -n "$response" ] || return 0

        update_id="$(printf '%s' "$response" | parse_first_update_id)"
        [ -n "$update_id" ] || return 0

        next_offset=$((update_id + 1))
        printf '%s\n' "$next_offset" > "$OFFSET_FILE"

        chat_id="$(printf '%s' "$response" | parse_first_chat_id)"
        text="$(printf '%s' "$response" | parse_first_text)"

        [ -n "$chat_id" ] || return 0
        [ -n "$text" ] || return 0

        handle_command "$chat_id" "$text"
}

notify_new_log_lines() {
        telegram_active || return 0
        [ -n "$(telegram_token)" ] || return 0
        [ -n "$(telegram_admin_chat_id)" ] || return 0

        log_file="$(log_cache_path)"
        [ -r "$log_file" ] || return 0

        current_count="$(wc -l "$log_file" 2>/dev/null | awk '{ print $1 + 0 }')"
        last_count="$(cat "$LOG_LINE_FILE" 2>/dev/null || true)"
        case "$last_count" in
                ''|*[!0-9]*)
                        printf '%s\n' "$current_count" > "$LOG_LINE_FILE"
                        return 0
                        ;;
        esac

        if [ "$current_count" -lt "$last_count" ]; then
                last_count=0
        fi

        [ "$current_count" -gt "$last_count" ] || return 0

        awk -v start="$last_count" 'NR > start { print }' "$log_file" | tail -n 10 |
                while IFS= read -r line; do
                        [ -n "$line" ] || continue
                        send_admin_message "Sheepfold: $line"
                done

        printf '%s\n' "$current_count" > "$LOG_LINE_FILE"
}

run_loop() {
        backoff=1

        log "Telegram adapter loop started"
        if telegram_active && [ -n "$(telegram_token)" ]; then
                sync_telegram_commands >/dev/null 2>&1 || true
        fi
        while :; do
                if telegram_active && [ -n "$(telegram_token)" ]; then
                        notify_new_log_lines
                        if poll_once; then
                                backoff=1
                        else
                                sleep "$backoff"
                                backoff=$((backoff * 2))
                                [ "$backoff" -le 60 ] || backoff=60
                        fi
                else
                        sleep 15
                fi
        done
}

case "$COMMAND" in
        run)
                run_loop
                ;;
        once)
                telegram_active && poll_once
                ;;
        send-test)
                if ! telegram_active; then
                        echo "Telegram is not the active messenger" >&2
                        exit 2
                fi
                if [ -z "$(telegram_token)" ] || [ -z "$(telegram_admin_chat_id)" ]; then
                        echo "Telegram bot token or admin chat ID is empty" >&2
                        exit 2
                fi
                sync_telegram_commands >/dev/null 2>&1 || true
                send_admin_message "Sheepfold Telegram –њ–Њ–і–Ї–ї—О—З–µ–љ –Ї —А–Њ—Г—В–µ—А—Г $(router_name)." || exit 1
                ;;
        send-admin)
                # –°–Є—Б—В–µ–Љ–љ—Л–µ –њ–Њ–Љ–Њ—Й–љ–Є–Ї–Є –Є—Б–њ–Њ–ї—М–Ј—Г—О—В —Н—В–Њ—В —Г–Ј–Ї–Є–є –≤—Е–Њ–і –Є –љ–µ –Ј–љ–∞—О—В —В–Њ–Ї–µ–љ Telegram.
                telegram_active || exit 0
                [ -n "${2:-}" ] || exit 2
                send_admin_message "$2"
                ;;
        sync-commands)
                telegram_active || {
                        echo "Telegram is not the active messenger" >&2
                        exit 2
                }
                sync_telegram_commands
                ;;
        status)
                printf 'active=%s\n' "$(global_get active_messenger none)"
                printf 'token_configured=%s\n' "$([ -n "$(telegram_token)" ] && printf 1 || printf 0)"
                printf 'admin_chat_id=%s\n' "$(telegram_admin_chat_id)"
                printf 'offset=%s\n' "$(cat "$OFFSET_FILE" 2>/dev/null || printf 0)"
                ;;
        *)
                echo "Usage: sheepfold-telegram-bot [run|once|send-test|send-admin MESSAGE|sync-commands|status]" >&2
                exit 1
                ;;
esac
