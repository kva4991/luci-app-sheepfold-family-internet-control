confirmation_code() {
        # –Я–Њ–і—В–≤–µ—А–ґ–і–µ–љ–Є–µ –Ј–∞—Й–Є—Й–∞–µ—В –Њ—В —Б–ї—Г—З–∞–є–љ–Њ–≥–Њ –Ј–∞–њ—Г—Б–Ї–∞ –Ї–Њ–Љ–∞–љ–і—Л –Є–Ј —Г–ґ–µ —А–∞–Ј—А–µ—И—С–љ–љ–Њ–≥–Њ
        # —З–∞—В–∞. –Я—А–µ–і—Б–Ї–∞–Ј—Г–µ–Љ—Л–є fallback –њ–Њ –≤—А–µ–Љ–µ–љ–Є –Ј–і–µ—Б—М –≤—Б—С —А–∞–≤–љ–Њ –љ–µ–і–Њ–њ—Г—Б—В–Є–Љ. ¬Іtgconfirm
        attempt=0
        while [ "$attempt" -lt 16 ]; do
                attempt=$((attempt + 1))
                if command -v sha256sum >/dev/null 2>&1; then
                        raw_hex="$(dd if=/dev/urandom bs=32 count=1 2>/dev/null | sha256sum | awk '{ print substr($1, 1, 6) }')"
                elif command -v openssl >/dev/null 2>&1; then
                        raw_hex="$(openssl rand -hex 16 2>/dev/null | cut -c1-6)"
                else
                        return 1
                fi
                case "$raw_hex" in ''|*[!0-9a-fA-F]*) return 1 ;; esac
                [ "${#raw_hex}" -eq 6 ] || return 1
                raw_value=$((0x$raw_hex))

                # 16 200 000 –і–µ–ї–Є—В—Б—П –љ–∞ 900 000 –±–µ–Ј –Њ—Б—В–∞—В–Ї–∞. –Ю—В–±—А–∞—Б—Л–≤–∞–љ–Є–µ
                # –≤–µ—А—Е–љ–µ–≥–Њ —Е–≤–Њ—Б—В–∞ —Г–±–Є—А–∞–µ—В modulo bias –Є —Г–Ї–ї–∞–і—Л–≤–∞–µ—В—Б—П –≤ 32 –±–Є—В–∞.
                [ "$raw_value" -lt 16200000 ] || continue
                printf '%06d' "$((raw_value % 900000 + 100000))"
                return 0
        done
        return 1
}

request_confirmation() {
        chat_id="$1"
        action="$2"
        title="$3"
        action_arg1="${4:--}"
        action_arg2="${5:--}"
        file="$(confirmation_file "$chat_id")" || return 1
        if ! code="$(confirmation_code)"; then
                log "Telegram confirmation code generation failed"
                send_message_to "$chat_id" "–Э–µ —Г–і–∞–ї–Њ—Б—М –±–µ–Ј–Њ–њ–∞—Б–љ–Њ —Б–Њ–Ј–і–∞—В—М –Ї–Њ–і –њ–Њ–і—В–≤–µ—А–ґ–і–µ–љ–Є—П. –Я–Њ–≤—В–Њ—А–Є—В–µ –њ–Њ–Ј–ґ–µ."
                return 1
        fi
        expires="$(($(date +%s) + 300))"

        umask 077
        pending_file="${file}.tmp.$$"
        # –Р—А–≥—Г–Љ–µ–љ—В—Л —Б–Њ—Е—А–∞–љ—П—О—В—Б—П –Њ—В–і–µ–ї—М–љ—Л–Љ–Є –њ–Њ–ї—П–Љ–Є, –∞ –љ–µ —З–∞—Б—В—М—О –Ї–Њ–Љ–∞–љ–і—Л shell.
        # –Я–Њ—Н—В–Њ–Љ—Г ID —Г—Б—В—А–Њ–є—Б—В–≤–∞ –Є –Љ–Є–љ—Г—В—Л –љ–µ–ї—М–Ј—П –њ—А–µ–≤—А–∞—В–Є—В—М –≤ –њ—А–Њ–Є–Ј–≤–Њ–ї—М–љ—Л–є –Ј–∞–њ—Г—Б–Ї. ¬Іtgconfirm
        if ! printf '%s\t%s\t%s\t%s\t%s\n' \
                "$action" "$action_arg1" "$action_arg2" "$code" "$expires" > "$pending_file"; then
                rm -f "$pending_file"
                return 1
        fi
        mv -f "$pending_file" "$file" || {
                rm -f "$pending_file"
                return 1
        }
        send_message_to "$chat_id" "–Э—Г–ґ–љ–Њ –њ–Њ–і—В–≤–µ—А–ґ–і–µ–љ–Є–µ: ${title}.

–Ф–ї—П –њ–Њ–і—В–≤–µ—А–ґ–і–µ–љ–Є—П –љ–∞–њ–Є—И–Є—В–µ:
–њ–Њ–і—В–≤–µ—А–ґ–і–∞—О ${code}

–Ъ–Њ–і –і–µ–є—Б—В–≤—Г–µ—В 5 –Љ–Є–љ—Г—В."
}

