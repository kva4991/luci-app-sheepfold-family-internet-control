#!/bin/sh
set -u

COMMAND="${1:-run}"
RUNTIME_DIR="${SHEEPFOLD_RUNTIME_DIR:-/tmp/sheepfold}"
OFFSET_FILE="$RUNTIME_DIR/telegram-update-offset"
LOG_LINE_FILE="$RUNTIME_DIR/telegram-log-line"
LOG_HELPER="/usr/libexec/sheepfold/sheepfold-log"
ROUTER_CONTROL="/usr/libexec/sheepfold/sheepfold-router-control"
UPDATER="/usr/libexec/sheepfold/sheepfold-updater"
DEFAULT_RAM_LOG="/tmp/sheepfold/events.log"
TELEGRAM_HTTP_TIMEOUT_SECONDS="${SHEEPFOLD_TELEGRAM_HTTP_TIMEOUT:-35}"

case "$TELEGRAM_HTTP_TIMEOUT_SECONDS" in ''|*[!0-9]*) TELEGRAM_HTTP_TIMEOUT_SECONDS=35 ;; esac
[ "$TELEGRAM_HTTP_TIMEOUT_SECONDS" -ge 30 ] || TELEGRAM_HTTP_TIMEOUT_SECONDS=30

mkdir -p "$RUNTIME_DIR"
chmod 700 "$RUNTIME_DIR" 2>/dev/null || true

log() {
        logger -t sheepfold-telegram "$*"
}

log_event() {
        if [ -x "$LOG_HELPER" ]; then
                "$LOG_HELPER" "$*"
        else
                log "$*"
        fi
}

global_get() {
        uci -q get "sheepfold.global.$1" 2>/dev/null || printf '%s' "$2"
}

router_name() {
        uci -q get system.@system[0].hostname 2>/dev/null || printf 'OpenWRT'
}

log_cache_path() {
        path="$(global_get log_cache_path "$DEFAULT_RAM_LOG")"
        case "$path" in
                /tmp/sheepfold/*) printf '%s\n' "$path" ;;
                *) printf '%s\n' "$DEFAULT_RAM_LOG" ;;
        esac
}

telegram_active() {
        [ "$(global_get active_messenger none)" = "telegram" ]
}

telegram_token() {
        global_get telegram_bot_token ''
}

telegram_admin_chat_id() {
        global_get telegram_admin_chat_id ''
}

fetch() {
        url="$1"
        data="${2:-}"

        if command -v uclient-fetch >/dev/null 2>&1; then
                if [ -n "$data" ]; then
                        uclient-fetch -q -T "$TELEGRAM_HTTP_TIMEOUT_SECONDS" -O- --post-data="$data" "$url" 2>/dev/null
                else
                        uclient-fetch -q -T "$TELEGRAM_HTTP_TIMEOUT_SECONDS" -O- "$url" 2>/dev/null
                fi
                return $?
        fi

        if command -v curl >/dev/null 2>&1; then
                if [ -n "$data" ]; then
                        curl -fsSL --connect-timeout 10 --max-time "$TELEGRAM_HTTP_TIMEOUT_SECONDS" --data-raw "$data" "$url" 2>/dev/null
                else
                        curl -fsSL --connect-timeout 10 --max-time "$TELEGRAM_HTTP_TIMEOUT_SECONDS" "$url" 2>/dev/null
                fi
                return $?
        fi

        if command -v wget >/dev/null 2>&1; then
                if [ -n "$data" ]; then
                        wget -q -T "$TELEGRAM_HTTP_TIMEOUT_SECONDS" -O- --post-data="$data" "$url" 2>/dev/null
                else
                        wget -q -T "$TELEGRAM_HTTP_TIMEOUT_SECONDS" -O- "$url" 2>/dev/null
                fi
                return $?
        fi

        return 127
}

form_escape() {
        sed ':a;N;$!ba;s/%/%25/g;s/&/%26/g;s/+/%2B/g;s/#/%23/g;s/=/%3D/g;s/ /%20/g;s/"/%22/g;s/{/%7B/g;s/}/%7D/g;s/\[/%5B/g;s/\]/%5D/g;s/:/%3A/g;s/,/%2C/g;s/\r//g;s/\n/%0A/g'
}

