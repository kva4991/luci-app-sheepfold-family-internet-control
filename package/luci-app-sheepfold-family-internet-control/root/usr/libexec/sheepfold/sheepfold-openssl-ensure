#!/bin/sh
set -eu

PACKAGE_MANAGER_HELPER="/usr/libexec/sheepfold/sheepfold-package-manager"
[ ! -r "$PACKAGE_MANAGER_HELPER" ] || . "$PACKAGE_MANAGER_HELPER"

uci_disable_logs() {
    uci -q set sheepfold.global.ai_individual_logs='0' 2>/dev/null || true
    uci -q commit sheepfold 2>/dev/null || true
}

openssl_works() {
    command -v openssl >/dev/null 2>&1 || return 1
    openssl version >/dev/null 2>&1 || return 1
    probe="/tmp/sheepfold-openssl-probe.$$"
    umask 077
    if ! printf 'sheepfold' | openssl enc -aes-256-cbc -pbkdf2 -salt \
        -pass pass:sheepfold-probe -out "$probe" >/dev/null 2>&1; then
        rm -f "$probe"
        return 1
    fi
    rm -f "$probe"
    return 0
}

if ! openssl_works; then
    if ! command -v sheepfold_package_manager >/dev/null 2>&1 ||
       ! sheepfold_package_manager >/dev/null 2>&1; then
        uci_disable_logs
        echo "The OpenWrt package manager is unavailable; OpenSSL could not be installed." >&2
        exit 1
    fi

    sheepfold_package_update_indexes >/dev/null 2>&1 || true
    sheepfold_package_install_named openssl-util >/dev/null 2>&1 || \
        sheepfold_package_install_named openssl >/dev/null 2>&1 || true
fi

if ! openssl_works; then
    uci_disable_logs
    echo "OpenSSL installation or verification failed; individual AI logs were disabled." >&2
    exit 1
fi

if ! /usr/libexec/sheepfold/sheepfold-key-derive >/dev/null 2>&1; then
    uci_disable_logs
    echo "Archive key initialization failed; individual AI logs were disabled." >&2
    exit 1
fi

printf 'ok\n'
