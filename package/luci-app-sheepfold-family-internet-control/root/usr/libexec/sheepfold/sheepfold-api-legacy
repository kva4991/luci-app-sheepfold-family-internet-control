#!/bin/sh
# Монолитный JSON-обработчик HTTP API Sheepfold.
# Имя *-legacy не означает «совместимость со старым релизом»: публичный вход —
# /www/cgi-bin/sheepfold-api, он маршрутизирует безопасные endpoint-ы отдельно
# и делегирует остальное сюда. До релиза это текущая реализация, а не архив.

TOKEN_COMMON="/usr/libexec/sheepfold/sheepfold-token-common"
[ -r "$TOKEN_COMMON" ] || exit 1
. "$TOKEN_COMMON"

json_escape() {
	# JSON здесь собирается POSIX shell-ом без jq, чтобы endpoint жил даже на лёгких роутерах.
	# Поэтому обязательно убираем переносы/табы и экранируем кавычки, иначе один лог сломает ответ API.
	printf '%s' "$1" | tr '\n' ' ' | sed 's/\\/\\\\/g; s/"/\\"/g; s/\r/ /g; s/\t/ /g'
}

header_json() {
	printf 'Status: %s\r\n' "$1"
	printf 'Content-Type: application/json; charset=utf-8\r\n'
	printf 'Access-Control-Allow-Origin: *\r\n'
	printf 'Access-Control-Allow-Methods: GET, POST, OPTIONS\r\n'
	printf 'Access-Control-Allow-Headers: Content-Type, Authorization, X-Sheepfold-Device-Id, X-Sheepfold-Device-Mac\r\n'
	printf '\r\n'
}

# ---------------------------------------------------------------------------
# auth_check — проверка Bearer-токена администратора.
# Токен принимается только из заголовка Authorization: Bearer.
# Передача token= в query string запрещена: она попадает в журналы и историю.
# Возвращает 0 (ok) или вызывает header_json и exit.
# ---------------------------------------------------------------------------
auth_check() {
	bearer=""

	if [ -n "$(form_get token "$QUERY_STRING")" ]; then
		header_json "400 Bad Request"
		printf '{"app":"sheepfold","ok":false,"error":"query_token_forbidden"}\n'
		exit 0
	fi

	if [ -n "${HTTP_AUTHORIZATION:-}" ]; then
		bearer="$(printf '%s' "$HTTP_AUTHORIZATION" | sed 's/^[Bb]earer[[:space:]]*//')"
	fi

	if [ -z "$bearer" ]; then
		header_json "401 Unauthorized"
		printf '{"app":"sheepfold","ok":false,"error":"auth_required","message":"Bearer token required."}\n'
		exit 0
	fi

	client_device_id="${HTTP_X_SHEEPFOLD_DEVICE_ID:-}"
	client_device_mac="${HTTP_X_SHEEPFOLD_DEVICE_MAC:-}"
	if ! token_request_source_matches "${REMOTE_ADDR:-}" "$client_device_mac"; then
		header_json "401 Unauthorized"
		printf '{"app":"sheepfold","ok":false,"error":"device_source_mismatch","message":"Administrator device source does not match the bound token."}\n'
		exit 0
	fi
	if ! token_device_is_admin_paired "$client_device_id" "$client_device_mac"; then
		# Отдельный код позволяет APK объяснить явное отвязывание устройства,
		# не принимая временную сетевую ошибку за отзыв доступа. §authrs1
		header_json "401 Unauthorized"
		printf '{"app":"sheepfold","ok":false,"error":"device_unbound","message":"Administrator device is no longer paired."}\n'
		exit 0
	fi

	# Делегируем проверку в sheepfold-router-control, который знает хэши и привязку к устройству.
	result="$(/usr/libexec/sheepfold/sheepfold-router-control check-token "$bearer" "$client_device_id" "$client_device_mac" 2>/dev/null || printf 'fail')"
	if [ "$result" != "ok" ]; then
		header_json "401 Unauthorized"
		printf '{"app":"sheepfold","ok":false,"error":"invalid_token","message":"Invalid or expired token."}\n'
		exit 0
	fi
}

router_name="$(uci -q get system.@system[0].hostname 2>/dev/null || printf OpenWrt)"
version="$(uci -q get sheepfold.global.ui_asset_version 2>/dev/null || printf unknown)"
app_port="$(uci -q get sheepfold.global.app_port 2>/dev/null || printf 5201)"
case "$app_port" in ''|*[!0-9]*) app_port=5201 ;; esac
[ "$app_port" -ge 1 ] && [ "$app_port" -le 65535 ] || app_port=5201
api_path="/cgi-bin/sheepfold-api"
http_host="${HTTP_HOST:-}"
[ -n "$http_host" ] || http_host="127.0.0.1:$app_port"
method="${REQUEST_METHOD:-GET}"
path_info="${PATH_INFO:-}"
query_string="${QUERY_STRING:-}"
remote_ip="${REMOTE_ADDR:-}"

kv_get() {
	key="$1"
	printf '%s\n' "$2" | sed -n "s/^$key=//p" | sed -n '1p'
}

json_pair() {
	key="$1"
	value="$2"
	comma="$3"
	printf '"%s":"%s"%s' "$(json_escape "$key")" "$(json_escape "$value")" "$comma"
}

url_decode() {
	value="$(printf '%s' "$1" | sed 's/+/ /g; s/%/\\x/g')"
	printf '%b' "$value"
}

MAX_REQUEST_BODY_BYTES=65536

read_request_body() {
	length="${CONTENT_LENGTH:-0}"
	case "$length" in
		''|*[!0-9]*) length=0 ;;
	esac
	[ "$length" -le "$MAX_REQUEST_BODY_BYTES" ] || return 2
	[ "$length" -gt 0 ] || return 0
	dd bs=1 count="$length" 2>/dev/null || return 1
}

read_request_body_checked() {
	body=""
	status=0

	body="$(read_request_body)" || status=$?
	case "$status" in
		2)
			header_json "413 Payload Too Large"
			printf '{"app":"sheepfold","ok":false,"error":"request_too_large","message":"Request body is too large."}\n'
			exit 0
			;;
		1)
			header_json "400 Bad Request"
			printf '{"app":"sheepfold","ok":false,"error":"body_read_failed","message":"Could not read request body."}\n'
			exit 0
			;;
	esac
	printf '%s' "$body"
}

form_get() {
	key="$1"
	body="$2"
	printf '%s' "$body" | tr '&' '\n' | while IFS='=' read -r item_key item_value; do
		[ "$item_key" = "$key" ] || continue
		url_decode "$item_value"
		break
	done
}

router_control_pair() {
	key="$1"
	printf '%s\n' "$2" | sed -n "s/^$key=//p" | sed -n '1p'
}

mask_private_context() {
	# Маскируем MAC/IP и секреты перед экспортом диагностического контекста.
	sed -E \
		-e 's/([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}/[mac]/g' \
		-e 's/([0-9]{1,3}\.){3}[0-9]{1,3}/[ip]/g' \
		-e 's/([Tt]oken|[Kk]ey|[Pp]assword|[Pp]ass|[Ss]ecret)=?[^[:space:],;]*/\1=[secret]/g'
}

# SHEEPFOLD_AI_BEGIN
program_log_context() {
	log_file="$(uci -q get sheepfold.global.log_cache_path 2>/dev/null || printf /tmp/sheepfold/events.log)"
	# Путь к журналу берётся из UCI, но для AI-контекста читаем только ожидаемую область /tmp/sheepfold.
	# Это не даёт превратить endpoint в произвольное чтение файлов через подменённый log_cache_path.
	case "$log_file" in
		/tmp/sheepfold/*) ;;
		*) log_file="/tmp/sheepfold/events.log" ;;
	esac
	if [ ! -r "$log_file" ]; then
		printf '%s' "Журнал Sheepfold недоступен или пуст."
		return 0
	fi
	tail -n 80 "$log_file" 2>/dev/null | mask_private_context
}

router_info_context() {
	/usr/libexec/sheepfold/sheepfold-router-control router-info 2>/dev/null | mask_private_context || true
}
# SHEEPFOLD_AI_END

# Android получает только итоговую возможность функции. Название провайдера и
# тем более ключ наружу не выдаются. В обычном IPK AI-handler отсутствует,
# поэтому единый APK автоматически скрывает все AI-разделы. §prodvar
# SHEEPFOLD_AI_BEGIN
ai_feature_available() {
	[ -x /usr/libexec/sheepfold/sheepfold-ai-handler ] || return 1
	[ "$(uci -q get sheepfold.global.product_variant 2>/dev/null || printf sheepfold)" = sheepfoldAi ] || return 1
	[ "$(uci -q get sheepfold.global.ai_enabled 2>/dev/null || printf 0)" = 1 ] || return 1
	provider="$(uci -q get sheepfold.global.ai_provider 2>/dev/null || printf none)"
	case "$provider" in
		deepseek) key="$(uci -q get sheepfold.global.deepseek_api_key 2>/dev/null || true)" ;;
		gemini) key="$(uci -q get sheepfold.global.gemini_api_key 2>/dev/null || true)" ;;
		grok) key="$(uci -q get sheepfold.global.grok_api_key 2>/dev/null || true)" ;;
		*) return 1 ;;
	esac
	[ -n "$key" ]
}
# SHEEPFOLD_AI_END

# ---------------------------------------------------------------------------
# client_status_json — GET /client-status
# Для детского APK. Не требует токена администратора.
# Идентифицирует устройство по IP из DHCP-аренды (REMOTE_ADDR).
# ---------------------------------------------------------------------------
client_status_json() {
	output="$(/usr/libexec/sheepfold/sheepfold-router-control client-status "$remote_ip" 2>/dev/null || true)"
	status_val="$(kv_get status "$output")"
	[ -n "$status_val" ] || status_val="unknown"
	schedule_name="$(kv_get schedule_name "$output")"
	schedule_conflict="$(kv_get schedule_conflict "$output")"
	next_change_at="$(kv_get next_change_at "$output")"
	warning_minutes="$(kv_get warning_before_minutes "$output")"
	[ -n "$warning_minutes" ] || warning_minutes="5"

	header_json "200 OK"
	printf '{"app":"sheepfold","ok":true,'
	json_pair status "$status_val" ,
	json_pair scheduleName "$schedule_name" ,
	json_pair scheduleConflict "$schedule_conflict" ,
	json_pair nextChangeAt "$next_change_at" ,
	json_pair warningBeforeMinutes "$warning_minutes" ''
	printf '}\n'
}

# ---------------------------------------------------------------------------
# devices_json — GET /devices
# Список всех устройств с их UCI-статусом. Требует авторизации.
# ---------------------------------------------------------------------------
devices_json() {
	auth_check
	output="$(/usr/libexec/sheepfold/sheepfold-router-control list-devices 2>/dev/null || true)"
	header_json "200 OK"
	printf '{"app":"sheepfold","ok":true,"devices":%s}\n' "${output:-[]}"
}

# ---------------------------------------------------------------------------
# device_action_json — POST /device/allow | /device/block | /device/temp-access
# Управление отдельным устройством. Требует авторизации.
# ---------------------------------------------------------------------------
device_action_json() {
	action="$1" # allow | block | temp-access
	auth_check
	body="$(read_request_body_checked)"
	mac="$(form_get mac "$body")"

	if [ -z "$mac" ]; then
		header_json "400 Bad Request"
		printf '{"app":"sheepfold","ok":false,"error":"mac_required","message":"Device MAC address is required."}\n'
		return 0
	fi

	# Валидация MAC — только стандартный формат XX:XX:XX:XX:XX:XX.
	# Без этой проверки mac мог бы стать shell-инъекцией в sheepfold-router-control.
	if ! printf '%s' "$mac" | grep -qE '^([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}$'; then
		header_json "400 Bad Request"
		printf '{"app":"sheepfold","ok":false,"error":"invalid_mac","message":"Invalid MAC address format."}\n'
		return 0
	fi

	# Инициализируем ctrl_status=0 явно: переменная используется после case,
	# но присваивается только при ненулевом коде выхода через «|| ctrl_status=$?».
	# Без инициализации на busybox ash «${ctrl_status:-0}» может унаследовать
	# значение из внешнего scope и ложно сигнализировать об ошибке.
	ctrl_status=0
	ctrl_result=""
	case "$action" in
		allow)
			ctrl_result="$(/usr/libexec/sheepfold/sheepfold-router-control device-allow "$mac" 2>&1)" || ctrl_status="$?"
			;;
		block)
			ctrl_result="$(/usr/libexec/sheepfold/sheepfold-router-control device-block "$mac" 2>&1)" || ctrl_status="$?"
			;;
		temp-access)
			minutes="$(form_get minutes "$body")"
			case "$minutes" in
				''|*[!0-9]*) minutes=30 ;;
			esac
			# Ограничиваем максимум — 24 часа (1440 минут).
			[ "$minutes" -le 1440 ] || minutes=1440
			ctrl_result="$(/usr/libexec/sheepfold/sheepfold-router-control device-temp-access "$mac" "$minutes" 2>&1)" || ctrl_status="$?"
			;;
	esac

	if [ "$ctrl_status" != "0" ]; then
		header_json "500 Internal Server Error"
		printf '{"app":"sheepfold","ok":false,"error":"action_failed","message":"%s"}\n' "$(json_escape "${ctrl_result:-unknown error}")"
		return 0
	fi

	header_json "200 OK"
	printf '{"app":"sheepfold","ok":true,"action":"%s","mac":"%s"}\n' \
		"$(json_escape "$action")" "$(json_escape "$mac")"
}

# ---------------------------------------------------------------------------
# global_block_json — POST /global-block
# Включить / выключить глобальную блокировку. Требует авторизации + confirm.
# ---------------------------------------------------------------------------
global_block_json() {
	auth_check
	body="$(read_request_body_checked)"
	enable="$(form_get enable "$body")"
	confirm="$(form_get confirm "$body")"

	if [ "$confirm" != "1" ]; then
		header_json "403 Forbidden"
		printf '{"app":"sheepfold","ok":false,"error":"confirmation_required","message":"Send confirm=1 to apply global block."}\n'
		return 0
	fi

	# Инициализируем явно по той же причине, что и ctrl_status в device_action_json.
	ctrl_status=0
	ctrl_result=""
	case "$enable" in
		1|true|on)
			ctrl_result="$(/usr/libexec/sheepfold/sheepfold-router-control global-block-on 2>&1)" || ctrl_status="$?"
			action_label="on"
			;;
		0|false|off)
			ctrl_result="$(/usr/libexec/sheepfold/sheepfold-router-control global-block-off 2>&1)" || ctrl_status="$?"
			action_label="off"
			;;
		*)
			# Неизвестное значение не должно отключать защиту по принципу fail-open.
			header_json "400 Bad Request"
			printf '{"app":"sheepfold","ok":false,"error":"invalid_global_block_value","message":"Enable must be 1 or 0."}\n'
			return 0
			;;
	esac

	if [ "$ctrl_status" != "0" ]; then
		header_json "500 Internal Server Error"
		printf '{"app":"sheepfold","ok":false,"error":"action_failed","message":"%s"}\n' "$(json_escape "${ctrl_result:-unknown error}")"
		return 0
	fi

	header_json "200 OK"
	printf '{"app":"sheepfold","ok":true,"globalBlock":"%s"}\n' "$(json_escape "$action_label")"
}

# ---------------------------------------------------------------------------
# log_json — GET /log
# Возвращает административный журнал. Требует авторизации.
# ---------------------------------------------------------------------------
log_json() {
	auth_check
	lines="$(form_get lines "$query_string")"
	case "$lines" in
		''|*[!0-9]*) lines=100 ;;
	esac
	[ "$lines" -le 1000 ] || lines=1000

	log_file="$(uci -q get sheepfold.global.log_cache_path 2>/dev/null || printf /tmp/sheepfold/events.log)"
	case "$log_file" in
		/tmp/sheepfold/*) ;;
		*) log_file="/tmp/sheepfold/events.log" ;;
	esac

	if [ ! -r "$log_file" ]; then
		header_json "200 OK"
		printf '{"app":"sheepfold","ok":true,"entries":[]}\n'
		return 0
	fi

	# Собираем строки как JSON-массив строк.
	# Маскируем MAC и IP — журнал может содержать приватные данные.
	#
	# ВАЖНО: while внутри пайпа запускается в subshell — переменная first=0
	# не видна снаружи и запятая никогда не печаталась бы между элементами.
	# Решение: читаем файл в переменную через $(...), итерируем уже в основном shell.
	header_json "200 OK"
	printf '{"app":"sheepfold","ok":true,"entries":['
	log_first=1
	log_lines="$(tail -n "$lines" "$log_file" 2>/dev/null | mask_private_context || true)"
	printf '%s\n' "$log_lines" | while IFS= read -r line; do
		[ -n "$line" ] || continue
		if [ "$log_first" = "1" ]; then
			log_first=0
		else
			printf ','
		fi
		printf '"%s"' "$(json_escape "$line")"
	done
	printf ']}\n'
}

# ---------------------------------------------------------------------------
# log_clear_json — POST /log/clear
# Очищает журнал после подтверждения. Требует авторизации + confirm.
# ---------------------------------------------------------------------------
log_clear_json() {
	auth_check
	body="$(read_request_body_checked)"
	confirm="$(form_get confirm "$body")"

	if [ "$confirm" != "1" ]; then
		header_json "403 Forbidden"
		printf '{"app":"sheepfold","ok":false,"error":"confirmation_required","message":"Send confirm=1 to clear the log."}\n'
		return 0
	fi

	log_file="$(uci -q get sheepfold.global.log_cache_path 2>/dev/null || printf /tmp/sheepfold/events.log)"
	case "$log_file" in
		/tmp/sheepfold/*) ;;
		*) log_file="/tmp/sheepfold/events.log" ;;
	esac

	: > "$log_file" 2>/dev/null || true

	header_json "200 OK"
	printf '{"app":"sheepfold","ok":true,"message":"Log cleared."}\n'
}

feedback_json() {
	auth_check
	body="$(read_request_body_checked)"
	category="$(form_get category "$body")"
	subject="$(form_get subject "$body")"
	message="$(form_get message "$body")"
	contact="$(form_get contact "$body")"
	include_diagnostics="$(form_get includeDiagnostics "$body")"
	[ -n "$include_diagnostics" ] || include_diagnostics=0

	if output="$(/usr/libexec/sheepfold/sheepfold-router-control feedback-submit android \
		"$category" "$subject" "$message" "$contact" "$include_diagnostics" 2>&1)"; then
		header_json "200 OK"
		printf '{"app":"sheepfold","ok":true,"message":"Feedback sent."}\n'
		return 0
	fi

	case "$output" in
		*rate_limited*) status="429 Too Many Requests"; error="rate_limited"; message_text="Too many messages. Try again later." ;;
		*not_configured*) status="503 Service Unavailable"; error="feedback_not_configured"; message_text="Feedback sending is not configured." ;;
		*invalid_*) status="400 Bad Request"; error="invalid_feedback"; message_text="Check the feedback fields." ;;
		*) status="502 Bad Gateway"; error="feedback_delivery_failed"; message_text="Could not deliver feedback. Try again later." ;;
	esac
	header_json "$status"
	printf '{"app":"sheepfold","ok":false,"error":"%s","message":"%s"}\n' "$error" "$message_text"
}

# ---------------------------------------------------------------------------
# router_info_json — GET /router-info
# Диагностический снимок. Без секретов.
# ---------------------------------------------------------------------------
router_info_json() {
	info="$(/usr/libexec/sheepfold/sheepfold-router-control router-info 2>/dev/null || true)"
	wifi_count="$(kv_get wifi_count "$info")"
	[ -n "$wifi_count" ] || wifi_count=0
	ai_available=false
	# SHEEPFOLD_AI_BEGIN
	ai_feature_available && ai_available=true
	# SHEEPFOLD_AI_END
	# SHEEPFOLD_AI_BEGIN
	ai_summary="Router model: $(kv_get router_model "$info"); firmware: $(kv_get firmware_version "$info"); Sheepfold: $(kv_get sheepfold_version "$info"); internet: $(kv_get internet_status "$info") ($(kv_get internet_reason "$info")); ping to ya.ru: $(kv_get ping_yandex_ms "$info") ms; Wi-Fi modules: $wifi_count; LAN ports: $(kv_get lan_ports_count "$info"); Podkop: $(kv_get podkop_installed "$info") $(kv_get podkop_version "$info"); AdGuard Home: $(kv_get adguard_installed "$info") $(kv_get adguard_version "$info"); uptime: $(kv_get uptime "$info"); load: $(kv_get load_average "$info"); memory: $(kv_get memory "$info")."
	# SHEEPFOLD_AI_END

	header_json "200 OK"
	printf '{"app":"sheepfold","ok":true,"routerName":"%s","diagnostics":{' "$(json_escape "$router_name")"
	json_pair currentTime "$(kv_get current_time "$info")" ,
	json_pair sheepfoldVersion "$(kv_get sheepfold_version "$info")" ,
	json_pair internetStatus "$(kv_get internet_status "$info")" ,
	json_pair internetReason "$(kv_get internet_reason "$info")" ,
	json_pair globalBlocked "$(uci -q get sheepfold.global.block_on_boot 2>/dev/null || printf 0)" ,
	json_pair pingYandexMs "$(kv_get ping_yandex_ms "$info")" ,
	json_pair firmwareVersion "$(kv_get firmware_version "$info")" ,
	json_pair openwrtRelease "$(kv_get openwrt_release "$info")" ,
	json_pair kernelVersion "$(kv_get kernel_version "$info")" ,
	json_pair routerModel "$(kv_get router_model "$info")" ,
	json_pair uptime "$(kv_get uptime "$info")" ,
	json_pair loadAverage "$(kv_get load_average "$info")" ,
	json_pair memory "$(kv_get memory "$info")" ,
	json_pair lanPortsCount "$(kv_get lan_ports_count "$info")" ,
	json_pair lanPorts "$(kv_get lan_ports "$info")" ,
	json_pair podkopInstalled "$(kv_get podkop_installed "$info")" ,
	json_pair podkopVersion "$(kv_get podkop_version "$info")" ,
	json_pair adguardInstalled "$(kv_get adguard_installed "$info")" ,
	json_pair adguardVersion "$(kv_get adguard_version "$info")" ''
	printf '},"wifiModules":['
	i=1
	while [ "$i" -le "$wifi_count" ]; do
		[ "$i" = "1" ] || printf ','
		printf '{'
		json_pair name "$(kv_get "wifi_${i}_name" "$info")" ,
		json_pair status "$(kv_get "wifi_${i}_status" "$info")" ,
		json_pair type "$(kv_get "wifi_${i}_type" "$info")" ,
		json_pair path "$(kv_get "wifi_${i}_path" "$info")" ,
		json_pair band "$(kv_get "wifi_${i}_band" "$info")" ,
		json_pair channel "$(kv_get "wifi_${i}_channel" "$info")" ,
		json_pair country "$(kv_get "wifi_${i}_country" "$info")" ,
		json_pair mode "$(kv_get "wifi_${i}_mode" "$info")" ''
		printf '}'
		i=$((i + 1))
	done
	printf ']'
	# SHEEPFOLD_AI_BEGIN
	printf ',"aiContextPreview":"%s"' "$(json_escape "$ai_summary")"
	# SHEEPFOLD_AI_END
	printf ',"capabilities":{"aiAssistant":%s}}\n' "$ai_available"
}

# ---------------------------------------------------------------------------
# pair_admin_device_json — POST /pair
# ---------------------------------------------------------------------------
pair_admin_device_json() {
	body="$(read_request_body_checked)"
	login="$(form_get login "$body")"
	code="$(form_get code "$body")"
	user_agent="${HTTP_USER_AGENT:-Android Sheepfold}"
	output=""
	status=0

	output="$(/usr/libexec/sheepfold/sheepfold-router-control pair-admin-device "$login" "$code" "$remote_ip" "$user_agent" 2>&1)" || status="$?"

	if [ "$status" != "0" ]; then
		header_json "403 Forbidden"
		printf '{"app":"sheepfold","ok":false,"paired":false,"error":"%s"}\n' "$(json_escape "$output")"
		return 0
	fi

	header_json "200 OK"
	printf '{"app":"sheepfold","ok":true,"paired":true,"routerName":"%s",' "$(json_escape "$router_name")"
	json_pair adminName "$(router_control_pair admin_name "$output")" ,
	json_pair adminLogin "$(router_control_pair admin_login "$output")" ,
	json_pair deviceName "$(router_control_pair device_name "$output")" ,
	json_pair mac "$(router_control_pair mac "$output")" ,
	json_pair ip "$(router_control_pair ip "$output")" ''
	printf '}\n'
}

# ---------------------------------------------------------------------------
# pair_status_json — GET /pair-status
# ---------------------------------------------------------------------------
pair_status_json() {
	login="$(form_get login "$query_string")"
	since="$(form_get since "$query_string")"

	if [ -z "$login" ]; then
		header_json "400 Bad Request"
		printf '{"app":"sheepfold","ok":false,"error":"login_required","message":"Administrator login is required."}\n'
		return 0
	fi

	case "$since" in
		''|*[!0-9]*) since=0 ;;
	esac

	output="$(/usr/libexec/sheepfold/sheepfold-router-control admin-pairing-status "$login" "$since" 2>/dev/null || true)"
	paired="$(kv_get paired "$output")"

	header_json "200 OK"
	if [ "$paired" = "1" ]; then
		printf '{"app":"sheepfold","ok":true,"paired":true,"routerName":"%s",' "$(json_escape "$router_name")"
		json_pair adminName "$(kv_get admin_name "$output")" ,
		json_pair adminLogin "$(kv_get admin_login "$output")" ,
		json_pair deviceName "$(kv_get device_name "$output")" ,
		json_pair mac "$(kv_get mac "$output")" ,
		json_pair pairedAt "$(kv_get paired_at "$output")" ''
		printf '}\n'
	else
		printf '{"app":"sheepfold","ok":true,"paired":false,"routerName":"%s"}\n' \
			"$(json_escape "$router_name")"
	fi
}

