# ---------------------------------------------------------------------------
# ai_assistant_json — POST /ai-assistant
# ---------------------------------------------------------------------------
deepseek_request() {
	payload="$1"
	api_key="$(uci -q get sheepfold.global.deepseek_api_key 2>/dev/null || true)"
	api_url="$(uci -q get sheepfold.global.deepseek_api_url 2>/dev/null || printf 'https://api.deepseek.com/chat/completions')"

	if [ -z "$api_key" ]; then
		header_json "400 Bad Request"
		printf '{"app":"sheepfold","ok":false,"error":"deepseek_api_key_missing","message":"DeepSeek API key is not configured on the router."}\n'
		return 0
	fi

	status=0
	if command -v uclient-fetch >/dev/null 2>&1; then
		response="$(uclient-fetch -qO- --header="Content-Type: application/json" --header="Authorization: Bearer $api_key" --post-data="$payload" "$api_url" 2>&1)" || status="$?"
	elif command -v wget >/dev/null 2>&1; then
		response="$(wget -q -O - --header="Content-Type: application/json" --header="Authorization: Bearer $api_key" --post-data="$payload" "$api_url" 2>&1)" || status="$?"
	elif command -v curl >/dev/null 2>&1; then
		response="$(curl -fsS -H "Content-Type: application/json" -H "Authorization: Bearer $api_key" --data "$payload" "$api_url" 2>&1)" || status="$?"
	else
		header_json "500 Internal Server Error"
		printf '{"app":"sheepfold","ok":false,"error":"http_client_missing","message":"Install uclient-fetch, wget, or curl on the router."}\n'
		return 0
	fi

	if [ "${status:-0}" != "0" ]; then
		header_json "502 Bad Gateway"
		printf '{"app":"sheepfold","ok":false,"error":"deepseek_request_failed","message":"%s"}\n' "$(json_escape "$response")"
		return 0
	fi

	header_json "200 OK"
	printf '%s\n' "$response"
}

gemini_request() {
	payload="$1"
	model="$2"
	api_key="$(uci -q get sheepfold.global.gemini_api_key 2>/dev/null || true)"
	api_url="$(uci -q get sheepfold.global.gemini_api_url 2>/dev/null || printf 'https://generativelanguage.googleapis.com/v1beta/models')"
	status=0

	if [ -z "$api_key" ]; then
		header_json "400 Bad Request"
		printf '{"app":"sheepfold","ok":false,"error":"gemini_api_key_missing","message":"Gemini API key is not configured on the router."}\n'
		return 0
	fi

	case "$api_url" in
		*:generateContent*) ;;
		*) api_url="${api_url%/}/$model:generateContent" ;;
	esac

	if command -v uclient-fetch >/dev/null 2>&1; then
		response="$(uclient-fetch -qO- --header="Content-Type: application/json" --header="x-goog-api-key: $api_key" --post-data="$payload" "$api_url" 2>&1)" || status="$?"
	elif command -v wget >/dev/null 2>&1; then
		response="$(wget -q -O - --header="Content-Type: application/json" --header="x-goog-api-key: $api_key" --post-data="$payload" "$api_url" 2>&1)" || status="$?"
	elif command -v curl >/dev/null 2>&1; then
		response="$(curl -fsS -H "Content-Type: application/json" -H "x-goog-api-key: $api_key" --data "$payload" "$api_url" 2>&1)" || status="$?"
	else
		header_json "500 Internal Server Error"
		printf '{"app":"sheepfold","ok":false,"error":"http_client_missing","message":"Install uclient-fetch, wget, or curl on the router."}\n'
		return 0
	fi

	if [ "${status:-0}" != "0" ]; then
		header_json "502 Bad Gateway"
		printf '{"app":"sheepfold","ok":false,"error":"gemini_request_failed","message":"%s"}\n' "$(json_escape "$response")"
		return 0
	fi

	header_json "200 OK"
	printf '%s\n' "$response"
}

ai_assistant_json() {
	body="$(read_request_body_checked)"
	provider="$(form_get provider "$body")"
	model="$(form_get model "$body")"
	parent_text="$(form_get message "$body")"
	include_info="$(form_get includeInfo "$body")"
	include_logs="$(form_get includeLogs "$body")"
	google_account="$(form_get googleAccount "$body")"
	context_text=""
	user_text=""
	system_prompt="Ты ИИ-помощник Sheepfold для родителя. Помогай спокойно разбирать семейные правила интернета, не ставь диагнозы, не изображай психотерапевта, не провоцируй наказания и скандалы. Если видно, что родитель не понимает тревоги и личность ребёнка, мягко направь разговор к причинам конфликта, страхам ребёнка и постепенной передаче самоконтроля. Если вопрос связан с риском для жизни, насилием, суицидом, наркотиками, экстремизмом или тяжёлым состоянием ребёнка, советуй обратиться к очному специалисту или экстренным службам. Не раскрывай технические данные ради любопытства; используй журнал и диагностику только для практического совета родителю."

	[ -n "$provider" ] || provider="$(uci -q get sheepfold.global.ai_provider 2>/dev/null || true)"
	if [ -z "$model" ]; then
		case "$provider" in
			# Модели по умолчанию — актуальные бесплатные/дешёвые варианты каждого провайдера.
			# gemini-3.5-flash и deepseek-v4-flash не существуют; правильные имена ниже.
			gemini) model="$(uci -q get sheepfold.global.gemini_model 2>/dev/null || printf gemini-2.0-flash)" ;;
			*) model="$(uci -q get sheepfold.global.deepseek_model 2>/dev/null || printf deepseek-chat)" ;;
		esac
	fi

	if [ -z "$parent_text" ]; then
		header_json "400 Bad Request"
		printf '{"app":"sheepfold","ok":false,"error":"empty_message","message":"Question text is required."}\n'
		return 0
	fi

	if [ "$include_info" = "1" ]; then
		# Дополнительный контекст отправляется только после явной галочки в APK.
		# Даже после этого router_info_context проходит через mask_ai_context.
		context_text="$context_text\n\n[Информация со страницы Sheepfold]\n$(router_info_context)"
	fi

	if [ "$include_logs" = "1" ]; then
		# Журнал нужен ИИ только как материал для спокойного совета родителю.
		context_text="$context_text\n\n[Журнал программы Sheepfold, последние записи, чувствительные поля скрыты]\n$(program_log_context)"
	fi

	if [ -n "$google_account" ]; then
		context_text="$context_text\n\n[Аккаунт родителя в Android]\n$google_account"
	fi

	user_text="$parent_text$context_text"

	case "$provider" in
		deepseek)
			payload="$(printf '{"model":"%s","messages":[{"role":"system","content":"%s"},{"role":"user","content":"%s"}],"temperature":0.4}' \
				"$(json_escape "$model")" \
				"$(json_escape "$system_prompt")" \
				"$(json_escape "$user_text")")"
			deepseek_request "$payload"
			;;
		gemini)
			payload="$(printf '{"systemInstruction":{"parts":[{"text":"%s"}]},"contents":[{"role":"user","parts":[{"text":"%s"}]}],"generationConfig":{"temperature":0.4}}' \
				"$(json_escape "$system_prompt")" \
				"$(json_escape "$user_text")")"
			gemini_request "$payload" "$(json_escape "$model")"
			;;
		*)
			header_json "400 Bad Request"
			printf '{"app":"sheepfold","ok":false,"error":"provider_not_supported","message":"AI provider is not supported yet."}\n'
			;;
	esac
}
# SHEEPFOLD_AI_END

# ===========================================================================
# Маршрутизация запросов
# ===========================================================================
blocked_public_path() {
	case "$path_info" in
		/pair-token)
			header_json "404 Not Found"
			printf '{"app":"sheepfold","ok":false,"error":"unknown_action"}\n'
			exit 0
			;;
		/settings/save)
			header_json "410 Gone"
			printf '{"app":"sheepfold","ok":false,"error":"legacy_settings_writer_disabled","message":"Use authenticated LuCI UCI forms with typed validation."}\n'
			exit 0
			;;
	esac
}

blocked_public_path

case "$method" in
	OPTIONS)
		header_json "204 No Content"
		exit 0
		;;
	GET)
		case "$path_info" in
			/router-info)
				router_info_json
				;;
			/client-status)
				# Детский APK — без авторизации, идентификация по IP.
				client_status_json
				;;
			/devices)
				devices_json
				;;
			/pair-status)
				pair_status_json
				;;
			/log)
				log_json
				;;
			*)
				# Корневой GET — discovery endpoint.
				header_json "200 OK"
				printf '{"app":"sheepfold","ok":true,"service":"sheepfold","routerName":"%s","version":"%s","appPort":"%s","apiPath":"%s","apiUrl":"https://%s%s"}\n' \
					"$(json_escape "$router_name")" "$(json_escape "$version")" \
					"$(json_escape "$app_port")" "$(json_escape "$api_path")" \
					"$(json_escape "$http_host")" "$(json_escape "$api_path")"
				;;
		esac
		;;
	POST)
		case "$path_info" in
			/pair)
				pair_admin_device_json
				;;
			/device/allow)
				device_action_json allow
				;;
			/device/block)
				device_action_json block
				;;
			/device/temp-access)
				device_action_json temp-access
				;;
			/global-block)
				global_block_json
				;;
			/log/clear)
				log_clear_json
				;;
			/feedback)
				feedback_json
				;;
			# SHEEPFOLD_AI_BEGIN
			/ai-assistant)
				ai_assistant_json
				;;
			# SHEEPFOLD_AI_END
			*)
				header_json "404 Not Found"
				printf '{"app":"sheepfold","ok":false,"error":"unknown_action","path":"%s"}\n' "$(json_escape "$path_info")"
				;;
		esac
		;;
	*)
		header_json "405 Method Not Allowed"
		printf '{"app":"sheepfold","ok":false,"error":"method_not_allowed"}\n'
		;;
esac
