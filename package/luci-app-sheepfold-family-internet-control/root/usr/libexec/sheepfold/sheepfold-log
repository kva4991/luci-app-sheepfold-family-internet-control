#!/bin/sh
set -eu

LOCK_COMMON="${SHEEPFOLD_LOCK_COMMON:-${0%/*}/sheepfold-lock-common}"
[ -r "$LOCK_COMMON" ] || LOCK_COMMON=/usr/libexec/sheepfold/sheepfold-lock-common
. "$LOCK_COMMON"
LOG_LOCK="${SHEEPFOLD_LOG_LOCK:-/tmp/sheepfold/log-maintenance.flock}"

DEFAULT_LOG="/tmp/sheepfold/events.log"
USB_MOUNT_POINT="/mnt/sheepfold-usb"
USB_LOG_DIR="${USB_MOUNT_POINT}/sheepfold/logs"
YANDEX_PUSH="/usr/libexec/sheepfold/sheepfold-yandex-disk"
GOOGLE_PUSH="/usr/libexec/sheepfold/sheepfold-google-drive"
YANDEX_PUSH_LOCK="/tmp/sheepfold/.yandex-push.scheduled"
YANDEX_PUSH_STAMP="/tmp/sheepfold/.yandex-push.last"
GOOGLE_PUSH_LOCK="/tmp/sheepfold/.google-push.scheduled"
GOOGLE_PUSH_STAMP="/tmp/sheepfold/.google-push.last"
CLOUD_PUSH_INTERVAL=300
MESSAGE="${*:-}"

log_path() {
        path="$(uci -q get sheepfold.global.log_cache_path 2>/dev/null || printf '%s' "$DEFAULT_LOG")"
        case "$path" in
                /tmp/*) printf '%s\n' "$path" ;;
                *) printf '%s\n' "$DEFAULT_LOG" ;;
        esac
}

log_storage_backend() {
        uci -q get sheepfold.global.log_storage 2>/dev/null || printf ram
}

mirror_to_usb() {
        line="$1"

        case "$(log_storage_backend)" in
                usb) ;;
                *) return 0 ;;
        esac

        grep -q " ${USB_MOUNT_POINT} " /proc/mounts 2>/dev/null || return 0
        mkdir -p "$USB_LOG_DIR" 2>/dev/null || return 0
        printf '%s\n' "$line" >> "${USB_LOG_DIR}/events.log"
        chmod 600 "${USB_LOG_DIR}/events.log" 2>/dev/null || true
}

schedule_yandex_push() {
        now=0
        last=0

        case "$(log_storage_backend)" in
                yandex_disk) ;;
                *) return 0 ;;
        esac

        [ -x "$YANDEX_PUSH" ] || return 0
        [ -f "$YANDEX_PUSH_LOCK" ] && return 0

        now="$(date +%s 2>/dev/null || printf 0)"
        case "$now" in ''|*[!0-9]*) now=0 ;; esac

        if [ -f "$YANDEX_PUSH_STAMP" ]; then
                last="$(cat "$YANDEX_PUSH_STAMP" 2>/dev/null || printf 0)"
                case "$last" in ''|*[!0-9]*) last=0 ;; esac
        fi

        if [ "$now" -gt 0 ] && [ "$last" -gt 0 ] && [ $((now - last)) -lt "$CLOUD_PUSH_INTERVAL" ]; then
                return 0
        fi

        mkdir -p /tmp/sheepfold 2>/dev/null || true
        : >"$YANDEX_PUSH_LOCK"

        (
                "$YANDEX_PUSH" push-events >/dev/null 2>&1 || true
                date +%s >"$YANDEX_PUSH_STAMP" 2>/dev/null || true
                rm -f "$YANDEX_PUSH_LOCK"
        ) &
}

schedule_google_push() {
        now=0
        last=0

        case "$(log_storage_backend)" in
                google_drive) ;;
                *) return 0 ;;
        esac

        [ -x "$GOOGLE_PUSH" ] || return 0
        [ -f "$GOOGLE_PUSH_LOCK" ] && return 0

        now="$(date +%s 2>/dev/null || printf 0)"
        case "$now" in ''|*[!0-9]*) now=0 ;; esac

        if [ -f "$GOOGLE_PUSH_STAMP" ]; then
                last="$(cat "$GOOGLE_PUSH_STAMP" 2>/dev/null || printf 0)"
                case "$last" in ''|*[!0-9]*) last=0 ;; esac
        fi

        if [ "$now" -gt 0 ] && [ "$last" -gt 0 ] && [ $((now - last)) -lt "$CLOUD_PUSH_INTERVAL" ]; then
                return 0
        fi

        mkdir -p /tmp/sheepfold 2>/dev/null || true
        : >"$GOOGLE_PUSH_LOCK"

        (
                "$GOOGLE_PUSH" push-events >/dev/null 2>&1 || true
                date +%s >"$GOOGLE_PUSH_STAMP" 2>/dev/null || true
                rm -f "$GOOGLE_PUSH_LOCK"
        ) &
}

[ -n "$MESSAGE" ] || exit 0

LOG_FILE="$(log_path)"
LOG_DIR="${LOG_FILE%/*}"
mkdir -p "$LOG_DIR"
chmod 700 "$LOG_DIR" 2>/dev/null || true

SAFE_MESSAGE="$(printf '%s' "$MESSAGE" | tr '\r\n\t' '   ' | cut -c1-4096)"
LINE="$(printf '%s\t%s' "$(date '+%d.%m.%Y %H:%M:%S')" "$SAFE_MESSAGE")"
append_log_line() (
        sheepfold_lock_acquire "$LOG_LOCK" 5 || return 1
        trap 'sheepfold_lock_release' EXIT HUP INT TERM
        printf '%s\n' "$LINE" >> "$LOG_FILE"
        chmod 600 "$LOG_FILE" 2>/dev/null || true
        mirror_to_usb "$LINE"
)
if ! append_log_line; then
        logger -t sheepfold "Could not append Sheepfold event log under lock" 2>/dev/null || true
fi
logger -t sheepfold "$SAFE_MESSAGE" 2>/dev/null || true

schedule_yandex_push
schedule_google_push
