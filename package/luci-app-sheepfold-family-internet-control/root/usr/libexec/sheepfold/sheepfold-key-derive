#!/bin/sh
# sheepfold-key-derive
#
# Итоговый ключ приватных архивов собирается из двух случайных компонентов,
# хранящихся отдельно в /etc/sheepfold с правами только для root:
#
#   KEY_PART  — /etc/sheepfold/.kp
#   APP_SALT  — /etc/sheepfold/.app_salt
#   FINAL_KEY = sha256(KEY_PART ":" APP_SALT)
#
# Оба компонента создаются лениво и атомарно при первом обращении. В пакет
# никогда не встраивается общая соль, поэтому обновление пакета не меняет ключ.
# Вывод: hex-строка итогового ключа в stdout.

set -eu

STATE_DIR="/etc/sheepfold"
KEY_PART_FILE="$STATE_DIR/.kp"
SALT_FILE="$STATE_DIR/.app_salt"

random_hex_32() {
    dd if=/dev/urandom bs=32 count=1 2>/dev/null | od -An -tx1 | tr -d ' \n'
}

ensure_secret_file() {
    target="$1"
    [ -s "$target" ] && return 0

    umask 077
    mkdir -p "$STATE_DIR"
    chmod 700 "$STATE_DIR"

    tmp="$target.tmp.$$"
    trap 'rm -f "$tmp"' EXIT HUP INT TERM
    random_hex_32 > "$tmp"
    [ "$(wc -c < "$tmp" | tr -d ' ')" -eq 64 ] || {
        echo "Failed to generate Sheepfold key material." >&2
        exit 1
    }
    chmod 600 "$tmp"
    mv -f "$tmp" "$target"
    trap - EXIT HUP INT TERM
}

ensure_key_material() {
    ensure_secret_file "$KEY_PART_FILE"
    ensure_secret_file "$SALT_FILE"
    chmod 600 "$KEY_PART_FILE" "$SALT_FILE"
}

derive() {
    command -v openssl >/dev/null 2>&1 || {
        echo "OpenSSL is required to derive the Sheepfold archive key." >&2
        exit 1
    }

    ensure_key_material
    key_part="$(cat "$KEY_PART_FILE")"
    app_salt="$(cat "$SALT_FILE")"

    [ ${#key_part} -eq 64 ] && [ ${#app_salt} -eq 64 ] || {
        echo "Sheepfold key material is invalid." >&2
        exit 1
    }

    printf '%s:%s' "$key_part" "$app_salt" | \
        openssl dgst -sha256 -hex 2>/dev/null | awk '{print $NF}'
}

derive
