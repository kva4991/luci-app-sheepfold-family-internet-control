#!/bin/sh
# sheepfold-key-derive
# Итоговый ключ собирается из двух случайных компонентов в /etc/sheepfold.

set -eu

STATE_DIR="/etc/sheepfold"
KEY_PART_FILE="$STATE_DIR/.kp"
SALT_FILE="$STATE_DIR/.app_salt"
LOCK_DIR="$STATE_DIR/.key-derive.lock"

random_hex_32() {
    dd if=/dev/urandom bs=32 count=1 2>/dev/null | od -An -tx1 | tr -d ' \n'
}

acquire_lock() {
    umask 077
    mkdir -p "$STATE_DIR"
    chmod 700 "$STATE_DIR"
    attempts=0
    while ! mkdir "$LOCK_DIR" 2>/dev/null; do
        attempts=$((attempts + 1))
        [ "$attempts" -lt 30 ] || {
            echo "Sheepfold key initialization is busy." >&2
            exit 1
        }
        sleep 1
    done
    trap 'rmdir "$LOCK_DIR" 2>/dev/null || true' EXIT HUP INT TERM
}

release_lock() {
    rmdir "$LOCK_DIR" 2>/dev/null || true
    trap - EXIT HUP INT TERM
}

ensure_secret_file() {
    target="$1"
    [ -s "$target" ] && return 0

    tmp="$target.tmp.$$"
    random_hex_32 > "$tmp"
    [ "$(wc -c < "$tmp" | tr -d ' ')" -eq 64 ] || {
        rm -f "$tmp"
        echo "Failed to generate Sheepfold key material." >&2
        exit 1
    }
    chmod 600 "$tmp"
    # Lock гарантирует, что два процесса не смешают компоненты разных генераций.
    mv -f "$tmp" "$target"
}

ensure_key_material() {
    ensure_secret_file "$KEY_PART_FILE"
    ensure_secret_file "$SALT_FILE"
    chmod 600 "$KEY_PART_FILE" "$SALT_FILE"
}

derive() {
    command -v openssl >/dev/null 2>&1 || {
        echo "OpenSSL is required to derive the Sheepfold archive key." >&2
        exit 1
    }

    acquire_lock
    ensure_key_material
    key_part="$(cat "$KEY_PART_FILE")"
    app_salt="$(cat "$SALT_FILE")"

    [ ${#key_part} -eq 64 ] && [ ${#app_salt} -eq 64 ] || {
        echo "Sheepfold key material is invalid." >&2
        exit 1
    }

    printf '%s:%s' "$key_part" "$app_salt" | \
        openssl dgst -sha256 -hex 2>/dev/null | awk '{print $NF}'
    release_lock
}

derive
