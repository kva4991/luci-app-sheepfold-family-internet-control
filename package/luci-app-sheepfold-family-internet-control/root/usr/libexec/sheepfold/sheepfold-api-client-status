#!/bin/sh
set -eu

json_escape() {
    printf '%s' "$1" | tr '\n\r\t' '   ' | sed 's/\\/\\\\/g; s/"/\\"/g'
}

kv_get() {
    key="$1"
    printf '%s\n' "$2" | sed -n "s/^$key=//p" | sed -n '1p'
}

header_json() {
    printf 'Status: %s\r\n' "$1"
    printf 'Content-Type: application/json; charset=utf-8\r\n'
    printf 'Cache-Control: no-store\r\n\r\n'
}

normalize_mac() { printf '%s' "$1" | tr '[:lower:]' '[:upper:]'; }

# Детское приложение получает только итоговый флаг доступности. Проверка
# повторяется на backend при каждом AI-запросе, поэтому поле не является
# разрешением само по себе. §prodvar
# SHEEPFOLD_AI_BEGIN
ai_feature_available() {
    [ -x /usr/libexec/sheepfold/sheepfold-ai-handler ] || return 1
    [ "$(uci -q get sheepfold.global.product_variant 2>/dev/null || printf sheepfold)" = sheepfoldAi ] || return 1
    [ "$(uci -q get sheepfold.global.ai_enabled 2>/dev/null || printf 0)" = 1 ] || return 1
    provider="$(uci -q get sheepfold.global.ai_provider 2>/dev/null || printf none)"
    case "$provider" in
        deepseek) key="$(uci -q get sheepfold.global.deepseek_api_key 2>/dev/null || true)" ;;
        gemini) key="$(uci -q get sheepfold.global.gemini_api_key 2>/dev/null || true)" ;;
        grok) key="$(uci -q get sheepfold.global.grok_api_key 2>/dev/null || true)" ;;
        *) return 1 ;;
    esac
    [ -n "$key" ]
}
# SHEEPFOLD_AI_END

mac_for_ip() {
    client_ip="$1"
    mac=""
    [ ! -r /tmp/dhcp.leases ] || mac="$(awk -v ip="$client_ip" '$3 == ip { print toupper($2); exit }' /tmp/dhcp.leases)"
    [ -n "$mac" ] || [ ! -r /proc/net/arp ] || mac="$(awk -v ip="$client_ip" '$1 == ip { print toupper($4); exit }' /proc/net/arp)"
    normalize_mac "$mac"
}

device_section_for_mac() {
    wanted="$(normalize_mac "$1")"
    for section in $(uci -q show sheepfold 2>/dev/null | sed -n 's/^sheepfold\.\([^.=]*\)=device$/\1/p'); do
        existing="$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)"
        [ "$(normalize_mac "$existing")" = "$wanted" ] || continue
        printf '%s\n' "$section"
        return 0
    done
    return 1
}

# SHEEPFOLD_AI_BEGIN
personal_group_for_device() {
    section="$1"
    mac="$(normalize_mac "$2")"
    device_group="$(uci -q get "sheepfold.$section.group" 2>/dev/null || true)"

    # Это подсказка для детского APK, а не источник доверия. Финальную проверку
    # при каждом запросе выполняет sheepfold-ai-gate.
    for group_section in $(uci -q show sheepfold 2>/dev/null | sed -n 's/^sheepfold\.\([^.=]*\)=personal_group$/\1/p'); do
        for existing in $(uci -q get "sheepfold.$group_section.deviceMac" 2>/dev/null || true); do
            [ "$(normalize_mac "$existing")" = "$mac" ] || continue
            uci -q get "sheepfold.$group_section.displayName" 2>/dev/null || \
                uci -q get "sheepfold.$group_section.name" 2>/dev/null || \
                printf '%s' "$group_section"
            return 0
        done
    done

    [ -n "$device_group" ] || return 1
    for group_section in $(uci -q show sheepfold 2>/dev/null | sed -n 's/^sheepfold\.\([^.=]*\)=group$/\1/p'); do
        [ "$(uci -q get "sheepfold.$group_section.personal" 2>/dev/null || printf 0)" = 1 ] || continue
        group_name="$(uci -q get "sheepfold.$group_section.name" 2>/dev/null || printf '%s' "$group_section")"
        [ "$device_group" = "$group_section" ] || [ "$device_group" = "$group_name" ] || continue
        printf '%s' "$group_name"
        return 0
    done

    return 1
}
# SHEEPFOLD_AI_END

remote_ip="${REMOTE_ADDR:-${1:-}}"
output="$(/usr/libexec/sheepfold/sheepfold-router-control client-status "$remote_ip" 2>/dev/null || true)"
status="$(kv_get status "$output")"
reason="$(kv_get reason "$output")"
schedule_conflict="$(kv_get schedule_conflict "$output")"
access_ends_at="$(kv_get next_change_at "$output")"
next_access_change_time="$(kv_get next_change_time "$output")"
[ -n "$status" ] || status=unknown
[ "$schedule_conflict" = 1 ] || schedule_conflict=0

case "$status" in
    allow|allowed|enabled|online)
        internet_state=enabled
        access_mode=allowlist
        if [ "$reason" = schedule_conflict_internet_on ]; then
            access_mode=scheduled
            message="Расписания конфликтуют; согласно настройке интернет оставлен включённым."
        elif [ "$reason" = schedule_allow ]; then
            access_mode=scheduled
            message="Интернет разрешён действующим расписанием."
        elif [ "$reason" = new_device_policy_allow ]; then
            access_mode=default
            message="Интернет разрешён настройкой для новых устройств."
        else
            message="Интернет доступен."
        fi
        ;;
    block|blocked|deny|denied|disabled|offline)
        internet_state=disabled
        access_mode=blocked
        case "$reason" in schedule_block|schedule_conflict_internet_off) access_mode=scheduled ;; esac
        case "$reason" in
            global_block) message="Интернет отключён общей семейной блокировкой." ;;
            blocklist) message="Устройство находится в чёрном списке устройств." ;;
            schedule_conflict_internet_off) message="Расписания конфликтуют; согласно настройке интернет оставлен выключенным." ;;
            *) message="Интернет ограничен правилами Sheepfold." ;;
        esac
        ;;
    temporary|temp-access|temp_access|temporary_access)
        internet_state=enabled
        access_mode=temporary
        message="Действует временный доступ."
        ;;
    scheduled)
        # Пока вычислитель расписания не вернул фактический результат, нельзя
        # сообщать ребёнку, что интернет подтверждённо включён.
        internet_state=unknown
        access_mode=scheduled
        message="Доступ определяется расписанием. Обновите статус после применения правила."
        ;;
    restricted)
        internet_state=unknown
        access_mode=restricted
        case "$reason" in
            temporary_access_expired) message="Временный доступ закончился; роутер применяет обычные правила." ;;
            *) message="Доступ ограничен отдельными правилами; полный статус пока не подтверждён." ;;
        esac
        ;;
    *)
        internet_state=unknown
        access_mode=unknown
        case "$reason" in
            mac_not_found) message="Роутер пока не определил это устройство." ;;
            device_not_registered) message="Устройство ещё не зарегистрировано в Sheepfold." ;;
            device_not_configured) message="Правила доступа для устройства не определены." ;;
            *) message="Статус доступа пока неизвестен." ;;
        esac
        ;;
esac

mac="$(mac_for_ip "$remote_ip")"
device_section="$(device_section_for_mac "$mac" 2>/dev/null || true)"
device_id=""
device_name=""
is_administrator=0
client_role=child
can_request_access_extension=0
wifi_network_reporting=0
wifi_location_reporting=0
# SHEEPFOLD_AI_BEGIN
personal_group_name=""
# SHEEPFOLD_AI_END
if [ -n "$device_section" ]; then
    device_id="$(/usr/libexec/sheepfold/sheepfold-device-id ensure "$device_section" 2>/dev/null || true)"
    device_name="$(uci -q get "sheepfold.$device_section.name" 2>/dev/null || true)"
    is_administrator="$(uci -q get "sheepfold.$device_section.admin_device" 2>/dev/null || printf 0)"
    # SHEEPFOLD_AI_BEGIN
    personal_group_name="$(personal_group_for_device "$device_section" "$mac" 2>/dev/null || true)"
    # SHEEPFOLD_AI_END
    if [ "$is_administrator" = 1 ]; then
        client_role=parent
    else
        is_administrator=0
        wifi_report_mode="$(uci -q get sheepfold.global.child_wifi_network_notifications 2>/dev/null || printf off)"
        case "$wifi_report_mode" in
            with_location) wifi_network_reporting=1; wifi_location_reporting=1 ;;
            network_only) wifi_network_reporting=1 ;;
        esac
        if [ -x /usr/libexec/sheepfold/sheepfold-access-request ] &&
           [ "$(/usr/libexec/sheepfold/sheepfold-access-request enabled 2>/dev/null || printf 0)" = 1 ]; then
            can_request_access_extension=1
        fi
    fi
fi
if [ -z "$device_name" ] && [ -r /tmp/dhcp.leases ]; then
    device_name="$(awk -v ip="$remote_ip" '$3 == ip { print $4; exit }' /tmp/dhcp.leases)"
    [ "$device_name" != "*" ] || device_name=""
fi

# SHEEPFOLD_AI_BEGIN
ai_enabled="$(uci -q get sheepfold.global.ai_enabled 2>/dev/null || printf 0)"
child_ai_consent="$(uci -q get sheepfold.global.child_ai_parental_consent 2>/dev/null || printf 0)"
ai_assistant_available=0
child_ai_available=0
child_ai_allowed=0
personal_group_required=0
if [ "$ai_enabled" = 1 ] && ai_feature_available; then
    ai_assistant_available=1
fi
if [ "$client_role" = child ] && [ "$ai_assistant_available" = 1 ] && [ "$child_ai_consent" = 1 ]; then
    child_ai_available=1
    if [ -n "$personal_group_name" ]; then
        child_ai_allowed=1
    else
        personal_group_required=1
    fi
fi
# SHEEPFOLD_AI_END

minutes_remaining=null
case "$access_ends_at" in
    ''|*[!0-9]*) ;;
    *)
        now="$(date +%s)"
        if [ "$access_ends_at" -gt "$now" ]; then
            minutes_remaining=$(( (access_ends_at - now + 59) / 60 ))
        else
            minutes_remaining=0
        fi
        ;;
esac

header_json "200 OK"
printf '{"app":"sheepfold","ok":true,"apiVersion":"2","serverTime":"%s","data":{' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
printf '"deviceId":"%s",' "$(json_escape "$device_id")"
printf '"deviceName":"%s",' "$(json_escape "$device_name")"
printf '"isAdministrator":%s,' "$([ "$is_administrator" = 1 ] && printf true || printf false)"
printf '"clientRole":"%s",' "$(json_escape "$client_role")"
printf '"canRequestAccessExtension":%s,' "$([ "$can_request_access_extension" = 1 ] && printf true || printf false)"
printf '"wifiNetworkReporting":%s,' "$([ "$wifi_network_reporting" = 1 ] && printf true || printf false)"
printf '"wifiLocationReporting":%s,' "$([ "$wifi_location_reporting" = 1 ] && printf true || printf false)"
# SHEEPFOLD_AI_BEGIN
printf '"aiAssistantAvailable":%s,' "$([ "$ai_assistant_available" = 1 ] && printf true || printf false)"
printf '"childAiAvailable":%s,' "$([ "$child_ai_available" = 1 ] && printf true || printf false)"
printf '"personalGroupName":"%s",' "$(json_escape "$personal_group_name")"
printf '"childAiAllowed":%s,' "$([ "$child_ai_allowed" = 1 ] && printf true || printf false)"
printf '"personalGroupRequired":%s,' "$([ "$personal_group_required" = 1 ] && printf true || printf false)"
# SHEEPFOLD_AI_END
printf '"internetState":"%s",' "$(json_escape "$internet_state")"
printf '"accessMode":"%s",' "$(json_escape "$access_mode")"
printf '"scheduleConflict":%s,' "$([ "$schedule_conflict" = 1 ] && printf true || printf false)"
if [ -n "$access_ends_at" ]; then
    printf '"accessEndsAt":"%s",' "$(json_escape "$access_ends_at")"
else
    printf '"accessEndsAt":null,'
fi
printf '"minutesRemaining":%s,' "$minutes_remaining"
if [ -n "$next_access_change_time" ]; then
    printf '"nextAccessChangeTime":"%s",' "$(json_escape "$next_access_change_time")"
else
    printf '"nextAccessChangeTime":null,'
fi
printf '"message":"%s"},"error":null}\n' "$(json_escape "$message")"
