#!/bin/sh
set -eu

UCODE_SOURCE="/usr/share/sheepfold/device-mdns.uc"
OUTPUT="/tmp/sheepfold/device-mdns.tsv"
TEMP="$OUTPUT.tmp.$$"

mkdir -p /tmp/sheepfold
chmod 700 /tmp/sheepfold 2>/dev/null || true
umask 077

if command -v ucode >/dev/null 2>&1 && [ -r "$UCODE_SOURCE" ]; then
        if ! ucode "$UCODE_SOURCE" > "$TEMP" 2>/dev/null; then
                : > "$TEMP"
        fi
else
        : > "$TEMP"
fi

chmod 600 "$TEMP" 2>/dev/null || true
mv -f "$TEMP" "$OUTPUT"
