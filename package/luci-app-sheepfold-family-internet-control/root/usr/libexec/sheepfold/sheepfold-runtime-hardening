#!/bin/sh
set -eu

ROOT="${1:-}"

path() { printf '%s%s' "$ROOT" "$1"; }
die() { echo "Sheepfold hardening check failed: $*" >&2; exit 1; }

CGI="$(path /www/cgi-bin/sheepfold-api)"
CGI_LEGACY="$(path /usr/libexec/sheepfold/sheepfold-api-legacy)"
CONTROL="$(path /usr/libexec/sheepfold/sheepfold-router-control)"
CONTROL_LEGACY="$(path /usr/libexec/sheepfold/sheepfold-router-control-legacy)"
PAIR_ACTIVATE="$(path /usr/libexec/sheepfold/sheepfold-pair-activate)"
PAIR_DEVICE="$(path /usr/libexec/sheepfold/sheepfold-pair-device)"
PAIR_COMMON="$(path /usr/libexec/sheepfold/sheepfold-pair-common)"
AI_GATE="$(path /usr/libexec/sheepfold/sheepfold-ai-gate)"
AI_POLICY="$(path /usr/libexec/sheepfold/sheepfold-ai-parenting-policy)"
ACTIVITY_LOG="$(path /usr/libexec/sheepfold/sheepfold-activity-log)"
MAINTENANCE_WINDOW="$(path /usr/libexec/sheepfold/sheepfold-maintenance-window)"
KEY_DERIVE="$(path /usr/libexec/sheepfold/sheepfold-key-derive)"
OPENSSL_ENSURE="$(path /usr/libexec/sheepfold/sheepfold-openssl-ensure)"
USB_STORAGE="$(path /usr/libexec/sheepfold/sheepfold-usb-storage)"
USB_DECOY="$(path /usr/libexec/sheepfold/sheepfold-usb-decoy)"
WELL_KNOWN_GENERATOR="$(path /www/.well-known/sheepfold.json.sh)"
ACL="$(path /usr/share/rpcd/acl.d/luci-app-sheepfold-family-internet-control.json)"

for required in \
    "$CGI" "$CGI_LEGACY" "$CONTROL" "$CONTROL_LEGACY" \
    "$PAIR_ACTIVATE" "$PAIR_DEVICE" "$PAIR_COMMON" "$AI_GATE" \
    "$OPENSSL_ENSURE" "$ACL"; do
    [ -f "$required" ] || die "missing file $required"
done

# Все новые helper-скрипты создаются через Git contents API как обычные файлы.
# Явно восстанавливаем executable bit, иначе cron и LuCI fs.exec молча не работают.
for executable in \
    "$CGI" "$CGI_LEGACY" "$CONTROL" "$CONTROL_LEGACY" \
    "$(path /usr/libexec/sheepfold/sheepfold-api-client-status)" \
    "$(path /usr/libexec/sheepfold/sheepfold-api-pair)" \
    "$PAIR_ACTIVATE" "$PAIR_DEVICE" "$AI_GATE" "$AI_POLICY" \
    "$ACTIVITY_LOG" "$MAINTENANCE_WINDOW" "$KEY_DERIVE" \
    "$OPENSSL_ENSURE" "$USB_STORAGE" "$USB_DECOY" \
    "$WELL_KNOWN_GENERATOR" \
    "$(path /usr/libexec/sheepfold/sheepfold-runtime-hardening)"; do
    [ ! -f "$executable" ] || chmod 0755 "$executable"
done
chmod 0644 "$PAIR_COMMON" "$ACL"

# Постоянное хранилище содержит только хэши Bearer-токенов. Plaintext туда не
# попадает; каталог недоступен обычным пользователям роутера.
mkdir -p "$(path /etc/sheepfold/tokens)"
chmod 0700 "$(path /etc/sheepfold)" "$(path /etc/sheepfold/tokens)" 2>/dev/null || true

grep -q 'sheepfold-api-legacy' "$CGI" || die "public CGI does not delegate through the hardened dispatcher"
grep -q '\[ "\$path_info" = "/pair-token" \]' "$CGI" || die "public CGI does not return 404 for pair-token"
! grep -q '^generate_pair_token_json()' "$CGI" || die "pair-token generator is present in public CGI"
! grep -q '^[[:space:]]*/pair-token)' "$CGI" || die "pair-token route is present in public CGI"
grep -q 'sheepfold-ai-gate' "$CGI" || die "AI gate is not connected"

grep -q 'PAIR_DEVICE=.*/sheepfold-pair-device' "$CONTROL" || die "pair-admin-device is not intercepted"
grep -q 'PAIR_ACTIVATE=.*/sheepfold-pair-activate' "$CONTROL" || die "pairing-code activation is not intercepted"
grep -q 'exec "\$PAIR_DEVICE"' "$CONTROL" || die "pair device helper is not executed"
grep -q 'exec "\$PAIR_ACTIVATE"' "$CONTROL" || die "pair activation helper is not executed"
grep -q '/etc/sheepfold/tokens' "$CONTROL" || die "persistent administrator token storage is missing"

grep -q 'pair_admin_section_for_login' "$PAIR_ACTIVATE" || die "existing administrator lookup is missing"
grep -q 'Create the account in LuCI first' "$PAIR_ACTIVATE" || die "missing-admin failure is not explicit"
! grep -q '=administrator' "$PAIR_ACTIVATE" || die "pair activation can create an administrator"

block_checks="$(grep -c 'pair_list_has_mac blocklist' "$PAIR_DEVICE" || true)"
[ "$block_checks" -ge 2 ] || die "pairing does not recheck blocklist"
! grep -q 'remove.*blocklist\|delete.*blocklist' "$PAIR_DEVICE" || die "pairing can mutate blocklist"
grep -q 'pair_store_token' "$PAIR_DEVICE" || die "successful pairing does not store a token hash"
grep -q 'pair_valid_code' "$PAIR_COMMON" || die "pairing-code alphabet validation is missing"

grep -q 'client_header_required' "$AI_GATE" || die "AI native-client check is missing"
grep -q 'ai_rate_limit_requests' "$AI_GATE" || die "AI per-device request limit is missing"
grep -q 'ai_rate_limit_window_seconds' "$AI_GATE" || die "AI rate-limit window is missing"
grep -q 'privileged_context_forbidden' "$AI_GATE" || die "AI privileged context guard is missing"

grep -q 'sheepfold-openssl-ensure' "$ACL" || die "OpenSSL verification helper is absent from LuCI ACL"
grep -q "ai_individual_logs='0'" "$OPENSSL_ENSURE" || die "OpenSSL failure does not disable individual logs"

for script in \
    "$CGI" "$CGI_LEGACY" "$CONTROL" "$CONTROL_LEGACY" \
    "$(path /usr/libexec/sheepfold/sheepfold-api-client-status)" \
    "$(path /usr/libexec/sheepfold/sheepfold-api-pair)" \
    "$PAIR_COMMON" "$PAIR_ACTIVATE" "$PAIR_DEVICE" "$AI_GATE" \
    "$AI_POLICY" "$ACTIVITY_LOG" "$MAINTENANCE_WINDOW" \
    "$KEY_DERIVE" "$OPENSSL_ENSURE" "$USB_STORAGE" "$USB_DECOY" \
    "$WELL_KNOWN_GENERATOR"; do
    [ ! -f "$script" ] || /bin/sh -n "$script" || die "shell syntax error in $script"
done

exit 0
