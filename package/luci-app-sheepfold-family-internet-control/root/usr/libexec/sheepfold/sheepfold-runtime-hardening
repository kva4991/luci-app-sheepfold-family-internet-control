#!/bin/sh
set -eu

ROOT="${1:-}"

path() { printf '%s%s' "$ROOT" "$1"; }
die() { echo "Sheepfold hardening check failed: $*" >&2; exit 1; }

CGI="$(path /www/cgi-bin/sheepfold-api)"
CGI_LEGACY="$(path /usr/libexec/sheepfold/sheepfold-api-legacy)"
CONTROL="$(path /usr/libexec/sheepfold/sheepfold-router-control)"
CONTROL_LEGACY="$(path /usr/libexec/sheepfold/sheepfold-router-control-legacy)"
CLIENT_STATUS="$(path /usr/libexec/sheepfold/sheepfold-client-status-effective)"
SERVICE="$(path /usr/libexec/sheepfold/sheepfold-service)"
DEVICE_DETECTOR="$(path /usr/libexec/sheepfold/sheepfold-device-detector)"
DEVICE_CLASSIFIER="$(path /usr/libexec/sheepfold/sheepfold-device-classifier)"
DEVICE_MDNS="$(path /usr/libexec/sheepfold/sheepfold-device-mdns)"
DEVICE_MDNS_UCODE="$(path /usr/share/sheepfold/device-mdns.uc)"
DEVICE_PRESENCE="$(path /usr/libexec/sheepfold/sheepfold-device-presence)"
DEVICE_RECLASSIFY="$(path /usr/libexec/sheepfold/sheepfold-device-reclassify)"
DHCP_SIGNALS="$(path /etc/hotplug.d/dhcp/90-sheepfold-device-signals)"
LED_CONTROL="$(path /usr/libexec/sheepfold/sheepfold-led-control)"
PAIR_ACTIVATE="$(path /usr/libexec/sheepfold/sheepfold-pair-activate)"
PAIR_DEVICE="$(path /usr/libexec/sheepfold/sheepfold-pair-device)"
PAIR_COMMON="$(path /usr/libexec/sheepfold/sheepfold-pair-common)"
PAIR_API="$(path /usr/libexec/sheepfold/sheepfold-api-pair)"
STATUS_API="$(path /usr/libexec/sheepfold/sheepfold-api-client-status)"
AI_GATE="$(path /usr/libexec/sheepfold/sheepfold-ai-gate)"
AI_HANDLER="$(path /usr/libexec/sheepfold/sheepfold-ai-handler)"
ACTIVITY_LOG="$(path /usr/libexec/sheepfold/sheepfold-activity-log)"
MAINTENANCE_WINDOW="$(path /usr/libexec/sheepfold/sheepfold-maintenance-window)"
KEY_DERIVE="$(path /usr/libexec/sheepfold/sheepfold-key-derive)"
OPENSSL_ENSURE="$(path /usr/libexec/sheepfold/sheepfold-openssl-ensure)"
USB_STORAGE="$(path /usr/libexec/sheepfold/sheepfold-usb-storage)"
WELL_KNOWN_GENERATOR="$(path /www/.well-known/sheepfold.json.sh)"
ACL="$(path /usr/share/rpcd/acl.d/luci-app-sheepfold-family-internet-control.json)"
PRIVACY_NOTICE="$(path /usr/share/sheepfold/PRIVACY_NOTICE.md)"
CUDY_PROFILE="$(path /usr/share/sheepfold/router-profiles/cudy,wr3000s-v1)"
CUDY_LED_APPLY_MODE="$CUDY_PROFILE/led/apply-mode"
CUDY_LED_PACKAGE="$CUDY_PROFILE/led/dependency-package"
CUDY_LED_COMMAND="$CUDY_PROFILE/led/dependency-command"
CUDY_FIX_INSTALL="$CUDY_PROFILE/fixLed/install"
CUDY_FIX_UNINSTALL="$CUDY_PROFILE/fixLed/uninstall"

for required in \
    "$CGI" "$CGI_LEGACY" "$CONTROL" "$CONTROL_LEGACY" "$CLIENT_STATUS" \
    "$SERVICE" "$DEVICE_DETECTOR" "$DEVICE_CLASSIFIER" "$DEVICE_MDNS" \
    "$DEVICE_MDNS_UCODE" "$DEVICE_PRESENCE" "$DEVICE_RECLASSIFY" \
    "$DHCP_SIGNALS" "$LED_CONTROL" "$PAIR_ACTIVATE" "$PAIR_DEVICE" \
    "$PAIR_COMMON" "$PAIR_API" "$STATUS_API" "$AI_GATE" "$AI_HANDLER" \
    "$ACTIVITY_LOG" "$MAINTENANCE_WINDOW" "$KEY_DERIVE" "$OPENSSL_ENSURE" \
    "$USB_STORAGE" "$WELL_KNOWN_GENERATOR" "$ACL" "$PRIVACY_NOTICE" \
    "$CUDY_LED_APPLY_MODE" "$CUDY_LED_PACKAGE" "$CUDY_LED_COMMAND" \
    "$CUDY_FIX_INSTALL" "$CUDY_FIX_UNINSTALL"; do
    [ -f "$required" ] || die "missing file $required"
done

# Git contents API не сохраняет executable bit, поэтому восстанавливаем его явно.
for executable in \
    "$CGI" "$CGI_LEGACY" "$CONTROL" "$CONTROL_LEGACY" "$CLIENT_STATUS" \
    "$SERVICE" "$DEVICE_DETECTOR" "$DEVICE_CLASSIFIER" "$DEVICE_MDNS" \
    "$DEVICE_PRESENCE" "$DEVICE_RECLASSIFY" "$DHCP_SIGNALS" "$LED_CONTROL" \
    "$STATUS_API" "$PAIR_API" "$PAIR_ACTIVATE" "$PAIR_DEVICE" "$AI_GATE" \
    "$AI_HANDLER" "$ACTIVITY_LOG" "$MAINTENANCE_WINDOW" "$KEY_DERIVE" \
    "$OPENSSL_ENSURE" "$USB_STORAGE" "$WELL_KNOWN_GENERATOR" \
    "$CUDY_LED_APPLY_MODE" "$CUDY_FIX_INSTALL" "$CUDY_FIX_UNINSTALL" \
    "$(path /usr/libexec/sheepfold/sheepfold-runtime-hardening)"; do
    chmod 0755 "$executable"
done
chmod 0644 "$PAIR_COMMON" "$ACL" "$PRIVACY_NOTICE" "$DEVICE_MDNS_UCODE" \
    "$CUDY_LED_PACKAGE" "$CUDY_LED_COMMAND"

mkdir -p "$(path /etc/sheepfold/tokens)"
chmod 0700 "$(path /etc/sheepfold)" "$(path /etc/sheepfold/tokens)" 2>/dev/null || true

# Публичный CGI обязан скрывать выпуск кода и защищать диагностику.
grep -q 'sheepfold-api-legacy' "$CGI" || die "public CGI does not delegate through the hardened dispatcher"
grep -q '\[ "\$path_info" = "/pair-token" \]' "$CGI" || die "public CGI does not return 404 for pair-token"
! grep -q '^generate_pair_token_json()' "$CGI" || die "pair-token generator is present in public CGI"
! grep -q '^[[:space:]]*/pair-token)' "$CGI" || die "pair-token route is present in public CGI"
grep -q 'AI_HANDLER=' "$CGI" || die "role-aware AI handler is not connected"
grep -q '/router-info|/pair-status)' "$CGI" || die "diagnostic routes are not intercepted"
grep -q 'query_token_forbidden' "$CGI" || die "Bearer token is still accepted in query string"
grep -q 'legacy_settings_writer_disabled' "$CGI" || die "legacy untyped settings writer remains enabled"

# Pairing не создаёт администратора и повторно проверяет blocklist.
grep -q 'PAIR_DEVICE=.*/sheepfold-pair-device' "$CONTROL" || die "pair-admin-device is not intercepted"
grep -q 'PAIR_ACTIVATE=.*/sheepfold-pair-activate' "$CONTROL" || die "pairing-code activation is not intercepted"
grep -q 'CLIENT_STATUS=.*/sheepfold-client-status-effective' "$CONTROL" || die "effective client status is not intercepted"
grep -q 'exec "\$PAIR_DEVICE"' "$CONTROL" || die "pair device helper is not executed"
grep -q 'exec "\$PAIR_ACTIVATE"' "$CONTROL" || die "pair activation helper is not executed"
grep -q 'exec "\$CLIENT_STATUS"' "$CONTROL" || die "effective client status helper is not executed"
grep -q '/etc/sheepfold/tokens' "$CONTROL" || die "persistent administrator token storage is missing"
grep -q 'pair_admin_section_for_login' "$PAIR_ACTIVATE" || die "existing administrator lookup is missing"
grep -q 'Create the account in LuCI first' "$PAIR_ACTIVATE" || die "missing-admin failure is not explicit"
! grep -q '=administrator' "$PAIR_ACTIVATE" || die "pair activation can create an administrator"

block_checks="$(grep -c 'pair_list_has_mac blocklist' "$PAIR_DEVICE" || true)"
[ "$block_checks" -ge 2 ] || die "pairing does not recheck blocklist"
! grep -q 'remove.*blocklist\|delete.*blocklist' "$PAIR_DEVICE" || die "pairing can mutate blocklist"
grep -q 'pair_store_token' "$PAIR_DEVICE" || die "successful pairing does not store a token hash"
grep -q 'pair_valid_code' "$PAIR_COMMON" || die "pairing-code alphabet validation is missing"
grep -q 'device_id' "$PAIR_DEVICE" || die "pairing does not return stable device id"

# Статус клиента учитывает blocklist, временный доступ и глобальную блокировку.
grep -q 'global_block' "$CLIENT_STATUS" || die "effective status ignores global block"
grep -q 'temporary_access_expired' "$CLIENT_STATUS" || die "effective status ignores expired temporary access"
grep -q 'schedule_pending_evaluation' "$CLIENT_STATUS" || die "scheduled status still claims an unverified result"

# Автоопределение использует независимые сигналы и не повторяет побочные действия.
grep -q 'DNSMASQ_VENDOR_CLASS' "$DHCP_SIGNALS" || die "DHCP vendor-class collection is missing"
grep -q 'DNSMASQ_REQUESTED_OPTIONS' "$DHCP_SIGNALS" || die "DHCP option fingerprint collection is missing"
grep -q 'device-signals.changed' "$SERVICE" || die "DHCP signal changes do not trigger detection"
grep -q 'device-detection.lock' "$SERVICE" || die "background detection is not serialized"
grep -q 'NETWORK_NAME_PATTERN=' "$DEVICE_CLASSIFIER" || die "network infrastructure guard is missing"
grep -q 'POLICY_VERSION="2"' "$DEVICE_CLASSIFIER" || die "device classification policy version is missing"
grep -q 'EVIDENCE_COUNT' "$DEVICE_CLASSIFIER" || die "independent evidence counting is missing"
grep -q 'nmap-mac-prefixes' "$DEVICE_CLASSIFIER" || die "local OUI lookup is missing"
grep -q 'mdns_has' "$DEVICE_CLASSIFIER" || die "mDNS evidence handling is missing"
grep -q 'ucode "\$UCODE_SOURCE"' "$DEVICE_MDNS" || die "mDNS shell wrapper does not invoke ucode safely"
grep -q 'ubus.call("umdns", "browse"' "$DEVICE_MDNS_UCODE" || die "mDNS reader does not use the OpenWrt browse API"
grep -q 'ubus.call("umdns", "hosts"' "$DEVICE_MDNS_UCODE" || die "mDNS reader does not use the OpenWrt hosts API"
grep -q 'device-mdns.tsv' "$DEVICE_DETECTOR" || die "mDNS snapshot is not included in detection"
grep -q 'detection_mdns_services' "$DEVICE_DETECTOR" || die "mDNS evidence is not persisted"
grep -q '\[ "\$evidence_count" -ge 2 \]' "$DEVICE_DETECTOR" || die "automatic group assignment does not require two evidence families"
grep -q 'detection_fingerprint' "$DEVICE_DETECTOR" || die "device fingerprint persistence is missing"
grep -q 'detection_policy_version' "$DEVICE_DETECTOR" || die "classification policy version is not persisted"
grep -q 'device-detection.last-scan' "$DEVICE_DETECTOR" || die "runtime last-scan state is missing"
assignment_calls="$(grep -c 'assign_no_restrictions_if_allowed "\$section"' "$DEVICE_DETECTOR" || true)"
[ "$assignment_calls" -eq 1 ] || die "automatic group assignment can run outside a new classification"
! grep -q 'revoke_unsafe_auto_assignment' "$DEVICE_DETECTOR" || die "automatic group rollback must not be present"
grep -q 'classify <name>' "$DEVICE_DETECTOR" || die "detector regression interface is missing"

# Онлайн-статус хранится только в RAM и не считает статическую запись присутствием.
grep -q 'DEVICE_PRESENCE=.*/sheepfold-device-presence' "$CONTROL" || die "device presence is not routed"
grep -q 'exec "\$DEVICE_PRESENCE"' "$CONTROL" || die "device presence helper is not executed"
grep -q 'ONLINE_WINDOW_SECONDS=900' "$DEVICE_PRESENCE" || die "device online window is not fifteen minutes"
grep -q 'refresh_from_dhcp_signals' "$DEVICE_PRESENCE" || die "DHCP presence history is missing"
grep -q 'refresh_from_arp' "$DEVICE_PRESENCE" || die "ARP presence refresh is missing"
grep -q '\*,arp,\*' "$DEVICE_PRESENCE" || die "static-only detector state can be treated as online"
grep -q '"\$PRESENCE" refresh' "$SERVICE" || die "presence history is not refreshed after detection"
! grep -q '/etc/sheepfold/device-presence' "$DEVICE_PRESENCE" || die "device presence is written to persistent flash"

# Повторное определение не может менять пользовательскую политику доступа.
grep -q 'DEVICE_RECLASSIFY=.*/sheepfold-device-reclassify' "$CONTROL" || die "device reclassification is not routed"
grep -q 'exec "\$DEVICE_RECLASSIFY"' "$CONTROL" || die "device reclassification helper is not executed"
grep -q 'manual_device_type_locked' "$DEVICE_RECLASSIFY" || die "manual device type is not protected"
grep -q 'device-detection.lock' "$DEVICE_RECLASSIFY" || die "manual reclassification is not serialized"
! grep -q 'delete.*\.group\|delete.*allowlist\|delete.*blocklist' "$DEVICE_RECLASSIFY" || die "reclassification can change access policy"

# LED helper выбирает профиль по board name и сохраняет общий fallback.
grep -q 'PROFILE_ROOT="/usr/share/sheepfold/router-profiles"' "$LED_CONTROL" || die "router profile root is missing"
grep -q '/led/apply-mode' "$LED_CONTROL" || die "explicit LED apply-mode entry point is missing"
grep -q 'exec "\$LEGACY" led-apply' "$LED_CONTROL" || die "generic LED fallback is missing"
grep -q 'led-repair-status' "$CONTROL" || die "LED repair status is not routed"
grep -q 'led-repair-apply' "$CONTROL" || die "LED repair apply is not routed"
[ "$(cat "$CUDY_LED_PACKAGE")" = "mdio-tools" ] || die "Cudy LED dependency package is invalid"
[ "$(cat "$CUDY_LED_COMMAND")" = "mdio" ] || die "Cudy LED dependency command is invalid"
grep -q 'mdio mt7530-0 0:0x1f raw 0x21 0x0008' "$CUDY_LED_APPLY_MODE" || die "Cudy WR3000S LED command is missing"
grep -q 'PREFERRED_LED="white:wan-online"' "$CUDY_FIX_INSTALL" || die "Cudy WAN online LED name is missing"
grep -q 'system.\$SECTION.sheepfold_managed' "$CUDY_FIX_INSTALL" || die "LED fix ownership marker is missing"
grep -q 'find_equivalent_section' "$CUDY_FIX_INSTALL" || die "LED fix does not preserve existing equivalent settings"
grep -q 'system.\$SECTION.sheepfold_managed' "$CUDY_FIX_UNINSTALL" || die "LED fix rollback does not verify ownership"

# AI gate проверяет идентичность, роль, согласие и квоту серверными данными.
grep -q 'device_identity_mismatch' "$AI_GATE" || die "AI device identity verification is missing"
grep -q 'client_role_mismatch' "$AI_GATE" || die "AI role verification is missing"
grep -q 'parental_consent_required' "$AI_GATE" || die "child AI parental consent is missing"
grep -q 'ai_rate_limit_requests' "$AI_GATE" || die "AI per-device request limit is missing"
grep -q 'privileged_context_forbidden' "$AI_GATE" || die "AI privileged context guard is missing"
grep -q 'Проверенная роль: ребёнок' "$AI_HANDLER" || die "child AI prompt is missing"
grep -q 'Обезличенное состояние роутера' "$AI_HANDLER" || die "AI diagnostics masking is missing"

# Журналы и ключи должны быть транзакционными.
grep -q 'sheepfold.log' "$ACTIVITY_LOG" || die "explicit activity-log filename format is missing"
grep -q 'restore_staged_logs' "$ACTIVITY_LOG" || die "activity-log rollback is missing"
! grep -q 'mtime "+7"' "$ACTIVITY_LOG" || die "hard-coded seven-day retention remains"
grep -q '.key-derive.lock' "$KEY_DERIVE" || die "key initialization lock is missing"
grep -q 'extroot_not_implemented_safely' "$USB_STORAGE" || die "unsafe automatic extroot remains enabled"
grep -q 'PRIVACY_NOTICE_SOURCE' "$USB_STORAGE" || die "USB privacy notice is not copied after mount"

# LuCI не получает общий read/write wildcard на runtime-каталог.
! grep -q '"/tmp/sheepfold/\*"' "$ACL" || die "broad runtime ACL wildcard remains"
grep -q 'sheepfold-openssl-ensure' "$ACL" || die "OpenSSL verification helper is absent from LuCI ACL"
grep -q "ai_individual_logs='0'" "$OPENSSL_ENSURE" || die "OpenSSL failure does not disable individual logs"

for script in \
    "$CGI" "$CGI_LEGACY" "$CONTROL" "$CONTROL_LEGACY" "$CLIENT_STATUS" \
    "$SERVICE" "$DEVICE_DETECTOR" "$DEVICE_CLASSIFIER" "$DEVICE_MDNS" \
    "$DEVICE_PRESENCE" "$DEVICE_RECLASSIFY" "$DHCP_SIGNALS" "$LED_CONTROL" \
    "$STATUS_API" "$PAIR_API" "$PAIR_COMMON" "$PAIR_ACTIVATE" "$PAIR_DEVICE" \
    "$AI_GATE" "$AI_HANDLER" "$ACTIVITY_LOG" "$MAINTENANCE_WINDOW" \
    "$KEY_DERIVE" "$OPENSSL_ENSURE" "$USB_STORAGE" "$WELL_KNOWN_GENERATOR" \
    "$CUDY_LED_APPLY_MODE" "$CUDY_FIX_INSTALL" "$CUDY_FIX_UNINSTALL"; do
    /bin/sh -n "$script" || die "shell syntax error in $script"
done

exit 0
