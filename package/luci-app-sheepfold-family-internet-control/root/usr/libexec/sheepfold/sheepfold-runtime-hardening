#!/bin/sh
set -eu

ROOT="${1:-}"
CGI="$ROOT/www/cgi-bin/sheepfold-api"
CONTROL="$ROOT/usr/libexec/sheepfold/sheepfold-router-control"
ACL="$ROOT/usr/share/rpcd/acl.d/luci-app-sheepfold-family-internet-control.json"

atomic_replace() {
    source_file="$1"
    generated_file="$2"
    chmod --reference="$source_file" "$generated_file" 2>/dev/null || chmod 0755 "$generated_file"
    mv -f "$generated_file" "$source_file"
}

patch_cgi() {
    [ -f "$CGI" ] || return 0
    tmp="$CGI.hardened.$$"
    has_gate=0
    grep -q 'SHEEPFOLD_AI_GATE_V1' "$CGI" 2>/dev/null && has_gate=1

    awk -v has_gate="$has_gate" '
        function print_client() {
            print "client_status_json() {"
            print "\texec /usr/libexec/sheepfold/sheepfold-api-client-status \"$remote_ip\""
            print "}"
        }
        function print_pair() {
            print "pair_admin_device_json() {"
            print "\texec /usr/libexec/sheepfold/sheepfold-api-pair"
            print "}"
        }
        BEGIN { skip=""; skip_case=0; in_ai=0 }
        /Access-Control-Allow-Origin: \*/ { next }
        skip_case > 0 { skip_case--; next }
        /^[[:space:]]*\/pair-token\)/ { skip_case=2; next }
        /^client_status_json\(\) \{$/ { print_client(); skip="client"; next }
        /^pair_admin_device_json\(\) \{$/ { print_pair(); skip="pair"; next }
        /^generate_pair_token_json\(\) \{$/ { skip="token"; next }
        skip != "" {
            if ($0 == "}") skip=""
            next
        }
        /^ai_assistant_json\(\) \{$/ { in_ai=1; print; next }
        in_ai && /body="\$\(read_request_body\)"/ {
            print
            if (!has_gate) {
                print "\t# SHEEPFOLD_AI_GATE_V1: ordinary LAN clients are rate-limited by resolved MAC;"
                print "\t# diagnostics, logs and provider overrides require an administrator token."
                print "\tprintf \047%s\047 \"$body\" | /usr/libexec/sheepfold/sheepfold-ai-gate || return 0"
            }
            next
        }
        in_ai && $0 == "}" { in_ai=0; print; next }
        { print }
    ' "$CGI" > "$tmp"

    atomic_replace "$CGI" "$tmp"
}

patch_router_control() {
    [ -f "$CONTROL" ] || return 0
    tmp="$CONTROL.hardened.$$"
    has_recheck=0
    grep -q 'SHEEPFOLD_PAIR_BLOCKLIST_RECHECK_V1' "$CONTROL" 2>/dev/null && has_recheck=1

    awk -v has_recheck="$has_recheck" '
        function print_activation() {
            print "activate_admin_pairing_code() {"
            print "        local login=\"${1:-}\" code=\"${2:-}\" display_name=\"${3:-}\" lifetime=\"${4:-600}\""
            print ""
            print "        [ -n \"$login\" ] || { echo \"Administrator login is required.\" >&2; return 2; }"
            print "        [ -n \"$code\" ] || { echo \"Pairing code is required.\" >&2; return 2; }"
            print "        case \"$lifetime\" in \047\047|*[!0-9]*) lifetime=600 ;; esac"
            print "        [ \"$lifetime\" -le 1800 ] || lifetime=1800"
            print ""
            print "        repair_sheepfold_uci_sections"
            print "        local admin_section"
            print "        admin_section=\"$(admin_section_for_login \"$login\")\" || {"
            print "                echo \"Administrator login was not found. Create the account in LuCI first.\" >&2"
            print "                return 2"
            print "        }"
            print ""
            print "        local expires_at"
            print "        expires_at=\"$(( $(date +%s) + lifetime ))\""
            print "        uci -q set \"sheepfold.$admin_section.pairing_code=$code\""
            print "        uci -q set \"sheepfold.$admin_section.pairing_code_expires=$expires_at\""
            print "        uci -q commit sheepfold"
            print ""
            print "        printf \047activated=1\\n\047"
            print "        printf \047admin_section=%s\\n\047 \"$admin_section\""
            print "        printf \047expires_at=%s\\n\047 \"$expires_at\""
            print "}"
        }
        BEGIN { skip_activation=0; in_pair=0 }
        /^pair_admin_device\(\) \{$/ { in_pair=1; print; next }
        in_pair && /device_section="\$\(device_section_for_mac "\$device_mac"\)"/ {
            print
            if (!has_recheck) {
                print ""
                print "        # SHEEPFOLD_PAIR_BLOCKLIST_RECHECK_V1: verify immediately before privilege writes."
                print "        list_has_mac blocklist \"$device_mac\" && {"
                print "                echo \"Blocklisted device cannot become an administrator device.\" >&2"
                print "                return 5"
                print "        }"
            }
            next
        }
        in_pair && /remove_mac_from_list blocklist "\$device_mac"/ { next }
        /^activate_admin_pairing_code\(\) \{$/ {
            in_pair=0
            print_activation()
            skip_activation=1
            next
        }
        skip_activation {
            if ($0 ~ /^# -----------------------------------------------------------------------------$/) {
                skip_activation=0
                print
            }
            next
        }
        { print }
    ' "$CONTROL" > "$tmp"

    atomic_replace "$CONTROL" "$tmp"
}

patch_acl() {
    [ -f "$ACL" ] || return 0
    grep -q 'sheepfold-openssl-ensure' "$ACL" 2>/dev/null && return 0
    tmp="$ACL.hardened.$$"
    awk '
        /"\/usr\/libexec\/sheepfold\/sheepfold-router-control": \[ "exec" \]/ {
            print "        \"/usr/libexec/sheepfold/sheepfold-openssl-ensure\": [ \"exec\" ],"
        }
        { print }
    ' "$ACL" > "$tmp"
    chmod 0644 "$tmp"
    mv -f "$tmp" "$ACL"
}

patch_cgi
patch_router_control
patch_acl

# Public code creation must not survive as an addressable CGI action.
if grep -q '/pair-token)' "$CGI" 2>/dev/null; then
    echo "Failed to remove public /pair-token route." >&2
    exit 1
fi
if grep -q 'admin_section_name_for_login.*login' "$CONTROL" 2>/dev/null && \
   ! grep -q 'Create the account in LuCI first' "$CONTROL" 2>/dev/null; then
    echo "Failed to harden administrator pairing activation." >&2
    exit 1
fi

exit 0
