#!/bin/sh
set -eu

DETECTOR="/usr/libexec/sheepfold/sheepfold-device-detector"
SCAN_LOCK="/tmp/sheepfold/device-detection.lock"
mac="$(printf '%s' "${1:-}" | tr '[:lower:]' '[:upper:]')"

printf '%s' "$mac" | grep -Eq '^([0-9A-F]{2}:){5}[0-9A-F]{2}$' || {
        echo "invalid_mac" >&2
        exit 2
}

section=""
for candidate in $(uci -q show sheepfold 2>/dev/null | sed -n 's/^sheepfold\.\([^.=]*\)=device$/\1/p'); do
        existing="$(uci -q get "sheepfold.$candidate.mac" 2>/dev/null | tr '[:lower:]' '[:upper:]' || true)"
        if [ "$existing" = "$mac" ]; then
                section="$candidate"
                break
        fi
done

[ -n "$section" ] || {
        echo "device_not_found" >&2
        exit 3
}

acquire_lock() {
        mkdir -p /tmp/sheepfold
        attempts=0
        while ! mkdir "$SCAN_LOCK" 2>/dev/null; do
                attempts=$((attempts + 1))
                [ "$attempts" -lt 30 ] || {
                        echo "detector_busy" >&2
                        return 1
                }
                sleep 1
        done
        trap 'rmdir "$SCAN_LOCK" 2>/dev/null || true' EXIT HUP INT TERM
}

release_lock() {
        rmdir "$SCAN_LOCK" 2>/dev/null || true
        trap - EXIT HUP INT TERM
}

acquire_lock || exit 5

# manual_device_type_locked: обычный авто-детектор не трогает тип, выбранный
# владельцем вручную. Нажатие «Определить заново» — отдельное явное решение
# владельца снова доверить тип автоматическому детектору.
uci -q set "sheepfold.$section.manual_device_type=0"
uci -q delete "sheepfold.$section.device_type" 2>/dev/null || true

for option in \
        detected_type \
        detection_confidence \
        detection_reason \
        detection_target_group \
        detection_auto_group_score \
        detection_evidence \
        detection_evidence_count \
        detection_hard_deny \
        detection_policy_version \
        detection_fingerprint \
        detection_ports \
        detection_oui_vendor \
        detection_mdns_services \
        detection_updated_at; do
        uci -q delete "sheepfold.$section.$option" 2>/dev/null || true
done

uci -q commit sheepfold

if [ -x "$DETECTOR" ] && ! "$DETECTOR" scan changed >/dev/null 2>&1; then
        release_lock
        echo "reclassification_scan_failed" >&2
        exit 6
fi

release_lock
printf 'status=reclassified\n'
printf 'section=%s\n' "$section"
printf 'mac=%s\n' "$mac"
