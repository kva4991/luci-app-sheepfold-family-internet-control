# -----------------------------------------------------------------------------
# set-device-status — полное обновление UCI-полей устройства
# Используется LuCI-страницей, не Android-приложением.
# -----------------------------------------------------------------------------

set_device_status() {
        local device_mac device_status device_name device_ip device_group device_type
        device_mac="$(normalize_mac "${1:-}")"
        device_status="${2:-}"
        device_name="${3:-}"
        device_ip="${4:-}"
        device_group="${5:-}"
        device_type="${6:-}"

        valid_mac "$device_mac" || { echo "Invalid MAC address" >&2; return 2; }

        case "$device_status" in
                allow|blocked|restricted|scheduled|new) ;;
                *) echo "Unsupported device status: $device_status" >&2; return 2 ;;
        esac

        repair_sheepfold_uci_sections
        ensure_list_section allowlist
        ensure_list_section blocklist
        local device_section
        device_section="$(device_section_for_mac "$device_mac")"
        local device_id
        device_id="$(uci -q get "sheepfold.$device_section.id" 2>/dev/null || true)"

        if [ "$device_status" = "blocked" ] && \
                [ "$(uci -q get "sheepfold.$device_section.admin_device" 2>/dev/null || printf 0)" = "1" ]; then
                echo "Administrator device cannot be added to blocklist" >&2
                return 3
        fi

        # Не переносим MAC между белым и чёрным списком автоматически —
        # это явное решение о доверии, которое пользователь должен принять осознанно.
        if [ "$device_status" = "allow" ] && list_has_mac blocklist "$device_mac"; then
                echo "Device is in blocklist. Remove from blocklist first." >&2
                return 3
        fi

        if [ "$device_status" = "blocked" ] && list_has_mac allowlist "$device_mac"; then
                echo "Device is in allowlist. Remove from allowlist first." >&2
                return 3
        fi

        [ -n "$device_name" ]   || device_name="$device_mac"
        [ -n "$device_group" ]  || device_group="Not configured"
        [ -n "$device_type" ]   || device_type="smart"

        uci -q set "sheepfold.$device_section.mac=$device_mac"
        uci -q set "sheepfold.$device_section.name=$device_name"
        uci -q set "sheepfold.$device_section.ip=$device_ip"
        uci -q set "sheepfold.$device_section.group=$device_group"
        uci -q set "sheepfold.$device_section.device_type=$device_type"
        uci -q set "sheepfold.$device_section.status=$device_status"

        if [ "$device_status" = "allow" ]; then
                add_mac_to_list allowlist "$device_mac"
                log_event "Устройство #${device_id} добавлено в белый список: $device_mac, IP ${device_ip:-неизвестен}"
        elif [ "$device_status" = "blocked" ]; then
                add_mac_to_list blocklist "$device_mac"
                log_event "Устройство #${device_id} добавлено в чёрный список: $device_mac, IP ${device_ip:-неизвестен}"
        else
                remove_mac_from_list allowlist "$device_mac"
                remove_mac_from_list blocklist "$device_mac"
                log_event "Устройство #${device_id} добавлено вручную: $device_mac, IP ${device_ip:-неизвестен}"
        fi

        uci -q commit sheepfold

        # Проверяем что UCI действительно записался — выявляет гонки при параллельных вызовах.
        local saved_status
        saved_status="$(uci -q get "sheepfold.$device_section.status" 2>/dev/null || printf '')"
        [ "$saved_status" = "$device_status" ] || { echo "UCI write verification failed" >&2; exit 1; }

        printf 'OK\n'
}

# -----------------------------------------------------------------------------
# pair-admin-device — финальный шаг сопряжения Android-приложения
#
# Получает login + одноразовый code (из QR), проверяет срок действия,
# определяет MAC телефона по IP, записывает device-секцию и выдаёт токен.
# -----------------------------------------------------------------------------

pair_admin_device() {
        local login="${1:-}" code="${2:-}" remote_ip="${3:-}" user_agent="${4:-}"

        repair_sheepfold_uci_sections
        ensure_list_section allowlist
        ensure_list_section blocklist

        local admin_section
        admin_section="$(admin_section_for_login "$login")" || {
                echo "Administrator login was not found" >&2
                return 2
        }

        local expected_code expires_at now
        expected_code="$(uci -q get "sheepfold.$admin_section.pairing_code" 2>/dev/null || true)"
        expires_at="$(uci -q get "sheepfold.$admin_section.pairing_code_expires" 2>/dev/null || printf 0)"
        now="$(date +%s)"

        [ -n "$expected_code" ] || {
                echo "Pairing code is not active. Open LuCI → Администраторы." >&2
                return 3
        }

        [ "$code" = "$expected_code" ] || { echo "Pairing code is invalid." >&2; return 3; }

        case "$expires_at" in ''|*[!0-9]*) expires_at=0 ;; esac

        if [ "$expires_at" -gt 0 ] && [ "$now" -gt "$expires_at" ]; then
                uci -q delete "sheepfold.$admin_section.pairing_code" 2>/dev/null || true
                uci -q delete "sheepfold.$admin_section.pairing_code_expires" 2>/dev/null || true
                uci -q commit sheepfold
                echo "Pairing code has expired. Open LuCI → Администраторы." >&2
                return 3
        fi

        local device_mac
        device_mac="$(mac_for_ip "$remote_ip" | sed -n '1p')"
        device_mac="$(normalize_mac "$device_mac")"
        valid_mac "$device_mac" || {
                echo "Could not determine phone MAC from DHCP leases or ARP table." >&2
                return 4
        }

        list_has_mac blocklist "$device_mac" && {
                echo "Blocklisted device cannot become an administrator device." >&2
                return 5
        }

        local admin_name device_name device_section device_id
        admin_name="$(uci -q get "sheepfold.$admin_section.display_name" 2>/dev/null || printf '%s' "$login")"
        device_name="$(name_for_ip "$remote_ip" | sed -n '1p')"
        [ -n "$device_name" ] && [ "$device_name" != "*" ] || device_name="Телефон администратора"
        device_section="$(device_section_for_mac "$device_mac")"
        device_id="$(/usr/libexec/sheepfold/sheepfold-device-id ensure "$device_section")"

        # Привязанный телефон администратора выводим из обычных правил:
        # он не должен зависеть от детских расписаний и должен всегда оставаться
        # в белом списке, иначе родитель потеряет управление в самый неудобный момент.
        uci -q set "sheepfold.$device_section.mac=$device_mac"
        uci -q set "sheepfold.$device_section.name=$device_name"
        uci -q set "sheepfold.$device_section.ip=$remote_ip"
        uci -q set "sheepfold.$device_section.device_type=phone"
        uci -q set "sheepfold.$device_section.manual_device_type=1"
        uci -q set "sheepfold.$device_section.group=Not configured"
        uci -q set "sheepfold.$device_section.schedules="
        uci -q set "sheepfold.$device_section.status=allow"
        uci -q set "sheepfold.$device_section.admin_device=1"
        uci -q set "sheepfold.$device_section.admin_owner=$admin_name"
        uci -q set "sheepfold.$device_section.admin_login=$login"
        uci -q set "sheepfold.$device_section.paired_from=android"
        uci -q set "sheepfold.$device_section.paired_at=$now"
        uci -q set "sheepfold.$device_section.pairing_user_agent=$user_agent"
        add_mac_to_list allowlist "$device_mac"
        remove_mac_from_list blocklist "$device_mac"

        # Код сопряжения одноразовый. Удаляем сразу после использования —
        # фото QR или подсмотренный код не должны работать повторно.
        uci -q delete "sheepfold.$admin_section.pairing_code" 2>/dev/null || true
        uci -q delete "sheepfold.$admin_section.pairing_code_expires" 2>/dev/null || true
        uci -q commit sheepfold

        # Выдаём долгоживущий Bearer-токен для последующих API-запросов.
        local session_token
        session_token="$(token_issue "$login")"

        log_event "Android-приложение привязало телефон администратора: #${device_id} $device_name, $device_mac, IP ${remote_ip:-?}, администратор $admin_name"

        printf 'paired=1\n'
        printf 'admin_name=%s\n' "$admin_name"
        printf 'admin_login=%s\n' "$login"
        printf 'device_name=%s\n' "$device_name"
        printf 'device_id=%s\n' "$device_id"
        printf 'mac=%s\n' "$device_mac"
        printf 'ip=%s\n' "$remote_ip"
        printf 'token=%s\n' "$session_token"
}

# -----------------------------------------------------------------------------
# activate-admin-pairing-code — генерирует одноразовый QR-код сопряжения
# Вызывается из LuCI при нажатии «Добавить телефон».
# -----------------------------------------------------------------------------

activate_admin_pairing_code() {
        local login="${1:-}" code="${2:-}" display_name="${3:-}" lifetime="${4:-600}"

        [ -n "$login" ] || { echo "Administrator login is required." >&2; return 2; }
        [ -n "$code" ]  || { echo "Pairing code is required." >&2; return 2; }

        case "$lifetime" in ''|*[!0-9]*) lifetime=600 ;; esac

        repair_sheepfold_uci_sections
        local admin_section
        admin_section="$(admin_section_for_login "$login" 2>/dev/null || true)"
        [ -n "$admin_section" ] || admin_section="$(admin_section_name_for_login "$login")"

        if [ "$(uci -q get "sheepfold.$admin_section" 2>/dev/null || true)" != "administrator" ]; then
                uci -q delete "sheepfold.$admin_section" 2>/dev/null || true
                uci -q set "sheepfold.$admin_section=administrator"
        fi

        [ -n "$display_name" ] || display_name="$login"
        local expires_at
        expires_at="$(( $(date +%s) + lifetime ))"

        uci -q set "sheepfold.$admin_section.display_name=$display_name"
        uci -q set "sheepfold.$admin_section.login=$login"
        uci -q set "sheepfold.$admin_section.pairing_code=$code"
        uci -q set "sheepfold.$admin_section.pairing_code_expires=$expires_at"
        uci -q commit sheepfold

        printf 'activated=1\n'
        printf 'admin_section=%s\n' "$admin_section"
        printf 'expires_at=%s\n' "$expires_at"
}

# -----------------------------------------------------------------------------
# admin-pairing-status — polling из LuCI: завершено ли сопряжение
# -----------------------------------------------------------------------------

admin_pairing_status() {
        local login="${1:-}" since="${2:-0}"

        repair_sheepfold_uci_sections
        case "$since" in ''|*[!0-9]*) since=0 ;; esac

        for section in $(uci -q show sheepfold 2>/dev/null | sed -n 's/^sheepfold\.\([^.=]*\)=device$/\1/p'); do
                local admin_device admin_login paired_at
                admin_device="$(uci -q get "sheepfold.$section.admin_device" 2>/dev/null || printf 0)"
                admin_login="$(uci -q get "sheepfold.$section.admin_login" 2>/dev/null || true)"
                paired_at="$(uci -q get "sheepfold.$section.paired_at" 2>/dev/null || printf 0)"

                [ "$admin_device" = "1" ] || continue
                [ "$admin_login" = "$login" ] || continue
                case "$paired_at" in ''|*[!0-9]*) paired_at=0 ;; esac
                [ "$paired_at" -ge "$since" ] || continue

                local device_name device_mac
                device_mac="$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)"
                device_name="$(uci -q get "sheepfold.$section.name" 2>/dev/null || true)"
                [ -n "$device_name" ] || device_name="$device_mac"

                printf 'paired=1\n'
                printf 'admin_name=%s\n' "$(uci -q get "sheepfold.$section.admin_owner" 2>/dev/null || printf '%s' "$login")"
                printf 'admin_login=%s\n' "$admin_login"
                printf 'device_name=%s\n' "$device_name"
                printf 'mac=%s\n' "$device_mac"
                printf 'ip=%s\n' "$(uci -q get "sheepfold.$section.ip" 2>/dev/null || true)"
                printf 'paired_at=%s\n' "$paired_at"
                return 0
        done

        printf 'paired=0\n'
}

# -----------------------------------------------------------------------------
# Wi-Fi управление
# -----------------------------------------------------------------------------

wifi_set_all() {
        local disabled="$1" changed=0

        for radio in $(uci -q show wireless 2>/dev/null | sed -n 's/^wireless\.\([^.=]*\)=wifi-device$/\1/p'); do
                uci -q set "wireless.$radio.disabled=$disabled"
                changed=1
        done

        [ "$changed" = "1" ] || { log "No wireless radios found."; return 1; }

        uci -q commit wireless
        wifi reload >/dev/null 2>&1 || wifi >/dev/null 2>&1 || true
}

wifi_enable() {
        wifi_set_all 0
        log_event "Wi-Fi включён Sheepfold"
}

wifi_disable() {
        wifi_set_all 1
        log_event "Wi-Fi отключён Sheepfold"
}

