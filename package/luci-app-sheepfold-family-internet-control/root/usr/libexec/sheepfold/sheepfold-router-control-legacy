#!/bin/sh
set -eu

# =============================================================================
# sheepfold-router-control-legacy — основной корпус CLI-команд Sheepfold.
#
# Суффикс *-legacy здесь не про «старую версию для пользователей». Тонкий фасад
# /usr/libexec/sheepfold/sheepfold-router-control перехватывает security-sensitive
# команды (SHA-256 токены, pairing, LED) и делегирует остальное в этот файл.
#
# Принимает единственный аргумент COMMAND и вызывает соответствующую функцию.
# Все функции пишут результат в stdout в формате key=value (по одному на строку),
# либо JSON-массив для list-devices.
#
# Правила именования:
#   - Функции — snake_case, отражают действие: device_allow, token_check.
#   - Переменные — snake_case, отражают содержимое: admin_section, device_mac.
#   - Константы (пути, флаги) — UPPER_SNAKE_CASE вверху файла.
# =============================================================================

COMMAND="${1:-status}"

RUNTIME_DIR="/tmp/sheepfold"
LED_DEFAULTS_FILE="$RUNTIME_DIR/led-defaults.tsv"
LED_ALERT_FLAG="$RUNTIME_DIR/new-device-alert"
LED_ALERT_ACK="$RUNTIME_DIR/new-device-alert.ack"
LED_ALERT_PID="$RUNTIME_DIR/led-alert.pid"
WPS_LEASES_SNAPSHOT="$RUNTIME_DIR/wps-leases-before.tsv"
WPS_ALLOWLIST_FLAG="$RUNTIME_DIR/wps-allowlist-window"
WIFI_LAST_ACTION_FILE="$RUNTIME_DIR/wifi-automation-last-action"
BLOCKED_HTTPD_PID="$RUNTIME_DIR/blocked-httpd.pid"
BLOCKED_HTTPD_ROOT="$RUNTIME_DIR/blocked-www"
WAN_STATE_FILE="$RUNTIME_DIR/wan-state"
TOKEN_DIR="$RUNTIME_DIR/tokens"
LOG_HELPER="/usr/libexec/sheepfold/sheepfold-log"

mkdir -p "$RUNTIME_DIR"

# -----------------------------------------------------------------------------
# Вспомогательные: логирование
# -----------------------------------------------------------------------------

log() {
        logger -t sheepfold-router-control "$*"
}

log_event() {
        if [ -x "$LOG_HELPER" ]; then
                "$LOG_HELPER" "$*"
        else
                log "$*"
        fi
}

# -----------------------------------------------------------------------------
# Вспомогательные: UCI
# -----------------------------------------------------------------------------

# Читает поле из sheepfold.global, возвращает значение по умолчанию если не задано.
global_get() {
        uci -q get "sheepfold.global.$1" 2>/dev/null || printf '%s' "$2"
}

# Создаёт секции UCI если их нет или они имеют неверный тип.
# Вызывается перед любой записью в sheepfold UCI.
repair_sheepfold_uci_sections() {
        mkdir -p /etc/config
        [ -e /etc/config/sheepfold ] || : > /etc/config/sheepfold
        chmod 600 /etc/config/sheepfold 2>/dev/null || true

        for pair in messenger:messenger_global export:export_global wifi_control:wifi_control_global pairing:pairing_global; do
                section_type="${pair%%:*}"
                section_name="${pair#*:}"

                if [ "$(uci -q get sheepfold.global 2>/dev/null || true)" = "$section_type" ]; then
                        uci -q rename "sheepfold.global=$section_name" 2>/dev/null || {
                                uci -q delete sheepfold.global 2>/dev/null || true
                                uci -q set "sheepfold.$section_name=$section_type"
                        }
                fi

                uci -q rename "sheepfold.@${section_type}[0]=$section_name" 2>/dev/null || true
        done

        if [ "$(uci -q get sheepfold.global 2>/dev/null || true)" != "sheepfold" ]; then
                uci -q rename sheepfold.global=legacy_global 2>/dev/null || \
                        uci -q delete sheepfold.global 2>/dev/null || true
                uci -q rename sheepfold.@sheepfold[0]=global 2>/dev/null || \
                        uci -q set sheepfold.global='sheepfold'
        fi

        uci -q commit sheepfold 2>/dev/null || true
}

# Завершает скрипт с ошибкой если active_messenger не совпадает с ожидаемым.
require_active_messenger() {
        local expected="$1"
        local actual
        actual="$(global_get active_messenger none)"

        if [ "$actual" != "$expected" ]; then
                echo "UCI active_messenger is '$actual', expected '$expected'" >&2
                exit 1
        fi
}

# -----------------------------------------------------------------------------
# Вспомогательные: валидация
# -----------------------------------------------------------------------------

valid_port() {
        case "$1" in ''|*[!0-9]*) return 1 ;; esac
        [ "$1" -ge 1 ] && [ "$1" -le 65535 ]
}

valid_hostname() {
        printf '%s' "$1" | grep -Eq '^([A-Za-z0-9]([A-Za-z0-9-]*[A-Za-z0-9])?\.)*[A-Za-z0-9]([A-Za-z0-9-]*[A-Za-z0-9])?$'
}

valid_timezone_name() {
        printf '%s' "$1" | grep -Eq '^[A-Za-z0-9_+.-]+(/[A-Za-z0-9_+.-]+)?$'
}

valid_posix_timezone() {
        printf '%s' "$1" | grep -Eq '^[A-Za-z0-9_+:-]+$'
}

# Нормализует MAC в верхний регистр и проверяет формат XX:XX:XX:XX:XX:XX.
normalize_mac() {
        printf '%s' "$1" | tr '[:lower:]' '[:upper:]'
}

valid_mac() {
        printf '%s' "$1" | grep -Eq '^([0-9A-F]{2}:){5}[0-9A-F]{2}$'
}

# -----------------------------------------------------------------------------
# Вспомогательные: UCI-списки устройств
# -----------------------------------------------------------------------------

ensure_list_section() {
        local name="$1"
        if [ "$(uci -q get "sheepfold.$name" 2>/dev/null || true)" != "list" ]; then
                uci -q delete "sheepfold.$name" 2>/dev/null || true
                uci -q set "sheepfold.$name=list"
        fi
}

list_has_mac() {
        local list_name="$1"
        local mac
        mac="$(normalize_mac "$2")"
        valid_mac "$mac" || return 1

        for existing in $(uci -q get "sheepfold.$list_name.mac" 2>/dev/null || true); do
                [ "$(normalize_mac "$existing")" = "$mac" ] && return 0
        done
        return 1
}

device_has_blocked_status() {
        local mac section existing
        mac="$(normalize_mac "$1")"
        valid_mac "$mac" || return 1

        for section in $(uci -q show sheepfold 2>/dev/null | sed -n 's/^sheepfold\.\([^.=]*\)=device$/\1/p'); do
                existing="$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)"
                [ "$(normalize_mac "$existing")" = "$mac" ] || continue
                [ "$(uci -q get "sheepfold.$section.status" 2>/dev/null || true)" = "blocked" ] && return 0
        done
        return 1
}

add_mac_to_list() {
        local list_name="$1"
        local mac
        mac="$(normalize_mac "$2")"
        valid_mac "$mac" || return 1
        ensure_list_section "$list_name"

        # Не добавляем дубликаты.
        for existing in $(uci -q get "sheepfold.$list_name.mac" 2>/dev/null || true); do
                [ "$(normalize_mac "$existing")" = "$mac" ] && return 0
        done

        uci -q add_list "sheepfold.$list_name.mac=$mac"
}

add_mac_to_allowlist() {
        add_mac_to_list allowlist "$1"
}

remove_mac_from_list() {
        local list_name="$1"
        local mac
        mac="$(normalize_mac "$2")"
        valid_mac "$mac" || return 0
        ensure_list_section "$list_name"

        local values
        values="$(uci -q get "sheepfold.$list_name.mac" 2>/dev/null || true)"
        uci -q delete "sheepfold.$list_name.mac" 2>/dev/null || true

        for existing in $values; do
                local normalized
                normalized="$(normalize_mac "$existing")"
                [ "$normalized" = "$mac" ] && continue
                valid_mac "$normalized" || continue
                uci -q add_list "sheepfold.$list_name.mac=$normalized"
        done
}

# Возвращает имя UCI-секции для устройства по MAC.
# Если секции ещё нет — создаёт пустую device-секцию.
device_section_for_mac() {
        local mac
        mac="$(normalize_mac "$1")"
        valid_mac "$mac" || return 1

        for section in $(uci -q show sheepfold 2>/dev/null | sed -n 's/^sheepfold\.\([^.=]*\)=device$/\1/p'); do
                local existing
                existing="$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)"
                if [ "$(normalize_mac "$existing")" = "$mac" ]; then
                        /usr/libexec/sheepfold/sheepfold-device-id ensure "$section" >/dev/null
                        printf '%s\n' "$section"
                        return 0
                fi
        done

        # Генерируем имя секции из MAC без двоеточий.
        local section
        section="device_$(printf '%s' "$mac" | tr -d ':' | tr '[:upper:]' '[:lower:]')"
        uci -q get "sheepfold.$section" >/dev/null 2>&1 || uci -q set "sheepfold.$section=device"
        uci -q set "sheepfold.$section.mac=$mac"
        /usr/libexec/sheepfold/sheepfold-device-id ensure "$section" >/dev/null
        printf '%s\n' "$section"
}

# -----------------------------------------------------------------------------
# Вспомогательные: UCI-секции администраторов
# -----------------------------------------------------------------------------

# Ищет секцию administrator по login, возвращает имя секции или код 1.
admin_section_for_login() {
        local login="$1"
        [ -n "$login" ] || return 1

        for section in $(uci -q show sheepfold 2>/dev/null | sed -n 's/^sheepfold\.\([^.=]*\)=administrator$/\1/p'); do
                local existing
                existing="$(uci -q get "sheepfold.$section.login" 2>/dev/null || true)"
                if [ "$existing" = "$login" ]; then
                        printf '%s\n' "$section"
                        return 0
                fi
        done
        return 1
}

# Генерирует имя UCI-секции для нового администратора по login.
admin_section_name_for_login() {
        local login="$1"
        case "$login" in
                SuperParent)
                        printf 'owner\n'
                        ;;
                *)
                        local section
                        section="admin_$(printf '%s' "$login" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9_]/_/g; s/^_*//; s/_*$//')"
                        [ "$section" != "admin_" ] || section="admin_manual"
                        printf '%s\n' "$section"
                        ;;
        esac
}

# -----------------------------------------------------------------------------
# Вспомогательные: вывод key=value
# -----------------------------------------------------------------------------

# Экранирует спецсимволы и переводы строк для безопасного вывода в key=value.
kv_safe() {
        printf '%s' "$1" | tr '\r\n\t' '   ' | sed 's/[[:space:]][[:space:]]*/ /g; s/^ //; s/ $//'
}

print_kv() {
        printf '%s=%s\n' "$1" "$(kv_safe "$2")"
}

# -----------------------------------------------------------------------------
# Вспомогательные: сеть
# -----------------------------------------------------------------------------

# Возвращает MAC-адрес устройства по его IP (из DHCP-аренд или ARP).
mac_for_ip() {
        local ip="$1"
        [ -n "$ip" ] || return 1

        if [ -r /tmp/dhcp.leases ]; then
                awk -v ip="$ip" '$3 == ip { print toupper($2); exit }' /tmp/dhcp.leases
        fi

        if [ -r /proc/net/arp ]; then
                awk -v ip="$ip" '$1 == ip { print toupper($4); exit }' /proc/net/arp
        fi
}

# Возвращает hostname устройства по IP из DHCP-аренд.
name_for_ip() {
        local ip="$1"
        [ -n "$ip" ] || return 1

        if [ -r /tmp/dhcp.leases ]; then
                awk -v ip="$ip" '$3 == ip { print $4; exit }' /tmp/dhcp.leases
        fi
}

ubus_wan_status() {
        local iface
        iface="$(global_get wan_interface wan)"
        ubus -S call "network.interface.$iface" status 2>/dev/null || true
}

wan_connectivity_ok() {
        for host in ya.ru gosuslugi.ru ntp1.vniiftri.ru 1.1.1.1 8.8.8.8; do
                ping -c 1 -W 2 "$host" >/dev/null 2>&1 && return 0
        done
        return 1
}

json_bool() {
        sed -n "s/.*\"$1\"[[:space:]]*:[[:space:]]*\(true\|false\).*/\1/p"
}

json_string() {
        sed -n "s/.*\"$1\"[[:space:]]*:[[:space:]]*\"\([^\"]*\)\".*/\1/p"
}

# -----------------------------------------------------------------------------
# Вспомогательные: версии пакетов
# -----------------------------------------------------------------------------

opkg_version() {
        opkg status "$1" 2>/dev/null | sed -n 's/^Version: //p' | sed -n '1p'
}

# Возвращает первую найденную версию из списка альтернативных имён пакета.
package_version_any() {
        for pkg in "$@"; do
                local version
                version="$(opkg_version "$pkg")"
                if [ -n "$version" ]; then
                        printf '%s' "$version"
                        return 0
                fi
        done
        return 1
}

# Возвращает 0, если хотя бы один пакет из списка есть в opkg list-upgradable.
package_upgradable_any() {
        local upgradable pkg

        command -v opkg >/dev/null 2>&1 || return 1
        upgradable="$(opkg list-upgradable 2>/dev/null || true)"
        [ -n "$upgradable" ] || return 1

        for pkg in "$@"; do
                if printf '%s\n' "$upgradable" | grep -q "^${pkg} "; then
                        return 0
                fi
        done
        return 1
}

ping_average_ms() {
        ping -c 3 -W 2 "$1" 2>/dev/null | \
                awk -F'/' '/round-trip|rtt/ { print $5; found=1 } END { if (!found) exit 1 }'
}

# Быстрый ping для LuCI-панели, чтобы не упираться в таймаут fs.exec.
ping_quick_ms() {
        ping -c 1 -W 2 "$1" 2>/dev/null | \
                awk -F'/' '/round-trip|rtt/ { print $5; found=1 } END { if (!found) exit 1 }'
}

storage_summary_text() {
        local target free_kb total_kb used_pct

        for target in /overlay /rom /; do
                [ -d "$target" ] || continue
                free_kb="$(df -k "$target" 2>/dev/null | awk 'NR==2 { print $4 }' || true)"
                total_kb="$(df -k "$target" 2>/dev/null | awk 'NR==2 { print $2 }' || true)"
                [ -n "$free_kb" ] && [ -n "$total_kb" ] || continue
                used_pct="$(awk -v free="$free_kb" -v total="$total_kb" 'BEGIN {
                        if (total > 0) printf "%.0f", (total - free) * 100 / total;
                        else print "0"
                }')"
                printf '%s: %.0f MB free / %.0f MB total (%s%% used)' \
                        "$target" "$(awk -v kb="$free_kb" 'BEGIN { printf "%.0f", kb / 1024 }')" \
                        "$(awk -v kb="$total_kb" 'BEGIN { printf "%.0f", kb / 1024 }')" "$used_pct"
                return 0
        done

        printf 'unknown'
}

router_board_json() {
        ubus -S call system board 2>/dev/null || cat /etc/board.json 2>/dev/null || true
}

router_board_field() {
        local field="$1"
        router_board_json | tr -d '\n' | json_string "$field" | sed -n '1p'
}

router_model_text() {
        local value

        for path in /tmp/sysinfo/model /tmp/sysinfo/board_name; do
                if [ -r "$path" ]; then
                        value="$(cat "$path" 2>/dev/null || true)"
                        [ -n "$value" ] && { printf '%s' "$value"; return 0; }
                fi
        done

        value="$(router_board_field model)"
        [ -n "$value" ] && { printf '%s' "$value"; return 0; }

        value="$(router_board_field board_name)"
        [ -n "$value" ] && { printf '%s' "$value"; return 0; }

        printf unknown
}

router_firmware_description() {
        local value

        value="$(router_board_field description)"
        [ -n "$value" ] && { printf '%s' "$value"; return 0; }

        value="$(router_board_field version)"
        [ -n "$value" ] && { printf 'OpenWrt %s' "$value"; return 0; }

        printf unknown
}

lan_ports_text() {
        local ports=""

        for port_path in /sys/class/net/lan*; do
                [ -e "$port_path" ] || continue
                ports="$ports ${port_path##*/}"
        done

        if [ -z "$ports" ] && [ -d /sys/class/net/br-lan/brif ]; then
                for port_path in /sys/class/net/br-lan/brif/*; do
                        [ -e "$port_path" ] || continue
                        ports="$ports ${port_path##*/}"
                done
        fi

        printf '%s' "$ports" | sed 's/^ //'
}

# -----------------------------------------------------------------------------
# Токены: check-token, issue-token, revoke-token
#
# Токены хранятся в $TOKEN_DIR/<sha256_хэш> как пустые файлы.
# Имя файла = sha256 от "$login:$plaintext_token".
# Plaintext никогда не записывается на диск.
# Токен выдаётся командой pair-admin-device после успешного сопряжения.
# -----------------------------------------------------------------------------

mkdir -p "$TOKEN_DIR"

# Хэширует строку через sha256sum (busybox) или openssl.
sha256_of() {
        if command -v sha256sum >/dev/null 2>&1; then
                printf '%s' "$1" | sha256sum | cut -d' ' -f1
        elif command -v openssl >/dev/null 2>&1; then
                printf '%s' "$1" | openssl dgst -sha256 | sed 's/^.* //'
        else
                # Запасной вариант: используем md5 если sha256 недоступен.
                # Это слабее, но лучше чем сломанный функционал на минимальных сборках.
                printf '%s' "$1" | md5sum | cut -d' ' -f1
        fi
}

# Выдаёт токен: создаёт файл-хэш и возвращает plaintext-токен в stdout.
token_issue() {
        local login="$1"
        local plaintext
        plaintext="$(cat /dev/urandom 2>/dev/null | tr -dc 'A-Za-z0-9' | head -c 40 || date +%s%N | sha256sum | cut -c1-40)"

        local hash
        hash="$(sha256_of "${login}:${plaintext}")"
        touch "$TOKEN_DIR/$hash"

        printf '%s\n' "$plaintext"
}

# Проверяет Bearer-токен. Выводит "ok" или "fail".
token_check() {
        local bearer="$1"
        [ -n "$bearer" ] || { printf 'fail\n'; return 0; }

        # Перебираем всех администраторов чтобы найти совпадение по хэшу.
        for section in $(uci -q show sheepfold 2>/dev/null | sed -n 's/^sheepfold\.\([^.=]*\)=administrator$/\1/p'); do
                local login
                login="$(uci -q get "sheepfold.$section.login" 2>/dev/null || true)"
                [ -n "$login" ] || continue

                local hash
                hash="$(sha256_of "${login}:${bearer}")"

                if [ -f "$TOKEN_DIR/$hash" ]; then
                        printf 'ok\n'
                        return 0
                fi
        done

        printf 'fail\n'
}

# Отзывает все токены администратора (при смене пароля или явном выходе).
token_revoke_for_login() {
        local login="$1"
        # Не можем перебирать токены обратно — просто удаляем все файлы в директории.
        # Это безопасно: все сессии будут завершены.
        rm -f "$TOKEN_DIR"/* 2>/dev/null || true
        log "Все токены отозваны для администратора: $login"
}

# -----------------------------------------------------------------------------
# client-status — статус клиентского устройства по IP
#
# Используется детским APK без авторизации.
# Устройство идентифицируется по REMOTE_ADDR → MAC → UCI-секция.
# Возвращает: status, schedule_name, next_change_at, warning_before_minutes.
# -----------------------------------------------------------------------------

client_status() {
        local client_ip="$1"
        [ -n "$client_ip" ] || { printf 'status=unknown\n'; return 0; }

        local client_mac
        client_mac="$(mac_for_ip "$client_ip" | sed -n '1p' || true)"
        client_mac="$(normalize_mac "$client_mac")"

        if ! valid_mac "$client_mac"; then
                printf 'status=unknown\n'
                printf 'reason=mac_not_found\n'
                return 0
        fi

        local device_section
        device_section="$(device_section_for_mac "$client_mac" 2>/dev/null || true)"

        if [ -z "$device_section" ]; then
                printf 'status=unknown\n'
                printf 'reason=device_not_registered\n'
                return 0
        fi

        local device_status schedule_name
        device_status="$(uci -q get "sheepfold.$device_section.status" 2>/dev/null || printf unknown)"
        schedule_name="$(uci -q get "sheepfold.$device_section.active_schedule" 2>/dev/null || true)"

        # Предупреждение выдаётся за 5 минут до смены статуса.
        # Время следующей смены вычисляется расписанием; здесь только читаем поле.
        local next_change_at
        next_change_at="$(uci -q get "sheepfold.$device_section.next_change_at" 2>/dev/null || true)"

        print_kv status "$device_status"
        print_kv schedule_name "$schedule_name"
        print_kv next_change_at "$next_change_at"
        print_kv warning_before_minutes "5"
}

# -----------------------------------------------------------------------------
# list-devices — список всех устройств
#
# Возвращает JSON-массив объектов. Используется GET /devices в CGI.
# -----------------------------------------------------------------------------

list_devices() {
        local first=1
        printf '['

        for section in $(uci -q show sheepfold 2>/dev/null | sed -n 's/^sheepfold\.\([^.=]*\)=device$/\1/p'); do
                local id mac name ip group device_type device_status admin_device
                id="$(/usr/libexec/sheepfold/sheepfold-device-id ensure "$section")"
                mac="$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)"
                [ -n "$mac" ] || continue

                name="$(uci -q get "sheepfold.$section.name" 2>/dev/null || printf '%s' "$mac")"
                ip="$(uci -q get "sheepfold.$section.ip" 2>/dev/null || true)"
                group="$(uci -q get "sheepfold.$section.group" 2>/dev/null || true)"
                device_type="$(uci -q get "sheepfold.$section.device_type" 2>/dev/null || printf smart)"
                device_status="$(uci -q get "sheepfold.$section.status" 2>/dev/null || printf new)"
                admin_device="$(uci -q get "sheepfold.$section.admin_device" 2>/dev/null || printf 0)"

                # Экранируем поля для безопасной вставки в JSON.
                local safe_name safe_group
                safe_name="$(printf '%s' "$name" | sed 's/\\/\\\\/g; s/"/\\"/g')"
                safe_group="$(printf '%s' "$group" | sed 's/\\/\\\\/g; s/"/\\"/g')"

                [ "$first" = "1" ] || printf ','
                printf '{"id":%s,"mac":"%s","name":"%s","ip":"%s","group":"%s","deviceType":"%s","status":"%s","adminDevice":%s}' \
                        "$id" "$mac" "$safe_name" "$ip" "$safe_group" "$device_type" "$device_status" \
                        "$([ "$admin_device" = "1" ] && printf true || printf false)"
                first=0
        done

        printf ']\n'
}

# -----------------------------------------------------------------------------
# device-allow — добавить устройство в белый список
# device-block — добавить устройство в чёрный список
# device-temp-access — временно разрешить устройство на N минут
# -----------------------------------------------------------------------------

device_allow() {
        local device_mac
        device_mac="$(normalize_mac "${1:-}")"
        valid_mac "$device_mac" || { echo "Invalid MAC: $device_mac" >&2; return 2; }

        repair_sheepfold_uci_sections
        ensure_list_section allowlist
        ensure_list_section blocklist

        local device_section
        device_section="$(device_section_for_mac "$device_mac")"
        local device_id
        device_id="$(uci -q get "sheepfold.$device_section.id" 2>/dev/null || true)"

        # Администраторское устройство уже в белом списке — ничего не меняем.
        if [ "$(uci -q get "sheepfold.$device_section.status" 2>/dev/null || true)" = "allow" ]; then
                printf 'OK\n'
                return 0
        fi

        if list_has_mac blocklist "$device_mac"; then
                echo "Device is in blocklist. Remove from blocklist first." >&2
                return 3
        fi

        uci -q set "sheepfold.$device_section.status=allow"
        add_mac_to_list allowlist "$device_mac"
        uci -q commit sheepfold

        log_event "Устройство #${device_id} добавлено в белый список через Android: $device_mac"
        printf 'OK\n'
}

device_block() {
        local device_mac
        device_mac="$(normalize_mac "${1:-}")"
        valid_mac "$device_mac" || { echo "Invalid MAC: $device_mac" >&2; return 2; }

        repair_sheepfold_uci_sections
        ensure_list_section allowlist
        ensure_list_section blocklist

        local device_section
        device_section="$(device_section_for_mac "$device_mac")"
        local device_id
        device_id="$(uci -q get "sheepfold.$device_section.id" 2>/dev/null || true)"

        # Администраторское устройство нельзя заблокировать — иначе родитель потеряет доступ.
        if [ "$(uci -q get "sheepfold.$device_section.admin_device" 2>/dev/null || printf 0)" = "1" ]; then
                echo "Administrator device cannot be blocked." >&2
                return 3
        fi

        if list_has_mac allowlist "$device_mac"; then
                echo "Device is in allowlist. Remove from allowlist first." >&2
                return 3
        fi

        uci -q set "sheepfold.$device_section.status=blocked"
        add_mac_to_list blocklist "$device_mac"
        remove_mac_from_list allowlist "$device_mac"
        uci -q commit sheepfold

        log_event "Устройство #${device_id} заблокировано через Android: $device_mac"
        printf 'OK\n'
}

device_temp_access() {
        local device_mac minutes
        device_mac="$(normalize_mac "${1:-}")"
        minutes="${2:-30}"

        valid_mac "$device_mac" || { echo "Invalid MAC: $device_mac" >&2; return 2; }

        case "$minutes" in ''|*[!0-9]*) minutes=30 ;; esac
        [ "$minutes" -le 1440 ] || minutes=1440

        repair_sheepfold_uci_sections
        ensure_list_section allowlist
        ensure_list_section blocklist
        local device_section
        device_section="$(device_section_for_mac "$device_mac")"
        local device_id
        device_id="$(uci -q get "sheepfold.$device_section.id" 2>/dev/null || true)"

        if list_has_mac blocklist "$device_mac" || \
                [ "$(uci -q get "sheepfold.$device_section.status" 2>/dev/null || true)" = "blocked" ]; then
                echo "Device is in blocklist. Temporary access cannot override blocklist." >&2
                return 3
        fi

        local expires_at
        expires_at=$(( $(date +%s) + minutes * 60 ))
        local previous_status previous_added previous_was_temp
        previous_status="$(uci -q get "sheepfold.$device_section.status" 2>/dev/null || printf restricted)"
        previous_added="$(uci -q get "sheepfold.$device_section.temp_access_allowlist_added" 2>/dev/null || true)"
        previous_was_temp=0
        case "$previous_status" in
                temp_access|temp-access|temporary)
                        previous_was_temp=1
                        previous_status="$(uci -q get "sheepfold.$device_section.temp_access_previous_status" 2>/dev/null || printf restricted)"
                        ;;
        esac

        # Временный доступ сохраняется как поле temp_access_until.
        # Если backend временно добавил MAC в allowlist, очистка после срока снимет только этот временный доступ.
        uci -q set "sheepfold.$device_section.temp_access_until=$expires_at"
        uci -q set "sheepfold.$device_section.temp_access_previous_status=$previous_status"
        if [ "$previous_added" = "1" ] || { [ "$previous_was_temp" = "1" ] && [ -z "$previous_added" ]; }; then
                uci -q set "sheepfold.$device_section.temp_access_allowlist_added=1"
        elif list_has_mac allowlist "$device_mac"; then
                uci -q set "sheepfold.$device_section.temp_access_allowlist_added=0"
        else
                uci -q set "sheepfold.$device_section.temp_access_allowlist_added=1"
                add_mac_to_list allowlist "$device_mac"
        fi
        uci -q set "sheepfold.$device_section.status=temp_access"
        uci -q commit sheepfold

        log_event "Временный доступ выдан устройству #${device_id} $device_mac на $minutes мин."
        print_kv expires_at "$expires_at"
        print_kv minutes "$minutes"
        printf 'OK\n'
}

expire_temp_access() {
        repair_sheepfold_uci_sections
        ensure_list_section allowlist

        local now changed
        now="$(date +%s)"
        changed=0

        for section in $(uci -q show sheepfold 2>/dev/null | sed -n 's/^sheepfold\.\([^.=]*\)=device$/\1/p'); do
                local status expires_at mac added previous_status device_id
                status="$(uci -q get "sheepfold.$section.status" 2>/dev/null || true)"
                case "$status" in
                        temp_access|temp-access|temporary) ;;
                        *) continue ;;
                esac

                expires_at="$(uci -q get "sheepfold.$section.temp_access_until" 2>/dev/null || printf 0)"
                case "$expires_at" in ''|*[!0-9]*) expires_at=0 ;; esac
                [ "$expires_at" -le "$now" ] || continue

                mac="$(normalize_mac "$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)")"
                added="$(uci -q get "sheepfold.$section.temp_access_allowlist_added" 2>/dev/null || printf 1)"
                if [ "$added" = "1" ] && valid_mac "$mac"; then
                        remove_mac_from_list allowlist "$mac"
                fi

                previous_status="$(uci -q get "sheepfold.$section.temp_access_previous_status" 2>/dev/null || printf restricted)"
                case "$previous_status" in
                        allow|blocked|restricted|scheduled|new) ;;
                        *) previous_status=restricted ;;
                esac

                # Старые версии могли оставить временный MAC в allowlist навсегда; этот проход чинит состояние.
                uci -q set "sheepfold.$section.status=$previous_status"
                uci -q delete "sheepfold.$section.temp_access_until" 2>/dev/null || true
                uci -q delete "sheepfold.$section.temp_access_previous_status" 2>/dev/null || true
                uci -q delete "sheepfold.$section.temp_access_allowlist_added" 2>/dev/null || true
                /usr/libexec/sheepfold/sheepfold-device-id ensure "$section" >/dev/null 2>&1 || true
                device_id="$(uci -q get "sheepfold.$section.id" 2>/dev/null || printf '?')"
                log_event "Временный доступ завершён для устройства #${device_id} $mac; восстановлен статус $previous_status."
                changed=1
        done

        [ "$changed" = "1" ] && uci -q commit sheepfold
        printf 'OK\n'
}

