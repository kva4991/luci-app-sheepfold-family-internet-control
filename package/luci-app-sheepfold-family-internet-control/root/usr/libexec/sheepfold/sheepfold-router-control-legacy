http_get() {
        local url="$1"
        if command -v uclient-fetch >/dev/null 2>&1; then
                uclient-fetch -qO- "$url" 2>/dev/null || true
        elif command -v wget >/dev/null 2>&1; then
                wget -q -O - "$url" 2>/dev/null || true
        elif command -v curl >/dev/null 2>&1; then
                curl -fsSL "$url" 2>/dev/null || true
        fi
}

messenger_check() {
        repair_sheepfold_uci_sections
        local active
        active="$(global_get active_messenger none)"
        printf 'active=%s\n' "$active"

        case "$active" in
                telegram)
                        local token
                        token="$(global_get telegram_bot_token '')"
                        if [ -z "$token" ]; then
                                printf 'status=error\nmessage=Токен Telegram-бота не заполнен\n'
                                return 1
                        fi
                        local response
                        response="$(http_get "https://api.telegram.org/bot${token}/getMe")"
                        if printf '%s' "$response" | grep -q '"ok"[[:space:]]*:[[:space:]]*true'; then
                                printf 'status=connected\nmessage=Telegram подключён\n'
                        else
                                printf 'status=error\nmessage=От сервера Telegram нет ответа\n'
                                return 1
                        fi
                        ;;
                vk)
                        local token community_id
                        token="$(global_get vk_access_token '')"
                        community_id="$(global_get vk_community_id '')"
                        if [ -z "$token" ] || [ -z "$community_id" ]; then
                                printf 'status=error\nmessage=Данные VK не заполнены\n'
                                return 1
                        fi
                        local response
                        response="$(http_get "https://api.vk.com/method/groups.getById?group_id=${community_id}&access_token=${token}&v=5.199")"
                        if printf '%s' "$response" | grep -q '"response"[[:space:]]*:'; then
                                printf 'status=connected\nmessage=VK подключён\n'
                        else
                                printf 'status=error\nmessage=От сервера VK нет ответа\n'
                                return 1
                        fi
                        ;;
                *)
                        printf 'status=disabled\nmessage=Мессенджер выключен\n'
                        ;;
        esac
}

# -----------------------------------------------------------------------------
# Время и NTP
# -----------------------------------------------------------------------------

ensure_system_time_sections() {
        uci -q get system.@system[0] >/dev/null 2>&1 || uci -q add system system >/dev/null
        if [ "$(uci -q get system.ntp 2>/dev/null || true)" != "timeserver" ]; then
                uci -q delete system.ntp 2>/dev/null || true
                uci -q set system.ntp='timeserver'
        fi
}

time_save() {
        local ntp_server_enabled="${1:-1}"
        local ntp_client_enabled="${2:-1}"
        local zonename="${3:-Europe/Moscow}"
        local timezone="${4:-MSK-3}"
        local servers="${5:-ntp1.vniiftri.ru ntp2.ntp-servers.net 3.openwrt.pool.ntp.org}"
        local normalized_servers=""

        case "$ntp_server_enabled" in 0|1) ;; *) ntp_server_enabled=1 ;; esac
        case "$ntp_client_enabled" in 0|1) ;; *) ntp_client_enabled=1 ;; esac
        valid_timezone_name "$zonename" || zonename="Europe/Moscow"
        valid_posix_timezone "$timezone" || timezone="MSK-3"

        for server in $servers; do
                valid_hostname "$server" || continue
                normalized_servers="${normalized_servers}${normalized_servers:+ }$server"
        done
        [ -n "$normalized_servers" ] || normalized_servers="ntp1.vniiftri.ru ntp2.ntp-servers.net 3.openwrt.pool.ntp.org"

        repair_sheepfold_uci_sections
        ensure_system_time_sections

        uci -q set "system.@system[0].zonename=$zonename"
        uci -q set "system.@system[0].timezone=$timezone"
        uci -q set "system.ntp.enabled=$ntp_client_enabled"
        uci -q set "system.ntp.enable_server=$ntp_server_enabled"
        uci -q delete system.ntp.server 2>/dev/null || true
        for server in $normalized_servers; do
                uci -q add_list "system.ntp.server=$server"
        done
        uci -q commit system

        uci -q set sheepfold.global.router_ntp_server_enabled="$ntp_server_enabled"
        uci -q set sheepfold.global.router_ntp_client_auto_configure="$ntp_client_enabled"
        uci -q set sheepfold.global.router_timezone_name="$zonename"
        uci -q set sheepfold.global.router_timezone="$timezone"
        uci -q set sheepfold.global.router_ntp_servers="$normalized_servers"
        uci -q commit sheepfold

        [ -x /etc/init.d/sysntpd ] && /etc/init.d/sysntpd restart >/dev/null 2>&1 || true
        log_event "Настройки времени сохранены: timezone $zonename, NTP $normalized_servers"
        printf 'OK\n'
}

# -----------------------------------------------------------------------------
# router-info — диагностический снимок состояния роутера
# -----------------------------------------------------------------------------

router_info() {
        local status_json wan_state wan_reason ping_ms ping_ya_ru_ms ping_google_com_ms ping_youtube_com_ms any_ping_ok
        local firmware release model kernel
        local sheepfold_version podkop_version adguard_version podkop_version_status
        local lan_ports lan_count uptime_text load_avg memory_text storage_text
        local wifi_radios wifi_index radio

        # LuCI вызывает router-info через fs.exec. set -e не должен обрывать
        # диагностику до первой строки key=value, иначе панель остаётся пустой.
        set +e

        status_json="$(ubus_wan_status)"
        wan_state="unknown"
        wan_reason="статус WAN неизвестен"
        ping_ya_ru_ms="$(ping_quick_ms ya.ru 2>/dev/null || true)"
        ping_google_com_ms="$(ping_quick_ms google.com 2>/dev/null || true)"
        ping_youtube_com_ms="$(ping_quick_ms youtube.com 2>/dev/null || true)"
        ping_ms="$ping_ya_ru_ms"
        any_ping_ok=0
        [ -n "$ping_ya_ru_ms" ] && any_ping_ok=1
        [ -n "$ping_google_com_ms" ] && any_ping_ok=1
        [ -n "$ping_youtube_com_ms" ] && any_ping_ok=1
        firmware="unknown"
        release="unknown"
        model="$(router_model_text)"
        kernel="$(uname -r 2>/dev/null || printf unknown)"
        sheepfold_version="$(opkg_version luci-app-sheepfold-family-internet-control)"
        podkop_version="$(package_version_any podkop luci-app-podkop || true)"
        adguard_version="$(package_version_any AdGuardHome adguardhome luci-app-adguardhome || true)"
        podkop_version_status="not_installed"
        if [ -n "$podkop_version" ]; then
                if package_upgradable_any podkop luci-app-podkop; then
                        podkop_version_status="outdated"
                else
                        podkop_version_status="up_to_date"
                fi
        fi
        lan_ports="$(lan_ports_text)"
        lan_count="0"
        uptime_text="$(awk '{ s=int($1); printf "%sd %sh %sm", int(s/86400), int((s%86400)/3600), int((s%3600)/60) }' /proc/uptime 2>/dev/null || printf unknown)"
        load_avg="$(cut -d' ' -f1-3 /proc/loadavg 2>/dev/null || printf unknown)"
        memory_text="$(awk '/MemTotal:/ { t=$2 } /MemAvailable:/ { a=$2 } END { if (t>0) printf "%.0f MB free / %.0f MB total", a/1024, t/1024; else print "unknown" }' /proc/meminfo 2>/dev/null || printf unknown)"
        storage_text="$(storage_summary_text)"

        [ -n "$sheepfold_version" ] || sheepfold_version="$(global_get ui_asset_version unknown)"

        if [ -r /etc/openwrt_release ]; then
                # shellcheck disable=SC1091
                . /etc/openwrt_release
                release="${DISTRIB_RELEASE:-unknown}"
                firmware="${DISTRIB_DESCRIPTION:-OpenWrt $release}"
        elif [ -r /etc/openwrt_version ]; then
                release="$(cat /etc/openwrt_version 2>/dev/null || printf unknown)"
                firmware="OpenWrt $release"
        else
                # На некоторых сборках OpenWrt release-файлы урезаны, но ubus
                # всё равно отдаёт system board. Берём описание оттуда, чтобы
                # страница "Информация" не превращалась в набор unknown.
                firmware="$(router_firmware_description)"
                release="$(router_board_field version)"
                [ -n "$release" ] || release="unknown"
        fi

        if [ -n "$status_json" ]; then
                local up available device
                up="$(printf '%s' "$status_json" | json_bool up | head -n 1)"
                available="$(printf '%s' "$status_json" | json_bool available | head -n 1)"
                device="$(printf '%s' "$status_json" | json_string l3_device | head -n 1)"

                if [ -n "$device" ] && [ -r "/sys/class/net/$device/carrier" ] && \
                        [ "$(cat "/sys/class/net/$device/carrier" 2>/dev/null || printf 1)" = "0" ]; then
                        wan_state="offline"
                        wan_reason="кабель WAN отключён или порт без линка"
                elif [ "$up" != "true" ]; then
                        wan_state="offline"
                        wan_reason="$([ "$available" = "false" ] && printf 'WAN-интерфейс недоступен' || printf 'WAN-интерфейс не поднят')"
                elif [ "$any_ping_ok" -eq 1 ]; then
                        wan_state="online"
                        wan_reason=""
                else
                        wan_state="limited"
                        wan_reason="WAN поднят, но проверочные хосты не ответили на ping"
                fi
        fi

        [ -n "$lan_ports" ] && lan_count="$(printf '%s\n' "$lan_ports" | awk '{ print NF + 0 }')"

        print_kv current_time        "$(date '+%d.%m.%Y %H:%M:%S %Z' 2>/dev/null || date)"
        print_kv sheepfold_version   "$sheepfold_version"
        print_kv internet_status     "$wan_state"
        print_kv internet_reason     "$wan_reason"
        print_kv ping_ya_ru_ms         "${ping_ya_ru_ms:-timeout}"
        print_kv ping_google_com_ms    "${ping_google_com_ms:-timeout}"
        print_kv ping_youtube_com_ms   "${ping_youtube_com_ms:-timeout}"
        print_kv ping_yandex_ms        "${ping_ya_ru_ms:-timeout}"
        print_kv firmware_version    "$firmware"
        print_kv openwrt_release     "$release"
        print_kv kernel_version      "$kernel"
        print_kv router_model        "$model"
        print_kv uptime              "$uptime_text"
        print_kv load_average        "$load_avg"
        print_kv memory              "$memory_text"
        print_kv lan_ports_count     "$lan_count"
        print_kv lan_ports           "${lan_ports:-unknown}"
        print_kv podkop_installed    "$([ -n "$podkop_version" ]  && printf yes || printf no)"
        print_kv podkop_version      "${podkop_version:-not installed}"
        print_kv podkop_version_status "$podkop_version_status"
        print_kv adguard_installed   "$([ -n "$adguard_version" ] && printf yes || printf no)"
        print_kv adguard_version     "${adguard_version:-not installed}"
        print_kv storage_space       "$storage_text"

        wifi_index=0
        wifi_radios="$(uci -q show wireless 2>/dev/null | sed -n 's/^wireless\.\([^.=]*\)=wifi-device$/\1/p' || true)"
        for radio in $wifi_radios; do
                wifi_index=$((wifi_index + 1))
                local disabled type path band channel country htmode
                disabled="$(uci -q get "wireless.$radio.disabled" 2>/dev/null || printf 0)"
                type="$(uci -q get "wireless.$radio.type" 2>/dev/null || printf unknown)"
                path="$(uci -q get "wireless.$radio.path" 2>/dev/null || uci -q get "wireless.$radio.phy" 2>/dev/null || printf unknown)"
                band="$(uci -q get "wireless.$radio.band" 2>/dev/null || uci -q get "wireless.$radio.hwmode" 2>/dev/null || printf unknown)"
                channel="$(uci -q get "wireless.$radio.channel" 2>/dev/null || printf auto)"
                country="$(uci -q get "wireless.$radio.country" 2>/dev/null || printf unknown)"
                htmode="$(uci -q get "wireless.$radio.htmode" 2>/dev/null || printf unknown)"

                print_kv "wifi_${wifi_index}_name"    "$radio"
                print_kv "wifi_${wifi_index}_status"  "$([ "$disabled" = "1" ] && printf disabled || printf enabled)"
                print_kv "wifi_${wifi_index}_type"    "$type"
                print_kv "wifi_${wifi_index}_path"    "$path"
                print_kv "wifi_${wifi_index}_band"    "$band"
                print_kv "wifi_${wifi_index}_channel" "$channel"
                print_kv "wifi_${wifi_index}_country" "$country"
                print_kv "wifi_${wifi_index}_mode"    "$htmode"
        done
        print_kv wifi_count "$wifi_index"
}

# -----------------------------------------------------------------------------
# wan-status-tick — периодическая проверка состояния WAN
# Вызывается из sheepfold-service каждые N секунд.
# -----------------------------------------------------------------------------

wan_status_tick() {
        local now last_line last_check
        now="$(date +%s)"
        last_line="$(cat "$WAN_STATE_FILE" 2>/dev/null || true)"
        last_check="$(printf '%s' "$last_line" | awk -F '\t' '{ print $3 }')"
        case "$last_check" in ''|*[!0-9]*) last_check=0 ;; esac

        # Не чаще одного раза в минуту.
        [ $((now - last_check)) -ge 60 ] || return 0

        local status_json state reason
        status_json="$(ubus_wan_status)"

        if [ -z "$status_json" ]; then
                state="offline"
                reason="не удалось получить статус WAN через ubus"
        else
                local up available device
                up="$(printf '%s' "$status_json" | json_bool up | head -n 1)"
                available="$(printf '%s' "$status_json" | json_bool available | head -n 1)"
                device="$(printf '%s' "$status_json" | json_string l3_device | head -n 1)"

                if [ -n "$device" ] && [ -r "/sys/class/net/$device/carrier" ] && \
                        [ "$(cat "/sys/class/net/$device/carrier" 2>/dev/null || printf 1)" = "0" ]; then
                        state="offline"; reason="кабель WAN отключён или порт без линка"
                elif [ "$up" != "true" ]; then
                        state="offline"
                        reason="$([ "$available" = "false" ] && printf 'WAN-интерфейс недоступен' || printf 'WAN-интерфейс не поднят')"
                elif wan_connectivity_ok; then
                        state="online"; reason="проверка связи прошла успешно"
                else
                        state="offline"; reason="таймаут проверки связи"
                fi
        fi

        local previous_state previous_reason
        previous_state="$(printf '%s' "$last_line" | awk -F '\t' '{ print $1 }')"
        previous_reason="$(printf '%s' "$last_line" | awk -F '\t' '{ print $2 }')"

        if [ -n "$previous_state" ] && \
                { [ "$state" != "$previous_state" ] || { [ "$state" = "offline" ] && [ "$reason" != "$previous_reason" ]; }; }; then
                if [ "$state" = "online" ]; then
                        log_event "Интернет на роутере восстановлен: $reason"
                else
                        log_event "У роутера пропал интернет: $reason"
                fi
        fi

        printf '%s\t%s\t%s\n' "$state" "$reason" "$now" > "$WAN_STATE_FILE"
}

# -----------------------------------------------------------------------------
# Страница блокировки (uhttpd на отдельном порту)
# -----------------------------------------------------------------------------

blocked_httpd_running() {
        [ -r "$BLOCKED_HTTPD_PID" ] || return 1
        local pid
        pid="$(cat "$BLOCKED_HTTPD_PID" 2>/dev/null || true)"
        [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

blocked_httpd_stop() {
        blocked_httpd_running && kill "$(cat "$BLOCKED_HTTPD_PID")" 2>/dev/null || true
        rm -f "$BLOCKED_HTTPD_PID"
}

blocked_httpd_start() {
        local port
        port="$(global_get blocked_page_port 5202)"
        valid_port "$port" || port=5202

        mkdir -p "$BLOCKED_HTTPD_ROOT"
        rm -f "$BLOCKED_HTTPD_ROOT/index.html"
        blocked_httpd_running && return 0

        if ! command -v uhttpd >/dev/null 2>&1; then
                log "uhttpd is not available for blocked page responder."
                return 0
        fi

        uhttpd -f -p "0.0.0.0:$port" -h "$BLOCKED_HTTPD_ROOT" -x /cgi-bin \
                -E /cgi-bin/sheepfold-blocked >/dev/null 2>&1 &
        printf '%s' "$!" > "$BLOCKED_HTTPD_PID"
        log "Blocked page responder started on port $port."
}

blocked_page_apply() {
        if [ "$(global_get blocked_page_enabled 1)" = "1" ]; then
                blocked_httpd_start
        else
                blocked_httpd_stop
        fi
}

# -----------------------------------------------------------------------------
# LED-управление
# -----------------------------------------------------------------------------

save_led_defaults() {
        [ -s "$LED_DEFAULTS_FILE" ] && return 0
        : > "$LED_DEFAULTS_FILE"
        for led in /sys/class/leds/*; do
                [ -d "$led" ] || continue
                local name trigger brightness
                name="${led##*/}"
                trigger="$(sed -n 's/.*\[\([^]]*\)\].*/\1/p' "$led/trigger" 2>/dev/null || true)"
                brightness="$(cat "$led/brightness" 2>/dev/null || printf 0)"
                printf '%s\t%s\t%s\n' "$name" "${trigger:-none}" "${brightness:-0}" >> "$LED_DEFAULTS_FILE"
        done
}

led_set() {
        local led="$1" brightness="$2"
        [ -d "$led" ] || return 0
        [ -w "$led/trigger" ]    && printf none        > "$led/trigger"    2>/dev/null || true
        [ -w "$led/brightness" ] && printf '%s' "$brightness" > "$led/brightness" 2>/dev/null || true
}

led_all() {
        save_led_defaults
        for led in /sys/class/leds/*; do
                led_set "$led" "$1"
        done
}

led_restore_defaults() {
        if [ -r "$LED_DEFAULTS_FILE" ]; then
                while IFS="$(printf '\t')" read -r name trigger brightness; do
                        local led="/sys/class/leds/$name"
                        [ -d "$led" ] || continue
                        [ -n "$trigger" ]    && [ -w "$led/trigger" ]    && printf '%s' "$trigger"    > "$led/trigger"    2>/dev/null || true
                        [ -n "$brightness" ] && [ -w "$led/brightness" ] && printf '%s' "$brightness" > "$led/brightness" 2>/dev/null || true
                done < "$LED_DEFAULTS_FILE"
                rm -f "$LED_DEFAULTS_FILE"
        else
                for led in /sys/class/leds/*; do
                        [ -d "$led" ] || continue
                        [ -w "$led/trigger" ] && printf default-on > "$led/trigger" 2>/dev/null || true
                done
        fi
}

led_off_forever() {
        led_all 0
        log "All router LEDs turned off by Sheepfold."
}

led_blink_code() {
        local seconds="${1:-30}" pattern="${2:-1010000}"
        local end=$(( $(date +%s) + seconds ))

        save_led_defaults
        while [ "$(date +%s)" -lt "$end" ]; do
                local i=1
                while [ "$i" -le "${#pattern}" ] && [ "$(date +%s)" -lt "$end" ]; do
                        local bit
                        bit="$(printf '%s' "$pattern" | cut -c "$i")"
                        [ "$bit" = "1" ] && led_all 1 || led_all 0
                        sleep 0.5
                        i=$((i + 1))
                done
        done
        led_restore_defaults
}

led_alert_loop_running() {
        [ -r "$LED_ALERT_PID" ] || return 1
        local pid
        pid="$(cat "$LED_ALERT_PID" 2>/dev/null || true)"
        [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

led_alert_loop() {
        printf '%s' "$$" > "$LED_ALERT_PID"
        save_led_defaults

        while [ -e "$LED_ALERT_FLAG" ] && \
                [ "$(global_get router_led_control router_default)" = "new_device_alert_until_luci_login" ]; do

                local count=0
                for led in /sys/class/leds/*; do [ -d "$led" ] && count=$((count + 1)); done

                if [ "$count" -le 0 ]; then
                        sleep 5
                elif [ "$count" -eq 1 ]; then
                        for v in 1 0 1 0; do led_all "$v"; sleep 0.5; done
                else
                        for active in /sys/class/leds/*; do
                                [ -d "$active" ] || continue
                                for led in /sys/class/leds/*; do
                                        [ -d "$led" ] || continue
                                        [ "$led" = "$active" ] && led_set "$led" 1 || led_set "$led" 0
                                done
                                sleep 0.5
                        done
                fi
        done

        led_restore_defaults
        rm -f "$LED_ALERT_PID"
}

led_alert_start() {
        [ "$(global_get router_led_control router_default)" = "new_device_alert_until_luci_login" ] || return 0
        [ -e "$LED_ALERT_FLAG" ] || return 0
        led_alert_loop_running && return 0
        "$0" led-alert-loop >/dev/null 2>&1 </dev/null &
}

led_alert_ack() {
        rm -f "$LED_ALERT_FLAG" "$LED_ALERT_ACK"
        led_restore_defaults
        log "New-device LED alert acknowledged."
}

# -----------------------------------------------------------------------------
# WPS
# -----------------------------------------------------------------------------

snapshot_leases() {
        if [ -r /tmp/dhcp.leases ]; then
                awk 'NF >= 4 { print toupper($2) }' /tmp/dhcp.leases | sort -u
        fi
}

start_wps_pbc() {
        local started=0

        if command -v ubus >/dev/null 2>&1; then
                for service in $(ubus list 'hostapd.*' 2>/dev/null || true); do
                        ubus call "$service" wps_start '{}' >/dev/null 2>&1 && started=1 || true
                done
        fi

        if command -v hostapd_cli >/dev/null 2>&1; then
                for dir in /var/run/hostapd /var/run/hostapd-*; do
                        [ -d "$dir" ] || continue
                        for sock in "$dir"/*; do
                                [ -S "$sock" ] || continue
                                hostapd_cli -p "$dir" -i "${sock##*/}" wps_pbc >/dev/null 2>&1 && started=1 || true
                        done
                done
        fi

        if [ "$started" = "1" ]; then
                log_event "WPS-подключение разрешено на 30 секунд"
        else
                log_event "Не удалось запустить WPS на роутере"
        fi
}

wps_allowlist_window() {
        snapshot_leases > "$WPS_LEASES_SNAPSHOT"
        touch "$WPS_ALLOWLIST_FLAG"
        start_wps_pbc
        "$0" led-blink-code 30 1010000 >/dev/null 2>&1 </dev/null &
        sleep 30

        snapshot_leases | while read -r mac; do
                [ -n "$mac" ] || continue
                grep -qx "$mac" "$WPS_LEASES_SNAPSHOT" 2>/dev/null && continue
                if list_has_mac blocklist "$mac" || device_has_blocked_status "$mac"; then
                        log_event "WPS-окно не добавило устройство из чёрного списка: $mac"
                        continue
                fi
                add_mac_to_allowlist "$mac"
        done

        uci -q commit sheepfold
        rm -f "$WPS_ALLOWLIST_FLAG" "$WPS_LEASES_SNAPSHOT"
        log_event "Окно WPS-добавления в белый список завершено"
}

wps_handle_action() {
        case "${1:-router_default}" in
                router_default|"")
                        return 0
                        ;;
                allow_wifi_connection)
                        start_wps_pbc
                        "$0" led-blink-code 30 1010000 >/dev/null 2>&1 </dev/null &
                        ;;
                allow_wifi_and_allowlist)
                        "$0" wps-allowlist-window >/dev/null 2>&1 </dev/null &
                        ;;
                disable_wifi)
                        wifi_disable
                        ;;
        esac
}

wps_button() {
        local press_kind="${1:-short}"
        if [ "$press_kind" = "long" ]; then
                wps_handle_action "$(global_get wps_long_press_action router_default)"
        else
                wps_handle_action "$(global_get wps_short_press_action router_default)"
        fi
}

# -----------------------------------------------------------------------------
# wifi-automation-tick — проверяет расписание автовключения/отключения Wi-Fi
# -----------------------------------------------------------------------------

wifi_automation_tick() {
        local now_time today
        now_time="$(date +%H:%M)"
        today="$(date +%Y-%m-%d)"

        local enable_mode enable_time disable_mode disable_time
        enable_mode="$(global_get wifi_auto_enable_mode never)"
        enable_time="$(global_get wifi_auto_enable_time 07:00)"
        disable_mode="$(global_get wifi_auto_disable_mode never)"
        disable_time="$(global_get wifi_auto_disable_time 23:00)"

        local last_action
        last_action="$(cat "$WIFI_LAST_ACTION_FILE" 2>/dev/null || true)"

        if [ "$enable_mode" = "time" ] && [ "$now_time" = "$enable_time" ]; then
                local key="$today enable $enable_time"
                if [ "$last_action" != "$key" ]; then
                        wifi_enable
                        printf '%s' "$key" > "$WIFI_LAST_ACTION_FILE"
                fi
        fi

        if [ "$disable_mode" = "time" ] && [ "$now_time" = "$disable_time" ]; then
                local key="$today disable $disable_time"
                if [ "$last_action" != "$key" ]; then
                        wifi_disable
                        printf '%s' "$key" > "$WIFI_LAST_ACTION_FILE"
                fi
        fi
}

# =============================================================================
# Диспетчер команд
# =============================================================================

case "$COMMAND" in

        # --- Токены ----------------------------------------------------------
        check-token)
                token_check "${2:-}"
                ;;
        revoke-tokens)
                token_revoke_for_login "${2:-}"
                ;;

        # --- Клиентский статус (детский APK, без авторизации) ----------------
        client-status)
                client_status "${2:-}"
                ;;

        # --- Устройства (требуют авторизации через CGI) -----------------------
        list-devices)
                list_devices
                ;;
        device-allow)
                device_allow "${2:-}"
                ;;
        device-block)
                device_block "${2:-}"
                ;;
        device-temp-access)
                device_temp_access "${2:-}" "${3:-30}"
                ;;
        expire-temp-access)
                expire_temp_access
                ;;

        # --- Глобальная блокировка интернета ---------------------------------
        global-block-on)
                global_block_on
                ;;
        global-block-off)
                global_block_off
                ;;

        # --- Legacy-команды LuCI (internet-enable/disable для совместимости) -
        internet-enable)
                global_internet_enable
                ;;
        internet-disable)
                global_internet_disable
                ;;
        internet-status)
                global_internet_status
                ;;

        # --- Сопряжение Android-приложения -----------------------------------
        pair-admin-device)
                pair_admin_device "${2:-}" "${3:-}" "${4:-}" "${5:-}"
                ;;
        activate-admin-pairing-code)
                activate_admin_pairing_code "${2:-}" "${3:-}" "${4:-}" "${5:-600}"
                ;;
        admin-pairing-status)
                admin_pairing_status "${2:-}" "${3:-0}"
                ;;

        # --- Wi-Fi ------------------------------------------------------------
        wifi-enable)
                wifi_enable
                ;;
        wifi-disable)
                wifi_disable
                ;;
        wifi-automation-tick)
                wifi_automation_tick
                ;;

        # --- Мессенджеры -----------------------------------------------------
        messenger-disable)
                messenger_disable
                ;;
        messenger-save-telegram)
                messenger_save_telegram "${2:-}" "${3:-}"
                ;;
        messenger-save-vk)
                messenger_save_vk "${2:-}" "${3:-}" "${4:-}"
                ;;
        messenger-status)
                messenger_status
                ;;
        messenger-check)
                messenger_check
                ;;

        # --- Время и NTP -----------------------------------------------------
        time-save)
                time_save "${2:-1}" "${3:-1}" "${4:-Europe/Moscow}" "${5:-MSK-3}" "${6:-ntp1.vniiftri.ru ntp2.ntp-servers.net 3.openwrt.pool.ntp.org}"
                ;;

        # --- Списки сайтов ---------------------------------------------------
        site-lists-update)
                /usr/libexec/sheepfold/sheepfold-site-lists update
                ;;
        site-lists-cron-apply)
                /usr/libexec/sheepfold/sheepfold-site-lists cron-apply
                ;;
        site-lists-status)
                /usr/libexec/sheepfold/sheepfold-site-lists status
                ;;

        # --- Диагностика -----------------------------------------------------
        log-storage-status)
                /usr/libexec/sheepfold/sheepfold-log-storage status
                ;;
        yandex-disk-test)
                /usr/libexec/sheepfold/sheepfold-yandex-disk test
                ;;
        yandex-disk-list)
                /usr/libexec/sheepfold/sheepfold-yandex-disk list
                ;;
        yandex-disk-download)
                /usr/libexec/sheepfold/sheepfold-yandex-disk download "${2:-}" "${3:-}"
                ;;
        yandex-disk-restore-config)
                /usr/libexec/sheepfold/sheepfold-yandex-disk restore-config "${2:-}"
                ;;
        yandex-disk-sync-status)
                /usr/libexec/sheepfold/sheepfold-yandex-disk sync-status
                ;;
        google-drive-test)
                /usr/libexec/sheepfold/sheepfold-google-drive test
                ;;
        google-drive-list)
                /usr/libexec/sheepfold/sheepfold-google-drive list
                ;;
        google-drive-download)
                /usr/libexec/sheepfold/sheepfold-google-drive download "${2:-}" "${3:-}"
                ;;
        google-drive-restore-config)
                /usr/libexec/sheepfold/sheepfold-google-drive restore-config "${2:-}"
                ;;
        google-drive-sync-status)
                /usr/libexec/sheepfold/sheepfold-google-drive sync-status
                ;;
        router-info)
                router_info
                ;;
        wan-status-tick)
                wan_status_tick
                ;;

        # --- Устройства (полное обновление, LuCI) ----------------------------
        set-device-status)
                set_device_status "${2:-}" "${3:-}" "${4:-}" "${5:-}" "${6:-}" "${7:-}"
                ;;

        # --- WPS -------------------------------------------------------------
        wps-button)
                wps_button "${2:-short}"
                ;;
        wps-allowlist-window)
                wps_allowlist_window
                ;;

        # --- LED -------------------------------------------------------------
        led-apply)
                case "$(global_get router_led_control router_default)" in
                        off_forever)                        led_off_forever   ;;
                        new_device_alert_until_luci_login) led_alert_start   ;;
                        *)                                 led_restore_defaults ;;
                esac
                ;;
        led-blink-code)
                led_blink_code "${2:-30}" "${3:-1010000}"
                ;;
        led-alert-start)
                led_alert_start
                ;;
        led-alert-loop)
                led_alert_loop
                ;;
        led-alert-ack)
                led_alert_ack
                ;;

        # --- Страница блокировки ---------------------------------------------
        blocked-page-apply)
                blocked_page_apply
                ;;
        blocked-page-stop)
                blocked_httpd_stop
                ;;

        # --- Общий статус ----------------------------------------------------
        status)
                printf 'wifi_auto_enable=%s %s\n'  "$(global_get wifi_auto_enable_mode never)"  "$(global_get wifi_auto_enable_time 07:00)"
                printf 'wifi_auto_disable=%s %s\n' "$(global_get wifi_auto_disable_mode never)" "$(global_get wifi_auto_disable_time 23:00)"
                printf 'wps_short=%s\n'             "$(global_get wps_short_press_action router_default)"
                printf 'wps_long=%s\n'              "$(global_get wps_long_press_action router_default)"
                printf 'router_led_control=%s\n'   "$(global_get router_led_control router_default)"
                printf 'blocked_page=%s %s\n'       "$(global_get blocked_page_enabled 1)" "$(global_get blocked_page_port 5202)"
                printf 'wan_state=%s\n'             "$(cat "$WAN_STATE_FILE" 2>/dev/null || true)"
                ;;

        *)
                echo "Usage: sheepfold-router-control <command> [args]" >&2
                echo "" >&2
                echo "Токены:           check-token <bearer>  |  revoke-tokens <login>" >&2
                echo "Клиент (APK):     client-status <ip>" >&2
                echo "Устройства:       list-devices  |  device-allow <mac>  |  device-block <mac>  |  device-temp-access <mac> [min]  |  expire-temp-access" >&2
                echo "Блокировка:       global-block-on  |  global-block-off  |  internet-enable  |  internet-disable  |  internet-status" >&2
                echo "Сопряжение:       pair-admin-device  |  activate-admin-pairing-code  |  admin-pairing-status" >&2
                echo "Wi-Fi:            wifi-enable  |  wifi-disable  |  wifi-automation-tick" >&2
                echo "Мессенджеры:      messenger-disable  |  messenger-save-telegram  |  messenger-save-vk  |  messenger-status  |  messenger-check" >&2
                echo "Время:            time-save" >&2
                echo "Списки сайтов:    site-lists-update  |  site-lists-cron-apply  |  site-lists-status" >&2
                echo "Диагностика:      router-info  |  wan-status-tick  |  status" >&2
                echo "WPS:              wps-button  |  wps-allowlist-window" >&2
                echo "LED:              led-apply  |  led-blink-code  |  led-alert-start  |  led-alert-loop  |  led-alert-ack" >&2
                echo "Страница блок.:   blocked-page-apply  |  blocked-page-stop" >&2
                exit 1
                ;;
esac
