#!/bin/sh
set -eu

ROWS="/tmp/sheepfold/device-identity.rows.$$"
ASSIGNMENTS="/tmp/sheepfold/device-identity.assignments.$$"
ONLINE_MACS="/tmp/sheepfold/device-identity.online.$$"
COLLISIONS="/tmp/sheepfold/device-identity.collisions.$$"
DIRTY_FLAG="${SHEEPFOLD_UCI_DIRTY_FLAG:-/tmp/sheepfold/device-identity.uci-dirty}"
PRESENCE="${SHEEPFOLD_DEVICE_PRESENCE:-/usr/libexec/sheepfold/sheepfold-device-presence}"

cleanup() {
        rm -f "$ROWS" "$ASSIGNMENTS" "$ONLINE_MACS" "$COLLISIONS"
}

trap cleanup EXIT HUP INT TERM

device_sections() {
        uci -q show sheepfold 2>/dev/null | sed -n 's/^sheepfold\.\([^.=]*\)=device$/\1/p'
}

normalize_mac() {
        printf '%s' "${1:-}" | tr '[:lower:]' '[:upper:]'
}

device_is_blocklisted() {
        local section mac status blocked_mac
        section="$1"
        mac="$(normalize_mac "$2")"
        status="$(uci -q get "sheepfold.$section.status" 2>/dev/null || true)"
        case "$status" in blocked|block) return 0 ;; esac
        for blocked_mac in $(uci -q get sheepfold.blocklist.mac 2>/dev/null || true) \
                $(uci -q get sheepfold.blocklist.macs 2>/dev/null || true); do
                [ "$(normalize_mac "$blocked_mac")" = "$mac" ] && return 0
        done
        return 1
}

mark_dirty() {
        : > "$DIRTY_FLAG"
}

set_if_changed() {
        local path value current
        path="$1"
        value="$2"
        current="$(uci -q get "$path" 2>/dev/null || true)"
        [ "$current" = "$value" ] && return 0
        uci -q set "$path=$value"
        mark_dirty
}

delete_if_present() {
        local path
        path="$1"
        uci -q get "$path" >/dev/null 2>&1 || return 0
        uci -q delete "$path"
        mark_dirty
}

compare_keys() {
        awk -v left="$1" -v right="$2" '
        function family(token, value) {
                value = token
                sub(/:.*/, "", value)
                return value
        }
        function strong_family(value) {
                return value == "device_uuid" || value == "upnp_uuid" || value == "wsd_uuid" || \
                        value == "upnp_serial" || value == "mdns_serial"
        }
        BEGIN {
                left_count = split(left, left_keys, /[ ]+/)
                right_count = split(right, right_keys, /[ ]+/)
                for (i = 1; i <= right_count; i++)
                        right_has[right_keys[i]] = 1
                family_count = 0
                strong = 0
                for (i = 1; i <= left_count; i++) {
                        token = left_keys[i]
                        if (token == "" || !right_has[token])
                                continue
                        current_family = family(token)
                        if (!seen_family[current_family]++) {
                                family_count++
                                if (strong_family(current_family))
                                        strong = 1
                        }
                }
                if (strong) {
                        print "strong"
                        exit 0
                }
                if (family_count >= 2) {
                        print "multifactor"
                        exit 0
                }
                exit 1
        }'
}

key_strength() {
        awk -v keys="$1" '
        function family(token, value) {
                value = token
                sub(/:.*/, "", value)
                return value
        }
        function strong_family(value) {
                return value == "device_uuid" || value == "upnp_uuid" || value == "wsd_uuid" || \
                        value == "upnp_serial" || value == "mdns_serial"
        }
        BEGIN {
                count = split(keys, items, /[ ]+/)
                for (i = 1; i <= count; i++) {
                        if (items[i] == "") continue
                        current_family = family(items[i])
                        if (family_seen[current_family]++) continue
                        family_count++
                        if (strong_family(current_family)) strong = 1
                }
                if (strong) {
                        print "strong"
                        exit 0
                }
                if (family_count >= 2) {
                        print "multifactor"
                        exit 0
                }
                print "insufficient"
        }'
}

assess_keys() {
        awk -v trusted="$1" -v current="$2" '
        function family(token, value) {
                value = token
                sub(/:.*/, "", value)
                return value
        }
        function strong_family(value) {
                return value == "device_uuid" || value == "upnp_uuid" || value == "wsd_uuid" || \
                        value == "upnp_serial" || value == "mdns_serial"
        }
        BEGIN {
                trusted_count = split(trusted, trusted_keys, /[ ]+/)
                current_count = split(current, current_keys, /[ ]+/)
                for (i = 1; i <= trusted_count; i++) {
                        token = trusted_keys[i]
                        if (token == "") continue
                        current_family = family(token)
                        trusted_family[current_family] = 1
                        trusted_token[token] = 1
                        family_order[++family_count] = current_family
                }
                for (i = 1; i <= current_count; i++) {
                        token = current_keys[i]
                        if (token == "") continue
                        current_family = family(token)
                        current_family_seen[current_family] = 1
                        current_token[token] = 1
                        if (!trusted_family[current_family])
                                family_order[++family_count] = current_family
                }
                for (i = 1; i <= trusted_count; i++) {
                        token = trusted_keys[i]
                        if (token != "" && current_token[token])
                                exact_family[family(token)] = 1
                }
                for (i = 1; i <= family_count; i++) {
                        current_family = family_order[i]
                        if (counted[current_family]++ || !trusted_family[current_family] || !current_family_seen[current_family])
                                continue
                        if (strong_family(current_family)) {
                                if (exact_family[current_family]) strong_match++
                                else strong_mismatch++
                        } else {
                                if (exact_family[current_family]) weak_match++
                                else weak_mismatch++
                        }
                }
                # Противоречие устойчивого UUID/serial важнее совпавшего слабого имени.
                if (strong_mismatch > 0) {
                        print "suspicious_strong"
                        exit 0
                }
                if (strong_match > 0) {
                        print "match_strong"
                        exit 0
                }
                if (weak_match >= 2) {
                        print "match_multifactor"
                        exit 0
                }
                if (weak_mismatch >= 2) {
                        print "suspicious_multifactor"
                        exit 0
                }
                print "insufficient"
        }'
}

build_assignments() {
        awk -F '\t' '
        function token_family(token, value) {
                value = token
                sub(/:.*/, "", value)
                return value
        }
        function strong_family(value) {
                return value == "device_uuid" || value == "upnp_uuid" || value == "wsd_uuid" || \
                        value == "upnp_serial" || value == "mdns_serial"
        }
        function root(value) {
                while (parent[value] != value) {
                        parent[value] = parent[parent[value]]
                        value = parent[value]
                }
                return value
        }
        function unite(left, right, left_root, right_root) {
                left_root = root(left)
                right_root = root(right)
                if (left_root == right_root)
                        return
                if (ids[left_root] <= ids[right_root])
                        parent[right_root] = left_root
                else
                        parent[left_root] = right_root
        }
        {
                index_value = ++device_count
                sections[index_value] = $1
                ids[index_value] = $2 + 0
                parent[index_value] = index_value
                key_count[index_value] = split($3, parts, /[ ]+/)
                for (part = 1; part <= key_count[index_value]; part++) {
                        keys[index_value, part] = parts[part]
                        has[index_value, parts[part]] = 1
                }
        }
        END {
                edge_count = 0
                pair_number = 0
                for (left = 1; left <= device_count; left++) {
                        for (right = left + 1; right <= device_count; right++) {
                                pair_number++
                                family_count = 0
                                strong = 0
                                for (part = 1; part <= key_count[left]; part++) {
                                        token = keys[left, part]
                                        if (token == "" || !has[right, token])
                                                continue
                                        current_family = token_family(token)
                                        if (family_seen[current_family] != pair_number) {
                                                family_seen[current_family] = pair_number
                                                family_count++
                                                if (strong_family(current_family))
                                                        strong = 1
                                        }
                                }
                                if (strong || family_count >= 2) {
                                        unite(left, right)
                                        edge_count++
                                        edge_left[edge_count] = left
                                        edge_right[edge_count] = right
                                        edge_strong[edge_count] = strong
                                }
                        }
                }

                for (index_value = 1; index_value <= device_count; index_value++) {
                        component = root(index_value)
                        component_size[component]++
                        if (!component_min_id[component] || ids[index_value] < component_min_id[component])
                                component_min_id[component] = ids[index_value]
                }
                for (edge = 1; edge <= edge_count; edge++) {
                        component = root(edge_left[edge])
                        if (edge_strong[edge])
                                component_strong[component] = 1
                }
                for (index_value = 1; index_value <= device_count; index_value++) {
                        component = root(index_value)
                        if (component_size[component] < 2)
                                continue
                        mode = component_strong[component] ? "strong_identifier" : "multiple_signal_families"
                        print sections[index_value] "\t" component_min_id[component] "\t" mode
                }
        }' "$ROWS" > "$ASSIGNMENTS"
}

assignment_for_section() {
        local section
        section="$1"
        awk -F '\t' -v wanted="$section" '$1 == wanted { print $2 "\t" $3; exit }' "$ASSIGNMENTS"
}

build_online_uuid_collisions() {
	: > "$ONLINE_MACS"
	: > "$COLLISIONS"
	if [ -x "$PRESENCE" ]; then
		"$PRESENCE" current 2>/dev/null |
			awk -F '\t' 'toupper($1) ~ /^([0-9A-F][0-9A-F]:){5}[0-9A-F][0-9A-F]$/ { print toupper($1) }' |
			sort -u > "$ONLINE_MACS"
	fi
	[ -s "$ONLINE_MACS" ] || return 0

	awk -F '\t' -v online_file="$ONLINE_MACS" '
		function family(token, value) {
			value = token
			sub(/:.*/, "", value)
			return value
		}
		function uuid_family(value) {
			return value == "device_uuid" || value == "upnp_uuid" || value == "wsd_uuid"
		}
		BEGIN {
			while ((getline online_mac < online_file) > 0)
				online[toupper(online_mac)] = 1
			close(online_file)
		}
		{
			index_value = ++count
			section[index_value] = $1
			id[index_value] = $2 + 0
			mac_address[index_value] = toupper($4)
			if (!online[mac_address[index_value]]) next
			key_count[index_value] = split($3, keys, /[ ]+/)
			for (key_index = 1; key_index <= key_count[index_value]; key_index++) {
				token = keys[key_index]
				if (token == "" || !uuid_family(family(token))) continue
				has[index_value, token] = 1
				all_tokens[token] = 1
				if (!owner[token] || id[index_value] < id[owner[token]]) owner[token] = index_value
			}
		}
		END {
			for (token in all_tokens) {
				primary = owner[token]
				for (index_value = 1; index_value <= count; index_value++) {
					if (index_value == primary || !has[index_value, token]) continue
					pair = section[index_value] SUBSEP id[primary]
					if (reported[pair]++) continue
					print section[index_value] "\t" id[primary] "\tduplicate_uuid_online"
				}
			}
		}
	' "$ROWS" > "$COLLISIONS"
}

collision_for_section() {
	local section
	section="$1"
	awk -F '\t' -v wanted="$section" '$1 == wanted { print $2 "\t" $3; exit }' "$COLLISIONS"
}

reconcile_staged() {
	local section id mac keys assignment logical_id mode confirmed current_suggestion now collision collision_with collision_reason accepted_with
        mkdir -p /tmp/sheepfold
        chmod 700 /tmp/sheepfold 2>/dev/null || true
        : > "$ROWS"

        for section in $(device_sections); do
                id="$(uci -q get "sheepfold.$section.id" 2>/dev/null || true)"
                mac="$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)"
                keys="$(uci -q get "sheepfold.$section.detection_identity_keys" 2>/dev/null || true)"
                case "$id" in ''|*[!0-9]*|0) continue ;; esac
                device_is_blocklisted "$section" "$mac" && continue
                [ -n "$keys" ] || continue
		printf '%s\t%s\t%s\t%s\n' "$section" "$id" "$keys" "$mac" >> "$ROWS"
        done

        build_assignments
	build_online_uuid_collisions
	now="$(date +%s)"
	for section in $(device_sections); do
		mac="$(uci -q get "sheepfold.$section.mac" 2>/dev/null || true)"
		# Постоянный чёрный список устройств не участвует даже в диагностическом
		# сопоставлении: для него остаются только presence и журнал запретов. §detlife1
		device_is_blocklisted "$section" "$mac" && continue
		collision="$(collision_for_section "$section")"
		if [ -n "$collision" ]; then
			collision_with="$(printf '%s' "$collision" | awk -F '\t' '{ print $1 }')"
			collision_reason="$(printf '%s' "$collision" | awk -F '\t' '{ print $2 }')"
			accepted_with="$(uci -q get "sheepfold.$section.identity_uuid_collision_accepted_with_id" 2>/dev/null || true)"
			if [ "$accepted_with" != "$collision_with" ]; then
				# Прежняя карточка (меньший #ID) не меняется. Только новая online-карточка
				# получает pending, который detector превращает в карантин. §detlife1
				set_if_changed "sheepfold.$section.identity_uuid_collision_with_id" "$collision_with"
				set_if_changed "sheepfold.$section.identity_uuid_collision_reason" "$collision_reason"
				set_if_changed "sheepfold.$section.identity_uuid_collision_pending" 1
			fi
		fi
		confirmed="$(uci -q get "sheepfold.$section.logical_device_confirmed" 2>/dev/null || printf 0)"
		assignment="$(assignment_for_section "$section")"
		if [ -z "$assignment" ]; then
			delete_if_present "sheepfold.$section.logical_device_suggestion_id"
			delete_if_present "sheepfold.$section.logical_device_suggestion_reason"
			delete_if_present "sheepfold.$section.logical_device_suggestion_at"
			if [ "$confirmed" != 1 ]; then
				delete_if_present "sheepfold.$section.logical_device_id"
				delete_if_present "sheepfold.$section.logical_device_link"
				delete_if_present "sheepfold.$section.logical_device_primary"
			fi
			continue
		fi

		logical_id="$(printf '%s' "$assignment" | awk -F '\t' '{ print $1 }')"
		mode="$(printf '%s' "$assignment" | awk -F '\t' '{ print $2 }')"
		id="$(uci -q get "sheepfold.$section.id" 2>/dev/null || true)"
		if [ "$confirmed" = 1 ]; then
			delete_if_present "sheepfold.$section.logical_device_suggestion_id"
			delete_if_present "sheepfold.$section.logical_device_suggestion_reason"
			delete_if_present "sheepfold.$section.logical_device_suggestion_at"
			continue
		fi

		# Совпавший UUID или два слабых семейства дают только предложение. Новый MAC
		# не становится старым логическим устройством и не получает его права без
		# решения родителя, даже если признак выглядит сильным. §devident1
		delete_if_present "sheepfold.$section.logical_device_id"
		delete_if_present "sheepfold.$section.logical_device_link"
		delete_if_present "sheepfold.$section.logical_device_primary"
		if [ "$id" = "$logical_id" ]; then
			delete_if_present "sheepfold.$section.logical_device_suggestion_id"
			delete_if_present "sheepfold.$section.logical_device_suggestion_reason"
			delete_if_present "sheepfold.$section.logical_device_suggestion_at"
			continue
		fi
		current_suggestion="$(uci -q get "sheepfold.$section.logical_device_suggestion_id" 2>/dev/null || true)"
		set_if_changed "sheepfold.$section.logical_device_suggestion_id" "$logical_id"
		set_if_changed "sheepfold.$section.logical_device_suggestion_reason" "$mode"
		[ "$current_suggestion" = "$logical_id" ] || set_if_changed "sheepfold.$section.logical_device_suggestion_at" "$now"
	done
}

case "${1:-reconcile}" in
        compare)
                compare_keys "${2:-}" "${3:-}"
                ;;
        strength)
                key_strength "${2:-}"
                ;;
        assess)
                assess_keys "${2:-}" "${3:-}"
                ;;
        reconcile-staged)
                reconcile_staged
                ;;
        reconcile)
                rm -f "$DIRTY_FLAG"
                reconcile_staged
                if [ -e "$DIRTY_FLAG" ]; then
                        uci -q commit sheepfold
                        rm -f "$DIRTY_FLAG"
                fi
                ;;
        *)
                echo "Usage: sheepfold-device-identity [compare <keys-a> <keys-b>|strength <keys>|assess <trusted> <current>|reconcile|reconcile-staged]" >&2
                exit 2
                ;;
esac
