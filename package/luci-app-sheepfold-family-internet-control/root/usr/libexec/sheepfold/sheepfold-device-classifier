#!/bin/sh
set -eu

NAME="${1:-}"
PORTS="${2:-}"
STATIC_NAME="${3:-}"
SIGNAL_FILE="${4:-}"
MAC="${5:-}"
MDNS_SERVICES="${6:-}"
MDNS_PROFILE="${7:-}"
SSDP_PROFILE="${8:-}"
WSD_PROFILE="${9:-}"
WIFI_PROFILE="${10:-}"
OUI_OVERRIDES="${SHEEPFOLD_OUI_OVERRIDES:-/usr/share/sheepfold/device-oui-overrides}"
NO_RESTRICTIONS_GROUP="$(uci -q get sheepfold.no_restrictions.name 2>/dev/null || printf 'Без ограничений')"
PERSONAL_DEVICES_GROUP="$(uci -q get sheepfold.personal_devices.name 2>/dev/null || printf 'Персональные устройства')"
POLICY_VERSION="10"
NETWORK_NAME_PATTERN='(^|[^a-z0-9])(openwrt|router|gateway|repeater|extender|access[ _-]?point|wireless[ _-]?ap|wi-?fi[ _-]?ap|mesh)([^a-z0-9]|$)|(^|[^a-z0-9])ap[-_][a-z0-9]'
SMART_HOME_GATEWAY_PATTERN='thread border router|matter bridge|homekit bridge|zigbee gateway|zigbee bridge|z-wave gateway|zwave gateway|aqara gateway|xiaomi gateway|mijia gateway|tuya gateway|tradfri gateway|ikea dirigera|dirigera|hue bridge|sonoff zigbee bridge'

TYPE="smart"
TYPE_CONFIDENCE=35
REASON="lightweight router metadata"
AUTO_SCORE=0
EVIDENCE=""
EVIDENCE_COUNT=0
HARD_DENY=0
NETWORK_DENY=0
OUI_VENDOR=""
COMPETING_EVIDENCE=""
COMPETING_SCORE=0

text_has() {
        printf '%s' "$1" | grep -Eiq "$2"
}

name_is_network_infrastructure() {
	# Явные ASCII-диапазоны обязательны: BusyBox tr на целевом роутере
	# искажает строки при использовании GNU-подобных POSIX-классов. (§bbxtr01)
        candidate_name="$(printf '%s' "$1" | tr 'A-Z' 'a-z')"
        [ -n "$candidate_name" ] || return 1

        if text_has "$candidate_name" "$SMART_HOME_GATEWAY_PATTERN"; then
                return 1
        fi

        text_has "$candidate_name" "$NETWORK_NAME_PATTERN"
}

signal_value() {
        key="$1"
        [ -r "$SIGNAL_FILE" ] || return 0
        awk -F '\t' -v wanted="$key" 'index($0, wanted "\t") == 1 { print substr($0, length(wanted) + 2); exit }' \
                "$SIGNAL_FILE" 2>/dev/null || true
}

wifi_profile_value() {
        local key part
        key="$1"
        for part in $(printf '%s' "$WIFI_PROFILE" | tr ',' ' '); do
                case "$part" in
                        "$key"=*) printf '%s\n' "${part#*=}"; return 0 ;;
                esac
        done
}

port_open() {
        printf '%s' "$PORTS" | grep -Eq "(^|,)${1}(,|$)"
}

mdns_has() {
        printf '%s' "$MDNS_SERVICES" | grep -Eiq "(^|,)${1}(,|$)"
}

network_port_profile() {
        port_open 22 && port_open 53 && { port_open 80 || port_open 443; }
}

add_evidence() {
        local family points
        family="$1"
        points="$2"

        case ",$EVIDENCE," in
                *,$family,*) return 0 ;;
        esac

        EVIDENCE="${EVIDENCE:+$EVIDENCE,}$family"
        EVIDENCE_COUNT=$((EVIDENCE_COUNT + 1))
        AUTO_SCORE=$((AUTO_SCORE + points))
        [ "$AUTO_SCORE" -le 100 ] || AUTO_SCORE=100
}

add_competing_evidence() {
	local family candidate_type points marker
	family="$1"
	candidate_type="$2"
	points="$3"
	marker="$family:$candidate_type"

	case ",$COMPETING_EVIDENCE," in
		*,$marker,*) return 0 ;;
	esac

	COMPETING_EVIDENCE="${COMPETING_EVIDENCE:+$COMPETING_EVIDENCE,}$marker"
	[ "$points" -le "$COMPETING_SCORE" ] || COMPETING_SCORE="$points"
}

eligible_type() {
        case "$1" in
                # Умная колонка остаётся распознанным типом, но это персональный
                # голосовой интерфейс, а не домашняя инфраструктура. Автоматически
                # обходить семейные ограничения ей нельзя. §devpas1
                server|engineering|camera|smart_home|vacuum|printer) return 0 ;;
                *) return 1 ;;
        esac
}

interactive_type() {
	case "$1" in
		network|phone|tablet|computer|tv|media_player|smart_watch|console) return 0 ;;
		*) return 1 ;;
	esac
}

personal_device_type() {
	case "$1" in
		phone|tablet|computer|tv|media_player|smart_watch) return 0 ;;
		*) return 1 ;;
	esac
}

classify_text() {
        local text lower detected_type detected_confidence detected_reason
        text="$1"
        lower="$(printf '%s' "$text" | tr 'A-Z' 'a-z')"
        detected_type="smart"
        detected_confidence=35
        detected_reason="lightweight router metadata"

        if name_is_network_infrastructure "$text"; then
                detected_type="network"
                detected_confidence=96
                detected_reason="network infrastructure marker"
        elif text_has "$lower" 'home[ -]?assistant|hassio|hass\.io|haos|openhab|adguard[ -]?home|adguardhome|file server|proxmox|truenas|freenas|openmediavault|synology|diskstation|qnap|unraid|docker host|portainer|smlight|slzb|zigbee2mqtt|zha coordinator|zigbee coordinator|zigbee gateway|zigbee bridge|matter bridge|thread border router|homekit bridge|smart home hub|smarthome hub|philips hue bridge|hue bridge|ikea dirigera|dirigera|tradfri gateway|aqara hub|aqara gateway|xiaomi gateway|mijia gateway|tuya gateway|sonoff zigbee bridge|hubitat|smartthings hub|aeotec hub|homey|fibaro home center|homematic|deconz|conbee|skyconnect|zwavejs|z-wave js|z-wave gateway|zwave gateway' ||
             text_has "$lower" '(^|[^a-z0-9])(samba|smb|cifs|nas|pve|omv)([^a-z0-9]|$)'; then
                detected_type="server"
                detected_confidence=86
                detected_reason="home infrastructure name marker"
        elif text_has "$lower" 'nvr|dvr|xvr|video recorder|videoregistrar|videonablyudenie|videonablydenie|videonabludenie|video-nablyudenie|video-nablydenie|cctv server|surveillance server|video server|ltv-rne|rvi-r|trassir|xmeye|ivms|hik-connect|smartpss|uniview|hikvision|hiwatch|hilook|dahua|beward|optimus|tantos|polyvision|hanwha|wisenet|axis|vivotek|tiandy'; then
                detected_type="server"
                detected_confidence=86
                detected_reason="video recorder or surveillance server name marker"
        elif text_has "$lower" 'zont|ectostroy|ectocontrol|myheat|teplocom|xital|telemetrika|owen|saures|baxi|navien|vaillant|buderus|protherm|ariston' ||
             text_has "$lower" '(^|[^a-z0-9])(boiler|kotel|heating|thermostat|alarm)([^a-z0-9]|$)|кот[её]л'; then
                detected_type="engineering"
                detected_confidence=86
                detected_reason="engineering, heating, or safety controller name marker"
        elif text_has "$lower" 'printer|print|epson|canon|hp-|brother'; then
                detected_type="printer"
                detected_confidence=82
                detected_reason="printer marker"
        elif text_has "$lower" '(^|[^a-z0-9])(ip[-_ ]?cam|webcam|camera|cam[0-9]+|cam[-_ ][0-9]+)([^a-z0-9]|$)'; then
                detected_type="camera"
                detected_confidence=82
                detected_reason="camera marker"
	elif text_has "$lower" 'apple watch|galaxy watch|pixel watch|mi watch|smart[ _-]?watch|smartwatch|wear os|wearos|amazfit|fitbit|garmin watch|huawei watch|honor watch'; then
		detected_type="smart_watch"
		detected_confidence=82
		detected_reason="smart watch marker"
	elif text_has "$lower" 'iphone|android|galaxy|redmi|pixel|phone'; then
		detected_type="phone"
                detected_confidence=78
                detected_reason="phone marker"
        elif text_has "$lower" 'ipad|tablet|pad'; then
                detected_type="tablet"
                detected_confidence=78
                detected_reason="tablet marker"
        elif text_has "$lower" 'desktop|laptop|notebook|macbook|pc-|windows|msft'; then
                detected_type="computer"
                detected_confidence=76
                detected_reason="computer marker"
	elif text_has "$lower" 'chromecast|mi box|android[ _-]?box|apple tv|fire tv|firetv|nvidia shield|roku|dune hd|dune player|kodi|media player|media[ _-]?player|streaming player|video player|видеоплеер|медиаплеер'; then
		detected_type="media_player"
		detected_confidence=80
		detected_reason="media player marker"
	elif text_has "$lower" '(^|[^a-z0-9])tv([^a-z0-9]|$)|androidtv|smarttv|smart[ _-]?tv|television'; then
		detected_type="tv"
                detected_confidence=76
                detected_reason="TV or media marker"
        elif text_has "$lower" 'playstation|ps4|ps5|xbox|switch|console'; then
                detected_type="console"
                detected_confidence=82
                detected_reason="game console marker"
        elif text_has "$lower" 'alice|alisa|yandex[ _-]?(station|stantsiya)|яндекс[ _-]?станц|smart speaker|sonos|homepod|alexa|amazon echo|google home|sberboom|marusya'; then
                detected_type="speaker"
                detected_confidence=84
                detected_reason="smart speaker marker"
        elif text_has "$lower" 'vacuum|roborock|dreame|deebot|ecovacs|irobot|roomba|miio|xiaomi-vacuum|viomi|ilife|eufy|yeedi'; then
                detected_type="vacuum"
                detected_confidence=80
                detected_reason="robot vacuum marker"
        elif text_has "$lower" 'warm floor|underfloor|floor heating|heated floor|thermoregulator|терморегулятор|т[её]пл[ыо]й пол|теплый пол|тёплый пол|подогрев пола|heater relay|smart relay|relay|реле|switch module|wall switch|light switch|выключател|освещен|свет|ламп|dimmer|диммер|curtain|curtains|blind|blinds|shade|roller shade|штор|жалюзи|карниз|kettle|чайник|iron|утюг|socket|plug|розетк|tuya|ewelink|sonoff|shelly|aqara|mijia|xiaomi smart|yeelight|philips hue|nanoleaf|wled|led controller|контроллер led|контроллер света|motion sensor|датчик движения|door sensor|window sensor|датчик двери|датчик окна|leak sensor|датчик протечки|smoke sensor|датчик дыма|temperature sensor|датчик температуры|humidity sensor|датчик влажности'; then
                detected_type="smart_home"
                detected_confidence=80
                detected_reason="smart-home appliance, relay, sensor, or actuator marker"
        elif text_has "$lower" '(^|[^a-z0-9])(espressif|esp8266|esp32|esp32c3|esp32-c3|esp32s3|esp32-s3|tasmota|esphome)([^a-z0-9]|$)'; then
                detected_type="smart_home"
                detected_confidence=82
                detected_reason="ESP smart-home device marker"
        fi

        printf '%s\t%s\t%s\n' "$detected_type" "$detected_confidence" "$detected_reason"
}

mac_is_locally_administered() {
        local normalized first_octet
        normalized="$(printf '%s' "$MAC" | tr 'a-z' 'A-Z')"
		printf '%s' "$normalized" | grep -Eq '^([0-9A-F]{2}:){5}[0-9A-F]{2}$' || return 1
        first_octet="${normalized%%:*}"
        [ $((0x$first_octet & 2)) -ne 0 ]
}

dhcp_client_id_matches_mac() {
	local normalized_mac normalized_client
	normalized_mac="$(printf '%s' "$MAC" | tr -d ':-' | tr 'A-Z' 'a-z')"
	normalized_client="$(printf '%s' "$1" | tr -d ':-' | tr 'A-Z' 'a-z')"
	case "$normalized_client" in
		"$normalized_mac"|"01$normalized_mac") return 0 ;;
	esac
	return 1
}

lookup_oui_vendor() {
	local prefix database vendor
	mac_is_locally_administered && return 0
	prefix="$(printf '%s' "$MAC" | tr -d ':' | tr 'a-z' 'A-Z' | cut -c1-6)"
	[ "${#prefix}" -eq 6 ] || return 0

	if [ -r "$OUI_OVERRIDES" ]; then
		vendor="$(awk -v wanted="$prefix" 'toupper($1) == wanted { $1=""; sub(/^[[:space:]]+/, ""); print; exit }' "$OUI_OVERRIDES" 2>/dev/null || true)"
		[ -z "$vendor" ] || { printf '%s\n' "$vendor"; return 0; }
	fi

	for database in /usr/share/nmap/nmap-mac-prefixes /usr/share/nmap/nmap-mac-prefixes.txt; do
                [ -r "$database" ] || continue
                awk -v wanted="$prefix" 'toupper($1) == wanted { $1=""; sub(/^[[:space:]]+/, ""); print; exit }' "$database"
                return 0
        done
}

oui_type() {
        local vendor
        vendor="$(printf '%s' "$1" | tr 'A-Z' 'a-z')"

        if text_has "$vendor" 'synology|qnap|ixsystems|truenas'; then
                printf 'server\n'
        elif text_has "$vendor" 'hikvision|dahua|axis communications|uniview|vivotek|tiandy'; then
                printf 'camera\n'
        elif text_has "$vendor" 'roborock|dreame|ecovacs|irobot'; then
                printf 'vacuum\n'
        elif text_has "$vendor" 'sonos|yandex|amazon technologies|google|apple'; then
                printf 'speaker\n'
        elif text_has "$vendor" 'espressif|tuya|shelly|sonoff|yeelight|lumi united|aqara'; then
                printf 'smart_home\n'
        elif text_has "$vendor" 'mikrotik|ubiquiti|tp-link|cudy|netgear|d-link|zyxel|tenda|keenetic|gl technologies|aruba|ruckus'; then
                printf 'network\n'
        else
                printf 'unknown\n'
        fi
}

apply_text_result() {
        local result family points candidate_type candidate_confidence candidate_reason
        result="$1"
        family="$2"
        points="$3"
        candidate_type="$(printf '%s' "$result" | awk -F '\t' '{ print $1 }')"
        candidate_confidence="$(printf '%s' "$result" | awk -F '\t' '{ print $2 }')"
        candidate_reason="$(printf '%s' "$result" | awk -F '\t' '{ print $3 }')"

        [ "$candidate_type" != "smart" ] || return 0

        if [ "$candidate_type" = "network" ]; then
                TYPE="network"
                TYPE_CONFIDENCE=96
                REASON="$candidate_reason"
                HARD_DENY=1
                NETWORK_DENY=1
                add_evidence "$family" 0
                return 0
        fi

        if { [ "$family" = "dhcp" ] || [ "$family" = "owner_configured" ]; } && interactive_type "$candidate_type"; then
                HARD_DENY=1
                add_evidence "$family" 0
		if [ "$TYPE" != smart ] && [ "$TYPE" != "$candidate_type" ]; then
			add_competing_evidence "$family" "$candidate_type" "$points"
		fi
                if [ "$family" = "owner_configured" ] || [ "$TYPE" = "smart" ]; then
                        TYPE="$candidate_type"
                        TYPE_CONFIDENCE="$candidate_confidence"
                        REASON="$candidate_reason"
                fi
                return 0
        fi

        if [ "$TYPE" = "smart" ]; then
                TYPE="$candidate_type"
                TYPE_CONFIDENCE="$candidate_confidence"
                REASON="$candidate_reason"
                add_evidence "$family" "$points"
                return 0
        fi

        if [ "$candidate_type" = "$TYPE" ]; then
                add_evidence "$family" "$points"
                [ "$candidate_confidence" -le "$TYPE_CONFIDENCE" ] || TYPE_CONFIDENCE="$candidate_confidence"
                TYPE_CONFIDENCE=$((TYPE_CONFIDENCE + 4))
                [ "$TYPE_CONFIDENCE" -le 99 ] || TYPE_CONFIDENCE=99
		return 0
        fi

	# Fingerbank-подобный принцип: независимый сильный признак другого типа нельзя
	# молча отбросить. Он уменьшит итоговую уверенность и автодоверие победителя.
	add_competing_evidence "$family" "$candidate_type" "$points"
}

name_result="$(classify_text "$NAME")"
apply_text_result "$name_result" name 50

if [ -n "$STATIC_NAME" ]; then
        static_result="$(classify_text "$STATIC_NAME")"
        apply_text_result "$static_result" owner_configured 40
fi

vendor_class="$(signal_value vendor_class)"
user_class="$(signal_value user_class)"
mud_url="$(signal_value mud_url)"
supplied_hostname="$(signal_value supplied_hostname)"
dhcp_client_id="$(signal_value client_id)"
dhcp_text="$vendor_class $user_class $mud_url $supplied_hostname"

if [ -n "$(printf '%s' "$dhcp_text" | tr -d ' ')" ]; then
        dhcp_result="$(classify_text "$dhcp_text")"
	apply_text_result "$dhcp_result" dhcp 35
fi

wifi_generation="$(wifi_profile_value generation)"
wifi_speed_class="$(wifi_profile_value speed)"
if [ "$TYPE" = smart ] && mac_is_locally_administered && \
   dhcp_client_id_matches_mac "$dhcp_client_id" && [ -n "$wifi_generation" ]; then
	# Android/iOS и некоторые ноутбуки скрывают OUI случайным MAC. Совпадающий
	# DHCP client-id вместе с реальной Wi-Fi association позволяет безопасно
	# считать устройство личным, но не доказывает бренд, модель или личность. §devpas1
	TYPE="phone"
	TYPE_CONFIDENCE=70
	REASON="private-address personal Wi-Fi client profile"
	HARD_DENY=1
	add_evidence dhcp_privacy 0
fi

if [ -n "$MDNS_PROFILE" ]; then
        mdns_profile_result="$(classify_text "$MDNS_PROFILE")"
        apply_text_result "$mdns_profile_result" mdns 35
fi

if [ -n "$SSDP_PROFILE" ]; then
        if text_has "$SSDP_PROFILE" 'internetgatewaydevice|wandevice|wanconnectiondevice|urn:schemas-upnp-org:device:router'; then
                TYPE="network"
                TYPE_CONFIDENCE=96
                REASON="UPnP network infrastructure service"
                HARD_DENY=1
                NETWORK_DENY=1
                add_evidence upnp 0
        elif text_has "$SSDP_PROFILE" 'printerdevice|printbasic|scannerdevice'; then
                TYPE="printer"
                [ "$TYPE_CONFIDENCE" -ge 90 ] || TYPE_CONFIDENCE=90
                REASON="printer UPnP service"
                add_evidence upnp 40
        elif text_has "$SSDP_PROFILE" 'digitalsecuritycamera|networkcamera|surveillance|nvr|dvr'; then
                TYPE="camera"
                [ "$TYPE_CONFIDENCE" -ge 88 ] || TYPE_CONFIDENCE=88
                REASON="camera or surveillance UPnP service"
                add_evidence upnp 40
        elif text_has "$SSDP_PROFILE" 'mediarenderer'; then
                if [ "$TYPE" = "speaker" ]; then
                        add_evidence upnp 35
                        TYPE_CONFIDENCE=$((TYPE_CONFIDENCE + 4))
                        [ "$TYPE_CONFIDENCE" -le 99 ] || TYPE_CONFIDENCE=99
                else
                        TYPE="media_player"
                        TYPE_CONFIDENCE=82
                        REASON="media renderer UPnP service"
                        HARD_DENY=1
                        add_evidence upnp 0
                fi
        elif text_has "$SSDP_PROFILE" 'mediaserver'; then
                TYPE="server"
                [ "$TYPE_CONFIDENCE" -ge 78 ] || TYPE_CONFIDENCE=78
                REASON="media server UPnP service"
                # DLNA MediaServer часто запущен на обычном ПК, поэтому один UPnP
                # ответ не должен выдавать привилегированную группу. §devident1
                HARD_DENY=1
                add_evidence upnp 0
        else
                ssdp_result="$(classify_text "$SSDP_PROFILE")"
                apply_text_result "$ssdp_result" upnp 35
        fi
fi

if [ -n "$WSD_PROFILE" ]; then
	if text_has "$WSD_PROFILE" 'networkvideotransmitter|network video transmitter|onvif.*video'; then
		TYPE="camera"
		[ "$TYPE_CONFIDENCE" -ge 90 ] || TYPE_CONFIDENCE=90
		REASON="network camera WS-Discovery type"
		add_evidence wsd 45
	elif text_has "$WSD_PROFILE" 'printdevicetype|print device|scandevicetype'; then
		TYPE="printer"
		[ "$TYPE_CONFIDENCE" -ge 90 ] || TYPE_CONFIDENCE=90
		REASON="printer WS-Discovery type"
		add_evidence wsd 45
	else
		wsd_result="$(classify_text "$WSD_PROFILE")"
		apply_text_result "$wsd_result" wsd 35
	fi
fi

OUI_VENDOR="$(lookup_oui_vendor || true)"
if [ -n "$OUI_VENDOR" ]; then
        candidate_oui_type="$(oui_type "$OUI_VENDOR")"
        if [ "$candidate_oui_type" = "network" ]; then
                if network_port_profile || [ "$TYPE" = "network" ]; then
                        TYPE="network"
                        TYPE_CONFIDENCE=96
                        REASON="network vendor and router service profile"
                        HARD_DENY=1
                        NETWORK_DENY=1
                        add_evidence oui 0
                fi
        elif [ "$candidate_oui_type" = "$TYPE" ]; then
                add_evidence oui 30
                TYPE_CONFIDENCE=$((TYPE_CONFIDENCE + 4))
                [ "$TYPE_CONFIDENCE" -le 99 ] || TYPE_CONFIDENCE=99
	elif [ "$TYPE" = "smart" ] && [ "$candidate_oui_type" != "unknown" ]; then
		TYPE="$candidate_oui_type"
		if [ "$candidate_oui_type" = smart_home ]; then
			# Узкий OUI IoT-производителя достаточен для значка типа, но одного
			# семейства по-прежнему недостаточно для «Без ограничений».
			TYPE_CONFIDENCE=72
		else
			TYPE_CONFIDENCE=65
		fi
		REASON="device manufacturer marker"
		add_evidence oui 30
	elif [ "$candidate_oui_type" != "unknown" ] && [ "$candidate_oui_type" != "$TYPE" ]; then
		add_competing_evidence oui "$candidate_oui_type" 30
        fi
fi

if mdns_has '_ipp\._tcp|_printer\._tcp'; then
        TYPE="printer"
        TYPE_CONFIDENCE=92
        REASON="printer mDNS service"
        # Принтерный сервис подтверждает тип, но сам по себе не означает
        # пользовательское устройство, которому запрещено автодоверие.
        add_evidence mdns 45
elif mdns_has '_home-assistant\._tcp'; then
        TYPE="server"
        [ "$TYPE_CONFIDENCE" -ge 92 ] || TYPE_CONFIDENCE=92
        REASON="Home Assistant mDNS service"
        add_evidence mdns 40
elif mdns_has '_hap\._tcp|_matter\._tcp|_meshcop\._udp'; then
        if [ "$TYPE" = "smart" ]; then
                TYPE="smart_home"
                TYPE_CONFIDENCE=72
                REASON="smart-home mDNS service"
        fi
        [ "$TYPE" != "smart_home" ] || add_evidence mdns 35
elif mdns_has '_googlecast\._tcp|_raop\._tcp|_airplay\._tcp'; then
        if [ "$TYPE" = "speaker" ]; then
                add_evidence mdns 35
                TYPE_CONFIDENCE=$((TYPE_CONFIDENCE + 4))
        elif [ "$TYPE" = "smart" ]; then
                TYPE="tv"
                TYPE_CONFIDENCE=72
                REASON="media mDNS service without appliance confirmation"
                HARD_DENY=1
                add_evidence mdns 0
        fi
fi

if port_open 8123; then
        TYPE="server"
        TYPE_CONFIDENCE=95
        REASON="Home Assistant port 8123 is open"
        add_evidence ports 40
elif port_open 8006; then
        TYPE="server"
        TYPE_CONFIDENCE=95
        REASON="Proxmox port 8006 is open"
        add_evidence ports 40
elif port_open 445 || port_open 548 || port_open 2049; then
        TYPE="server"
        [ "$TYPE_CONFIDENCE" -ge 86 ] || TYPE_CONFIDENCE=86
        REASON="file sharing service is open"
        add_evidence ports 35
elif { port_open 554 || port_open 8554; } && { [ "$TYPE" = "camera" ] || [ "$TYPE" = "server" ]; }; then
        [ "$TYPE_CONFIDENCE" -ge 88 ] || TYPE_CONFIDENCE=88
        REASON="surveillance streaming service is open"
        add_evidence ports 35
elif port_open 9100 || port_open 631; then
        TYPE="printer"
        [ "$TYPE_CONFIDENCE" -ge 86 ] || TYPE_CONFIDENCE=86
        REASON="printer service is open"
        # IPP/JetDirect — независимое подтверждение принтера, не жёсткий запрет.
        add_evidence ports 45
fi

if personal_device_type "$TYPE"; then
        case "$wifi_generation:$wifi_speed_class" in
                he:*|vht:very_fast|vht:fast)
                        # Современный Wi-Fi слегка подтверждает уже найденный личный тип.
                        # Он не становится самостоятельным evidence и потому никогда не
                        # выдаёт привилегированную группу «Без ограничений». §devpas1
                        TYPE_CONFIDENCE=$((TYPE_CONFIDENCE + 3))
                        [ "$TYPE_CONFIDENCE" -le 99 ] || TYPE_CONFIDENCE=99
                        ;;
        esac
elif [ "$TYPE" = smart_home ] || [ "$TYPE" = engineering ] || [ "$TYPE" = vacuum ]; then
        case "$wifi_generation:$wifi_speed_class" in
                he:very_fast)
                        # Это лишь противоречие гипотезе «простой IoT»: современные
                        # модули встречаются и в бытовой технике, поэтому тип не меняется.
                        add_competing_evidence wifi_capabilities personal 10
                        ;;
                legacy:slow|ht:slow)
                        TYPE_CONFIDENCE=$((TYPE_CONFIDENCE + 2))
                        [ "$TYPE_CONFIDENCE" -le 99 ] || TYPE_CONFIDENCE=99
                        ;;
        esac
fi

if name_is_network_infrastructure "$NAME"; then
        NETWORK_DENY=1
fi

if [ "$NETWORK_DENY" = "1" ]; then
        TYPE="network"
        TYPE_CONFIDENCE=96
        REASON="network infrastructure evidence"
        HARD_DENY=1
fi

if interactive_type "$TYPE"; then
        HARD_DENY=1
fi

if [ "$COMPETING_SCORE" -gt 0 ]; then
	# Fingerbank снижает score максимум примерно на 27% из-за лучшего конкурента.
	# Здесь используется та же ограниченная идея без внешней базы и сетевого API.
	conflict_penalty=$((COMPETING_SCORE * 27 / 50))
	[ "$conflict_penalty" -le 27 ] || conflict_penalty=27
	TYPE_CONFIDENCE=$((TYPE_CONFIDENCE - conflict_penalty))
	[ "$TYPE_CONFIDENCE" -ge 30 ] || TYPE_CONFIDENCE=30
	AUTO_SCORE=$((AUTO_SCORE - conflict_penalty))
	[ "$AUTO_SCORE" -ge 0 ] || AUTO_SCORE=0
	REASON="$REASON; competing evidence: $COMPETING_EVIDENCE"
fi

TARGET_GROUP=""
if eligible_type "$TYPE"; then
	TARGET_GROUP="$NO_RESTRICTIONS_GROUP"
elif personal_device_type "$TYPE"; then
	# Эта группа только упорядочивает личные экраны и компьютеры. Она не даёт
	# обхода блокировок, поэтому уверенно определённый тип можно назначить без
	# инфраструктурного требования двух независимых доказательств.
	TARGET_GROUP="$PERSONAL_DEVICES_GROUP"
	AUTO_SCORE="$TYPE_CONFIDENCE"
else
	AUTO_SCORE=0
fi

printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
        "$TYPE" "$TYPE_CONFIDENCE" "$TARGET_GROUP" "$REASON" \
        "$AUTO_SCORE" "$EVIDENCE" "$EVIDENCE_COUNT" "$HARD_DENY" \
	"$POLICY_VERSION" "$OUI_VENDOR" "$COMPETING_EVIDENCE"
