#!/bin/sh
set -eu

COMMAND="${1:-check}"
OWNER="kva4991"
REPO="luci-app-sheepfold-family-internet-control"
case "$0" in
        */*) SCRIPT_DIR="${0%/*}" ;;
        *) SCRIPT_DIR="/usr/libexec/sheepfold" ;;
esac
PACKAGE_MANAGER_HELPER="${SHEEPFOLD_PACKAGE_MANAGER_HELPER:-${SCRIPT_DIR}/sheepfold-package-manager}"
if [ ! -r "$PACKAGE_MANAGER_HELPER" ]; then
        printf 'Sheepfold package manager adapter was not found: %s\n' "$PACKAGE_MANAGER_HELPER" >&2
        exit 1
fi
. "$PACKAGE_MANAGER_HELPER"
PACKAGE_MANAGER="$(sheepfold_package_manager)" || {
        printf 'OpenWrt package manager was not found (opkg or apk).\n' >&2
        exit 1
}
case "$PACKAGE_MANAGER" in
        opkg) PACKAGE_EXTENSION='ipk' ;;
        apk) PACKAGE_EXTENSION='apk' ;;
        *)
                printf 'Unsupported OpenWrt package manager: %s\n' "$PACKAGE_MANAGER" >&2
                exit 1
                ;;
esac
PRODUCT_VARIANT="$(uci -q get sheepfold.global.product_variant 2>/dev/null || printf sheepfold)"
case "$PRODUCT_VARIANT" in
        sheepfoldAi) ASSET_PACKAGE="luci-app-sheepfold-ai-support" ;;
        *) ASSET_PACKAGE="luci-app-sheepfold-family-internet-control" ;;
esac
INSTALLED_PACKAGE="luci-app-sheepfold-family-internet-control"
WORK_DIR="${SHEEPFOLD_UPDATE_WORK_DIR:-/tmp/sheepfold/update}"
RUNTIME_DIR="${SHEEPFOLD_UPDATE_RUNTIME_DIR:-/tmp/sheepfold}"
API_URL="${SHEEPFOLD_UPDATE_API_URL:-https://api.github.com/repos/${OWNER}/${REPO}/releases/latest}"
RELEASE_JSON="${WORK_DIR}/latest-release.json"
PACKAGE_FILE="${WORK_DIR}/${ASSET_PACKAGE}-latest.${PACKAGE_EXTENSION}"
LOG_FILE="${RUNTIME_DIR}/update.log"
STATUS_FILE="${RUNTIME_DIR}/update.status"
PID_FILE="${RUNTIME_DIR}/update.pid"
CONFIG_FILE="${SHEEPFOLD_UPDATE_CONFIG_FILE:-/etc/config/sheepfold}"
MIGRATION_CONFIG_BACKUP="${SHEEPFOLD_UPDATE_MIGRATION_BACKUP:-/etc/sheepfold/migrations/sheepfold.config.pre-upgrade}"
CONFIG_BACKUP="${WORK_DIR}/sheepfold-config-before-update"
CONFIG_BACKUP_STATE="${WORK_DIR}/sheepfold-config-before-update.state"
SHEEPFOLD_INIT="${SHEEPFOLD_UPDATE_SERVICE_INIT:-/etc/init.d/sheepfold}"
RPCD_INIT="${SHEEPFOLD_UPDATE_RPCD_INIT:-/etc/init.d/rpcd}"
JSHN_LIBRARY="${SHEEPFOLD_UPDATE_JSHN_LIBRARY:-/usr/share/libubox/jshn.sh}"
LANGUAGE="$(uci -q get sheepfold.global.language 2>/dev/null || printf ru)"
DOWNLOAD_TIMEOUT_SECONDS="${SHEEPFOLD_UPDATE_DOWNLOAD_TIMEOUT:-120}"
MAX_DOWNLOAD_BYTES="${SHEEPFOLD_UPDATE_MAX_DOWNLOAD_BYTES:-67108864}"

case "$DOWNLOAD_TIMEOUT_SECONDS" in ''|*[!0-9]*) DOWNLOAD_TIMEOUT_SECONDS=120 ;; esac
case "$MAX_DOWNLOAD_BYTES" in ''|*[!0-9]*) MAX_DOWNLOAD_BYTES=67108864 ;; esac
[ "$DOWNLOAD_TIMEOUT_SECONDS" -ge 1 ] || DOWNLOAD_TIMEOUT_SECONDS=1
[ "$MAX_DOWNLOAD_BYTES" -ge 1 ] || MAX_DOWNLOAD_BYTES=1
MAX_DOWNLOAD_BLOCKS=$((MAX_DOWNLOAD_BYTES / 512 + 1))

mkdir -p "$RUNTIME_DIR" "$WORK_DIR"
chmod 700 "$WORK_DIR"

text() {
        key="$1"
        shift || true

        if [ "$LANGUAGE" = "ru" ]; then
                case "$key" in
                        updater_title) printf '%s' "Обновление Sheepfold" ;;
                        checking_release) printf '%s' "Проверка последнего релиза GitHub..." ;;
                        downloading) printf 'Загрузка: %s' "$1" ;;
                        download_failed) printf 'Загрузка через %s не удалась, код выхода %s.' "$1" "$2" ;;
                        no_downloader) printf '%s' "Не найден загрузчик. Установите uclient-fetch, curl или wget." ;;
                        download_too_large) printf 'Загрузка превышает безопасный размер %s байт.' "$1" ;;
                        no_tag) printf '%s' "Не удалось прочитать тег последнего stable-релиза с GitHub." ;;
                        no_package) printf 'Последний stable-релиз %s не содержит пакет Sheepfold для OpenWrt.' "$1" ;;
                        no_package_version) printf '%s' "Не удалось прочитать версию пакета Sheepfold из имени файла релиза." ;;
                        current_version) printf 'Текущая установленная версия: %s' "${1:-unknown}" ;;
                        latest_release) printf 'Последний stable-релиз: %s' "$1" ;;
                        latest_package_version) printf 'Версия пакета в релизе: %s' "$1" ;;
                        package_url) printf 'Адрес пакета: %s' "$1" ;;
                        update_available) printf '%s' "Доступно обновление." ;;
                        no_updates) printf '%s' "Обновлений нет. Установленная версия уже актуальна." ;;
                        downloading_package) printf '%s' "Загрузка пакета..." ;;
                        empty_package) printf '%s' "Загруженный пакет пустой." ;;
                        invalid_package) printf 'Загруженный пакет OpenWrt не прошёл проверку: %s.' "$1" ;;
                        untrusted_package_url) printf '%s' "GitHub вернул адрес пакета вне официального раздела релизов Sheepfold." ;;
                        installing_package) printf '%s' "Установка пакета..." ;;
                        install_failed) printf 'Установка пакета завершилась ошибкой, код %s.' "$1" ;;
                        config_backup_failed) printf '%s' "Не удалось создать резервную копию настроек; установка не запущена." ;;
                        config_restored) printf '%s' "Предыдущие настройки Sheepfold восстановлены." ;;
                        config_restore_failed) printf '%s' "Не удалось автоматически восстановить предыдущие настройки Sheepfold." ;;
                        installed_version_mismatch) printf 'После установки роутер сообщает версию %s вместо ожидаемой %s.' "$1" "$2" ;;
                        reloading_service) printf '%s' "Перезапуск сервиса Sheepfold..." ;;
                        update_completed) printf '%s' "Обновление завершено." ;;
                        already_running) printf 'Обновление уже выполняется. PID: %s' "$1" ;;
                        started_background) printf 'Обновление запущено в фоне. PID: %s' "$1" ;;
                        usage) printf '%s' "Использование: sheepfold-updater [check|probe|start|status|log|install]" ;;
                        *) printf '%s' "$key" ;;
                esac
                return
        fi

        case "$key" in
                updater_title) printf '%s' "Sheepfold updater" ;;
                checking_release) printf '%s' "Checking latest GitHub release..." ;;
                downloading) printf 'Downloading: %s' "$1" ;;
                download_failed) printf 'Download failed with %s, exit code %s.' "$1" "$2" ;;
                no_downloader) printf '%s' "No downloader found. Install uclient-fetch, curl, or wget." ;;
                download_too_large) printf 'Download exceeds the safe size of %s bytes.' "$1" ;;
                no_tag) printf '%s' "Could not read latest stable release tag from GitHub." ;;
                no_package) printf 'Latest stable release %s does not contain a Sheepfold package for OpenWrt.' "$1" ;;
                no_package_version) printf '%s' "Could not read Sheepfold package version from release asset name." ;;
                current_version) printf 'Current installed version: %s' "${1:-unknown}" ;;
                latest_release) printf 'Latest stable release: %s' "$1" ;;
                latest_package_version) printf 'Latest package version: %s' "$1" ;;
                package_url) printf 'Package URL: %s' "$1" ;;
                update_available) printf '%s' "Update is available." ;;
                no_updates) printf '%s' "No updates available. Installed version is already current." ;;
                downloading_package) printf '%s' "Downloading package..." ;;
                empty_package) printf '%s' "Downloaded package is empty." ;;
                invalid_package) printf 'Downloaded OpenWrt package validation failed: %s.' "$1" ;;
                untrusted_package_url) printf '%s' "GitHub returned a package URL outside the official Sheepfold release path." ;;
                installing_package) printf '%s' "Installing package..." ;;
                install_failed) printf 'Package installation failed with exit code %s.' "$1" ;;
                config_backup_failed) printf '%s' "Could not back up settings; installation was not started." ;;
                config_restored) printf '%s' "Previous Sheepfold settings were restored." ;;
                config_restore_failed) printf '%s' "Could not automatically restore previous Sheepfold settings." ;;
                installed_version_mismatch) printf 'Router reports version %s after installation, expected %s.' "$1" "$2" ;;
                reloading_service) printf '%s' "Reloading Sheepfold service..." ;;
                update_completed) printf '%s' "Update completed." ;;
                already_running) printf 'Update is already running. PID: %s' "$1" ;;
                started_background) printf 'Update started in background. PID: %s' "$1" ;;
                usage) printf '%s' "Usage: sheepfold-updater [check|probe|start|status|log|install]" ;;
                *) printf '%s' "$key" ;;
        esac
}

say() {
        text "$@"
        printf '\n'
}

fetch() {
        url="$1"
        output="$2"

        say downloading "$url"
        rm -f "$output"
        if command -v uclient-fetch >/dev/null 2>&1; then
                if (
                        ulimit -f "$MAX_DOWNLOAD_BLOCKS" 2>/dev/null || true
                        uclient-fetch -q -T "$DOWNLOAD_TIMEOUT_SECONDS" -O "$output" "$url"
                ); then
                        code=0
                else
                        # Код нужно забирать именно в else: после завершившегося if некоторые sh уже вернут 0.
                        code="$?"
                fi
                downloader=uclient-fetch
        elif command -v curl >/dev/null 2>&1; then
                if (
                        ulimit -f "$MAX_DOWNLOAD_BLOCKS" 2>/dev/null || true
                        curl -fsSL --connect-timeout 15 --max-time "$DOWNLOAD_TIMEOUT_SECONDS" -o "$output" "$url"
                ); then
                        code=0
                else
                        code="$?"
                fi
                downloader=curl
        elif command -v wget >/dev/null 2>&1; then
                if (
                        ulimit -f "$MAX_DOWNLOAD_BLOCKS" 2>/dev/null || true
                        wget -q -T "$DOWNLOAD_TIMEOUT_SECONDS" -O "$output" "$url"
                ); then
                        code=0
                else
                        code="$?"
                fi
                downloader=wget
        else
                say no_downloader >&2
                return 1
        fi

        if [ "$code" -ne 0 ]; then
                rm -f "$output"
                say download_failed "$downloader" "$code" >&2
                return "$code"
        fi

        download_size="$(wc -c < "$output" | tr -d ' ')"
        case "$download_size" in ''|*[!0-9]*) download_size=0 ;; esac
        if [ "$download_size" -gt "$MAX_DOWNLOAD_BYTES" ]; then
                rm -f "$output"
                say download_too_large "$MAX_DOWNLOAD_BYTES" >&2
                return 1
        fi
        return 0
}

current_version() {
        sheepfold_package_version "$INSTALLED_PACKAGE"
}

latest_package_version() {
        case "$PACKAGE_MANAGER" in
                opkg)
                        basename "$PACKAGE_URL" |
                                sed -n "s/^${ASSET_PACKAGE}_\\([^_]*\\)_all\\.ipk$/\\1/p" |
                                sed -n '1p'
                        ;;
                apk)
                        basename "$PACKAGE_URL" |
                                sed -n "s/^${ASSET_PACKAGE}-\\(.*\\)\\.apk$/\\1/p" |
                                sed -n '1p'
                        ;;
        esac
}

trusted_package_url() {
        # Одного JSON от API недостаточно: устанавливаем только asset из официального
        # release path и с точным префиксом выбранной редакции (§updsafe).
        trusted_prefix="https://github.com/${OWNER}/${REPO}/releases/download/"
        case "$PACKAGE_MANAGER" in
                opkg)
                        case "$PACKAGE_URL" in
                                "$trusted_prefix"*/"${ASSET_PACKAGE}_"*_all.ipk) return 0 ;;
                                *) return 1 ;;
                        esac
                        ;;
                apk)
                        case "$PACKAGE_URL" in
                                "$trusted_prefix"*/"${ASSET_PACKAGE}-"*.apk) return 0 ;;
                                *) return 1 ;;
                        esac
                        ;;
        esac
}

archive_member() {
        wanted="$1"
        awk -v wanted="$wanted" '
                {
                        original = $0
                        normalized = $0
                        sub(/^\.\//, "", normalized)
                        if (normalized == wanted) {
                                count++
                                member = original
                        }
                }
                END {
                        if (count == 1) print member
                        else exit 1
                }
        '
}

archive_paths_safe() {
        awk '
                {
                        path = $0
                        sub(/^\.\//, "", path)
                        if (path == "" || path ~ /^\//) exit 1
                        # tar может повторить запись каталога при добавлении нескольких деревьев,
                        # но два одноимённых файла делают содержимое неоднозначным.
                        if (seen[path]++ && path !~ /\/$/) exit 1
                        count = split(path, parts, "/")
                        for (i = 1; i <= count; i++)
                                if (parts[i] == "..") exit 1
                }
        '
}

package_validation_reason() {
        reason="$1"
        if [ "$LANGUAGE" = ru ]; then
                case "$reason" in
                        outer_archive) printf '%s' 'повреждён внешний архив' ;;
                        missing_parts) printf '%s' 'отсутствуют обязательные части пакета' ;;
                        format_version) printf '%s' 'неверная версия формата пакета' ;;
                        control_archive) printf '%s' 'повреждён control.tar.gz' ;;
                        control_description) printf '%s' 'не читается описание пакета' ;;
                        package_name) printf '%s' 'имя пакета не совпадает с выбранным вариантом' ;;
                        package_version) printf '%s' 'версия внутри пакета не совпадает с именем файла' ;;
                        architecture) printf '%s' 'неподдерживаемая архитектура пакета' ;;
                        data_archive) printf '%s' 'повреждён или небезопасен data.tar.gz' ;;
                        apk_integrity) printf '%s' 'нарушена целостность APK-контейнера' ;;
                        apk_metadata) printf '%s' 'не читаются метаданные APK-пакета' ;;
                        *) printf '%s' 'неизвестная ошибка структуры пакета' ;;
                esac
                return
        fi
        case "$reason" in
                outer_archive) printf '%s' 'outer archive is damaged' ;;
                missing_parts) printf '%s' 'required package members are missing' ;;
                format_version) printf '%s' 'package format version is invalid' ;;
                control_archive) printf '%s' 'control.tar.gz is damaged' ;;
                control_description) printf '%s' 'package metadata cannot be read' ;;
                package_name) printf '%s' 'package name does not match the selected product' ;;
                package_version) printf '%s' 'embedded version does not match the asset filename' ;;
                architecture) printf '%s' 'package architecture is unsupported' ;;
                data_archive) printf '%s' 'data.tar.gz is damaged or unsafe' ;;
                apk_integrity) printf '%s' 'APK container integrity check failed' ;;
                apk_metadata) printf '%s' 'APK package metadata cannot be read' ;;
                *) printf '%s' 'unknown package structure error' ;;
        esac
}

validation_error() {
        say invalid_package "$(package_validation_reason "$1")" >&2
        rm -f "$WORK_DIR"/validate-*.$$ 2>/dev/null || true
}

validate_ipk_package() {
        outer_list="$WORK_DIR/validate-outer.$$.list"
        control_archive="$WORK_DIR/validate-control.$$.tar.gz"
        control_list="$WORK_DIR/validate-control.$$.list"
        control_file="$WORK_DIR/validate-control.$$.txt"
        data_archive="$WORK_DIR/validate-data.$$.tar.gz"
        data_list="$WORK_DIR/validate-data.$$.list"
        rm -f "$WORK_DIR"/validate-*.$$ 2>/dev/null || true

        if ! tar -tzf "$PACKAGE_FILE" > "$outer_list" 2>/dev/null || ! archive_paths_safe < "$outer_list"; then
                validation_error outer_archive
                return 1
        fi
        if ! debian_member="$(archive_member debian-binary < "$outer_list")" || \
           ! control_member="$(archive_member control.tar.gz < "$outer_list")" || \
           ! data_member="$(archive_member data.tar.gz < "$outer_list")"; then
                validation_error missing_parts
                return 1
        fi

        debian_version="$(tar -xzOf "$PACKAGE_FILE" "$debian_member" 2>/dev/null | tr -d '\r\n' || true)"
        if [ "$debian_version" != 2.0 ]; then
                validation_error format_version
                return 1
        fi
        if ! (
                ulimit -f "$MAX_DOWNLOAD_BLOCKS" 2>/dev/null || true
                tar -xzOf "$PACKAGE_FILE" "$control_member"
        ) > "$control_archive" 2>/dev/null || \
           ! tar -tzf "$control_archive" > "$control_list" 2>/dev/null || \
           ! archive_paths_safe < "$control_list" || \
           ! package_control_member="$(archive_member control < "$control_list")"; then
                validation_error control_archive
                return 1
        fi
        if ! tar -xzOf "$control_archive" "$package_control_member" > "$control_file" 2>/dev/null; then
                validation_error control_description
                return 1
        fi

        package_name="$(sed -n 's/^Package:[[:space:]]*//p' "$control_file" | sed -n '1p')"
        package_version="$(sed -n 's/^Version:[[:space:]]*//p' "$control_file" | sed -n '1p')"
        package_architecture="$(sed -n 's/^Architecture:[[:space:]]*//p' "$control_file" | sed -n '1p')"
        package_name_count="$(grep -c '^Package:' "$control_file" 2>/dev/null || true)"
        package_version_count="$(grep -c '^Version:' "$control_file" 2>/dev/null || true)"
        package_architecture_count="$(grep -c '^Architecture:' "$control_file" 2>/dev/null || true)"
        if [ "$package_name_count" != 1 ] || [ "$package_version_count" != 1 ] || [ "$package_architecture_count" != 1 ]; then
                validation_error control_description
                return 1
        fi
        if [ "$package_name" != "$INSTALLED_PACKAGE" ]; then
                validation_error package_name
                return 1
        fi
        if [ "$package_version" != "$LATEST_VERSION" ]; then
                validation_error package_version
                return 1
        fi
        if [ "$package_architecture" != all ]; then
                validation_error architecture
                return 1
        fi

        if ! (
                ulimit -f "$MAX_DOWNLOAD_BLOCKS" 2>/dev/null || true
                tar -xzOf "$PACKAGE_FILE" "$data_member"
        ) > "$data_archive" 2>/dev/null || \
           ! tar -tzf "$data_archive" > "$data_list" 2>/dev/null || \
           ! archive_paths_safe < "$data_list"; then
                validation_error data_archive
                return 1
        fi

        rm -f "$outer_list" "$control_archive" "$control_list" "$control_file" "$data_archive" "$data_list"
        return 0
}

validate_apk_package() {
        apk_metadata="$WORK_DIR/validate-apk.$$"
        rm -f "$apk_metadata" 2>/dev/null || true

        # --allow-untrusted допускает релизный ключ проекта, которого ещё нет в
        # системном keyring, но verify всё равно проверяет структуру и хеши ADB.
        if ! apk verify --allow-untrusted "$PACKAGE_FILE" >/dev/null 2>&1; then
                validation_error apk_integrity
                return 1
        fi
        if ! apk adbdump --allow-untrusted --format json "$PACKAGE_FILE" > "$apk_metadata" 2>/dev/null || \
           [ ! -s "$apk_metadata" ] || \
           [ ! -r "$JSHN_LIBRARY" ]; then
                validation_error apk_metadata
                return 1
        fi

        # json_load_file читает большой список payload-путей прямо из файла и не
        # заталкивает весь adbdump в аргумент shell, где легко упереться в ARG_MAX.
        . "$JSHN_LIBRARY"
        json_init
        if ! json_load_file "$apk_metadata" || ! json_select info; then
                validation_error apk_metadata
                return 1
        fi
        json_get_var package_name name
        json_get_var package_version version
        json_get_var package_architecture arch
        json_select ..

        if [ "$package_name" != "$INSTALLED_PACKAGE" ]; then
                validation_error package_name
                return 1
        fi
        if [ "$package_version" != "$LATEST_VERSION" ]; then
                validation_error package_version
                return 1
        fi
        if [ -z "$package_architecture" ]; then
                validation_error architecture
                return 1
        fi
        router_architecture="$(apk --print-arch 2>/dev/null || true)"
        case "$package_architecture" in
                all|noarch|"$router_architecture") ;;
                *)
                        validation_error architecture
                        return 1
                        ;;
        esac

        rm -f "$apk_metadata"
        return 0
}

validate_package() {
        case "$PACKAGE_MANAGER" in
                opkg) validate_ipk_package ;;
                apk) validate_apk_package ;;
        esac
}

backup_config() {
        rm -f "$CONFIG_BACKUP" "$CONFIG_BACKUP_STATE"
        umask 077
        if [ -r "$CONFIG_FILE" ]; then
                cp "$CONFIG_FILE" "$CONFIG_BACKUP" || return 1
                printf 'present\n' > "$CONFIG_BACKUP_STATE" || return 1
        else
                printf 'absent\n' > "$CONFIG_BACKUP_STATE" || return 1
        fi
        chmod 600 "$CONFIG_BACKUP" "$CONFIG_BACKUP_STATE" 2>/dev/null || true
}

restore_config() {
        [ -r "$CONFIG_BACKUP_STATE" ] || return 1
        config_parent="${CONFIG_FILE%/*}"
        [ "$config_parent" != "$CONFIG_FILE" ] || config_parent=.
        mkdir -p "$config_parent"
        case "$(sed -n '1p' "$CONFIG_BACKUP_STATE")" in
                present)
                        restore_source="$CONFIG_BACKUP"
                        [ -s "$restore_source" ] || restore_source="$MIGRATION_CONFIG_BACKUP"
                        [ -s "$restore_source" ] || return 1
                        cp "$restore_source" "$CONFIG_FILE" || return 1
                        chmod 600 "$CONFIG_FILE" 2>/dev/null || true
                        ;;
                absent) rm -f "$CONFIG_FILE" || return 1 ;;
                *) return 1 ;;
        esac
        return 0
}

cleanup_install_files() {
        rm -f "$PACKAGE_FILE" "$CONFIG_BACKUP" "$CONFIG_BACKUP_STATE" "$WORK_DIR"/validate-*.$$ 2>/dev/null || true
}

version_is_newer() {
        latest="$1"
        current="$2"

        [ -z "$current" ] && return 0
        [ -z "$latest" ] && return 1

        sheepfold_package_is_newer "$latest" "$current"
}

read_release_info() {
        say checking_release
        fetch "$API_URL" "$RELEASE_JSON"

        TAG="$(sed -n 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$RELEASE_JSON" | sed -n '1p')"
        case "$PACKAGE_MANAGER" in
                opkg)
                        PACKAGE_URL="$(sed -n 's/.*"browser_download_url"[[:space:]]*:[[:space:]]*"\([^"]*_all\.ipk\)".*/\1/p' "$RELEASE_JSON" | grep "/${ASSET_PACKAGE}_" | sed -n '1p')"
                        ;;
                apk)
                        PACKAGE_URL="$(sed -n 's/.*"browser_download_url"[[:space:]]*:[[:space:]]*"\([^"]*\.apk\)".*/\1/p' "$RELEASE_JSON" | grep "/${ASSET_PACKAGE}-" | sed -n '1p')"
                        ;;
        esac
        LATEST_VERSION="$(latest_package_version)"

        if [ -z "${TAG:-}" ]; then
                say no_tag >&2
                exit 1
        fi

        if [ -z "${PACKAGE_URL:-}" ]; then
                say no_package "$TAG" >&2
                exit 1
        fi

        if ! trusted_package_url; then
                say untrusted_package_url >&2
                exit 1
        fi

        if [ -z "${LATEST_VERSION:-}" ]; then
                say no_package_version >&2
                exit 1
        fi
}

print_check() {
        read_release_info
        CURRENT_VERSION="$(current_version || true)"
        say current_version "${CURRENT_VERSION:-unknown}"
        say latest_release "$TAG"
        say latest_package_version "$LATEST_VERSION"
        say package_url "$PACKAGE_URL"
        if version_is_newer "$LATEST_VERSION" "$CURRENT_VERSION"; then
                say update_available
        else
                say no_updates
        fi
}

print_probe() {
        # Machine-readable check for the periodic maintenance job. It reuses the
        # updater's trusted release parsing but never downloads or installs a package.
        read_release_info >/dev/null
        CURRENT_VERSION="$(current_version || true)"
        available=0
        version_is_newer "$LATEST_VERSION" "$CURRENT_VERSION" && available=1
        printf 'available=%s\n' "$available"
        printf 'current_version=%s\n' "${CURRENT_VERSION:-unknown}"
        printf 'latest_version=%s\n' "$LATEST_VERSION"
        printf 'tag=%s\n' "$TAG"
}

install_update() {
        say updater_title
        read_release_info
        CURRENT_VERSION="$(current_version || true)"
        say current_version "${CURRENT_VERSION:-unknown}"
        say latest_release "$TAG"
        say latest_package_version "$LATEST_VERSION"

        if ! version_is_newer "$LATEST_VERSION" "$CURRENT_VERSION"; then
                say no_updates
                return 2
        fi

        say downloading_package
        fetch "$PACKAGE_URL" "$PACKAGE_FILE"

        if [ ! -s "$PACKAGE_FILE" ]; then
                say empty_package >&2
                exit 1
        fi

        # Не полагаемся только на сообщение package manager: до установки проверяем
        # контейнер и внутренние метаданные выбранного формата (§updsafe).
        if ! validate_package; then
                cleanup_install_files
                return 1
        fi

        if ! backup_config; then
                say config_backup_failed >&2
                cleanup_install_files
                return 1
        fi

        say installing_package
        if sheepfold_package_install_file "$PACKAGE_FILE" 0; then
                install_code=0
        else
                install_code="$?"
        fi
        if [ "$install_code" -ne 0 ]; then
                say install_failed "$install_code" >&2
                if restore_config; then
                        say config_restored
                else
                        say config_restore_failed >&2
                fi
                cleanup_install_files
                return "$install_code"
        fi

        INSTALLED_VERSION="$(current_version || true)"
        if [ "$INSTALLED_VERSION" != "$LATEST_VERSION" ]; then
                say installed_version_mismatch "${INSTALLED_VERSION:-unknown}" "$LATEST_VERSION" >&2
                if restore_config; then
                        say config_restored
                else
                        say config_restore_failed >&2
                fi
                cleanup_install_files
                return 1
        fi

        cleanup_install_files

        say reloading_service
        [ -x "$SHEEPFOLD_INIT" ] && "$SHEEPFOLD_INIT" restart || true
        [ -x "$RPCD_INIT" ] && "$RPCD_INIT" reload || true

        say update_completed
}

pid_running() {
        [ -r "$PID_FILE" ] || return 1
        pid="$(cat "$PID_FILE" 2>/dev/null || true)"
        [ -n "$pid" ] || return 1
        kill -0 "$pid" 2>/dev/null
}

start_update() {
        if pid_running; then
                say already_running "$(cat "$PID_FILE")"
                return 0
        fi

        : > "$LOG_FILE"
        echo "running" > "$STATUS_FILE"
        "$0" run-background >/dev/null 2>&1 </dev/null &
        echo "$!" > "$PID_FILE"
        say started_background "$!"
}

run_background() {
        echo "$$" > "$PID_FILE"
        : > "$LOG_FILE"
        echo "running" > "$STATUS_FILE"

        code=0
        "$0" install-foreground >>"$LOG_FILE" 2>&1 || code="$?"

        if [ "$code" = "0" ]; then
                echo "ok" > "$STATUS_FILE"
        elif [ "$code" = "2" ]; then
                echo "no_update" > "$STATUS_FILE"
        else
                echo "failed:${code}" > "$STATUS_FILE"
        fi

        rm -f "$PID_FILE"
}

print_status() {
        if pid_running; then
                cat "$STATUS_FILE" 2>/dev/null || echo "running"
                return 0
        fi

        cat "$STATUS_FILE" 2>/dev/null || echo "idle"
}

print_log() {
        cat "$LOG_FILE" 2>/dev/null || true
}

case "$COMMAND" in
        check)
                print_check
                ;;
        probe)
                print_probe
                ;;
        start)
                start_update
                ;;
        status)
                print_status
                ;;
        log)
                print_log
                ;;
        install)
                code=0
                install_update || code="$?"
                [ "$code" = "2" ] && exit 0
                exit "$code"
                ;;
        install-foreground)
                install_update
                ;;
        run-background)
                run_background
                ;;
        *)
                say usage >&2
                exit 1
                ;;
esac
