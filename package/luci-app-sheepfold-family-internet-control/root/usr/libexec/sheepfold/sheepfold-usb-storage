#!/bin/sh
# sheepfold-usb-storage
#
# Управление USB-хранилищем для приватных логов Sheepfold.
#
# Команды:
#   scan          -> JSON список найденных USB/SD-устройств
#   info <dev>    -> JSON с деталями одного устройства
#   format <dev>  -> быстрое форматирование в ext4/f2fs/vfat
#   mount [dev]   -> подключить в /mnt/sheepfold-usb
#   umount        -> отключить
#   status        -> JSON статус
#   archive-push  -> переместить архивы из RAM на USB
#   setup-swap    -> создать файл подкачки 128 МБ
#   setup-extroot -> настроить extroot (/overlay на USB)
#
# UCI (sheepfold.usb.*):
#   device        — /dev/sda1
#   enabled       — 0/1
#   role          — logs_only | swap_logs | extroot_logs
#   encrypt       — 0/1 (AES-256-CBC, по умолчанию 1)

set -eu

MOUNT_POINT="/mnt/sheepfold-usb"
USB_LOG_DIR="${MOUNT_POINT}/sheepfold-logs"
RAM_ARCHIVE_DIR="/tmp/sheepfold/.private/archive"
KEY_FILE="/etc/sheepfold/.usb_key"
SWAP_FILE="${MOUNT_POINT}/.sheepfold_swap"
SWAP_SIZE_MB=128

uci_get() { uci -q get "sheepfold.usb.$1" 2>/dev/null || echo "${2:-}"; }

is_mounted() {
    grep -q " ${MOUNT_POINT} " /proc/mounts 2>/dev/null
}

get_disk_usage_role() {
    DEV="$1"; ROLE="logs_only"
    grep -q "$DEV" /proc/swaps 2>/dev/null && ROLE="swap_logs"
    grep "$DEV" /proc/mounts 2>/dev/null | grep -q '/overlay' 2>/dev/null && ROLE="extroot_logs"
    echo "$ROLE"
}

get_free_pct() {
    df -k "$1" 2>/dev/null | awk 'NR==2{if($2>0) printf "%d", int(($4/$2)*100); else print 0}'
}

max_log_pct() {
    ROLE=$(uci_get role logs_only)
    case "$ROLE" in
        extroot_logs|swap_logs) echo 70 ;;
        *) echo 100 ;;
    esac
}

ensure_key() {
    KEY_DIR=$(dirname "$KEY_FILE")
    mkdir -p "$KEY_DIR" && chmod 700 "$KEY_DIR"
    if [ ! -f "$KEY_FILE" ]; then
        dd if=/dev/urandom bs=32 count=1 2>/dev/null | \
            od -An -tx1 | tr -d ' \n' > "$KEY_FILE"
        chmod 600 "$KEY_FILE"
    fi
}

encrypt_archive() {
    SRC="$1"; DST="${SRC}.enc"
    ensure_key
    if command -v openssl >/dev/null 2>&1; then
        openssl enc -aes-256-cbc -pbkdf2 -iter 100000 \
            -pass "file:${KEY_FILE}" -in "$SRC" -out "$DST" 2>/dev/null
    else
        cp "$SRC" "$DST"
    fi
    echo "$DST"
}

# -- scan -----------------------------------------------------------------
cmd_scan() {
    printf '['
    FIRST=1
    for BLK in /sys/block/sd* /sys/block/mmcblk*; do
        [ -d "$BLK" ] || continue
        BASE=$(basename "$BLK")
        DEV="/dev/${BASE}"
        [ -b "$DEV" ] || continue
        case "$BASE" in mmcblk0) continue ;; esac  # встроенный eMMC

        SIZE_B=$(cat "${BLK}/size" 2>/dev/null || echo 0)
        SIZE_GB=$(awk "BEGIN{printf \"%.1f\", $SIZE_B * 512 / 1073741824}")
        VENDOR=$(cat "${BLK}/device/vendor" 2>/dev/null | tr -d '\n ' || echo '')
        MODEL=$(cat  "${BLK}/device/model"  2>/dev/null | sed 's/  */ /g;s/^ //;s/ $//' || echo "$BASE")
        IS_USB=0
        readlink -f "$BLK" 2>/dev/null | grep -qi 'usb' && IS_USB=1
        ROLE=$(get_disk_usage_role "$DEV")
        CURRENT=0
        [ "$(uci_get device)" = "$DEV" ] && [ "$(uci_get enabled 0)" = "1" ] && CURRENT=1

        [ "$FIRST" = "1" ] || printf ','
        FIRST=0
        printf '{"dev":"%s","vendor":"%s","model":"%s","size_gb":%s,"is_usb":%d,"role":"%s","current":%d}' \
            "$DEV" "$VENDOR" "$MODEL" "$SIZE_GB" "$IS_USB" "$ROLE" "$CURRENT"
    done
    printf ']\n'
}

# -- info -----------------------------------------------------------------
cmd_info() {
    DEV="${1:-}"
    [ -b "$DEV" ] || { printf '{"error":"not_found"}\n'; return 1; }
    BASE=$(basename "$DEV" | sed 's/[0-9]*$//')
    BLK="/sys/block/${BASE}"
    SIZE_B=$(cat "${BLK}/size" 2>/dev/null || echo 0)
    SIZE_GB=$(awk "BEGIN{printf \"%.1f\", $SIZE_B * 512 / 1073741824}")
    VENDOR=$(cat "${BLK}/device/vendor" 2>/dev/null | tr -d '\n ' || echo '')
    MODEL=$(cat  "${BLK}/device/model"  2>/dev/null | sed 's/  */ /g;s/^ //;s/ $//' || echo "$BASE")
    FS=$(blkid -o value -s TYPE "$DEV" 2>/dev/null || echo '')
    MOUNTED=0; is_mounted && grep -q "$DEV" /proc/mounts 2>/dev/null && MOUNTED=1
    ROLE=$(get_disk_usage_role "$DEV")
    FREE_PCT=0; [ "$MOUNTED" = 1 ] && FREE_PCT=$(get_free_pct "$MOUNT_POINT")
    printf '{"dev":"%s","vendor":"%s","model":"%s","size_gb":%s,"fs":"%s","mounted":%d,"free_pct":%s,"role":"%s"}\n' \
        "$DEV" "$VENDOR" "$MODEL" "$SIZE_GB" "$FS" "$MOUNTED" "$FREE_PCT" "$ROLE"
}

# -- format ---------------------------------------------------------------
cmd_format() {
    DEV="${1:-}"
    [ -b "$DEV" ] || { printf '{"error":"not_found"}\n'; return 1; }
    umount "$DEV" 2>/dev/null || true
    umount "$MOUNT_POINT" 2>/dev/null || true
    if command -v mkfs.ext4 >/dev/null 2>&1; then
        mkfs.ext4 -F -L sheepfold "$DEV" >/dev/null 2>&1; FS="ext4"
    elif command -v mkfs.f2fs >/dev/null 2>&1; then
        mkfs.f2fs -f -l sheepfold "$DEV" >/dev/null 2>&1; FS="f2fs"
    elif command -v mkfs.vfat >/dev/null 2>&1; then
        mkfs.vfat -n SHEEPFOLD "$DEV" >/dev/null 2>&1; FS="vfat"
    else
        printf '{"error":"no_mkfs","hint":"install kmod-fs-ext4 e2fsprogs"}\n'; return 1
    fi
    printf '{"ok":true,"dev":"%s","fs":"%s"}\n' "$DEV" "$FS"
}

# -- mount ----------------------------------------------------------------
cmd_mount() {
    DEV="${1:-$(uci_get device)}"
    [ -b "$DEV" ] || { printf '{"error":"device_not_found","dev":"%s"}\n' "$DEV"; return 1; }
    is_mounted && { printf '{"ok":true,"already":true}\n'; return 0; }
    mkdir -p "$MOUNT_POINT"
    mount "$DEV" "$MOUNT_POINT" 2>/dev/null || { printf '{"error":"mount_failed","dev":"%s"}\n' "$DEV"; return 1; }
    mkdir -p "$USB_LOG_DIR" && chmod 700 "$USB_LOG_DIR"
    printf '{"ok":true,"mount_point":"%s"}\n' "$MOUNT_POINT"
}

# -- umount ---------------------------------------------------------------
cmd_umount() {
    is_mounted || { printf '{"ok":true,"already":true}\n'; return 0; }
    [ -f "$SWAP_FILE" ] && swapoff "$SWAP_FILE" 2>/dev/null || true
    umount "$MOUNT_POINT" 2>/dev/null && printf '{"ok":true}\n' || printf '{"error":"umount_failed"}\n'
}

# -- status ---------------------------------------------------------------
cmd_status() {
    ENABLED=$(uci_get enabled 0)
    DEV=$(uci_get device '')
    ROLE=$(uci_get role logs_only)
    ENCRYPT=$(uci_get encrypt 1)
    MOUNTED=0; is_mounted && MOUNTED=1
    FREE_PCT=0; USED_KB=0; TOTAL_KB=0; ARCHIVES=0
    if [ "$MOUNTED" = 1 ]; then
        FREE_PCT=$(get_free_pct "$MOUNT_POINT")
        USED_KB=$(du -sk "$USB_LOG_DIR" 2>/dev/null | awk '{print $1}' || echo 0)
        TOTAL_KB=$(df -k "$MOUNT_POINT" 2>/dev/null | awk 'NR==2{print $2}' || echo 0)
        ARCHIVES=$(find "$USB_LOG_DIR" -name '*.tar.gz' -o -name '*.tar' -o -name '*.enc' 2>/dev/null | wc -l | tr -d ' ')
    fi
    printf '{"enabled":%s,"dev":"%s","role":"%s","encrypt":%s,"mounted":%d,"free_pct":%s,"used_kb":%s,"total_kb":%s,"archives":%s,"max_log_pct":%s}\n' \
        "$ENABLED" "$DEV" "$ROLE" "$ENCRYPT" "$MOUNTED" "$FREE_PCT" "$USED_KB" "$TOTAL_KB" "$ARCHIVES" "$(max_log_pct)"
}

# -- archive-push ---------------------------------------------------------
cmd_archive_push() {
    [ "$(uci_get enabled 0)" = "1" ] || return 0
    is_mounted || cmd_mount >/dev/null || return 1
    mkdir -p "$USB_LOG_DIR"

    MAX_PCT=$(max_log_pct)
    USED_PCT=$(df -k "$MOUNT_POINT" 2>/dev/null | awk 'NR==2{if($2>0) printf "%d", int(($3/$2)*100); else print 100}')
    if [ "$USED_PCT" -ge "$MAX_PCT" ]; then
        OLDEST=$(find "$USB_LOG_DIR" -type f | sort | head -1)
        [ -n "$OLDEST" ] && rm -f "$OLDEST" || true
    fi

    ENCRYPT=$(uci_get encrypt 1)
    PUSHED=0; ERRORS=0
    for ARC in "${RAM_ARCHIVE_DIR}"/*.tar.gz "${RAM_ARCHIVE_DIR}"/*.tar; do
        [ -f "$ARC" ] || continue
        DEST_NAME=$(basename "$ARC")
        if [ "$ENCRYPT" = "1" ]; then
            ENC=$(encrypt_archive "$ARC") || { ERRORS=$((ERRORS+1)); continue; }
            mv "$ENC" "${USB_LOG_DIR}/${DEST_NAME}.enc" && rm -f "$ARC"
        else
            mv "$ARC" "${USB_LOG_DIR}/${DEST_NAME}"
        fi
        PUSHED=$((PUSHED+1))
    done
    printf '{"ok":true,"pushed":%d,"errors":%d}\n' "$PUSHED" "$ERRORS"
}

# -- setup-swap -----------------------------------------------------------
cmd_setup_swap() {
    is_mounted || cmd_mount >/dev/null || { printf '{"error":"not_mounted"}\n'; return 1; }
    [ -f "$SWAP_FILE" ] && swapoff "$SWAP_FILE" 2>/dev/null || true
    dd if=/dev/zero of="$SWAP_FILE" bs=1M count="$SWAP_SIZE_MB" 2>/dev/null
    chmod 600 "$SWAP_FILE" && mkswap "$SWAP_FILE" >/dev/null 2>&1 && swapon "$SWAP_FILE"
    printf '{"ok":true,"swap_file":"%s","size_mb":%d}\n' "$SWAP_FILE" "$SWAP_SIZE_MB"
}

# -- setup-extroot --------------------------------------------------------
cmd_setup_extroot() {
    DEV="${1:-$(uci_get device)}"
    [ -b "$DEV" ] || { printf '{"error":"device_not_found"}\n'; return 1; }
    command -v block >/dev/null 2>&1 || {
        printf '{"error":"block_mount_missing","hint":"opkg install block-mount"}\n'; return 1
    }
    UUID=$(blkid -o value -s UUID "$DEV" 2>/dev/null || echo '')
    [ -n "$UUID" ] || { printf '{"error":"no_uuid","hint":"format device first"}\n'; return 1; }
    uci -q del fstab.sheepfold_overlay 2>/dev/null || true
    uci set fstab.sheepfold_overlay=mount
    uci set fstab.sheepfold_overlay.uuid="$UUID"
    uci set fstab.sheepfold_overlay.target='/overlay'
    uci set fstab.sheepfold_overlay.enabled='1'
    uci commit fstab
    printf '{"ok":true,"uuid":"%s","hint":"reboot_required"}\n' "$UUID"
}

# -- dispatcher -----------------------------------------------------------
COMMAND="${1:-}"; shift || true
case "$COMMAND" in
    scan)          cmd_scan ;;
    info)          cmd_info "$@" ;;
    format)        cmd_format "$@" ;;
    mount)         cmd_mount "$@" ;;
    umount)        cmd_umount ;;
    status)        cmd_status ;;
    archive-push)  cmd_archive_push ;;
    setup-swap)    cmd_setup_swap ;;
    setup-extroot) cmd_setup_extroot "$@" ;;
    *) echo "Usage: sheepfold-usb-storage <scan|info|format|mount|umount|status|archive-push|setup-swap|setup-extroot>" >&2; exit 1 ;;
esac
