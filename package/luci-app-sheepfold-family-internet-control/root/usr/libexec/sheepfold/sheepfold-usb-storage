#!/bin/sh
# Управление съёмным USB-хранилищем Sheepfold.
# Разрушительные операции разрешены только для removable или USB-backed block devices,
# которые не используются корневой системой, overlay или swap.

set -eu

MOUNT_POINT="/mnt/sheepfold-usb"
USB_ROOT_DIR="${MOUNT_POINT}/sheepfold"
USB_LOG_DIR="${USB_ROOT_DIR}/logs"
RAM_ARCHIVE_DIR="/tmp/sheepfold/.private/archive"
SWAP_FILE="${USB_ROOT_DIR}/.swap"
SWAP_SIZE_MB=128
KEY_DERIVE="/usr/libexec/sheepfold/sheepfold-key-derive"
RUNTIME_KEY="/tmp/sheepfold/.runtime_key"
PRIVACY_NOTICE_SOURCE="/usr/share/sheepfold/PRIVACY_NOTICE.md"

uci_get() {
    uci -q get "sheepfold.usb.$1" 2>/dev/null || printf '%s' "${2:-}"
}

json_escape() {
    printf '%s' "$1" | tr '\r\n\t' '   ' | sed 's/\\/\\\\/g; s/"/\\"/g'
}

mounted_source() {
    awk -v target="$MOUNT_POINT" '$2 == target { print $1; exit }' /proc/mounts 2>/dev/null
}

is_mounted() {
    [ -n "$(mounted_source)" ]
}

parent_block_name() {
    base_name="$(basename "$1")"
    case "$base_name" in
        sd[a-z]) printf '%s\n' "$base_name" ;;
        sd[a-z][0-9]*) printf '%s\n' "$base_name" | sed 's/[0-9].*$//' ;;
        mmcblk[0-9]) printf '%s\n' "$base_name" ;;
        mmcblk[0-9]p[0-9]*) printf '%s\n' "${base_name%p*}" ;;
        nvme[0-9]n[0-9]) printf '%s\n' "$base_name" ;;
        nvme[0-9]n[0-9]p[0-9]*) printf '%s\n' "${base_name%p*}" ;;
        *) return 1 ;;
    esac
}

is_system_backing_device() {
    wanted_parent="$1"
    while read -r source target _rest; do
        case "$target" in /|/overlay) ;; *) continue ;; esac
        case "$source" in /dev/*) ;; *) continue ;; esac
        source_parent="$(parent_block_name "$source" 2>/dev/null || true)"
        [ "$source_parent" = "$wanted_parent" ] && return 0
    done < /proc/mounts

    if [ -r /proc/swaps ]; then
        while read -r source _rest; do
            case "$source" in /dev/*) ;; *) continue ;; esac
            source_parent="$(parent_block_name "$source" 2>/dev/null || true)"
            [ "$source_parent" = "$wanted_parent" ] && return 0
        done < /proc/swaps
    fi
    return 1
}

is_safe_removable_device() {
    device="$1"
    [ -b "$device" ] || return 1
    parent="$(parent_block_name "$device" 2>/dev/null || true)"
    [ -n "$parent" ] || return 1
    [ -e "/sys/class/block/$parent" ] || return 1
    is_system_backing_device "$parent" && return 1

    removable="$(cat "/sys/class/block/$parent/removable" 2>/dev/null || printf 0)"
    sys_path="$(readlink -f "/sys/class/block/$parent" 2>/dev/null || true)"
    [ "$removable" = 1 ] || printf '%s' "$sys_path" | grep -qi '/usb'
}

require_safe_removable_device() {
    device="$1"
    if ! is_safe_removable_device "$device"; then
        printf '{"error":"unsafe_device","dev":"%s","hint":"only non-system removable USB-backed devices are allowed"}\n' \
            "$(json_escape "$device")"
        return 1
    fi
}

get_free_pct() {
    df -k "$1" 2>/dev/null | awk 'NR==2 { if ($2 > 0) printf "%d", int(($4 / $2) * 100); else print 0 }'
}

get_free_kb() {
    df -k "$1" 2>/dev/null | awk 'NR==2 { print $4 }'
}

max_log_pct() {
    case "$(uci_get role logs_only)" in
        extroot_logs|swap_logs) printf '70\n' ;;
        *) printf '100\n' ;;
    esac
}

get_disk_usage_role() {
    device="$1"
    role=logs_only
    grep -q "^$device " /proc/swaps 2>/dev/null && role=swap_logs
    grep "^$device " /proc/mounts 2>/dev/null | grep -q ' /overlay ' 2>/dev/null && role=extroot_logs
    printf '%s\n' "$role"
}

write_privacy_notice() {
    [ -r "$PRIVACY_NOTICE_SOURCE" ] || return 0
    mkdir -p "$USB_ROOT_DIR"
    tmp_notice="${USB_ROOT_DIR}/PRIVACY_NOTICE.md.tmp.$$"
    if cp "$PRIVACY_NOTICE_SOURCE" "$tmp_notice"; then
        chmod 0644 "$tmp_notice"
        mv -f "$tmp_notice" "${USB_ROOT_DIR}/PRIVACY_NOTICE.md"
    else
        rm -f "$tmp_notice"
        return 1
    fi
}

cmd_mount() {
    device="${1:-$(uci_get device)}"
    require_safe_removable_device "$device" || return 1
    source="$(mounted_source)"
    if [ -n "$source" ]; then
        if [ "$source" = "$device" ]; then
            mkdir -p "$USB_LOG_DIR"
            chmod 700 "$USB_ROOT_DIR" "$USB_LOG_DIR" 2>/dev/null || true
            write_privacy_notice || true
            printf '{"ok":true,"already":true,"mount_point":"%s"}\n' "$MOUNT_POINT"
            return 0
        fi
        printf '{"error":"mount_point_busy","requested":"%s","mounted":"%s"}\n' \
            "$(json_escape "$device")" "$(json_escape "$source")"
        return 1
    fi

    mkdir -p "$MOUNT_POINT"
    if ! mount "$device" "$MOUNT_POINT" 2>/dev/null; then
        printf '{"error":"mount_failed","dev":"%s"}\n' "$(json_escape "$device")"
        return 1
    fi
    if ! mkdir -p "$USB_LOG_DIR"; then
        umount "$MOUNT_POINT" 2>/dev/null || true
        printf '{"error":"storage_directory_failed"}\n'
        return 1
    fi
    chmod 700 "$USB_ROOT_DIR" "$USB_LOG_DIR" 2>/dev/null || true
    write_privacy_notice || true
    printf '{"ok":true,"mount_point":"%s","log_dir":"%s"}\n' "$MOUNT_POINT" "$USB_LOG_DIR"
}

ensure_device_mounted() {
    device="$1"
    require_safe_removable_device "$device" || return 1
    source="$(mounted_source)"
    if [ -n "$source" ]; then
        [ "$source" = "$device" ] && return 0
        printf '{"error":"mount_point_busy","requested":"%s","mounted":"%s"}\n' \
            "$(json_escape "$device")" "$(json_escape "$source")"
        return 1
    fi
    cmd_mount "$device" >/dev/null
}

valid_key() {
    [ ${#1} -eq 64 ] && printf '%s' "$1" | grep -Eq '^[0-9a-fA-F]{64}$'
}

get_key() {
    if [ -s "$RUNTIME_KEY" ]; then
        cached_key="$(cat "$RUNTIME_KEY" 2>/dev/null || true)"
        if valid_key "$cached_key"; then
            printf '%s' "$cached_key"
            return 0
        fi
        rm -f "$RUNTIME_KEY"
    fi

    [ -x "$KEY_DERIVE" ] || {
        echo "Sheepfold key derivation helper is unavailable." >&2
        return 1
    }
    key_hex="$($KEY_DERIVE)" || return 1
    valid_key "$key_hex" || {
        echo "Sheepfold key derivation returned invalid data." >&2
        return 1
    }

    mkdir -p "$(dirname "$RUNTIME_KEY")"
    chmod 700 "$(dirname "$RUNTIME_KEY")"
    umask 077
    tmp_key="$RUNTIME_KEY.tmp.$$"
    printf '%s' "$key_hex" > "$tmp_key"
    chmod 600 "$tmp_key"
    mv -f "$tmp_key" "$RUNTIME_KEY"
    printf '%s' "$key_hex"
}

encrypt_archive() {
    source_archive="$1"
    encrypted_archive="${source_archive}.enc"
    temporary_archive="${encrypted_archive}.tmp.$$"

    command -v openssl >/dev/null 2>&1 || {
        echo "OpenSSL is required; refusing to write an unencrypted .enc archive." >&2
        return 1
    }
    key_hex="$(get_key)" || return 1
    rm -f "$temporary_archive"

    if ! printf '%s' "$key_hex" | \
        openssl enc -aes-256-cbc -pbkdf2 -iter 100000 \
            -pass stdin -in "$source_archive" -out "$temporary_archive" 2>/dev/null; then
        rm -f "$temporary_archive"
        echo "Archive encryption failed." >&2
        return 1
    fi
    [ -s "$temporary_archive" ] || {
        rm -f "$temporary_archive"
        echo "Archive encryption produced an empty file." >&2
        return 1
    }
    chmod 600 "$temporary_archive"
    mv -f "$temporary_archive" "$encrypted_archive"
    printf '%s\n' "$encrypted_archive"
}

cmd_scan() {
    printf '['
    first=1
    for node in /sys/class/block/*; do
        [ -e "$node" ] || continue
        base="$(basename "$node")"
        case "$base" in loop*|ram*|zram*|mtd*|ubiblock*|dm-*) continue ;; esac
        device="/dev/$base"
        is_safe_removable_device "$device" || continue

        parent="$(parent_block_name "$device")"
        size_blocks="$(cat "$node/size" 2>/dev/null || printf 0)"
        size_gb="$(awk "BEGIN { printf \"%.1f\", $size_blocks * 512 / 1073741824 }")"
        vendor="$(cat "/sys/class/block/$parent/device/vendor" 2>/dev/null | tr -d '\n ' || true)"
        model="$(cat "/sys/class/block/$parent/device/model" 2>/dev/null | sed 's/  */ /g;s/^ //;s/ $//' || printf '%s' "$base")"
        is_usb=0
        readlink -f "/sys/class/block/$parent" 2>/dev/null | grep -qi '/usb' && is_usb=1
        role="$(get_disk_usage_role "$device")"
        current=0
        [ "$(uci_get device)" = "$device" ] && [ "$(uci_get enabled 0)" = 1 ] && current=1
        [ "$first" = 1 ] || printf ','
        first=0
        printf '{"dev":"%s","vendor":"%s","model":"%s","size_gb":%s,"is_usb":%d,"role":"%s","current":%d}' \
            "$(json_escape "$device")" "$(json_escape "$vendor")" "$(json_escape "$model")" \
            "$size_gb" "$is_usb" "$role" "$current"
    done
    printf ']\n'
}

cmd_info() {
    device="${1:-}"
    require_safe_removable_device "$device" || return 1
    base="$(basename "$device")"
    node="/sys/class/block/$base"
    parent="$(parent_block_name "$device")"
    size_blocks="$(cat "$node/size" 2>/dev/null || printf 0)"
    size_gb="$(awk "BEGIN { printf \"%.1f\", $size_blocks * 512 / 1073741824 }")"
    vendor="$(cat "/sys/class/block/$parent/device/vendor" 2>/dev/null | tr -d '\n ' || true)"
    model="$(cat "/sys/class/block/$parent/device/model" 2>/dev/null | sed 's/  */ /g;s/^ //;s/ $//' || printf '%s' "$base")"
    filesystem="$(blkid -o value -s TYPE "$device" 2>/dev/null || true)"
    mounted=0
    [ "$(mounted_source)" = "$device" ] && mounted=1
    free_pct=0
    [ "$mounted" = 0 ] || free_pct="$(get_free_pct "$MOUNT_POINT")"
    printf '{"dev":"%s","vendor":"%s","model":"%s","size_gb":%s,"fs":"%s","mounted":%d,"free_pct":%s,"role":"%s"}\n' \
        "$(json_escape "$device")" "$(json_escape "$vendor")" "$(json_escape "$model")" \
        "$size_gb" "$(json_escape "$filesystem")" "$mounted" "$free_pct" "$(get_disk_usage_role "$device")"
}

cmd_format() {
    device="${1:-}"
    require_safe_removable_device "$device" || return 1
    source="$(mounted_source)"
    [ "$source" != "$device" ] || umount "$MOUNT_POINT" 2>/dev/null || true
    umount "$device" 2>/dev/null || true
    grep -q "^$device " /proc/mounts 2>/dev/null && {
        printf '{"error":"device_busy","dev":"%s"}\n' "$(json_escape "$device")"
        return 1
    }

    if command -v mkfs.ext4 >/dev/null 2>&1; then
        mkfs.ext4 -F -L sheepfold "$device" >/dev/null 2>&1
        filesystem=ext4
    elif command -v mkfs.f2fs >/dev/null 2>&1; then
        mkfs.f2fs -f -l sheepfold "$device" >/dev/null 2>&1
        filesystem=f2fs
    else
        printf '{"error":"no_supported_mkfs","hint":"install e2fsprogs and kmod-fs-ext4"}\n'
        return 1
    fi
    printf '{"ok":true,"dev":"%s","fs":"%s"}\n' "$(json_escape "$device")" "$filesystem"
}

cmd_umount() {
    source="$(mounted_source)"
    [ -n "$source" ] || { printf '{"ok":true,"already":true}\n'; return 0; }
    [ ! -f "$SWAP_FILE" ] || swapoff "$SWAP_FILE" 2>/dev/null || true
    rm -f "$RUNTIME_KEY" 2>/dev/null || true
    if umount "$MOUNT_POINT" 2>/dev/null; then
        printf '{"ok":true,"device":"%s"}\n' "$(json_escape "$source")"
    else
        printf '{"error":"umount_failed","device":"%s"}\n' "$(json_escape "$source")"
        return 1
    fi
}

cmd_status() {
    enabled="$(uci_get enabled 0)"
    device="$(uci_get device '')"
    role="$(uci_get role logs_only)"
    encrypt="$(uci_get encrypt 1)"
    key_ready=0
    if command -v openssl >/dev/null 2>&1 && [ -x "$KEY_DERIVE" ] && "$KEY_DERIVE" >/dev/null 2>&1; then
        key_ready=1
    fi
    source="$(mounted_source)"
    mounted=0
    mismatch=0
    [ -n "$device" ] && [ "$source" = "$device" ] && mounted=1
    [ -n "$source" ] && [ "$source" != "$device" ] && mismatch=1
    free_pct=0
    used_kb=0
    total_kb=0
    archives=0
    if [ "$mounted" = 1 ]; then
        free_pct="$(get_free_pct "$MOUNT_POINT")"
        used_kb="$(du -sk "$USB_LOG_DIR" 2>/dev/null | awk '{print $1}' || printf 0)"
        total_kb="$(df -k "$MOUNT_POINT" 2>/dev/null | awk 'NR==2 { print $2 }' || printf 0)"
        archives="$(find "$USB_LOG_DIR" \( -name '*.enc' -o -name '*.tar.gz' -o -name '*.tar' \) -type f 2>/dev/null | wc -l | tr -d ' ')"
    fi
    printf '{"enabled":%s,"dev":"%s","role":"%s","encrypt":%s,"key_ready":%d,"mounted":%d,"mounted_source":"%s","mount_mismatch":%d,"free_pct":%s,"used_kb":%s,"total_kb":%s,"archives":%s,"max_log_pct":%s}\n' \
        "$enabled" "$(json_escape "$device")" "$(json_escape "$role")" "$encrypt" "$key_ready" "$mounted" \
        "$(json_escape "$source")" "$mismatch" "$free_pct" "$used_kb" "$total_kb" "$archives" "$(max_log_pct)"
}

cmd_archive_push() {
    [ "$(uci_get enabled 0)" = 1 ] || return 0
    device="$(uci_get device '')"
    [ -n "$device" ] || { printf '{"error":"device_not_configured"}\n'; return 1; }
    ensure_device_mounted "$device" || return 1
    mkdir -p "$USB_LOG_DIR"
    max_pct="$(max_log_pct)"

    while :; do
        used_pct="$(df -k "$MOUNT_POINT" 2>/dev/null | awk 'NR==2 { if ($2 > 0) printf "%d", int(($3 / $2) * 100); else print 100 }')"
        [ "$used_pct" -lt "$max_pct" ] && break
        oldest="$(find "$USB_LOG_DIR" -maxdepth 1 -type f \( -name '*.enc' -o -name '*.tar.gz' -o -name '*.tar' \) 2>/dev/null | sort | sed -n '1p')"
        [ -n "$oldest" ] || break
        rm -f -- "$oldest"
    done

    encrypt="$(uci_get encrypt 1)"
    pushed=0
    errors=0
    for archive in "$RAM_ARCHIVE_DIR"/*.tar.gz "$RAM_ARCHIVE_DIR"/*.tar; do
        [ -f "$archive" ] || continue
        destination_name="$(basename "$archive")"
        if [ "$encrypt" = 1 ]; then
            encrypted="$(encrypt_archive "$archive")" || { errors=$((errors + 1)); continue; }
            if mv "$encrypted" "${USB_LOG_DIR}/${destination_name}.enc"; then
                rm -f "$archive"
            else
                rm -f "$encrypted"
                errors=$((errors + 1))
                continue
            fi
        else
            mv "$archive" "${USB_LOG_DIR}/${destination_name}" || { errors=$((errors + 1)); continue; }
        fi
        pushed=$((pushed + 1))
    done
    write_privacy_notice || true
    if [ "$errors" -gt 0 ]; then
        printf '{"ok":false,"pushed":%d,"errors":%d,"error":"archive_push_failed"}\n' "$pushed" "$errors"
        return 1
    fi
    printf '{"ok":true,"pushed":%d,"errors":0}\n' "$pushed"
}

cmd_setup_swap() {
    device="${1:-$(uci_get device)}"
    ensure_device_mounted "$device" || return 1
    required_kb=$(((SWAP_SIZE_MB + 32) * 1024))
    free_kb="$(get_free_kb "$MOUNT_POINT")"
    case "$free_kb" in ''|*[!0-9]*) free_kb=0 ;; esac
    if [ "$free_kb" -lt "$required_kb" ]; then
        printf '{"error":"insufficient_space","required_kb":%d,"free_kb":%d}\n' "$required_kb" "$free_kb"
        return 1
    fi

    mkdir -p "$USB_ROOT_DIR"
    [ ! -f "$SWAP_FILE" ] || swapoff "$SWAP_FILE" 2>/dev/null || true
    temporary_swap="${SWAP_FILE}.tmp.$$"
    rm -f "$temporary_swap"
    if ! dd if=/dev/zero of="$temporary_swap" bs=1M count="$SWAP_SIZE_MB" conv=fsync 2>/dev/null; then
        rm -f "$temporary_swap"
        printf '{"error":"swap_allocation_failed"}\n'
        return 1
    fi
    chmod 600 "$temporary_swap"
    if ! mkswap "$temporary_swap" >/dev/null 2>&1; then
        rm -f "$temporary_swap"
        printf '{"error":"mkswap_failed"}\n'
        return 1
    fi
    mv -f "$temporary_swap" "$SWAP_FILE"
    if ! swapon "$SWAP_FILE"; then
        rm -f "$SWAP_FILE"
        printf '{"error":"swapon_failed"}\n'
        return 1
    fi

    uci -q delete fstab.sheepfold_swap 2>/dev/null || true
    uci set fstab.sheepfold_swap=swap
    uci set fstab.sheepfold_swap.device="$SWAP_FILE"
    uci set fstab.sheepfold_swap.enabled='1'
    uci commit fstab
    printf '{"ok":true,"swap_file":"%s","size_mb":%d,"persistent":true}\n' "$SWAP_FILE" "$SWAP_SIZE_MB"
}

cmd_setup_extroot() {
    device="${1:-$(uci_get device)}"
    require_safe_removable_device "$device" || return 1
    printf '{"error":"extroot_not_implemented_safely","dev":"%s","hint":"Automatic extroot is disabled until Sheepfold can copy and verify the existing overlay and provide rollback."}\n' \
        "$(json_escape "$device")"
    return 1
}

command_name="${1:-}"
shift || true
case "$command_name" in
    scan) cmd_scan ;;
    info) cmd_info "$@" ;;
    format) cmd_format "$@" ;;
    mount) cmd_mount "$@" ;;
    umount) cmd_umount ;;
    status) cmd_status ;;
    archive-push) cmd_archive_push ;;
    setup-swap) cmd_setup_swap "$@" ;;
    setup-extroot) cmd_setup_extroot "$@" ;;
    *) echo "Usage: sheepfold-usb-storage <scan|info|format|mount|umount|status|archive-push|setup-swap|setup-extroot>" >&2; exit 1 ;;
esac
