#!/bin/sh
set -eu

LEGACY="/usr/libexec/sheepfold/sheepfold-router-control-legacy"
PROFILE_ROOT="/usr/share/sheepfold/router-profiles"
INSTALL_LOCK="/tmp/sheepfold/led-dependency-install.lock"

board_name() {
    if [ -r /tmp/sysinfo/board_name ]; then
        cat /tmp/sysinfo/board_name
        return 0
    fi

    if command -v ubus >/dev/null 2>&1 && command -v jsonfilter >/dev/null 2>&1; then
        ubus -S call system board 2>/dev/null | jsonfilter -e '@.board_name' 2>/dev/null || true
        return 0
    fi

    printf 'unknown\n'
}

safe_board_name() {
    current_board="$(board_name)"
    case "$current_board" in
        ''|*[!A-Za-z0-9,._-]*)
            printf 'unknown\n'
            ;;
        *)
            printf '%s\n' "$current_board"
            ;;
    esac
}

profile_dir() {
    printf '%s/%s\n' "$PROFILE_ROOT" "$(safe_board_name)"
}

read_profile_value() {
    value_file="$(profile_dir)/$1"
    [ -r "$value_file" ] || return 1
    sed -n '1{s/[[:space:]]*$//;p;}' "$value_file"
}

dependency_package() {
    package="$(read_profile_value led/dependency-package 2>/dev/null || true)"
    case "$package" in
        ''|*[!A-Za-z0-9+_.-]*)
            return 1
            ;;
        *)
            printf '%s\n' "$package"
            ;;
    esac
}

dependency_command() {
    command_name="$(read_profile_value led/dependency-command 2>/dev/null || true)"
    case "$command_name" in
        ''|*[!A-Za-z0-9+_.-]*)
            return 1
            ;;
        *)
            printf '%s\n' "$command_name"
            ;;
    esac
}

dependency_installed() {
    package="$1"
    command_name="$(dependency_command 2>/dev/null || true)"

    opkg status "$package" 2>/dev/null | grep -q '^Status:.* installed' || return 1
    [ -z "$command_name" ] || command -v "$command_name" >/dev/null 2>&1
}

print_dependency_status() {
    current_board="$(safe_board_name)"
    package="$(dependency_package 2>/dev/null || true)"
    required=0
    installed=0

    if [ -n "$package" ]; then
        required=1
        if dependency_installed "$package"; then
            installed=1
        fi
    fi

    printf 'board=%s\n' "$current_board"
    printf 'required=%s\n' "$required"
    printf 'installed=%s\n' "$installed"
    printf 'package=%s\n' "$package"
}

acquire_install_lock() {
    mkdir -p /tmp/sheepfold
    attempts=0
    while ! mkdir "$INSTALL_LOCK" 2>/dev/null; do
        attempts=$((attempts + 1))
        [ "$attempts" -lt 120 ] || {
            echo "Dependency installation is already running." >&2
            return 1
        }
        sleep 1
    done
    trap 'rmdir "$INSTALL_LOCK" 2>/dev/null || true' EXIT HUP INT TERM
}

release_install_lock() {
    rmdir "$INSTALL_LOCK" 2>/dev/null || true
    trap - EXIT HUP INT TERM
}

install_dependency() {
    package="$(dependency_package 2>/dev/null || true)"
    [ -n "$package" ] || {
        echo "This router profile does not declare an LED dependency." >&2
        return 2
    }

    if dependency_installed "$package"; then
        printf 'status=already_installed\n'
        printf 'package=%s\n' "$package"
        return 0
    fi

    command -v opkg >/dev/null 2>&1 || {
        echo "opkg is unavailable." >&2
        return 3
    }

    acquire_install_lock
    if ! opkg update; then
        release_install_lock
        echo "Could not update package lists." >&2
        return 4
    fi

    if ! opkg install "$package"; then
        release_install_lock
        echo "Could not install $package." >&2
        return 5
    fi

    if ! dependency_installed "$package"; then
        release_install_lock
        echo "$package was installed, but its required command is unavailable." >&2
        return 6
    fi

    release_install_lock
    printf 'status=installed\n'
    printf 'package=%s\n' "$package"
}

apply_led_mode() {
    profile_apply_mode="$(profile_dir)/led/apply-mode"

    if [ -x "$profile_apply_mode" ]; then
        exec "$profile_apply_mode"
    fi

    exec "$LEGACY" led-apply
}

print_repair_status() {
    repair_dir="$(profile_dir)/fixLed"
    available=0
    enabled="$(uci -q get sheepfold.global.router_led_repair 2>/dev/null || printf 0)"

    if [ -x "$repair_dir/install" ] && [ -x "$repair_dir/uninstall" ]; then
        available=1
    fi

    case "$enabled" in
        1) ;;
        *) enabled=0 ;;
    esac

    printf 'board=%s\n' "$(safe_board_name)"
    printf 'available=%s\n' "$available"
    printf 'enabled=%s\n' "$enabled"
}

apply_repair() {
    repair_dir="$(profile_dir)/fixLed"
    enabled="$(uci -q get sheepfold.global.router_led_repair 2>/dev/null || printf 0)"

    if [ ! -x "$repair_dir/install" ] || [ ! -x "$repair_dir/uninstall" ]; then
        printf 'status=unsupported\n'
        return 0
    fi

    if [ "$enabled" = "1" ]; then
        exec "$repair_dir/install"
    fi

    exec "$repair_dir/uninstall"
}

case "${1:-}" in
    dependency-status)
        print_dependency_status
        ;;
    dependency-install)
        install_dependency
        ;;
    repair-status)
        print_repair_status
        ;;
    repair-apply)
        apply_repair
        ;;
    apply)
        apply_led_mode
        ;;
    *)
        echo "Usage: sheepfold-led-control <dependency-status|dependency-install|repair-status|repair-apply|apply>" >&2
        exit 1
        ;;
esac
