#!/bin/sh

TOKEN_FILE="${SHEEPFOLD_ADGUARD_TOKEN_FILE:-/etc/sheepfold/adguard-feed.token}"
FEED_FILE="${SHEEPFOLD_ADGUARD_FEED_FILE:-/tmp/sheepfold/adguard/filter.txt}"

deny() {
	printf 'Status: 403 Forbidden\r\nContent-Type: text/plain; charset=utf-8\r\nCache-Control: no-store\r\n\r\nForbidden\n'
	exit 0
}

case "${REMOTE_ADDR:-}" in
	127.0.0.1|::1|::ffff:127.0.0.1) ;;
	*) deny ;;
esac

requested_token=''
old_ifs="$IFS"
IFS='&'
for parameter in ${QUERY_STRING:-}; do
	case "$parameter" in token=*) requested_token="${parameter#token=}" ;; esac
done
IFS="$old_ifs"

[ -s "$TOKEN_FILE" ] || deny
[ "$requested_token" = "$(cat "$TOKEN_FILE")" ] || deny

if [ ! -r "$FEED_FILE" ]; then
	printf 'Status: 503 Service Unavailable\r\nContent-Type: text/plain; charset=utf-8\r\nCache-Control: no-store\r\nRetry-After: 60\r\n\r\nSheepfold filter is not ready\n'
	exit 0
fi

printf 'Content-Type: text/plain; charset=utf-8\r\nCache-Control: no-store\r\nX-Content-Type-Options: nosniff\r\n\r\n'
cat "$FEED_FILE"
