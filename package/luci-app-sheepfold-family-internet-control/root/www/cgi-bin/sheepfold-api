#!/bin/sh
set -u

LEGACY="/usr/libexec/sheepfold/sheepfold-api-legacy"
PAIR="/usr/libexec/sheepfold/sheepfold-api-pair"
STATUS="/usr/libexec/sheepfold/sheepfold-api-client-status"
# SHEEPFOLD_AI_BEGIN
AI_GATE="/usr/libexec/sheepfold/sheepfold-ai-gate"
AI_HANDLER="/usr/libexec/sheepfold/sheepfold-ai-handler"
# SHEEPFOLD_AI_END
RATE_LIMIT="/usr/libexec/sheepfold/sheepfold-api-rate-limit"
ACCESS_REQUEST="/usr/libexec/sheepfold/sheepfold-access-request"
ADMIN_NOTIFICATION="/usr/libexec/sheepfold/sheepfold-admin-notification"
SIM_MONITOR="/usr/libexec/sheepfold/sheepfold-sim-monitor"
CHILD_WIFI_MONITOR="/usr/libexec/sheepfold/sheepfold-child-wifi-monitor"
method="${REQUEST_METHOD:-GET}"
path_info="${PATH_INFO:-}"
client_ip="${REMOTE_ADDR:-unknown}"

header_json() {
    printf 'Status: %s\r\n' "$1"
    printf 'Content-Type: application/json; charset=utf-8\r\n'
    [ -z "${2:-}" ] || printf 'Retry-After: %s\r\n' "$2"
    printf 'Cache-Control: no-store\r\n\r\n'
}

method_not_allowed() {
    header_json "405 Method Not Allowed"
    printf '{"app":"sheepfold","ok":false,"error":"method_not_allowed"}\n'
    exit 0
}

rate_limit_exceeded() {
    header_json "429 Too Many Requests" "60"
    printf '{"app":"sheepfold","ok":false,"error":"rate_limited","message":"Too many requests from this client. Try again later."}\n'
    exit 0
}

enforce_rate_limit() {
    bucket="$1"
    limit="$2"
    window="$3"
    [ -x "$RATE_LIMIT" ] || return 0
    "$RATE_LIMIT" check "$bucket" "$client_ip" "$limit" "$window" || rate_limit_exceeded
}

require_admin() {
    bearer=""
    client_device_id="${HTTP_X_SHEEPFOLD_DEVICE_ID:-}"
    client_device_mac="${HTTP_X_SHEEPFOLD_DEVICE_MAC:-}"
    case "${HTTP_AUTHORIZATION:-}" in [Bb]earer\ *) bearer="${HTTP_AUTHORIZATION#* }" ;; esac
    if [ -z "$bearer" ] || \
       [ "$(/usr/libexec/sheepfold/sheepfold-router-control check-token "$bearer" "$client_device_id" "$client_device_mac" 2>/dev/null || printf fail)" != ok ]; then
        header_json "401 Unauthorized"
        printf '{"app":"sheepfold","ok":false,"error":"auth_required","message":"Valid administrator Bearer token required."}\n'
        exit 0
    fi
    authenticated_admin_login="$(/usr/libexec/sheepfold/sheepfold-router-control token-login "$bearer" "$client_device_id" "$client_device_mac" 2>/dev/null || true)"
    if [ -z "$authenticated_admin_login" ]; then
        header_json "401 Unauthorized"
        printf '{"app":"sheepfold","ok":false,"error":"auth_required"}\n'
        exit 0
    fi
}

run_legacy() {
    "$LEGACY" | sed '/^Access-Control-Allow-/d'
}

# Постоянный Bearer нельзя передавать в URL: query string попадает в журналы и историю.
case "&${QUERY_STRING:-}&" in
    *'&token='*)
        header_json "400 Bad Request"
        printf '{"app":"sheepfold","ok":false,"error":"query_token_forbidden"}\n'
        exit 0
        ;;
esac

# Выпуск pairing-кода не является частью публичного HTTP API.
if [ "$path_info" = "/pair-token" ]; then
    header_json "404 Not Found"
    printf '{"app":"sheepfold","ok":false,"error":"unknown_action"}\n'
    exit 0
fi

if [ "$method" = "OPTIONS" ]; then
    header_json "204 No Content"
    exit 0
fi

case "$path_info" in
    /ping)
        [ "$method" = "GET" ] || method_not_allowed
        # Discovery имеет свой небольшой лимит. Иначе проверка APK попадает в
        # общий api_write и может принять исчерпанный лимит команд за отсутствие роутера.
        enforce_rate_limit discovery 30 60
        run_legacy
        ;;
    /pair)
        [ "$method" = "POST" ] || method_not_allowed
        enforce_rate_limit pair 12 60
        exec "$PAIR"
        ;;
    /client-status)
        [ "$method" = "GET" ] || method_not_allowed
        enforce_rate_limit client_status 120 60
        exec "$STATUS" "${REMOTE_ADDR:-}"
        ;;
    /access-request)
        [ "$method" = "POST" ] || method_not_allowed
        enforce_rate_limit access_request 3 300
        if output="$($ACCESS_REQUEST create "${REMOTE_ADDR:-}" 2>/dev/null)"; then
            header_json "200 OK"
            printf '%s\n' "$output"
        else
            result=$?
            case "$result" in
                2) status="404 Not Found"; error="device_not_registered"; message="Router could not identify this device." ;;
                3) status="403 Forbidden"; error="access_requests_disabled"; message="No administrator accepts access requests." ;;
                4) status="403 Forbidden"; error="administrator_device"; message="Administrator devices cannot send child access requests." ;;
                *) status="500 Internal Server Error"; error="request_failed"; message="Could not save access request." ;;
            esac
            header_json "$status"
            printf '{"app":"sheepfold","ok":false,"error":"%s","message":"%s"}\n' "$error" "$message"
        fi
        ;;
    /sim-report)
        [ "$method" = "POST" ] || method_not_allowed
        enforce_rate_limit sim_report 12 300
        length="${CONTENT_LENGTH:-0}"
        case "$length" in ''|*[!0-9]*) length=0 ;; esac
        if [ "$length" -le 0 ] || [ "$length" -gt 2048 ]; then
            header_json "413 Payload Too Large"
            printf '{"app":"sheepfold","ok":false,"error":"invalid_sim_report"}\n'
            exit 0
        fi
        body="$(dd bs=1 count="$length" 2>/dev/null || true)"
        # MAC и Sheepfold ID не принимаются из тела: helper находит устройство
        # только по адресу соединения в DHCP/ARP роутера. §simchg1
        if output="$(printf '%s\n' "$body" | "$SIM_MONITOR" report "${REMOTE_ADDR:-}" 2>/dev/null)"; then
            header_json "200 OK"
            printf '%s\n' "$output"
        else
            result=$?
            case "$result" in
                2) status="404 Not Found"; error="device_not_registered" ;;
                3) status="403 Forbidden"; error="administrator_device" ;;
                4) status="400 Bad Request"; error="invalid_sim_report" ;;
                *) status="500 Internal Server Error"; error="sim_report_failed" ;;
            esac
            header_json "$status"
            printf '{"app":"sheepfold","ok":false,"error":"%s"}\n' "$error"
        fi
        ;;
    /wifi-network-report)
        [ "$method" = "POST" ] || method_not_allowed
        enforce_rate_limit wifi_network_report 12 300
        length="${CONTENT_LENGTH:-0}"
        case "$length" in ''|*[!0-9]*) length=0 ;; esac
        if [ "$length" -le 0 ] || [ "$length" -gt 1024 ]; then
            header_json "413 Payload Too Large"
            printf '{"app":"sheepfold","ok":false,"error":"invalid_wifi_network_report"}\n'
            exit 0
        fi
        body="$(dd bs=1 count="$length" 2>/dev/null || true)"
        # Ни MAC, ни Sheepfold ID не принимаются от детского APK. §childwifi1
        if output="$(printf '%s\n' "$body" | "$CHILD_WIFI_MONITOR" report "${REMOTE_ADDR:-}" 2>/dev/null)"; then
            header_json "200 OK"
            printf '%s\n' "$output"
        else
            result=$?
            case "$result" in
                2) status="404 Not Found"; error="device_not_registered" ;;
                3) status="403 Forbidden"; error="administrator_device" ;;
                4) status="400 Bad Request"; error="invalid_wifi_network_report" ;;
                *) status="500 Internal Server Error"; error="wifi_network_report_failed" ;;
            esac
            header_json "$status"
            printf '{"app":"sheepfold","ok":false,"error":"%s"}\n' "$error"
        fi
        ;;
    /access-requests)
        [ "$method" = "GET" ] || method_not_allowed
        enforce_rate_limit admin_read 120 60
        require_admin
        header_json "200 OK"
        "$ACCESS_REQUEST" list "$authenticated_admin_login"
        ;;
    /notifications)
        [ "$method" = "GET" ] || method_not_allowed
        enforce_rate_limit admin_read 120 60
        require_admin
        header_json "200 OK"
        "$ADMIN_NOTIFICATION" list
        ;;
    /child-wifi-networks)
        case "$method" in
            GET|DELETE) ;;
            *) method_not_allowed ;;
        esac
        enforce_rate_limit admin_read 120 60
        require_admin
        header_json "200 OK"
        case "$method" in
            GET) "$CHILD_WIFI_MONITOR" list ;;
            DELETE) "$CHILD_WIFI_MONITOR" clear ;;
        esac
        ;;
    /router-info|/pair-status)
        [ "$method" = "GET" ] || method_not_allowed
        enforce_rate_limit admin_read 120 60
        require_admin
        run_legacy
        ;;
    /feedback)
        [ "$method" = "POST" ] || method_not_allowed
        # Кроме общей защиты Cloud Function ограничиваем поток ещё на домашнем роутере.
        enforce_rate_limit feedback 3 3600
        require_admin
        run_legacy
        ;;
    /settings/save)
        header_json "410 Gone"
        printf '{"app":"sheepfold","ok":false,"error":"legacy_settings_writer_disabled","message":"Use authenticated LuCI UCI forms with typed validation."}\n'
        ;;
    # SHEEPFOLD_AI_BEGIN
    /ai-assistant)
        [ "$method" = "POST" ] || method_not_allowed
        enforce_rate_limit ai_assistant 30 60
        length="${CONTENT_LENGTH:-0}"
        case "$length" in ''|*[!0-9]*) length=0 ;; esac
        if [ "$length" -gt 16384 ]; then
            header_json "413 Payload Too Large"
            printf '{"app":"sheepfold","ok":false,"error":"request_too_large"}\n'
            exit 0
        fi
        body=""
        [ "$length" -le 0 ] || body="$(dd bs=1 count="$length" 2>/dev/null || true)"
        if ! printf '%s' "$body" | "$AI_GATE"; then
            exit 0
        fi
        printf '%s' "$body" | /bin/sh "$AI_HANDLER"
        ;;
    # SHEEPFOLD_AI_END
    *)
        enforce_rate_limit api_write 90 60
        run_legacy
        ;;
esac
