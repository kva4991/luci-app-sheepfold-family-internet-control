msgid "Delete schedule"
msgstr "Удалить расписание"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Delete schedule?"
msgstr "Удалить расписание?"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Disable without deleting"
msgstr "Выключить без удаления"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Duplicate schedule"
msgstr "Создать копию расписания"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Edit schedule"
msgstr "Редактировать расписание"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Enable schedule"
msgstr "Включить расписание"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Enter a name, select targets and days, and set a valid time interval."
msgstr "Введите название, выберите устройства или группы, дни и корректный интервал времени."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Enter a valid bedtime."
msgstr "Укажите корректное время отбоя."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Individual devices"
msgstr "Отдельные устройства"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Internet access rule priority"
msgstr "Приоритет правил доступа в интернет"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Internet allowed"
msgstr "Интернет разрешён"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Internet blocked"
msgstr "Интернет заблокирован"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Move down"
msgstr "Переместить ниже"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Move up"
msgstr "Переместить выше"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "next day"
msgstr "следующего дня"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "No days selected"
msgstr "Дни не выбраны"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "No schedules yet"
msgstr "Расписаний пока нет"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "No suitable devices or groups."
msgstr "Нет подходящих устройств или групп."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "No targets selected"
msgstr "Устройства или группы не выбраны"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Remove time interval"
msgstr "Удалить интервал времени"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Reset order"
msgstr "Вернуть стандартный порядок"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Rules higher in the list take priority. Emergency-useful sites never open access to the router itself."
msgstr "Правила выше в списке имеют больший приоритет. Аварийно-полезные сайты никогда не открывают доступ к самому роутеру."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "The order is temporarily fixed so that the router always applies exactly what the interface shows."
msgstr "Порядок временно нельзя изменять: так роутер всегда применяет именно то, что показывает интерфейс."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Use at least 12 characters for the backup password."
msgstr "Используйте для пароля резервной копии не менее 12 символов."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "The backup contains a device in both the allowlist and the blocklist."
msgstr "В резервной копии одно устройство одновременно находится в белом и чёрном списках устройств."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "The backup does not contain the required Sheepfold sections."
msgstr "В резервной копии нет обязательных разделов Sheepfold."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "This browser cannot create or open an encrypted backup."
msgstr "Этот браузер не может создать или открыть зашифрованную резервную копию."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Backup passwords do not match."
msgstr "Пароли резервной копии не совпадают."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Encrypting backup..."
msgstr "Резервная копия шифруется..."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Encrypted full backup saved."
msgstr "Зашифрованная полная резервная копия сохранена."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Create encrypted backup"
msgstr "Создать зашифрованную копию"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "This backup contains passwords and tokens. Keep the file and its password separately. Without the password, the backup cannot be restored."
msgstr "Эта резервная копия содержит пароли и токены. Храните файл и пароль от него отдельно. Без пароля восстановить резервную копию не получится."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Backup password"
msgstr "Пароль резервной копии"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Repeat backup password"
msgstr "Повторите пароль резервной копии"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Settings were restored, but router services could not be refreshed."
msgstr "Настройки восстановлены, но не удалось обновить службы роутера."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Applying backup..."
msgstr "Резервная копия применяется..."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Settings imported successfully. The page will reload."
msgstr "Настройки успешно импортированы. Страница будет перезагружена."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Import and apply"
msgstr "Импортировать и применить"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "The backup contains: %s devices, %s groups, %s schedules, %s administrators, %s static DHCP leases and %s Wi-Fi sections."
msgstr "В резервной копии: устройств — %s, групп — %s, расписаний — %s, администраторов — %s, постоянных DHCP-аренд — %s, разделов Wi-Fi — %s."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Existing Sheepfold settings, static DHCP leases and Wi-Fi settings will be replaced."
msgstr "Текущие настройки Sheepfold, постоянные DHCP-аренды и настройки Wi-Fi будут заменены."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "The encrypted backup contains secrets."
msgstr "Зашифрованная резервная копия содержит секретные данные."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "This backup does not contain secrets. Existing matching secrets will be kept; missing ones must be entered again."
msgstr "Эта резервная копия не содержит секретных данных. Совпадающие текущие пароли и токены сохранятся, а отсутствующие потребуется ввести заново."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Wi-Fi may restart and temporarily disconnect this device."
msgstr "Wi-Fi может перезапуститься и временно отключить это устройство."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Decrypting backup..."
msgstr "Резервная копия расшифровывается..."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Could not decrypt the backup. Check the password and file."
msgstr "Не удалось расшифровать резервную копию. Проверьте пароль и файл."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Decrypt and check"
msgstr "Расшифровать и проверить"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Open encrypted backup"
msgstr "Открыть зашифрованную резервную копию"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "The backup file is too large."
msgstr "Файл резервной копии слишком большой."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "A backup containing passwords or tokens must be encrypted."
msgstr "Резервная копия с паролями или токенами должна быть зашифрована."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Could not import settings. The previous settings were kept."
msgstr "Не удалось импортировать настройки. Предыдущие настройки сохранены."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Schedule deleted."
msgstr "Расписание удалено."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Schedule disabled."
msgstr "Расписание выключено."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Schedule enabled"
msgstr "Расписание включено"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Schedule enabled."
msgstr "Расписание включено."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Schedule name"
msgstr "Название расписания"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Schedule saved."
msgstr "Расписание сохранено."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "This rule overlaps the opposite rule:"
msgstr "Это правило пересекается с противоположным правилом:"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Time intervals"
msgstr "Интервалы времени"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Time is not set"
msgstr "Время не задано"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Unnamed schedule"
msgstr "Расписание без названия"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Weekdays"
msgstr "Будни"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Weekends"
msgstr "Выходные"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "Off"
msgstr "Выключен"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "On"
msgstr "Включен"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "When internet enable and disable schedules conflict, internet will be"
msgstr "При конфликте правил включения и отключения интернета между расписаниями интернет будет"

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "The conflict will still be shown in the interface and written to the journal. Device schedules remain more specific than group schedules."
msgstr "Sheepfold всё равно покажет конфликт и запишет его в журнал. Расписание отдельного устройства остаётся важнее расписания группы."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "According to the conflict setting, internet will be on."
msgstr "Согласно настройке конфликта интернет будет включен."

#: htdocs/luci-static/resources/view/sheepfold/overview.js
msgid "According to the conflict setting, internet will be off."
msgstr "Согласно настройке конфликта интернет будет выключен."

msgid "Personal devices"
msgstr "Персональные устройства"

msgid "May child devices send this administrator requests for 30 more minutes of internet?"
msgstr "Можно ли присылать вам запросы на продление интернета на 30 минут с детских устройств?"

msgid "Disabled by default. A request only notifies the parent and never grants internet automatically."
msgstr "По умолчанию выключено. Запрос только уведомляет родителя и никогда не включает интернет автоматически."

msgid "AI assistant prompt version"
msgstr "Версия промпта ИИ-помощника"

msgid "Version 2 (recommended)"
msgstr "Версия 2 (рекомендуется)"

msgid "Version 1 (original draft)"
msgstr "Версия 1 (первоначальная редакция)"

msgid "The selected version is used for conversations with parents. Changing it does not send any data until a parent starts a conversation."
msgstr "Выбранная версия используется в разговорах с родителями. Её смена не отправляет данные, пока родитель сам не начнёт разговор."

msgid "Automatic setup for new devices is disabled."
msgstr "Автонастройка новых устройств выключена."

msgid "Automatic assignment to No restrictions is disabled."
msgstr "Автоматическое добавление в группу «Без ограничений» выключено."

msgid "This device was manually removed from No restrictions and will not be added again automatically."
msgstr "Устройство вручную удалили из группы «Без ограничений», поэтому повторно автоматически оно не добавится."

msgid "Automatic assignment to Personal devices is disabled."
msgstr "Автоматическое добавление в группу «Персональные устройства» выключено."

msgid "This device was manually removed from Personal devices and will not be added again automatically."
msgstr "Устройство вручную удалили из группы «Персональные устройства», поэтому повторно автоматически оно не добавится."

msgid "This device type is not safe for automatic assignment to No restrictions."
msgstr "Этот тип устройства нельзя безопасно добавлять в группу «Без ограничений» автоматически."

msgid "The type is recognized, but automatic assignment to No restrictions still needs a second independent router-side signal."
msgstr "Тип распознан, но для добавления в группу «Без ограничений» нужен второй независимый признак от роутера."

msgid "Device type confidence is still too low for automatic grouping."
msgstr "Уверенность в типе устройства пока недостаточна для автоматического добавления в группу."

msgid "A device from the device blocklist is never assigned automatically."
msgstr "Устройство из чёрного списка устройств никогда не добавляется в группу автоматически."

msgid "The device is already in another group; automatic setup does not replace a parent choice."
msgstr "Устройство уже находится в другой группе: автонастройка не заменяет выбор родителя."

msgid "The detected group has been assigned automatically."
msgstr "Распознанная группа назначена автоматически."

msgid "Protect the router with a password"
msgstr "Защитите роутер паролем"

msgid "Sheepfold could not verify the router root password. Settings remain locked for safety. Install the current Sheepfold package or set the router password and reload this page."
msgstr "Sheepfold не смог проверить root-пароль роутера. Для безопасности настройки заблокированы. Установите актуальный пакет Sheepfold или задайте пароль роутера и обновите страницу."

msgid "The router root password is not set. Until you create it, anyone connected to the home network may be able to change router and Sheepfold settings."
msgstr "Root-пароль роутера не задан. Пока вы его не установите, любой подключённый к домашней сети человек может получить возможность изменить настройки роутера и Sheepfold."

msgid "Go to router password setup"
msgstr "Перейти к установке пароля роутера"

msgid "Check again"
msgstr "Проверить ещё раз"

msgid "Feedback / suggestions"
msgstr "Отзыв / предложения"

msgid "Suggestion"
msgstr "Предложение"

msgid "Problem or error"
msgstr "Проблема или ошибка"

msgid "Question"
msgstr "Вопрос"

msgid "Other"
msgstr "Другое"

msgid "Short summary"
msgstr "Кратко опишите тему"

msgid "Describe what happened or what you suggest changing."
msgstr "Опишите, что произошло или что вы предлагаете изменить."

msgid "Optional email or messenger contact"
msgstr "Необязательный адрес почты или контакт в мессенджере"

msgid "Checking whether feedback sending is configured..."
msgstr "Проверяется настройка отправки отзывов..."

msgid "Send message"
msgstr "Отправить сообщение"

msgid "Sending..."
msgstr "Отправка..."

msgid "Enter a subject up to 120 characters."
msgstr "Введите тему длиной до 120 символов."

msgid "The message must contain from 10 to 4000 characters."
msgstr "Сообщение должно содержать от 10 до 4000 символов."

msgid "The feedback service did not respond in time."
msgstr "Сервис отзывов не ответил вовремя."

msgid "Thank you. Your message was sent to the Sheepfold developer."
msgstr "Спасибо. Сообщение отправлено разработчику Sheepfold."

msgid "Could not send the message. Try again later."
msgstr "Не удалось отправить сообщение. Повторите попытку позже."

msgid "Feedback sending is available."
msgstr "Отправка отзывов доступна."

msgid "Feedback sending has not been configured by the project owner yet."
msgstr "Владелец проекта пока не настроил отправку отзывов."

msgid "Could not check the feedback service status."
msgstr "Не удалось проверить состояние сервиса отзывов."

msgid "Tell the developer about a problem or suggest an improvement. The router sends only the fields shown in this form."
msgstr "Расскажите разработчику о проблеме или предложите улучшение. Роутер отправит только поля, показанные в этой форме."

msgid "Message type"
msgstr "Тип сообщения"

msgid "Subject"
msgstr "Тема"

msgid "Message"
msgstr "Сообщение"

msgid "Contact for reply"
msgstr "Контакт для ответа"

msgid "Optional. Leave empty if you do not need a reply. This value will be stored with the message in Yandex Cloud."
msgstr "Необязательно. Оставьте поле пустым, если ответ не нужен. Значение сохранится вместе с сообщением в Yandex Cloud."

msgid "Attach minimal technical information: Sheepfold version and variant, router model, and OpenWrt firmware version. Device lists, logs, MAC/IP addresses, settings, and secrets are never attached."
msgstr "Приложить минимальные технические сведения: версию и вариант Sheepfold, модель роутера и версию прошивки OpenWrt. Списки устройств, журналы, MAC/IP-адреса, настройки и секреты не прикладываются."

msgid "Tell the developer about a problem or suggest an improvement. Along with the form fields, the router sends the Sheepfold version and a random installation identifier that is not based on device data."
msgstr "Расскажите разработчику о проблеме или предложите улучшение. Вместе с полями формы роутер отправит версию Sheepfold и случайный идентификатор установки, не основанный на данных устройств."

msgid "Attach a diagnostic report (recommended for a problem): router and network status, versions, resources, safe Sheepfold settings, and counts of devices and rules. Passwords, tokens, MAC/IP addresses, names, SSIDs, logs, and browsing history are never attached."
msgstr "Приложить диагностический отчёт (рекомендуется при проблеме): состояние роутера и сети, версии, ресурсы, безопасные настройки Sheepfold и количество устройств и правил. Пароли, токены, MAC/IP-адреса, имена, SSID, журналы и история сайтов не отправляются."

msgid "Enter a valid domain name, for example gosuslugi.ru."
msgstr "Введите правильное имя домена, например gosuslugi.ru."

msgid "This domain is already in the emergency-useful sites list."
msgstr "Этот домен уже добавлен в список аварийно-полезных сайтов."

msgid "Site prepared. Press Save settings to apply it."
msgstr "Сайт подготовлен. Нажмите «Сохранить настройки», чтобы применить изменение."

msgid "Site removal prepared. Press Save settings to apply it."
msgstr "Удаление сайта подготовлено. Нажмите «Сохранить настройки», чтобы применить изменение."

msgid "Some services load maps, sign-in pages, or images from additional technical domains. If a site opens incompletely, add only the domains required for its useful function."
msgstr "Некоторые сервисы загружают карты, страницы входа или изображения с дополнительных технических доменов. Если сайт открывается не полностью, добавьте только домены, необходимые для его полезной функции."

msgid "Checking site list application status..."
msgstr "Проверяется применение списков сайтов..."

msgid "Configure allowlists and blocklists in AdGuard Home. Sheepfold does not duplicate or overwrite its DNS rules."
msgstr "Настройте белые и чёрные списки сайтов в AdGuard Home. Sheepfold не дублирует и не перезаписывает его DNS-правила."

msgid "Could not apply the new site lists."
msgstr "Не удалось применить новые списки сайтов."

msgid "Could not read site list application status."
msgstr "Не удалось получить состояние применения списков сайтов."

msgid "Loaded domains: allowlist %s, blocklist %s."
msgstr "Загружено доменов: белый список — %s, чёрный список — %s."

msgid "No strict allowlist group is currently using the loaded allowlist."
msgstr "Сейчас загруженный белый список не используется ни одной группой со строгим доступом."

msgid "Refresh status"
msgstr "Обновить состояние"

msgid "Refresh the status after the first list update or after saving the integration settings."
msgstr "Обновите состояние после первой загрузки списков или после сохранения настроек интеграции."

msgid "Sheepfold firewall rules are not available."
msgstr "Правила сетевого экрана Sheepfold недоступны."

msgid "Sheepfold is waiting for the first successful site list download."
msgstr "Sheepfold ожидает первую успешную загрузку списков сайтов."

msgid "Site filtering is delegated to AdGuard Home."
msgstr "Фильтрация сайтов передана AdGuard Home."

msgid "Site list application status is not available yet."
msgstr "Состояние применения списков сайтов пока недоступно."

msgid "Site list filtering is disabled."
msgstr "Фильтрация по спискам сайтов выключена."

msgid "Site list filtering is left off instead of incorrectly blocking devices. The router needs a dnsmasq build with nftset support."
msgstr "Чтобы не заблокировать устройства ошибочно, фильтрация по спискам сайтов оставлена выключенной. На роутере нужна версия DNS-службы dnsmasq с поддержкой nftset."

msgid "Site lists are applied by Sheepfold."
msgstr "Списки сайтов применены Sheepfold."

msgid "Sources with update errors: %s. Last working copies are kept."
msgstr "Источников с ошибками обновления: %s. Сохранены последние рабочие копии."

msgid "Strict allowlist groups are protected by the loaded allowlist."
msgstr "Для групп со строгим доступом применяется загруженный белый список сайтов."

msgid "The combined site lists are too large for safe application on this router."
msgstr "Итоговые списки сайтов слишком велики для безопасного применения на этом роутере."

msgid "The previous working DNS configuration is kept when one exists."
msgstr "Предыдущая рабочая настройка DNS сохранена, если она уже существовала."

msgid "The router could not update the Sheepfold site filtering rules."
msgstr "Роутер не смог обновить правила фильтрации сайтов Sheepfold."

msgid "The router DNS configuration directory is invalid."
msgstr "На роутере неверно задана папка конфигурации DNS."

msgid "The router DNS service cannot apply Sheepfold site lists."
msgstr "DNS-служба роутера не может применить списки сайтов Sheepfold."

msgid "The router DNS service could not restart with the new site lists."
msgstr "DNS-служба роутера не смогла перезапуститься с новыми списками сайтов."

msgid "The router DNS service rejected the new site list configuration."
msgstr "DNS-служба роутера отклонила новую конфигурацию списков сайтов."

msgid "The site blocklist is active."
msgstr "Чёрный список сайтов действует."

msgid "The site blocklist is not active."
msgstr "Чёрный список сайтов не действует."

msgid "Until verified domains are available, strict allowlist groups are left online instead of accidentally blocking all internet access."
msgstr "Пока проверенные домены не загружены, устройства групп со строгим доступом остаются в интернете, чтобы случайно не заблокировать им весь доступ."
