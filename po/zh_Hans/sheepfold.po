msgid "USB flash space is running low"
msgstr "USB 闪存盘剩余空间不足"

#: htdocs/luci-static/resources/sheepfold/features/storage/panel.js
msgid "USB flash is mounted and ready"
msgstr "USB 闪存盘已挂载并可用"

#: htdocs/luci-static/resources/sheepfold/features/storage/panel.js
msgid "USB flash is enabled but not mounted"
msgstr "USB 闪存盘已启用但未挂载"

#: htdocs/luci-static/resources/sheepfold/features/storage/panel.js
msgid "Yandex Disk helper is missing"
msgstr "缺少 Yandex Disk 辅助程序"

